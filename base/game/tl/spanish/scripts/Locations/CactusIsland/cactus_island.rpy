translate spanish m_cactus_island_1b43759e:

    # nami "From a distance, this island looks like a cluster of enormous cacti."
    nami "Desde la distancia, esta isla parece un grupo de enormes cactus."

# game/scripts/Locations/CactusIsland/cactus_island.rpy:34
