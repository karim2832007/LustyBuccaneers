    nami "Allí veo un pasaje que lleva a lo que parece un pueblo, con varios edificios. Podríamos atracar cerca."

# game/scripts/Locations/CactusIsland/cactus_island.rpy:38
translate spanish m_cactus_island_0448e2a7:

