# game/scripts/Locations/CactusIsland/cactus_island.rpy:35
translate spanish m_cactus_island_e8667c50:

    # robin "This island seems to be a hub for a large number of bounty hunters, a border outpost where the World Government's law isn't very present..."
    robin "Esta isla parece ser un centro para un gran número de cazarrecompensas, un puesto fronterizo donde la ley del Gobierno Mundial no está muy presente..."

# game/scripts/Locations/CactusIsland/cactus_island.rpy:36
translate spanish m_cactus_island_d46429fb:

    # yamato "We have to be careful, but if they want trouble with us... They'll get it! There's no need to be afraid."
    yamato "Tenemos que tener cuidado, pero si quieren problemas con nosotros... ¡Los tendrán! No hay por qué tener miedo."

# game/scripts/Locations/CactusIsland/cactus_island.rpy:37
