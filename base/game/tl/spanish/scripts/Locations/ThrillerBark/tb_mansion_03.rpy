translate spanish m_tb_mansion_03_267f8cbb:

    # nami "This place is gigantic... It seems endless..."
    nami "Este lugar es gigantesco... Parece interminable..."

# game/scripts/Locations/ThrillerBark/tb_mansion_03.rpy:40
translate spanish m_tb_mansion_03_354cca67:

    # yamato "Captain, look over there, someone is approaching!"
    yamato "¡Capitán, mire allá, alguien se acerca!"

# game/scripts/Locations/ThrillerBark/tb_mansion_03.rpy:57
translate spanish m_tb_mansion_03_a9241430:

    # robin "And it doesn't look friendly... It's some kind of... samurai?!?"
    robin "Y no parece amigable... ¡Es una especie de... samurái!?"

# game/scripts/Locations/ThrillerBark/tb_mansion_03.rpy:58
translate spanish m_tb_mansion_03_cf99e373:

    # yamato "Yes!... He's carrying a katana!... unlike the ones we've encountered here before, he could be dangerous!"
    yamato "¡Sí!... ¡Lleva una katana!... ¡A diferencia de los que hemos encontrado aquí antes, podría ser peligroso!"

# game/scripts/Locations/ThrillerBark/tb_mansion_03.rpy:60
translate spanish m_tb_mansion_03_58529c69:

    # unknown "You are not welcome here... I'm surprised you have come this far!"
    unknown "No eres bienvenido aquí... ¡Me sorprende que hayas llegado hasta aquí!"

# game/scripts/Locations/ThrillerBark/tb_mansion_03.rpy:61
translate spanish m_tb_mansion_03_4583897d:

    # unknown "But this is where it ends. You've seen too much! This will be your end."
    unknown "Pero aquí termina todo. ¡Has visto demasiado! Este será tu fin."

# game/scripts/Locations/ThrillerBark/tb_mansion_03.rpy:74
translate spanish m_tb_mansion_03_cd01c723:

    # nami "For a moment, I thought we wouldn't make it out of this alive!"
    nami "¡Por un momento pensé que no saldríamos de esto con vida!"

# game/scripts/Locations/ThrillerBark/tb_mansion_03.rpy:86
translate spanish m_tb_mansion_03_3010d44b:

    # robin "Now we can uncover the mystery at the end of this room..."
    robin "Ahora podemos descubrir el misterio al final de esta habitación..."

# game/scripts/Locations/ThrillerBark/tb_mansion_03.rpy:87
translate spanish m_tb_mansion_03_22d77676:

    # robin "It seems we're not far from the final chamber..."
    robin "Parece que no estamos lejos de la cámara final..."

