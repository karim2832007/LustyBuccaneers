    # player "Wow!! So this is Acacia!!!"
    player "¡Guau! ¡Así que esta es Acacia!"

# game/scripts/Locations/Dressrosa/dr_acacia.rpy:33
translate spanish m_dr_acacia_a9e29104:

    # robin "That's right, Captain, this is the port city of Acacia."
    robin "Así es, Capitán, esta es la ciudad portuaria de Acacia."

# game/scripts/Locations/Dressrosa/dr_acacia.rpy:34
translate spanish m_dr_acacia_d24c9675:

    # robin "From what I've read, every foreigner who comes here is fascinated for three reasons..."
    robin "Por lo que he leído, cada extranjero que llega aquí queda fascinado por tres razones..."

# game/scripts/Locations/Dressrosa/dr_acacia.rpy:35
translate spanish m_dr_acacia_e351e36f:

    # robin "First, for its flower fields and beautiful floral fragrances, or its delicious food and aromatic dishes..."
    robin "Primero, por sus campos de flores y hermosas fragancias florales, o su deliciosa comida y platos aromáticos..."

# game/scripts/Locations/Dressrosa/dr_acacia.rpy:36
translate spanish m_dr_acacia_c8709d7d:

    # robin "Second, for the fire of its passionate women and their beautiful dances!"
    robin "¡Segundo, por el fuego de sus apasionadas mujeres y sus hermosos bailes!"

# game/scripts/Locations/Dressrosa/dr_acacia.rpy:37
translate spanish m_dr_acacia_dbb62632:

    # player "(That sounds really good!!! I won't be bored around here!)"
    player "(¡Eso suena muy bien! ¡No me aburriré aquí!)"

# game/scripts/Locations/Dressrosa/dr_acacia.rpy:38
translate spanish m_dr_acacia_7da329a4:

    # robin "And lastly... For that..."
    robin "Y por último...Por eso..."

# game/scripts/Locations/Dressrosa/dr_acacia.rpy:39
translate spanish m_dr_acacia_221a0d0f:

    # robin "I didn't believe it either... but look over there..."
    robin "Yo tampoco lo creí...pero mira allá..."

# game/scripts/Locations/Dressrosa/dr_acacia.rpy:41
translate spanish m_dr_acacia_0f5f02ca:

    # player "!!!"
    player "!!!"

# game/scripts/Locations/Dressrosa/dr_acacia.rpy:42
translate spanish m_dr_acacia_f71d1b49:

    # player "What the hell!?!"
    player "¡¿¡Qué demonios!?!"

# game/scripts/Locations/Dressrosa/dr_acacia.rpy:46
translate spanish m_dr_acacia_6674db59:

    # nami "P-plush dolls?!?"
    nami "¿¡Muñecas de peluche?!?"

# game/scripts/Locations/Dressrosa/dr_acacia.rpy:47
translate spanish m_dr_acacia_4930708a:

    # nami "It's like... as if they were their partners or friends!?!"
    nami "¡Es como... como si fueran sus compañeros o amigos!?!"

# game/scripts/Locations/Dressrosa/dr_acacia.rpy:48
translate spanish m_dr_acacia_bd55771a:

    # yamato "But how... Look over there!"
    yamato "Pero cómo... ¡Mira allá!"

# game/scripts/Locations/Dressrosa/dr_acacia.rpy:52
translate spanish m_dr_acacia_c6f5542c:

    # robin "Yes, that's right... This sight leaves everyone astonished..."
    robin "Sí, así es... Esta vista deja a todos atónitos..."

# game/scripts/Locations/Dressrosa/dr_acacia.rpy:56
translate spanish m_dr_acacia_6de8c7d7:

    # player "It's a bunch of toys! Hahaha how fun!!"
    player "¡Son un montón de juguetes! ¡Jajajajaja qué divertido!"

# game/scripts/Locations/Dressrosa/dr_acacia.rpy:68
translate spanish m_dr_acacia_a5969b66:

    # player "This is really amazing!!! How is it possible that they're walking?!?"
    player "¡¡¡Esto es realmente asombroso!!! ¿Cómo es posible que estén caminando?"

# game/scripts/Locations/Dressrosa/dr_acacia.rpy:69
translate spanish m_dr_acacia_74cf80e0:

    # robin "It's a truly fascinating phenomenon... I didn't believe the reports I read... But being here and seeing it with my own eyes, there's no doubt."
    robin "Es un fenómeno realmente fascinante... No creía en los informes que leí... Pero estando aquí y viéndolo con mis propios ojos, no hay duda."

# game/scripts/Locations/Dressrosa/dr_acacia.rpy:70
translate spanish m_dr_acacia_5eb93394:

    # robin "It's a mystery I'd like to uncover..."
    robin "Es un misterio que me gustaría descubrir..."

# game/scripts/Locations/Dressrosa/dr_acacia.rpy:71
translate spanish m_dr_acacia_a0d04494:

    # yamato "Nobody here seems surprised by them..."
    yamato "Nadie aquí parece sorprendido por ellos..."

# game/scripts/Locations/Dressrosa/dr_acacia.rpy:72
translate spanish m_dr_acacia_42542027:

    # yamato "It's like it's something normal..."
    yamato "Es como si fuera algo normal..."

# game/scripts/Locations/Dressrosa/dr_acacia.rpy:73
translate spanish m_dr_acacia_658a8598:

    # nami "Everywhere, and so naturally, toys live together with humans... no wonder this feels strange to all visitors."
    nami "En todas partes y de forma tan natural, los juguetes conviven con los humanos... no es de extrañar que esto resulte extraño a todos los visitantes."

# game/scripts/Locations/Dressrosa/dr_acacia.rpy:74
translate spanish m_dr_acacia_06bb5c9d:

    # yamato "It's really very strange... Maybe we'll learn more once we walk the streets and talk to the people around here."
    yamato "Es realmente muy extraño... Tal vez aprendamos más cuando caminemos por las calles y hablemos con la gente de aquí."

# game/scripts/Locations/Dressrosa/dr_acacia.rpy:76
translate spanish m_dr_acacia_1e74315c:

    # nami "Could it be related to the new king of this island? All that [robin.n] told us when we read about the tournament..."
    nami "¿Podría estar relacionado con el nuevo rey de esta isla? Todo eso [robin.n] nos lo contó cuando leímos sobre el torneo..."

# game/scripts/Locations/Dressrosa/dr_acacia.rpy:77
translate spanish m_dr_acacia_dfc2824c:

    # nami "I don't really know much about the culture here, but I don't remember it ever being mentioned that toys were walking around everywhere from the start..."
    nami "Realmente no sé mucho sobre la cultura de aquí, pero no recuerdo que se haya mencionado nunca que desde el principio los juguetes anduvieran por todas partes..."

# game/scripts/Locations/Dressrosa/dr_acacia.rpy:79
translate spanish m_dr_acacia_9f6d39db:

    # robin "It could be related, but obviously it wouldn't come to light if that were the case..."
    robin "Podría estar relacionado, pero obviamente no saldría a la luz si ese fuera el caso..."

# game/scripts/Locations/Dressrosa/dr_acacia.rpy:80
translate spanish m_dr_acacia_71540328:

    # robin "The navy and the world government would have it tightly sealed if it were connected... We're talking about a Shichibukai!"
    robin "La marina y el gobierno mundial lo tendrían perfectamente sellado si estuviera conectado... ¡Estamos hablando de un Shichibukai!"

# game/scripts/Locations/Dressrosa/dr_acacia.rpy:81
translate spanish m_dr_acacia_3480a411:

    # player "Hmm, all this is suspicious..."
    player "Hmm, todo esto es sospechoso..."

# game/scripts/Locations/Dressrosa/dr_acacia.rpy:82
translate spanish m_dr_acacia_b570ed08:

    # player "But I don't care if toys walk around!! Let's go to the coliseum!"
    player "¡Pero no me importa si los juguetes andan por ahí! ¡Vamos al coliseo!"

# game/scripts/Locations/Dressrosa/dr_acacia.rpy:83
translate spanish m_dr_acacia_59b669a6:

    # player "Once we have the fruit in our possession, we'll see what we can uncover about these mysterious toys!"
    player "Una vez que tengamos la fruta en nuestro poder, ¡veremos qué podemos descubrir sobre estos misteriosos juguetes!"

# game/scripts/Locations/Dressrosa/dr_acacia.rpy:84
translate spanish m_dr_acacia_b28a7654:

    # player "Let's go!!"
    player "¡¡Vamos!!"

