    # player "Hahaha, what are you talking about? This place is a mess... Looks like it's been abandoned for a while..."
    player "Jajaja, ¿de qué hablas? Este lugar es un desastre... Parece que lleva tiempo abandonado..."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:41
translate spanish m_ar_erumalu_89a49bb7:

    # nami "Doesn't look like there's anyone around here..."
    nami "No parece que haya nadie por aquí..."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:48
translate spanish m_ar_erumalu_183a491b:

    # vivi "Unfortunately... It's just as you say..."
    vivi "Lamentablemente... es tal como dices..."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:49
translate spanish m_ar_erumalu_f8154b65:

    # vivi "It's a shame, but this is Erumalu."
    vivi "Es una pena, pero esto es Erumalu."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:51
translate spanish m_ar_erumalu_d9ab3131:

    # player "What are you saying!?! This is really Erumalu?"
    player "¿¡Qué estás diciendo!? ¿De verdad es Erumalu?"

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:52
translate spanish m_ar_erumalu_bffb11e0:

    # player "Things don't seem to be going well here..."
    player "Las cosas no parecen ir bien aquí..."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:56
translate spanish m_ar_erumalu_ab6a2918:

    # nami "Shut up, Captain..."
    nami "Cállate, Capitán..."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:60
translate spanish m_ar_erumalu_388968b0:

    # nami "Forgive him [vivi.n], our Captain is a bit insensitive..."
    nami "Perdónalo [vivi.n], nuestro Capitán es un poco insensible..."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:61
translate spanish m_ar_erumalu_b0e3e567:

    # vivi "Don't worry [nami.n], [player.n] is right... This is truly tragic..."
    vivi "No te preocupes [nami.n], [player.n] tiene razón... Esto es realmente trágico..."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:62
translate spanish m_ar_erumalu_fb9ac8a1:

    # vivi "Erumalu used to be known as the Green City."
    vivi "Erumalu solía ser conocida como la Ciudad Verde."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:63
translate spanish m_ar_erumalu_2717ba1a:

    # yamato "The Green City?!?"
    yamato "¿¡La ciudad verde?!?"

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:64
translate spanish m_ar_erumalu_7c5346e4:

    # vivi "That's right... Years ago, this town was bustling with people and trade..."
    vivi "Así es... Hace años, este pueblo estaba lleno de gente y comercio..."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:65
translate spanish m_ar_erumalu_0e1efb18:

    # vivi "This place served as a meeting point or a rest stop between villages."
    vivi "Este lugar sirvió como punto de encuentro o parada de descanso entre pueblos."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:66
translate spanish m_ar_erumalu_51cf0ee0:

    # vivi "But this is the reality now..."
    vivi "Pero esta es la realidad ahora..."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:67
translate spanish m_ar_erumalu_88f72ed5:

    # vivi "The constant sandstorms never stopped battering this city, and so its citizens fled, and the canals dried up."
    vivi "Las constantes tormentas de arena nunca dejaron de azotar esta ciudad, por lo que sus ciudadanos huyeron y los canales se secaron."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:71
translate spanish m_ar_erumalu_e7a87878:

    # vivi "I don't know what they're doing or planning, but all of this is the fault of the Baroque Works!!"
    vivi "¡No sé qué están haciendo o planeando, pero todo esto es culpa de Baroque Works!"

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:72
translate spanish m_ar_erumalu_91ecd55c:

    # vivi "This is what Baroque Works is doing to my country..."
    vivi "Esto es lo que Baroque Works le está haciendo a mi país..."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:73
translate spanish m_ar_erumalu_84ffdc10:

    # vivi "And what the people of Alabasta are suffering every single day!!"
    vivi "¡¡¡Y lo que sufre la gente de Arabasta cada día!!!"

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:74
translate spanish m_ar_erumalu_0610e455:

    # vivi "Now Erumalu looks like a ghost town!!"
    vivi "¡¡¡Ahora Erumalu parece un pueblo fantasma!!!"

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:78
translate spanish m_ar_erumalu_9af6f2b0:

    # nami "This is terrible!!"
    nami "¡¡¡Esto es terrible!!!"

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:79
translate spanish m_ar_erumalu_e0e43049:

    # nami "We have to stop them as soon as possible!"
    nami "¡Tenemos que detenerlos lo antes posible!"

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:83
translate spanish m_ar_erumalu_946cb83d:

    # vivi "That's right, [nami.n]!"
    vivi "¡Así es, [nami.n]!"

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:85
translate spanish m_ar_erumalu_375d7789:

    # vivi "I'm sure that together we can do it!!"
    vivi "¡Estoy seguro que juntos podemos lograrlo!"

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:90
translate spanish m_ar_erumalu_27b6275e:

    # robin "But there's something I don't understand..."
    robin "Pero hay algo que no entiendo..."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:91
translate spanish m_ar_erumalu_4f0c1dc8:

    # robin "How could such a prosperous city end up like this...?"
    robin "¿Cómo pudo una ciudad tan próspera terminar así...?"

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:97
translate spanish m_ar_erumalu_0db7aac7:

    # vivi "That is the heart of the matter... And this isn't something that has only happened here, it's happening all over the kingdom..."
    vivi "Ése es el corazón del asunto... Y esto no es algo que sólo ha sucedido aquí, está sucediendo en todo el reino..."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:98
translate spanish m_ar_erumalu_c0cf0e90:

    # vivi "Not long ago, as I was saying, Erumalu was a prosperous city full of vegetation..."
    vivi "No hace mucho tiempo, como decía, Erumalu era una ciudad próspera y llena de vegetación..."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:99
translate spanish m_ar_erumalu_42e4f2e1:

    # vivi "It has never rained much in these lands, but with its water reserves, Erumalu had enough..."
    vivi "Nunca ha llovido mucho en estas tierras, pero con sus reservas de agua, Erumalu tenía suficiente..."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:102
translate spanish m_ar_erumalu_5a48d1e5:

    # vivi "This is where [crocodile.n] and his group, somehow, come into play..."
    vivi "Aquí es donde [crocodile.n] y su grupo, de alguna manera, entran en juego..."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:103
translate spanish m_ar_erumalu_942b9668:

    # vivi "It hasn't rained a single drop in three years!!"
    vivi "¡¡¡No ha llovido ni una gota en tres años!!!"

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:104
translate spanish m_ar_erumalu_1ea1fef7:

    # vivi "Though rain is becoming scarcer throughout the kingdom..."
    vivi "Aunque la lluvia es cada vez más escasa en todo el reino..."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:105
translate spanish m_ar_erumalu_a88c42d5:

    # vivi "There's one place where the rain falls more than usual!"
    vivi "¡Hay un lugar donde llueve más de lo habitual!"

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:106
translate spanish m_ar_erumalu_b1976c2a:

    # vivi "And that is in the kingdom's capital, Alubarna, the city where the royal palace is, my family's home."
    vivi "Y eso es en la capital del reino, Alubarna, la ciudad donde está el palacio real, la casa de mi familia."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:107
translate spanish m_ar_erumalu_3a1f7f59:

    # player "What a luck!!"
    player "¡¡¡Que suerte!!"

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:108
translate spanish m_ar_erumalu_15840808:

    # vivi "Well, it's not... Some people called it the king's miracle..."
    vivi "Bueno, no lo es... Algunos lo llamaron el milagro del rey..."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:109
translate spanish m_ar_erumalu_f506e1cf:

    # vivi "But that's not true... As you said [player.n], there are those who don't believe it, who think there's something behind all this... And to top it off..."
    vivi "Pero eso no es cierto... Como bien dices [player.n], hay quienes no lo creen, que piensan que hay algo detrás de todo esto... Y para colmo..."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:110
translate spanish m_ar_erumalu_8fd580d3:

    # vivi "Recently, large shipments of Dance Powder were discovered arriving in the kingdom!"
    vivi "¡Recientemente, se descubrió que grandes cargamentos de polvo de baile llegaban al reino!"

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:112
translate spanish m_ar_erumalu_6dfb250d:

    # player "Dance Powder?!?"
    player "¿¡Polvo de baile?!?"

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:114
translate spanish m_ar_erumalu_db39c7ec:

    # nami "I think I've heard about this..."
    nami "Creo que he oído hablar de esto..."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:115
translate spanish m_ar_erumalu_4d076346:

    # robin "Dance Powder is also known as the powder that produces rain..."
    robin "El polvo de baile también se conoce como el polvo que produce la lluvia..."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:116
translate spanish m_ar_erumalu_e1afc783:

    # robin "When it turns into smoke, it creates rain wherever it passes..."
    robin "Cuando se convierte en humo, crea lluvia por donde pasa..."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:117
translate spanish m_ar_erumalu_1983c956:

    # robin "That's why the country that created it danced with joy after seeing rain fall following years of drought. That's where its name comes from..."
    robin "Por eso el país que lo creó bailó de alegría al ver caer la lluvia tras años de sequía. De ahí viene su nombre..."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:118
translate spanish m_ar_erumalu_7c074422:

    # robin "While this might sound good, its use has severe unintended consequences..."
    robin "Aunque esto puede sonar bien, su uso tiene graves consecuencias no deseadas..."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:119
translate spanish m_ar_erumalu_cd7eed40:

    # robin "Dance Powder artificially affects clouds..."
    robin "Dance Powder afecta artificialmente a las nubes..."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:120
translate spanish m_ar_erumalu_ebc9b6f4:

    # robin "This way, while it does create rain, it steals it from the surrounding areas, causing severe droughts."
    robin "De esta manera, si bien crea lluvia, la roba de las áreas circundantes, causando sequías severas."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:121
translate spanish m_ar_erumalu_d5e45486:

    # robin "The neighboring country of its creators suffered massive droughts as a result, which led to a war between the two nations."
    robin "El país vecino de sus creadores sufrió como consecuencia sequías masivas que provocaron una guerra entre ambas naciones."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:122
translate spanish m_ar_erumalu_61d3503f:

    # robin "After a great massacre, the World Government imposed a ban on its use."
    robin "Después de una gran masacre, el Gobierno Mundial impuso la prohibición de su uso."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:123
translate spanish m_ar_erumalu_e9182b9a:

    # robin "Its production and possession are illegal..."
    robin "Su producción y posesión son ilegales..."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:124
translate spanish m_ar_erumalu_38c50e37:

    # vivi "That's right, everything [robin.n] said is true."
    vivi "Así es, todo lo que [robin.n] dijo es verdad."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:125
translate spanish m_ar_erumalu_711d3d90:

    # player "Always so well-informed, my [robin.n]!!"
    player "¡¡Siempre tan bien informado, mi [robin.n]!!"

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:126
translate spanish m_ar_erumalu_26219c9d:

    # player "So... Does that mean the king brought in this shipment illegally?"
    player "Entonces... ¿Eso significa que el rey trajo este cargamento ilegalmente?"

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:129
translate spanish m_ar_erumalu_464c5b0d:

    # nami "Of course not, Captain!!! Let her finish the story!"
    nami "¡Claro que no, Capitán! ¡Que termine la historia!"

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:132
translate spanish m_ar_erumalu_51fe1cc8:

    # vivi "My father is a wise and kind person, he would never use tools that harm others..."
    vivi "Mi padre es una persona sabia y amable, nunca usaría herramientas que dañen a otros..."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:137
translate spanish m_ar_erumalu_460eadc9:

    # vivi "Going back to the case of my kingdom..."
    vivi "Volviendo al caso de mi reino..."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:138
translate spanish m_ar_erumalu_db98d112:

    # vivi "When the people discovered these shipments..."
    vivi "Cuando la gente descubrió estos envíos..."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:139
translate spanish m_ar_erumalu_ee26e583:

    # vivi "They blamed my father, the king, for causing the droughts in all the other cities by using this powder for his own benefit..."
    vivi "Culparon a mi padre, el rey, de provocar las sequías en todas las demás ciudades al utilizar este polvo para su propio beneficio..."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:140
translate spanish m_ar_erumalu_0a355f09:

    # vivi "But my father was not the one who ordered it!"
    vivi "¡Pero no fue mi padre quien lo ordenó!"

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:141
translate spanish m_ar_erumalu_ed8ff706:

    # vivi "We didn't know who was responsible... But while we were investigating..."
    vivi "No sabíamos quién era el responsable... Pero mientras investigábamos..."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:142
translate spanish m_ar_erumalu_c27fef48:

    # vivi "Not long after, a massive amount of Dance Powder was found inside the palace."
    vivi "No mucho después, se encontró una enorme cantidad de polvo de baile dentro del palacio."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:144
translate spanish m_ar_erumalu_40b1ce79:

    # robin "Were there infiltrators in the palace?"
    robin "¿Había infiltrados en el palacio?"

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:146
translate spanish m_ar_erumalu_afbd0359:

    # vivi "It seems so... They wanted to frame the royal family for the droughts!"
    vivi "Parece que sí... ¡Querían incriminar a la familia real por las sequías!"

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:147
translate spanish m_ar_erumalu_a705a6bd:

    # vivi "Since this incident, the people's distrust in the king has been growing daily..."
    vivi "Desde este incidente, la desconfianza del pueblo hacia el rey ha ido creciendo día a día..."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:148
translate spanish m_ar_erumalu_1d63d52f:

    # vivi "Obviously, this was all orchestrated, but the discontent keeps rising..."
    vivi "Obviamente todo esto fue orquestado, pero el descontento sigue aumentando..."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:149
translate spanish m_ar_erumalu_28a319b2:

    # vivi "There are more and more uprisings... I want to prevent a civil war!"
    vivi "Cada vez hay más levantamientos... ¡Quiero evitar una guerra civil!"

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:150
translate spanish m_ar_erumalu_bf2a5537:

    # vivi "Many towns are being ruined by the droughts, and the rain never comes!!"
    vivi "¡Muchos pueblos están siendo arruinados por las sequías y la lluvia nunca llega!"

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:151
translate spanish m_ar_erumalu_9c7eedb2:

    # vivi "{size=35}It's as if the skies have abandoned us, and the sandstorms keep coming one after another!{/size}"
    vivi "{size=35}¡Es como si los cielos nos hubieran abandonado y las tormentas de arena siguieran llegando una tras otra!{/size}"

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:153
translate spanish m_ar_erumalu_26687c71:

    # robin "Mnmnm... It's really strange..."
    robin "Mmm... Es realmente extraño..."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:154
translate spanish m_ar_erumalu_2162926a:

    # vivi "Many people have left in search of other oases or more humid lands..."
    vivi "Mucha gente se ha ido en busca de otros oasis o tierras más húmedas..."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:155
translate spanish m_ar_erumalu_07ee6aab:

    # vivi "And that's how the Green City withered away!"
    vivi "¡Y así fue como la Ciudad Verde se marchitó!"

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:156
translate spanish m_ar_erumalu_288db26b:

    # vivi "We have to move on to Yuba now!"
    vivi "¡Tenemos que seguir hacia Yuba ahora!"

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:158
translate spanish m_ar_erumalu_7fe1a1f3:

    # nami "That's where the rebel army is, right?"
    nami "Ahí es donde está el ejército rebelde, ¿verdad?"

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:160
translate spanish m_ar_erumalu_2e4475f5:

    # vivi "That's what I believe. I will convince their leader to stop the revolt."
    vivi "Eso es lo que creo. Convenceré a su líder para que detenga la revuelta."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:161
translate spanish m_ar_erumalu_51fbef66:

    # vivi "[crocodile.n] is behind all of this, I have no doubt... His plan is already in motion, we have to uncover it and stop him!!"
    vivi "[crocodile.n] está detrás de todo esto, no tengo ninguna duda... ¡Su plan ya está en marcha, tenemos que descubrirlo y detenerlo!"

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:162
translate spanish m_ar_erumalu_035beeeb:

    # vivi "I will tell him the whole truth and everything I've discovered to prevent more bloodshed."
    vivi "Le contaré toda la verdad y todo lo que he descubierto para evitar más derramamiento de sangre."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:164
translate spanish m_ar_erumalu_4bfd9e94:

    # player "Understood, let's get moving!"
    player "Entendido, ¡manos a la obra!"

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:197
translate spanish ar_erumalu_coast_e8dca44d:

    # narrador "As you were heading to your destination, you came across a strange creature..."
    narrador "Mientras te dirigías a tu destino, te topaste con una extraña criatura..."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:198
translate spanish ar_erumalu_coast_7138e908:

    # yamato "What the hell is that?"
    yamato "¿Qué carajo es eso?"

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:204
translate spanish ar_erumalu_coast_014d167b:

    # nami "Is it a turtle?!?"
    nami "¿¡Es una tortuga?!?"

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:205
translate spanish ar_erumalu_coast_80392650:

    # player "It looks more like a seal..."
    player "Parece más bien una foca..."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:206
translate spanish ar_erumalu_coast_1f31b8d5:

    # nami "Look at it, how cute! It looks like it's dancing!"
    nami "¡Míralo, qué monada! ¡Parece que está bailando!"

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:207
translate spanish ar_erumalu_coast_05f47570:

    # robin "I think it has bad intentions..."
    robin "Creo que tiene malas intenciones..."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:208
translate spanish ar_erumalu_coast_eea55ab1:

    # yamato "Hahaha, what are you talking about?"
    yamato "Jajajajaja ¿de qué estás hablando?"

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:209
translate spanish ar_erumalu_coast_6b901c4a:

    # vivi "It's a Kung Fu Dugong!"
    vivi "¡Es un dugongo de Kung Fu!"

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:210
translate spanish ar_erumalu_coast_a7feff16:

    # vivi "They're always looking for a fight, as if they were training..."
    vivi "Siempre están buscando pelea, como si estuvieran entrenando..."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:211
translate spanish ar_erumalu_coast_b9a062a6:

    # vivi "It could be dangerous, don't get too close! It might be looking for trouble!!"
    vivi "Podría ser peligroso, ¡no te acerques demasiado! ¡Podría estar buscando problemas!"

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:212
translate spanish ar_erumalu_coast_e0bd3940:

    # player "So you want to fight!"
    player "¡Así que quieres pelear!"

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:213
translate spanish ar_erumalu_coast_8f923131:

    # player "Don't worry, ladies, I'll take care of this!"
    player "¡No se preocupen señoras, yo me encargaré de esto!"

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:226
translate spanish ar_erumalu_coast_91a4d6ab:

    # vivi "Wow, you defeated it with your bare hands! You're really strong..."
    vivi "¡Guau, lo venciste con tus propias manos! Eres muy fuerte..."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:229
