translate spanish m_arabasta_51f741de:

    # nami "Island in sight, Captain!"
    nami "¡Isla a la vista, Capitán!"

# game/scripts/Locations/Arabasta/arabasta.rpy:31
translate spanish m_arabasta_898a9d04:

    # player "Wow, it's a massive desert."
    player "Vaya, es un desierto enorme."

# game/scripts/Locations/Arabasta/arabasta.rpy:32
translate spanish m_arabasta_8938466f:

    # yamato "It's such a huge island! All you can see is sand everywhere..."
    yamato "¡Es una isla enorme! Solo se ve arena por todas partes..."

# game/scripts/Locations/Arabasta/arabasta.rpy:33
translate spanish m_arabasta_46bd9b29:

    # nami "This is perfect, we can get a good tan here!"
    nami "¡Esto es perfecto! ¡Aquí podemos broncearnos bien!"

# game/scripts/Locations/Arabasta/arabasta.rpy:34
translate spanish m_arabasta_c495d16f:

    # player "Hahaha, there's no time for that right now, [nami.n]..."
    player "Jajaja, no hay tiempo para eso ahora, [nami.n]..."

# game/scripts/Locations/Arabasta/arabasta.rpy:35
translate spanish m_arabasta_7d8486f4:

    # player "(Although I'd love to see all of them in swimsuits...)"
    player "(Aunque me encantaría verlos a todos en traje de baño...)"

# game/scripts/Locations/Arabasta/arabasta.rpy:36
translate spanish m_arabasta_e687bc49:

    # yamato "So this is [Arabasta.n]..."
    yamato "Así que esto es [Arabasta.n]..."

# game/scripts/Locations/Arabasta/arabasta.rpy:37
translate spanish m_arabasta_c29754fa:

    # robin "Technically speaking, this is Sandy Island, one of the largest islands in Paradise."
    robin "Técnicamente hablando, esta es Sandy Island, una de las islas más grandes del Paraíso."

# game/scripts/Locations/Arabasta/arabasta.rpy:38
translate spanish m_arabasta_57f89bba:

    # robin "And here lies the Kingdom of [Arabasta.n], one of the twenty kingdoms that founded the World Government."
    robin "Y aquí se encuentra el Reino de [Arabasta.n], uno de los veinte reinos que fundaron el Gobierno Mundial."

# game/scripts/Locations/Arabasta/arabasta.rpy:39
translate spanish m_arabasta_9b238ab1:

    # vivi "You're quite well-informed, [robin.n]! Everything you've said is absolutely correct!"
    vivi "¡Estás muy bien informado, [robin.n]! ¡Todo lo que has dicho es totalmente cierto!"

# game/scripts/Locations/Arabasta/arabasta.rpy:40
translate spanish m_arabasta_677fb01c:

    # robin "Thank you. I had planned to come here... It's a land rich in history and historical sites..."
    robin "Gracias. Tenía pensado venir aquí... Es una tierra rica en historia y sitios históricos..."

# game/scripts/Locations/Arabasta/arabasta.rpy:41
translate spanish m_arabasta_7e0c2147:

    # robin "There's so much to do here..."
    robin "Hay tanto que hacer aquí..."

# game/scripts/Locations/Arabasta/arabasta.rpy:42
translate spanish m_arabasta_f6ee6ac1:

    # vivi "You'll all have time to see and enjoy all its beauty..."
    vivi "Todos tendréis tiempo para ver y disfrutar de toda su belleza..."

# game/scripts/Locations/Arabasta/arabasta.rpy:43
translate spanish m_arabasta_d9f2582a:

    # vivi "But for now, let's focus..."
    vivi "Pero por ahora, centrémonos en..."

# game/scripts/Locations/Arabasta/arabasta.rpy:44
translate spanish m_arabasta_e76febd7:

    # vivi "Is a very large island, and the high temperatures make traveling between the different cities difficult."
    vivi "Es una isla muy grande y las altas temperaturas dificultan el desplazamiento entre las diferentes ciudades."

# game/scripts/Locations/Arabasta/arabasta.rpy:45
translate spanish m_arabasta_c2569ab3:

    # vivi "Especially now, as we're suffering from a severe drought..."
    vivi "Especialmente ahora, que estamos sufriendo una grave sequía..."

# game/scripts/Locations/Arabasta/arabasta.rpy:46
translate spanish m_arabasta_1c3f84a5:

    # vivi "This is, unfortunately, one of the reasons for the widespread discontent among the people..."
    vivi "Ésta es, lamentablemente, una de las razones del descontento generalizado entre la gente..."

# game/scripts/Locations/Arabasta/arabasta.rpy:47
translate spanish m_arabasta_60fe8f1b:

    # yamato "On top of everything else, we need to avoid drawing attention. Baroque Works might be looking for us."
    yamato "Además de todo lo demás, debemos evitar llamar la atención. Baroque Works podría estar buscándonos."

# game/scripts/Locations/Arabasta/arabasta.rpy:48
translate spanish m_arabasta_4d11d27c:

    # vivi "Exactly!!"
    vivi "¡¡Exactamente!!"

# game/scripts/Locations/Arabasta/arabasta.rpy:49
translate spanish m_arabasta_30b48718:

    # vivi "The best course of action is to head to Nanohana first. It's a large port city not far from here."
    vivi "Lo mejor es ir primero a Nanohana. Es una gran ciudad portuaria no muy lejos de aquí."

# game/scripts/Locations/Arabasta/arabasta.rpy:50
translate spanish m_arabasta_80e8ad3b:

    # vivi "We can stock up on everything we need there, and with so many people around, we can keep a low profile."
    vivi "Allí podremos abastecernos de todo lo que necesitemos y, con tanta gente alrededor, podremos mantener un perfil bajo."

# game/scripts/Locations/Arabasta/arabasta.rpy:51
translate spanish m_arabasta_85077991:

    # vivi "Afterward, the next step would be to head to a small oasis town, the village of Yuba."
    vivi "Después, el siguiente paso sería dirigirse a un pequeño pueblo oasis, el pueblo de Yuba."

# game/scripts/Locations/Arabasta/arabasta.rpy:52
translate spanish m_arabasta_cc9003fc:

    # vivi "That's why we need to gather supplies first to reach it."
    vivi "Por eso primero debemos reunir suministros para llegar hasta allí."

# game/scripts/Locations/Arabasta/arabasta.rpy:53
translate spanish m_arabasta_40321a9c:

    # player "Alright, sounds like a good plan! You heard her, let's head to Nanohana!"
    player "¡Bien, parece un buen plan! Ya la oíste, ¡vamos a Nanohana!"

translate spanish strings:

    # game/scripts/Locations/Arabasta/arabasta.rpy:58
    old "Go to Nanohana"
    new "Ir a Nanohana"

