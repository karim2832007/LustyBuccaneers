# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:33
translate spanish m_ar_yuba_entrance_714e0134:

    # player "Another village buried in sand..."
    player "Otro pueblo enterrado en la arena..."

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:34
translate spanish m_ar_yuba_entrance_2b73643b:

    # player "Is this the base of the Rebel Army?... There doesn't seem to be much movement..."
    player "¿Es esta la base del Ejército Rebelde?... No parece haber mucho movimiento..."

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:36
translate spanish m_ar_yuba_entrance_04bccf46:

    # vivi "Although I haven't been here for many years, it should be impossible for the city to be in these conditions."
    vivi "Aunque no he estado aquí durante muchos años, debería ser imposible que la ciudad estuviera en estas condiciones."

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:37
translate spanish m_ar_yuba_entrance_b871c003:

    # vivi "I don't understand how this is possible... I haven't been away from the kingdom for that long..."
    vivi "No entiendo cómo es esto posible... No he estado lejos del reino por tanto tiempo..."

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:38
translate spanish m_ar_yuba_entrance_f84c48d9:

    # vivi "The situation is much worse than I thought..."
    vivi "La situación es mucho peor de lo que pensaba..."

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:39
translate spanish m_ar_yuba_entrance_9676b6f7:

    # vivi "The sandstorms have devastated the city of Yuba."
    vivi "Las tormentas de arena han devastado la ciudad de Yuba."

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:43
translate spanish m_ar_yuba_entrance_29de1734:

    # nami "This is terrible..."
    nami "Esto es terrible..."

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:44
translate spanish m_ar_yuba_entrance_10d501a0:

    # nami "It looks very similar to how Erumalu was..."
    nami "Se parece mucho a cómo era Erumalu..."

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:48
translate spanish m_ar_yuba_entrance_89c8acf2:

    # robin "[vivi.n], didn't you say this was an oasis city?"
    robin "[vivi.n] ¿No dijiste que esta era una ciudad oasis?"

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:50
translate spanish m_ar_yuba_entrance_45122e85:

    # vivi "That's right... Let's go in, I need to see the oasis!"
    vivi "Así es... ¡Entremos, necesito ver el oasis!"

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:85
translate spanish ar_yuba_desert_08044ee4:

    # player "I'm burning up!!!"
    player "¡¡¡Me estoy quemando!!!"

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:86
translate spanish ar_yuba_desert_c3e75401:

    # player "This is really tough to cross!!"
    player "¡¡¡Es realmente difícil cruzar esto!!!"

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:89
translate spanish ar_yuba_desert_0c4a9c26:

    # player "Right now, it would be great to feel the cold of an island like [DrumIsland.n]."
    player "Ahora mismo sería genial sentir el frío de una isla como [DrumIsland.n]."

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:91
translate spanish ar_yuba_desert_70127bb8:

    # robin "The heat is really intense at this hour!"
    robin "¡El calor es realmente intenso a esta hora!"

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:92
translate spanish ar_yuba_desert_526fa87c:

    # robin "I think you're the only one not affected by this, [vivi.n]."
    robin "Creo que eres el único al que esto no le afecta, [vivi.n]."

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:94
translate spanish ar_yuba_desert_b003901d:

    # vivi "I was born and raised here, so it doesn't affect me much… I guess it's just what I'm used to!"
    vivi "Nací y crecí aquí, así que no me afecta mucho... ¡Supongo que es a lo que estoy acostumbrada!"

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:96
translate spanish ar_yuba_desert_cb336810:

    # nami "There are too many dunes! It would be much better to be sunbathing with a cool drink on a beach chair."
    nami "¡Hay demasiadas dunas! Sería mucho mejor tomar el sol con una bebida refrescante en una tumbona."

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:98
translate spanish ar_yuba_desert_6b0b5f45:

    # vivi "Some of these dunes are 300 meters high! This is a desert with many years of history..."
    vivi "¡Algunas de estas dunas alcanzan los 300 metros de altura! Este es un desierto con muchos años de historia..."

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:100
translate spanish ar_yuba_desert_e6193c32:

    # player "Wow, 300 meters? That's like climbing a mountain!!"
    player "¡Guau! ¿300 metros? ¡Es como escalar una montaña!"

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:102
translate spanish ar_yuba_desert_e8d313ed:

    # vivi "Hahah, maybe a small one!!"
    vivi "¡Jajaja! ¡Quizás uno pequeño!"

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:103
translate spanish ar_yuba_desert_bdc51de3:

    # vivi "It would be good to rest, but it is dangerous."
    vivi "Sería bueno descansar, pero es peligroso."

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:104
translate spanish ar_yuba_desert_25e3ed92:

    # vivi "We have to stay alert, there are many dangers in the desert..."
    vivi "Tenemos que estar alerta, hay muchos peligros en el desierto..."

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:113
translate spanish ar_yuba_desert_cc8012d2:

    # nami "What's happening? What's that tremor?"
    nami "¿Qué pasa? ¿Qué es ese temblor?"

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:126
translate spanish ar_yuba_desert_f9fad373:

    # nami "It's huge!!! Come protect me Captain!!"
    nami "¡Es enorme! ¡Ven a protegerme, Capitán!"

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:128
translate spanish ar_yuba_desert_0f8c9fde:

    # vivi "It's a Sandora Dragon!!!"
    vivi "¡¡¡Es un Dragón Sandora!!!"

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:129
translate spanish ar_yuba_desert_be6a7b98:

    # nami "What is that?!?"
    nami "¿¡¿Qué es eso?!?"

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:130
translate spanish ar_yuba_desert_ab794da9:

    # vivi "It's the largest reptile living in the desert… We're really unlucky today!"
    vivi "Es el reptil más grande que vive en el desierto... ¡Qué mala suerte hemos tenido hoy!"

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:131
translate spanish ar_yuba_desert_ffb201f7:

    # vivi "It waits in the sand, lying in wait for its prey..."
    vivi "Espera en la arena, al acecho de su presa..."

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:132
translate spanish ar_yuba_desert_f7986a53:

    # vivi "It has incredibly sharp fangs and claws!!!"
    vivi "¡Tiene colmillos y garras increíblemente afilados!"

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:133
translate spanish ar_yuba_desert_1b2ffe50:

    # player "Stay behind me, girls. I'll handle this!"
    player "¡Quédense detrás de mí, chicas! ¡Yo me encargo!"

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:134
translate spanish ar_yuba_desert_fc10ac40:

    # vivi "Be careful!"
    vivi "¡Ten cuidado!"

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:148
translate spanish ar_yuba_desert_c5ce23a4:

    # player "Phewww, it's tough to fight in this heat!"
    player "Ufff, ¡es duro luchar con este calor!"

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:149
translate spanish ar_yuba_desert_3d494d6f:

    # vivi "You're so strong, [player.n]! With you, we can travel safely through these lands!"
    vivi "¡Eres tan fuerte, [player.n]! ¡Contigo, podemos viajar seguros por estas tierras!"

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:152
translate spanish ar_yuba_desert_86395de6:

    # narrador "[vivi.n] Love +1"
    narrador "[vivi.n] Amor +1"

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:154
translate spanish ar_yuba_desert_ece3467f:

    # player "Hahaha, no need to worry, princess. On another note… can we eat it?"
    player "Jajaja, no te preocupes, princesa. Por cierto... ¿podemos comerlo?"

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:156
translate spanish ar_yuba_desert_57f03cff:

    # vivi "Haha, of course! The Sandora Dragon is a highly prized source of meat in [Arabasta.n]!"
    vivi "¡Jaja, claro! ¡El dragón Sandora es una fuente de carne muy preciada en [Arabasta.n]!"

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:159
translate spanish ar_yuba_desert_d5d30426:

    # narrador "Do you want to keep the Sandora Dragon meat?" nointeract
    narrador "¿Quieres conservar la carne del Dragón Sandora?" nointeract

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:162
translate spanish ar_yuba_desert_c42361ad:

    # narrador "+6 Food"
    narrador "+6 Comida"

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:163
translate spanish ar_yuba_desert_f5d39822:

    # player "Great! Now we have more meat for the journey."
    player "¡Genial! Ahora tenemos más carne para el viaje."

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:167
translate spanish ar_yuba_desert_2eebde06:

    # player "I changed my mind. Let's just keep moving!"
    player "Cambié de opinión. ¡Sigamos adelante!"

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:170
translate spanish ar_yuba_desert_fdcf4e16:

    # vivi "Despite everything, it looks like we got lucky. Sandora Dragons usually hunt in pairs."
    vivi "A pesar de todo, parece que tuvimos suerte. Los dragones de Sandora suelen cazar en parejas."

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:172
translate spanish ar_yuba_desert_8f305986:

    # yamato "Maybe it ran away after seeing [player.n]'s strength."
    yamato "Tal vez huyó después de ver la fuerza de [player.n]."

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:174
translate spanish ar_yuba_desert_559b98dc:

    # player "Hahaha, of course!"
    player "Jajajaja, ¡por supuesto!"

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:176
translate spanish ar_yuba_desert_05f4bf92:

    # vivi "Guys, the border of Yuba is just behind those big rocks."
    vivi "Chicos, la frontera de Yuba está justo detrás de esas grandes rocas."

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:177
translate spanish ar_yuba_desert_ca94d0b5:

    # vivi "Let's make one final push, and we'll be there!!"
    vivi "¡Hagamos un último esfuerzo y llegaremos!"

# game/scripts/Locations/Arabasta/ar_yuba_entrance.rpy:178
translate spanish ar_yuba_desert_2c9792e7:

    # player "Excellent, let's move out!"
    player "¡Excelente, vamos a mudarnos!"

