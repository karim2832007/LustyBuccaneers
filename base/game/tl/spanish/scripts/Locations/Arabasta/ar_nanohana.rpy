# game/scripts/Locations/Arabasta/ar_nanohana.rpy:26
translate spanish m_ar_nanohana_f8161c6e:

    # vivi "Well, we finally made it! Welcome to Nanohana."
    vivi "¡Por fin lo logramos! Bienvenidos a Nanohana."

# game/scripts/Locations/Arabasta/ar_nanohana.rpy:30
translate spanish m_ar_nanohana_e99566e1:

    # nami "Wow, it's a massive city! It's filled with all kinds of shops and goods everywhere!"
    nami "¡Guau, es una ciudad enorme! ¡Está llena de todo tipo de tiendas y productos por todas partes!"

# game/scripts/Locations/Arabasta/ar_nanohana.rpy:31
translate spanish m_ar_nanohana_70f038d6:

    # vivi "That's right, Nanohana is the kingdom's main port city."
    vivi "Así es, Nanohana es la principal ciudad portuaria del reino."

# game/scripts/Locations/Arabasta/ar_nanohana.rpy:32
translate spanish m_ar_nanohana_7dec7059:

    # vivi "In addition to the port, it's known for its abundance of bazaars, and thanks to its proximity to an oasis, it doesn't face many issues from the current drought."
    vivi "Además del puerto, es conocido por su abundancia de bazares, y gracias a su proximidad a un oasis, no enfrenta muchos problemas por la sequía actual."

# game/scripts/Locations/Arabasta/ar_nanohana.rpy:33
translate spanish m_ar_nanohana_0f0eb5d0:

    # vivi "It's a bustling hub of activity and trade!"
    vivi "¡Es un centro animado de actividad y comercio!"

# game/scripts/Locations/Arabasta/ar_nanohana.rpy:34
translate spanish m_ar_nanohana_5dd45a01:

    # vivi "But we'll have time to explore it later..."
    vivi "Pero tendremos tiempo para explorarlo más tarde..."

# game/scripts/Locations/Arabasta/ar_nanohana.rpy:38
translate spanish m_ar_nanohana_fe242a04:

    # vivi "[karoo.n], come here!"
    vivi "[karoo.n], ¡ven aquí!"

# game/scripts/Locations/Arabasta/ar_nanohana.rpy:46
translate spanish m_ar_nanohana_c3f63993:

    # vivi "You're such a fast boy... I'm confident I can entrust this important task to you."
    vivi "Eres un chico tan rápido... Estoy seguro de que puedo confiarte esta importante tarea."

# game/scripts/Locations/Arabasta/ar_nanohana.rpy:47
translate spanish m_ar_nanohana_58017648:

    # vivi "We'd only slow you down, and we can't afford to waste any time..."
    vivi "Sólo lo retrasaríamos y no podemos permitirnos perder el tiempo..."

# game/scripts/Locations/Arabasta/ar_nanohana.rpy:48
translate spanish m_ar_nanohana_56e4ef36:

    # vivi "I want you to go to the palace in Alubarna by yourself... You know exactly where it is..."
    vivi "Quiero que vayas tú solo al palacio de Alubarna... Sabes exactamente dónde está..."

# game/scripts/Locations/Arabasta/ar_nanohana.rpy:49
translate spanish m_ar_nanohana_d0cccbe5:

    # vivi "Deliver this letter to my father, and only to him!! It's crucial that he receives it personally."
    vivi "¡Entrégale esta carta a mi padre, y solo a él! Es crucial que la reciba personalmente."

# game/scripts/Locations/Arabasta/ar_nanohana.rpy:50
translate spanish m_ar_nanohana_19bee979:

    # vivi "When they see you, they'll recognize you and let you through without any issues."
    vivi "Cuando te vean, te reconocerán y te dejarán pasar sin problemas."

# game/scripts/Locations/Arabasta/ar_nanohana.rpy:51
translate spanish m_ar_nanohana_58cfc5fc:

    # vivi "In this letter, I explain everything I've discovered along with [igaram.n]."
    vivi "En esta carta explico todo lo que he descubierto junto con [igaram.n]."

# game/scripts/Locations/Arabasta/ar_nanohana.rpy:52
translate spanish m_ar_nanohana_e738ed05:

    # vivi "Everything related to Baroque Works, and even all the information I gathered about their leader, [crocodile.n], is detailed here."
    vivi "Todo lo relacionado con Baroque Works, e incluso toda la información que he recopilado sobre su líder, [crocodile.n], se detalla aquí."

# game/scripts/Locations/Arabasta/ar_nanohana.rpy:53
translate spanish m_ar_nanohana_2def5ea0:

    # vivi "I also wrote about [player.n] and his crew, that I've returned with strong friends I trust, and that they will be a great help!"
    vivi "También escribí sobre [player.n] y su tripulación, que he regresado con amigos fuertes en quienes confío y que serán de gran ayuda."

# game/scripts/Locations/Arabasta/ar_nanohana.rpy:55
translate spanish m_ar_nanohana_7f61a469:

    # vivi "This is a mission of vital importance, [karoo.n]!! But I know you'll do a great job..."
    vivi "¡Esta es una misión de vital importancia, [karoo.n]! Pero sé que harás un gran trabajo..."

# game/scripts/Locations/Arabasta/ar_nanohana.rpy:56
translate spanish m_ar_nanohana_61dab64f:

    # vivi "Go... Thank you for everything, and take care of the water while you're in the desert!"
    vivi "Vamos... Gracias por todo, y cuida el agua mientras estés en el desierto!"

# game/scripts/Locations/Arabasta/ar_nanohana.rpy:57
translate spanish m_ar_nanohana_f7fcd4aa:

    # player "Good luck, [karoo.n]!"
    player "¡Buena suerte, [karoo.n]!"

# game/scripts/Locations/Arabasta/ar_nanohana.rpy:58
translate spanish m_ar_nanohana_c1ffa842:

    # vivi "Run, go to my father!"
    vivi "¡Corre, ve a ver a mi padre!"

# game/scripts/Locations/Arabasta/ar_nanohana.rpy:59
translate spanish m_ar_nanohana_cb11d720:

    # vivi "Tell him we can save the kingdom!!"
    vivi "¡¡¡Dile que podemos salvar el reino!!!"

# game/scripts/Locations/Arabasta/ar_nanohana.rpy:68
translate spanish m_ar_nanohana_239a5b86:

    # player "Very well thought out [vivi.n]! Stay calm [karoo.n] will take care of it..."
    player "¡Muy bien pensado [vivi.n]! Mantén la calma [karoo.n], me encargaré..."

# game/scripts/Locations/Arabasta/ar_nanohana.rpy:69
translate spanish m_ar_nanohana_20390a39:

    # player "Everything will be fine, we also have to get down to work!"
    player "Todo irá bien, ¡nosotros también tenemos que ponernos manos a la obra!"

# game/scripts/Locations/Arabasta/ar_nanohana.rpy:71
translate spanish m_ar_nanohana_f52c8e7a:

    # vivi "Y-yes yes... Thanks for your kind words!"
    vivi "S-sí sí... ¡Gracias por tus amables palabras!"

# game/scripts/Locations/Arabasta/ar_nanohana.rpy:74
