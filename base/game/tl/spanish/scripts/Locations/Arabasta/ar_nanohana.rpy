# game/scripts/Locations/Arabasta/ar_nanohana.rpy:86
translate spanish m_ar_nanohana_1629f8aa:

    # vivi "Alright, we have work to do as well..."
    vivi "Está bien, también tenemos trabajo que hacer..."

# game/scripts/Locations/Arabasta/ar_nanohana.rpy:87
translate spanish m_ar_nanohana_fe0fa259:

    # vivi "First and foremost, we need to stock up on water and anything else we might need... Also, we need to get a map."
    vivi "Lo primero y más importante, necesitamos abastecernos de agua y cualquier otra cosa que podamos necesitar... Además, necesitamos conseguir un mapa."

# game/scripts/Locations/Arabasta/ar_nanohana.rpy:88
translate spanish m_ar_nanohana_ea7e60fa:

    # player "A map?"
    player "¿Un mapa?"

# game/scripts/Locations/Arabasta/ar_nanohana.rpy:89
translate spanish m_ar_nanohana_397cc9ee:

    # vivi "Yes, it's vital..."
    vivi "Sí, es vital..."

# game/scripts/Locations/Arabasta/ar_nanohana.rpy:90
translate spanish m_ar_nanohana_b257986f:

    # vivi "We have to cross the desert, and lately, there have been many sandstorms, among other dangers to overcome."
    vivi "Tenemos que cruzar el desierto, y últimamente ha habido muchas tormentas de arena, entre otros peligros que superar."

# game/scripts/Locations/Arabasta/ar_nanohana.rpy:91
translate spanish m_ar_nanohana_ddb137b6:

    # vivi "With a map, you could easily navigate and avoid getting lost."
    vivi "Con un mapa podrás navegar fácilmente y evitar perderte."

# game/scripts/Locations/Arabasta/ar_nanohana.rpy:92
translate spanish m_ar_nanohana_9cc0d714:

    # vivi "This way, we can save water and avoid unnecessary delays."
    vivi "De esta forma podremos ahorrar agua y evitar retrasos innecesarios."

# game/scripts/Locations/Arabasta/ar_nanohana.rpy:93
translate spanish m_ar_nanohana_b5406330:

    # player "Understood. We'll get the map, food, water, and anything else we think is important."
    player "Entendido. Conseguiremos el mapa, comida, agua y todo lo que consideremos importante."

# game/scripts/Locations/Arabasta/ar_nanohana.rpy:94
translate spanish m_ar_nanohana_5216ea89:

    # player "Let's get to it!"
    player "¡Vamos a ello!"

# game/scripts/Locations/Arabasta/ar_nanohana.rpy:96
translate spanish m_ar_nanohana_92c83ef7:

    # vivi "Perfect, I'll give you this task. I have to keep a low profile and not make myself seen easily... I am the princess after all."
    vivi "Perfecto, te encargo esta tarea. Tengo que pasar desapercibida y no hacerme notar fácilmente... Soy la princesa después de todo."

# game/scripts/Locations/Arabasta/ar_nanohana.rpy:97
translate spanish m_ar_nanohana_edc8f94c:

    # vivi "When you have everything ready, take a look at the map, and let's head to Yuba!"
    vivi "Cuando tengas todo listo, echa un vistazo al mapa y ¡vamos hacia Yuba!"

