# game/scripts/Locations/BlackDrum/di_castle_room.rpy:25
translate spanish m_di_castle_room_8f44af26:

    # unknown "Hold on there! Who are you..."
    unknown "¡Espera! ¿Quién eres?"

# game/scripts/Locations/BlackDrum/di_castle_room.rpy:26
translate spanish m_di_castle_room_072bbdea:

    # unknown "I didn't see any bad intentions, which is why I let you get this far... But it's time you tell me what you want!"
    unknown "No vi ninguna mala intención, por eso te dejé llegar hasta aquí... ¡Pero es hora de que me digas qué quieres!"

# game/scripts/Locations/BlackDrum/di_castle_room.rpy:37
translate spanish m_di_castle_room_7c4f1e34:

    # robin "Hello! We've come here because of some rumors... it's said that a doctor lives here, are you Doctorine?"
    robin "¡Hola! Vinimos aquí por unos rumores... Dicen que aquí vive un doctor, ¿eres Doctorine?"

# game/scripts/Locations/BlackDrum/di_castle_room.rpy:44
translate spanish m_di_castle_room_4bf56b43:

    # unknown "That's me, but don't call me that, it's too familiar... My real name is..."
    unknown "Ese soy yo, pero no me llames así, es demasiado familiar... Mi verdadero nombre es..."

# game/scripts/Locations/BlackDrum/di_castle_room.rpy:48
translate spanish m_di_castle_room_ad20b851:

    # kureha "I'm Doctor [kureha.n]. What brings you here? No one climbs a mountain without something important to do..."
    kureha "Soy el Doctor [kureha.n]. ¿Qué te trae por aquí? Nadie sube una montaña sin algo importante que hacer..."

# game/scripts/Locations/BlackDrum/di_castle_room.rpy:50
translate spanish m_di_castle_room_b18c93f1:

    # player "(Wow, she's gorgeous... Crazy? No way, she's really sexy!!)"
    player "(Wow, ella es hermosa... ¿Loco? ¡De ninguna manera, ella es realmente sexy!)"

# game/scripts/Locations/BlackDrum/di_castle_room.rpy:61
translate spanish m_di_castle_room_2d07f812:

    # robin "We're looking for the [SakuraFlower.n]."
    robin "Estamos buscando el [SakuraFlower.n]."

# game/scripts/Locations/BlackDrum/di_castle_room.rpy:63
translate spanish m_di_castle_room_781c8a3e:

    # robin "We've gathered information, and the only lead we have is you... That's why we're here."
    robin "Hemos recopilado información y la única pista que tenemos eres tú... Por eso estamos aquí."

# game/scripts/Locations/BlackDrum/di_castle_room.rpy:65
translate spanish m_di_castle_room_25c0802b:

    # kureha "Haha, searching for the [SakuraFlower.n] in a cold biome... It's impossible to think a sakura tree could grow in such a harsh environment... with all this cold!"
    kureha "Jaja, buscando el [SakuraFlower.n] en un bioma frío... Es imposible pensar que un árbol de sakura podría crecer en un entorno tan duro... ¡con todo este frío!"

# game/scripts/Locations/BlackDrum/di_castle_room.rpy:67
translate spanish m_di_castle_room_505edd3f:

    # robin "Thanks to a book, we found out that you have knowledge about this tree and its connection to this island."
    robin "Gracias a un libro, descubrimos que tienes conocimientos sobre este árbol y su conexión con esta isla."

# game/scripts/Locations/BlackDrum/di_castle_room.rpy:69
translate spanish m_di_castle_room_a479ccd6:

    # robin "We're aware of the climate issue... But we truly believe you can help us."
    robin "Estamos conscientes del problema climático... Pero realmente creemos que puedes ayudarnos."

# game/scripts/Locations/BlackDrum/di_castle_room.rpy:71
translate spanish m_di_castle_room_6cc3045f:

    # kureha "You seem like a smart girl. Why are you so keen on finding the [SakuraFlower.n]?"
    kureha "Pareces una chica inteligente. ¿Por qué te interesa tanto encontrar el [SakuraFlower.n]?"

# game/scripts/Locations/BlackDrum/di_castle_room.rpy:73
translate spanish m_di_castle_room_d85fb36a:

    # robin "We met a young woman who needs it..."
    robin "Conocimos a una joven que lo necesita..."

# game/scripts/Locations/BlackDrum/di_castle_room.rpy:75
translate spanish m_di_castle_room_f3769e3c:

    # player "(And what a beautiful young woman!!)"
    player "(¡¡Y qué jovencita más guapa!!)"

# game/scripts/Locations/BlackDrum/di_castle_room.rpy:77
translate spanish m_di_castle_room_729e930d:

    # robin "She's desperate because of a sick family member... She believes the [SakuraFlower.n] can help, and so do we."
    robin "Ella está desesperada por un familiar enfermo... Ella cree que los [SakuraFlower.n] pueden ayudar, y nosotros también."

# game/scripts/Locations/BlackDrum/di_castle_room.rpy:79
translate spanish m_di_castle_room_e1784d0b:

    # kureha "I see... I usually don't help strangers... but for some reason, you give me a sense of trust and calm..."
    kureha "Ya veo... Normalmente no ayudo a desconocidos... pero por alguna razón, tú me das una sensación de confianza y tranquilidad..."

# game/scripts/Locations/BlackDrum/di_castle_room.rpy:81
translate spanish m_di_castle_room_bbc9b9f9:

    # kureha "If it can help others, I won't stand idly by... I'll tell you the truth..."
    kureha "Si puede ayudar a otros no me quedaré de brazos cruzados... Te diré la verdad..."

# game/scripts/Locations/BlackDrum/di_castle_room.rpy:83
translate spanish m_di_castle_room_c6fd4752:

    # kureha "I'm not the expert on this subject..."
    kureha "No soy experto en este tema..."

# game/scripts/Locations/BlackDrum/di_castle_room.rpy:85
translate spanish m_di_castle_room_c664b9d9:

    # kureha "The truth is, a long time ago, there was a foolish doctor who spent years researching sakura trees..."
    kureha "La verdad es que, hace mucho tiempo, hubo un médico tonto que pasó años investigando los árboles de sakura..."

# game/scripts/Locations/BlackDrum/di_castle_room.rpy:87
translate spanish m_di_castle_room_5007eb2a:

    # kureha "He had a rather unusual approach to treating diseases... But that didn't make him any less of a genius!"
    kureha "Tenía un enfoque bastante inusual para tratar las enfermedades... ¡Pero eso no lo hacía menos genio!"

# game/scripts/Locations/BlackDrum/di_castle_room.rpy:89
translate spanish m_di_castle_room_14bfe87c:

    # kureha "He tirelessly researched until he figured out how to make a sakura tree grow on this island!"
    kureha "¡Investigó incansablemente hasta que descubrió cómo hacer crecer un árbol de sakura en esta isla!"

# game/scripts/Locations/BlackDrum/di_castle_room.rpy:91
translate spanish m_di_castle_room_a120b63d:

    # kureha "He said it would heal the hearts of the people on this island... hehe, he really was a fool..."
    kureha "Dijo que curaría los corazones de la gente de esta isla... jeje, realmente era un tonto..."

# game/scripts/Locations/BlackDrum/di_castle_room.rpy:93
translate spanish m_di_castle_room_af45a9b2:

    # kureha "So it seems you've come to the right place, as that fool managed to do the impossible."
    kureha "Entonces parece que has llegado al lugar correcto, ya que ese tonto logró hacer lo imposible."

# game/scripts/Locations/BlackDrum/di_castle_room.rpy:95
translate spanish m_di_castle_room_f758cf1f:

    # robin "So he actually made sakura trees bloom on this winter island?!?"
    robin "¿Entonces realmente hizo que los árboles de sakura florecieran en esta isla invernal?"

# game/scripts/Locations/BlackDrum/di_castle_room.rpy:97
translate spanish m_di_castle_room_65868d46:

    # kureha "He made it possible!... I can tell you where to find it..."
    kureha "¡Él lo hizo posible!...Te puedo decir dónde encontrarlo..."

# game/scripts/Locations/BlackDrum/di_castle_room.rpy:99
translate spanish m_di_castle_room_fde0edac:

    # kureha "I would have my assistant guide you, but they're not here right now... and I'm quite busy myself..."
    kureha "Me gustaría que mi asistente te guiara, pero no está aquí ahora... y yo también estoy bastante ocupado..."

# game/scripts/Locations/BlackDrum/di_castle_room.rpy:101
translate spanish m_di_castle_room_15bbea64:

    # kureha "But first, you must promise me you'll take only what's necessary without harming the tree..."
    kureha "Pero primero debes prometerme que tomarás sólo lo necesario sin dañar el árbol..."

# game/scripts/Locations/BlackDrum/di_castle_room.rpy:103
translate spanish m_di_castle_room_4a1a1be6:

    # player "We have a deal, we'll only take what we need..."
    player "Tenemos un trato, solo tomaremos lo que necesitemos..."

# game/scripts/Locations/BlackDrum/di_castle_room.rpy:105
translate spanish m_di_castle_room_917ab5ba:

    # kureha "It would be a shame not to have access to its fruits anymore..."
    kureha "Sería una pena no tener más acceso a sus frutos..."

# game/scripts/Locations/BlackDrum/di_castle_room.rpy:107
translate spanish m_di_castle_room_91150874:

    # kureha "You'd be harming yourselves if you broke your promise and wanted to return later..."
    kureha "Os estaríais haciendo daño si rompierais vuestra promesa y quisierais volver más tarde..."

# game/scripts/Locations/BlackDrum/di_castle_room.rpy:109
translate spanish m_di_castle_room_6d6d648d:

    # kureha "After passing the village, head into the forest before climbing up to the castle."
    kureha "Después de pasar el pueblo, adéntrate en el bosque antes de subir al castillo."

# game/scripts/Locations/BlackDrum/di_castle_room.rpy:111
translate spanish m_di_castle_room_6631ff7a:

    # kureha "From there, walk east without stopping, even though it may seem like there's no path, you'll reach the sakura tree."
    kureha "Desde allí camina hacia el este sin detenerte, aunque parezca que no hay camino, llegarás al árbol de sakura."

# game/scripts/Locations/BlackDrum/di_castle_room.rpy:113
translate spanish m_di_castle_room_0a9cc912:

    # robin "Thank you so much. If you ever need anything, don't hesitate to ask!"
    robin "Muchas gracias. Si alguna vez necesitas algo, ¡no dudes en preguntar!"

# game/scripts/Locations/BlackDrum/di_castle_room.rpy:115
translate spanish m_di_castle_room_6317edef:

    # kureha "We'll meet again... Now, go on with your business!"
    kureha "Nos volveremos a encontrar... ¡Ahora, continúa con tus asuntos!"

# game/scripts/Locations/BlackDrum/di_castle_room.rpy:117
translate spanish m_di_castle_room_8c7815cc:

    # player "(We'll definitely meet again, my sexy doctor...)"
    player "(Seguramente nos volveremos a encontrar, mi sexy doctor...)"

