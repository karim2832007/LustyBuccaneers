    # unknown "Mmm? Are you talking to me?"
    unknown "¿Mmm? ¿Me estás hablando a mí?"

# game/scripts/Locations/BlackDrum/drum_island_village.rpy:35
translate spanish m_drum_island_village_49b44071:

    # robin "Hehe... Let me handle this, Captain..."
    robin "Jeje... Déjame manejar esto, Capitán..."

# game/scripts/Locations/BlackDrum/drum_island_village.rpy:37
translate spanish m_drum_island_village_72e10741:

    # robin "Hello, nice to meet you, sir! We just arrived and we're looking for directions... Maybe you have some information about the [SakuraFlower.n]..."
    robin "Hola, ¡encantado de conocerlo, señor! Acabamos de llegar y buscamos indicaciones... Quizás tenga información sobre [SakuraFlower.n]..."

# game/scripts/Locations/BlackDrum/drum_island_village.rpy:39
translate spanish m_drum_island_village_c3a78133:

    # unknown "Hello miss! Lately, there have been several travelers asking the same thing..."
    unknown "¡Hola señorita! Últimamente, varios viajeros me han preguntado lo mismo..."

# game/scripts/Locations/BlackDrum/drum_island_village.rpy:41
translate spanish m_drum_island_village_9da94a0f:

    # unknown "It's not common to find that flower, I wouldn't know where to find it... As you can see, this island has a pretty harsh climate for any kind of plants!"
    unknown "No es común encontrar esa flor, no sabría dónde encontrarla... Como podéis ver esta isla tiene un clima bastante duro para cualquier tipo de planta!"

# game/scripts/Locations/BlackDrum/drum_island_village.rpy:43
translate spanish m_drum_island_village_8a61e119:

    # robin "That's quite apparent!... Maybe you could point us to a doctor or a flora specialist in the village?"
    robin "¡Eso es bastante evidente!... ¿Podrías indicarnos dónde encontrar un médico o un especialista en flora en el pueblo?"

# game/scripts/Locations/BlackDrum/drum_island_village.rpy:45
translate spanish m_drum_island_village_b4f08e12:

    # unknown "There are no doctors here!... Only the Isshi-20, but that group wouldn't help you even if you asked... They only serve the king..."
    unknown "¡Aquí no hay médicos!... Solo los Isshi-20, pero ese grupo no te ayudaría aunque lo pidieras... Solo sirven al rey..."

# game/scripts/Locations/BlackDrum/drum_island_village.rpy:47
translate spanish m_drum_island_village_ed750093:

    # robin "How can there be no doctors on the island!?!... That's serious!"
    robin "¡¿Cómo es posible que no haya médicos en la isla?!... ¡Eso es grave!"

# game/scripts/Locations/BlackDrum/drum_island_village.rpy:49
translate spanish m_drum_island_village_27e204e6:

    # unknown "It really is... But that's the current situation... Maybe... There is someone who could help."
    unknown "Realmente lo es... Pero esa es la situación actual... Tal vez... Hay alguien que pueda ayudar."

# game/scripts/Locations/BlackDrum/drum_island_village.rpy:51
translate spanish m_drum_island_village_89829bc4:

    # player "Who are you referring to!?!"
    player "¿A quién te refieres?"

# game/scripts/Locations/BlackDrum/drum_island_village.rpy:53
translate spanish m_drum_island_village_d1e4b5ca:

    # unknown "A crazy old woman, a doctor, retired, I think... But I don't know if she'd help you..."
    unknown "Una vieja loca, doctora, jubilada, creo... Pero no sé si te ayudaría..."

# game/scripts/Locations/BlackDrum/drum_island_village.rpy:55
translate spanish m_drum_island_village_bbea4199:

    # robin "Are you talking about Doctorine?"
    robin "¿Estás hablando de Doctorine?"

# game/scripts/Locations/BlackDrum/drum_island_village.rpy:57
translate spanish m_drum_island_village_1fded216:

    # unknown "Yeah, that's the one, hahaha, it's strange that outsiders know her... I didn't know she was that famous..."
    unknown "Sí, esa es, jajaja, es raro que la gente de fuera la conozca... No sabía que fuera tan famosa..."

# game/scripts/Locations/BlackDrum/drum_island_village.rpy:59
translate spanish m_drum_island_village_d91e92fe:

    # robin "Do you know where we could find her?"
    robin "¿Sabes dónde podemos encontrarla?"

# game/scripts/Locations/BlackDrum/drum_island_village.rpy:61
translate spanish m_drum_island_village_512daebb:

    # unknown "Unfortunately for you, she doesn't live in the village..."
    unknown "Desafortunadamente para ti, ella no vive en el pueblo..."

# game/scripts/Locations/BlackDrum/drum_island_village.rpy:63
translate spanish m_drum_island_village_62741fc2:

    # unknown "Look over there, at the top... You'll have to head that way, through the forest, until you reach her castle..."
    unknown "Mira allí, arriba... Tendrás que seguir por allí, a través del bosque, hasta llegar a su castillo..."

# game/scripts/Locations/BlackDrum/drum_island_village.rpy:65
translate spanish m_drum_island_village_0c75d053:

    # unknown "She's probably there, ever since the king left, she's taken over the place according to rumors..."
    unknown "Probablemente ella esté allí, desde que el rey se fue, ella se ha apoderado del lugar según los rumores..."

# game/scripts/Locations/BlackDrum/drum_island_village.rpy:67
translate spanish m_drum_island_village_5af76519:

    # unknown "But be careful, there are wild animals in the forest, and the weather won't make the climb easy..."
    unknown "Pero cuidado, hay animales salvajes en el bosque y el clima no hará fácil la subida..."

# game/scripts/Locations/BlackDrum/drum_island_village.rpy:69
translate spanish m_drum_island_village_3a8fa3d0:

    # robin "Don't worry, thank you very much for your help!"
    robin "No te preocupes, ¡muchas gracias por tu ayuda!"

# game/scripts/Locations/BlackDrum/drum_island_village.rpy:72
translate spanish m_drum_island_village_5d0d61ca:

    # player "Alright, let's move! We're getting closer to finding the flower..."
    player "¡Bien, a movernos! Cada vez estamos más cerca de encontrar la flor..."

