    narrador "El sonido de los puñetazos y el crujido de las pesas resuena en el gimnasio del barco."

# game/scripts/Events/Girls/Yamato/Training/yamato_training_1.rpy:18
translate spanish event_yamato_training_1_e2a7085a:

    # narrador "Among the equipment, you see [yamato.n] training intensely, her breathing steady and determined."
    narrador "Entre el equipo, se ve a [yamato.n] entrenando intensamente, su respiración constante y decidida."

# game/scripts/Events/Girls/Yamato/Training/yamato_training_1.rpy:20
translate spanish event_yamato_training_1_7fe87856:

    # player "(Wow... she hasn't slowed down for a single second...)"
    player "(¡Guau... no ha disminuido la velocidad ni un solo segundo...)"

# game/scripts/Events/Girls/Yamato/Training/yamato_training_1.rpy:21
translate spanish event_yamato_training_1_377e61d0:

    # player "(She's so sexy... even when she's just stretching...)"
    player "(Es tan sexy... incluso cuando solo está estirándose...)"

# game/scripts/Events/Girls/Yamato/Training/yamato_training_1.rpy:23
translate spanish event_yamato_training_1_baf3059d:

    # yamato "Ah! [player.n]! I didn't hear you come in. Why are you just standing there staring at me without saying anything?"
    yamato "¡Ah! [player.n]! No te oí entrar. ¿Por qué te quedas ahí parado mirándome sin decir nada?"

# game/scripts/Events/Girls/Yamato/Training/yamato_training_1.rpy:24
translate spanish event_yamato_training_1_557da0de:

    # player "I was simply admiring your beauty, [yamato.n]."
    player "Simplemente estaba admirando tu belleza, [yamato.n]."

# game/scripts/Events/Girls/Yamato/Training/yamato_training_1.rpy:25
translate spanish event_yamato_training_1_aef35237:

    # yamato "Hahaha, you'll never change!"
    yamato "¡Jajaja, nunca cambiarás!"

# game/scripts/Events/Girls/Yamato/Training/yamato_training_1.rpy:27
translate spanish event_yamato_training_1_cfa37b72:

    # yamato "I was just warming up a bit before starting the heavy exercises."
    yamato "Estaba calentando un poco antes de empezar con los ejercicios más intensos."

# game/scripts/Events/Girls/Yamato/Training/yamato_training_1.rpy:28
translate spanish event_yamato_training_1_a95e9dda:

    # player "Looks like you take it very seriously... you should teach me your routine sometime."
    player "Parece que te lo tomas muy en serio... deberías enseñarme tu rutina algún día."

# game/scripts/Events/Girls/Yamato/Training/yamato_training_1.rpy:29
translate spanish event_yamato_training_1_407089e5:

    # yamato "Really? I didn't think you'd be interested in training with me."
    yamato "¿En serio? No pensé que te interesara entrenar conmigo."

# game/scripts/Events/Girls/Yamato/Training/yamato_training_1.rpy:30
translate spanish event_yamato_training_1_555bd7a5:

    # player "Of course I am. Besides... there's no better motivation than doing it by your side."
    player "Por supuesto que sí. Además... no hay mejor motivación que hacerlo a tu lado."

# game/scripts/Events/Girls/Yamato/Training/yamato_training_1.rpy:31
translate spanish event_yamato_training_1_5daf9c74:

    # yamato "Hahaha, you always know what to say... Alright, let's see if you can keep up with me."
    yamato "Jajaja, siempre sabes qué decir... Bueno, veamos si puedes seguirme el ritmo."

# game/scripts/Events/Girls/Yamato/Training/yamato_training_1.rpy:32
translate spanish event_yamato_training_1_47c5f710:

    # player "That sounds like a challenge, and challenges don't scare me."
    player "Eso suena a reto, y los retos no me asustan."

# game/scripts/Events/Girls/Yamato/Training/yamato_training_1.rpy:34
translate spanish event_yamato_training_1_da104f51:

    # yamato "Excellent! Then let's make a little game out of it..."
    yamato "¡Excelente! Entonces, convirtámoslo en un pequeño juego..."

# game/scripts/Events/Girls/Yamato/Training/yamato_training_1.rpy:35
translate spanish event_yamato_training_1_b71f80c5:

    # player "A game?"
    player "¿Un juego?"

# game/scripts/Events/Girls/Yamato/Training/yamato_training_1.rpy:36
translate spanish event_yamato_training_1_a51ed939:

    # yamato "Yes, a game!"
    yamato "¡Sí, un juego!"

# game/scripts/Events/Girls/Yamato/Training/yamato_training_1.rpy:37
translate spanish event_yamato_training_1_670efee8:

    # yamato "I'll give you a dumbbell, and you'll have to hold it—same as me."
    yamato "Te daré una mancuerna y tendrás que sostenerla, igual que yo."

# game/scripts/Events/Girls/Yamato/Training/yamato_training_1.rpy:38
translate spanish event_yamato_training_1_dc1e6638:

    # yamato "But to make it more entertaining for me, I'll use much heavier weight than you."
    yamato "Pero para que me resulte más entretenido, usaré un peso mucho mayor que el tuyo."

# game/scripts/Events/Girls/Yamato/Training/yamato_training_1.rpy:39
translate spanish event_yamato_training_1_ea1b5a6f:

    # yamato "That way, we'll both be training, and whoever drops their dumbbell first loses..."
    yamato "De esa forma, ambos estaremos entrenando, y quien suelte primero la mancuerna pierde..."

# game/scripts/Events/Girls/Yamato/Training/yamato_training_1.rpy:40
translate spanish event_yamato_training_1_f0cc695b:

    # yamato "Simple, right?!?"
    yamato "¡Sencillo, ¿verdad?!"

# game/scripts/Events/Girls/Yamato/Training/yamato_training_1.rpy:41
translate spanish event_yamato_training_1_ed411fe3:

    # player "So I just have to hold it longer than you?"
    player "¿Entonces tengo que sostenerlo más tiempo que tú?"

# game/scripts/Events/Girls/Yamato/Training/yamato_training_1.rpy:42
translate spanish event_yamato_training_1_4f97be45:

    # yamato "Exactly—but even if you have less weight, I won't make it easy for you!"
    yamato "Exacto, pero aunque peses menos, ¡no te lo pondré fácil!"

# game/scripts/Events/Girls/Yamato/Training/yamato_training_1.rpy:43
translate spanish event_yamato_training_1_3469c804:

    # player "Alright, sounds fair... let's begin!"
    player "De acuerdo, me parece bien... ¡empecemos!"

# game/scripts/Events/Girls/Yamato/Training/yamato_training_1.rpy:44
translate spanish event_yamato_training_1_c2f59502:

    # yamato "Perfect. I warn you... I don't plan on holding back!"
    yamato "Perfecto. Te advierto... ¡No pienso contenerme!"

# game/scripts/Events/Girls/Yamato/Training/yamato_training_1.rpy:45
translate spanish event_yamato_training_1_06dd0165:

    # player "Just the way I like it, [yamato.n]. Let's see if you can wear me out before the day ends."
    player "Justo como me gusta, [yamato.n]. A ver si consigues cansarme antes de que acabe el día."

# game/scripts/Events/Girls/Yamato/Training/yamato_training_1.rpy:46
translate spanish event_yamato_training_1_2daf2a3e:

    # yamato "Hehehe, careful what you wish for, [player.n]... when I train, I don't let anyone quit halfway."
    yamato "Jejeje, cuidado con lo que deseas, [player.n]... cuando entreno, no dejo que nadie se rinda a la mitad."

# game/scripts/Events/Girls/Yamato/Training/yamato_training_1.rpy:52
translate spanish event_yamato_training_1_fc04733d:

    # yamato "Back again, [player.n]?!"
    yamato "¿¡De vuelta otra vez, [player.n]?!"

# game/scripts/Events/Girls/Yamato/Training/yamato_training_1.rpy:53
translate spanish event_yamato_training_1_1017985d:

    # yamato "Are you ready to compete? How about another little game again..."
    yamato "¿Estás listo para competir? ¿Qué tal otro jueguito?"

# game/scripts/Events/Girls/Yamato/Training/yamato_training_1.rpy:54
translate spanish event_yamato_training_1_84eeadd3:

    # player "Alright, let's get started!"
    player "¡Muy bien, empecemos!"

# game/scripts/Events/Girls/Yamato/Training/yamato_training_1.rpy:60
translate spanish event_yamato_training_1_868e0893:

    # yamato "Ready?!?"
    yamato "¿¡¿Listo?!?"

# game/scripts/Events/Girls/Yamato/Training/yamato_training_1.rpy:61
translate spanish event_yamato_training_1_a478c3c7:

    # yamato "Goooo!!"
    yamato "¡¡Vamos!!"

