# game/scripts/Events/Player/backstory.rpy:16
translate spanish backstory_7302bef8:

    # narrador "Wealth, fame, power. The King of the Pirates, a legendary pirate, achieved everything this world had to offer."
    narrador "Riqueza, fama, poder. El Rey de los Piratas, un pirata legendario, logró todo lo que este mundo podía ofrecer."

# game/scripts/Events/Player/backstory.rpy:18
translate spanish backstory_76e53e47:

    # narrador "My treasure? It's yours if you want it. Find it! I left everything the world has on that last island!..."
    narrador "¿Mi tesoro? Es tuyo si lo quieres. ¡Encuéntralo! ¡Dejé todo lo que el mundo tiene en esa última isla!..."

# game/scripts/Events/Player/backstory.rpy:20
translate spanish backstory_806a19fc:

    # narrador "With just those words, prior to his death, he stirred the entire world to search for the greatest pirate treasure."
    narrador "Con sólo esas palabras, antes de morir, conmovió al mundo entero a buscar el mayor tesoro pirata."

# game/scripts/Events/Player/backstory.rpy:22
translate spanish backstory_cb03637a:

    # narrador "And so, men set their sights on the Grand Line, chasing after their dreams. The world has truly entered a Great Pirate Era!"
    narrador "Y así, los hombres pusieron la mira en Grand Line, persiguiendo sus sueños. ¡El mundo ha entrado en una verdadera era de la Gran Pirata!"

# game/scripts/Events/Player/backstory.rpy:32
translate spanish backstory_9be354cd:

    # player "I am [player.n], a young pirate unlike any other..."
    player "Soy [player.n], un joven pirata diferente a cualquier otro..."

# game/scripts/Events/Player/backstory.rpy:34
translate spanish backstory_a87ad40e:

    # player "My main goal is to travel across the world, visiting island after island to...:"
    player "Mi objetivo principal es viajar por todo el mundo, visitando isla tras isla para...:"

# game/scripts/Events/Player/backstory.rpy:38
translate spanish backstory_b2b2a34b:

    # player "I'll be a free spirit, living from adventure to adventure, forming the best crew! I'll defeat anyone who gets in my way. My crew, especially me, will claim the greatest rewards... we'll be the most wanted and earn the respect and recognition of the entire world..."
    player "Seré un espíritu libre, viviendo de aventura en aventura, ¡formando la mejor tripulación! Derrotaré a cualquiera que se interponga en mi camino. Mi tripulación, especialmente yo, reclamará las mayores recompensas... seremos los más deseados y nos ganaremos el respeto y el reconocimiento del mundo entero..."

# game/scripts/Events/Player/backstory.rpy:44
translate spanish backstory_c2f4437d:

    # narrador "Strengh +1 | Charisma +1"
    narrador "Fuerza +1 | Carisma +1"

# game/scripts/Events/Player/backstory.rpy:47
translate spanish backstory_304eebb1:

    # player "I will become the greatest swordsman of all seas! I've sworn to myself to become the best, so I'll train tirelessly to defeat the current recognized number one in the world and take away that title... No one will be able to stop me in a fight!"
    player "¡Me convertiré en el mejor espadachín de todos los mares! Me juré a mí mismo ser el mejor, así que entrenaré incansablemente para derrotar al actual número uno del mundo y arrebatarle ese título... ¡Nadie podrá detenerme en una pelea!"

# game/scripts/Events/Player/backstory.rpy:52
translate spanish backstory_3bf5bc08:

    # narrador "Strengh +2"
    narrador "Fuerza +2"

# game/scripts/Events/Player/backstory.rpy:56
translate spanish backstory_b3ea27d9:

    # player "Women!!! Clearly the most important thing in this life... I'll search far and wide for the best women in the world, assemble my own harem as a crew, and live with them wherever that cursed treasure may be, away from the rest of the world..."
    player "¡¡¡Mujeres!!! Sin duda, lo más importante en esta vida... Buscaré por todas partes a las mejores mujeres del mundo, formaré mi propio harén y viviré con ellas dondequiera que esté ese tesoro maldito, lejos del resto del mundo..."

# game/scripts/Events/Player/backstory.rpy:61
translate spanish backstory_d0fff4d0:

    # narrador "Charisma +2"
    narrador "Carisma +2"

# game/scripts/Events/Player/backstory.rpy:64
translate spanish backstory_f11cc5b2:

    # player "From the bottom of the chain, I will reach the top! There's nothing stopping me from moving forward, there are no differences between right and wrong. By any means necessary, I will become the king who dominates everything!"
    player "Desde abajo de la cadena, ¡llegaré a la cima! Nada me impide avanzar; no hay diferencia entre el bien y el mal. ¡Sea cual sea el medio, me convertiré en el rey que lo domina todo!"

# game/scripts/Events/Player/backstory.rpy:71
translate spanish backstory_2e61f026:

    # narrador "Strengh +1 | Luck +1"
    narrador "Fuerza +1 | Suerte +1"

# game/scripts/Events/Player/backstory.rpy:73
translate spanish backstory_6c6358c4:

    # player "(And so, I decided to set sail... I'll start with a small crew... Even though they're all women, don't be deceived, these are the cleverest, strongest, and smartest around...)"
    player "(Y así, decidí zarpar... Empezaré con una pequeña tripulación... Aunque todas sean mujeres, no os dejéis engañar, ellas son las más listas, fuertes e inteligentes que hay...)"

# game/scripts/Events/Player/backstory.rpy:85
translate spanish backstory_d423b205:

    # narrador "One of the best navigators I've ever met..."
    narrador "Uno de los mejores navegantes que he conocido..."

# game/scripts/Events/Player/backstory.rpy:86
translate spanish backstory_e8adcd92:

    # narrador "Skilled in business, theft, and piracy, indispensable for sailing the seas..."
    narrador "Hábil en los negocios, el robo y la piratería, indispensable para navegar en los mares..."

# game/scripts/Events/Player/backstory.rpy:90
translate spanish backstory_747a7fd5:

    # nami "Ahoy, Captain! I'll guide us through the seas in search of the greatest treasures."
    nami "¡Ahoy, Capitán! Nos guiaré por los mares en busca de los mayores tesoros."

# game/scripts/Events/Player/backstory.rpy:91
translate spanish backstory_621ebaa3:

    # nami "Rest assured that with my guidance, we'll travel a path of fortunes like none you've ever seen."
    nami "Ten por seguro que con mi guía recorreremos un camino de fortuna como nunca has visto jamás."

# game/scripts/Events/Player/backstory.rpy:95
translate spanish backstory_e2aaf308:

    # narrador "The next addition was one of the smartest individuals I've ever met..."
    narrador "La siguiente incorporación fue una de las personas más inteligentes que he conocido..."

# game/scripts/Events/Player/backstory.rpy:96
translate spanish backstory_3ffcdf28:

    # narrador "Not only does she know a lot about history and politics, but she's also familiar with many ancient languages, exotic fruits, and all kinds of vital information to progress on our journey..."
    narrador "No sólo sabe mucho de historia y política, sino que también está familiarizada con muchos idiomas antiguos, frutas exóticas y todo tipo de información vital para progresar en nuestro viaje..."

# game/scripts/Events/Player/backstory.rpy:105
translate spanish backstory_6a23fac4:

    # robin "It's a pleasure, Captain! Let's discover together the mysteries and teachings hidden within the seas and different civilizations."
    robin "¡Un placer, Capitán! Descubramos juntos los misterios y las enseñanzas que esconden los mares y las diferentes civilizaciones."

# game/scripts/Events/Player/backstory.rpy:109
translate spanish backstory_2fb7b5ea:

    # narrador "Lastly, a strong and brave woman, always seeking new experiences and challenges alike..."
    narrador "Por último, una mujer fuerte y valiente, siempre en busca de nuevas experiencias y retos por igual..."

# game/scripts/Events/Player/backstory.rpy:110
translate spanish backstory_a82b8892:

    # narrador "A fanatic of training and self-improvement, with a wild heart thirsty for adventures..."
    narrador "Un fanático del entrenamiento y la superación, con un corazón salvaje sediento de aventuras..."

# game/scripts/Events/Player/backstory.rpy:119
translate spanish backstory_4009d260:

    # yamato "Hi, Captain! Rest assured that with me on this journey, you'll have a strong ally when facing any other crew."
    yamato "¡Hola, capitán! Tenga la seguridad de que conmigo en este viaje tendrá un aliado fuerte para enfrentarse a cualquier otra tripulación."

# game/scripts/Events/Player/backstory.rpy:120
translate spanish backstory_80b20e3a:

    # yamato "I'm eager for our next adventure and to confront other pirates!"
    yamato "¡Estoy ansioso por nuestra próxima aventura y enfrentarnos a otros piratas!"

# game/scripts/Events/Player/backstory.rpy:124
translate spanish backstory_b16a0331:

    # narrador "And so, with my goals set firmly, I decided to set sail to achieve my objective!"
    narrador "Y así, con mis metas firmemente establecidas, ¡decidí zarpar para lograr mi objetivo!"

# game/scripts/Events/Player/backstory.rpy:140
translate spanish backstory_fe2508dc:

    # player "With these three sexy, intelligent, and strong ladies, I will set my plan in motion..."
    player "Con estas tres damas sexys, inteligentes y fuertes, pondré en marcha mi plan..."

# game/scripts/Events/Player/backstory.rpy:141
translate spanish backstory_bb772c63:

    # player "I plan to recruit a few more members along the way... Let's see who we can find on the next islands..."
    player "Planeo reclutar algunos miembros más a lo largo del camino... Veamos a quién podemos encontrar en las próximas islas..."

# game/scripts/Events/Player/backstory.rpy:142
translate spanish backstory_89b2accd:

    # player "For now, it's time to prepare everything... Let's set sail!!"
    player "Por ahora, es momento de prepararlo todo... ¡Zarpemos!!"

