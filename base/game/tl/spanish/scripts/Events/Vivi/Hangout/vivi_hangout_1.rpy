translate spanish vivi_hangout_1_f818c271:

    # vivi "Alabasta has suffered too much. I have seen my home on the brink of destruction, I have seen my people suffer injustices..."
    vivi "Arabasta ha sufrido demasiado. He visto mi hogar al borde de la destrucción, he visto a mi gente sufrir injusticias..."

# game/scripts/Events/Vivi/Hangout/vivi_hangout_1.rpy:10
translate spanish vivi_hangout_1_2101d215:

    # vivi "But I have sworn to do everything in my power to protect them..."
