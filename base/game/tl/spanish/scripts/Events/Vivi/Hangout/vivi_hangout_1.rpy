# game/scripts/Events/Vivi/Hangout/vivi_hangout_1.rpy:11
translate spanish vivi_hangout_1_adc1dfc7:

    # vivi "Thanks to you and all the girls, I was able to do it last time... But what about the future?"
    vivi "Gracias a ti y a todas las chicas, pude hacerlo la última vez... ¿Pero qué pasa con el futuro?"

# game/scripts/Events/Vivi/Hangout/vivi_hangout_1.rpy:12
translate spanish vivi_hangout_1_1132221f:

    # vivi "Sometimes I wonder if I will ever truly be able to guarantee peace in my kingdom..."
