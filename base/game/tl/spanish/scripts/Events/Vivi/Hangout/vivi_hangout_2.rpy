translate spanish vivi_hangout_2_9f11d363:

    # player "You seem to be in a great mood today, [vivi.n]!"
    player "¡Parece que estás de muy buen humor hoy, [vivi.n]!"

# game/scripts/Events/Vivi/Hangout/vivi_hangout_2.rpy:6
translate spanish vivi_hangout_2_b2394754:

    # vivi "Do you really think so? Are you implying that I usually am not?"
    vivi "¿De verdad lo crees? ¿Insinúas que normalmente no lo soy?"

# game/scripts/Events/Vivi/Hangout/vivi_hangout_2.rpy:7
translate spanish vivi_hangout_2_1453f573:

    # player "No, no, I didn't mean that! Don't misunderstand me!"
    player "¡No, no, no quise decir eso! ¡No me malinterpretes!"

# game/scripts/Events/Vivi/Hangout/vivi_hangout_2.rpy:9
translate spanish vivi_hangout_2_cff5b610:

    # vivi "Hahaha! Just kidding, [player.n]!"
    vivi "¡Jajaja! ¡Es broma, [player.n]!"

# game/scripts/Events/Vivi/Hangout/vivi_hangout_2.rpy:10
translate spanish vivi_hangout_2_c0d72bea:

    # vivi "I've always tried to keep a smile, even in difficult moments."
    vivi "Siempre he intentado mantener una sonrisa, incluso en los momentos difíciles."

# game/scripts/Events/Vivi/Hangout/vivi_hangout_2.rpy:11
translate spanish vivi_hangout_2_b01a1d9b:

    # vivi "That doesn't mean I'm feeling bad now... Quite the opposite, but it became a habit to be like this."
    vivi "Eso no quiere decir que me sienta mal ahora... Todo lo contrario, pero se ha convertido en un hábito ser así."

# game/scripts/Events/Vivi/Hangout/vivi_hangout_2.rpy:13
translate spanish vivi_hangout_2_fe9bd6ce:

    # vivi "When I infiltrated Baroque Works, I had to pretend to be someone I wasn't for years..."
    vivi "Cuando me infiltré en Baroque Works, tuve que fingir ser alguien que no era durante años..."

# game/scripts/Events/Vivi/Hangout/vivi_hangout_2.rpy:14
translate spanish vivi_hangout_2_648e4ddd:

    # vivi "That taught me that sometimes you have to put on a facade to protect what truly matters."
    vivi "Eso me enseñó que a veces hay que poner una fachada para proteger lo que realmente importa."

# game/scripts/Events/Vivi/Hangout/vivi_hangout_2.rpy:15
translate spanish vivi_hangout_2_39324d50:

    # vivi "I hope to change that little by little... To express how I feel at all times, to never be forced to pretend again…"
    vivi "Espero cambiar eso poco a poco... Poder expresar lo que siento en todo momento, no volver a verme obligada a fingir nunca más..."

# game/scripts/Events/Vivi/Hangout/vivi_hangout_2.rpy:20
translate spanish vivi_hangout_2_fc725396:

    # player "I must admit that your acting was impeccable."
    player "Debo admitir que tu actuación fue impecable."

# game/scripts/Events/Vivi/Hangout/vivi_hangout_2.rpy:21
translate spanish vivi_hangout_2_dfc2658e:

    # player "If I didn't know the truth, I would never have suspected."
    player "Si no supiera la verdad nunca lo habría sospechado."

# game/scripts/Events/Vivi/Hangout/vivi_hangout_2.rpy:23
translate spanish vivi_hangout_2_53ad3f77:

    # vivi "Hahaha! I'll take it as a compliment, but it's not something I'm proud of."
    vivi "¡Jajaja! Lo tomaré como un cumplido, pero no es algo de lo que esté orgulloso."

# game/scripts/Events/Vivi/Hangout/vivi_hangout_2.rpy:24
translate spanish vivi_hangout_2_4b5af613:

    # vivi "I prefer to be honest with the people who matter to me."
    vivi "Prefiero ser honesto con las personas que me importan."

# game/scripts/Events/Vivi/Hangout/vivi_hangout_2.rpy:25
translate spanish vivi_hangout_2_cf6157a2:

    # player "Don't worry, little by little it will become easier for you!"
    player "¡No te preocupes, poco a poco te resultará más fácil!"

# game/scripts/Events/Vivi/Hangout/vivi_hangout_2.rpy:28
translate spanish vivi_hangout_2_20647bc3:

    # narrador "[vivi.n] love +1"
    narrador "[vivi.n] amor +1"

# game/scripts/Events/Vivi/Hangout/vivi_hangout_2.rpy:32
translate spanish vivi_hangout_2_8c301e1b:

    # player "Here, you don't need to pretend, Vivi. You can be yourself."
    player "Aquí no tienes que fingir, Vivi. Puedes ser tú misma."

# game/scripts/Events/Vivi/Hangout/vivi_hangout_2.rpy:34
translate spanish vivi_hangout_2_fbaff0a0:

    # vivi "That's... nice to hear. It makes me feel more comfortable with you."
    vivi "Me alegra oír eso. Me hace sentir más cómoda contigo."

# game/scripts/Events/Vivi/Hangout/vivi_hangout_2.rpy:35
translate spanish vivi_hangout_2_7c7c9936:

    # player "With me, you can be exactly who you are, you don't have to pretend anymore… I will do everything possible to make it easier for you!"
    player "Conmigo podrás ser exactamente quien eres, ya no tienes que fingir más… ¡Haré todo lo posible para que te resulte más fácil!"

# game/scripts/Events/Vivi/Hangout/vivi_hangout_2.rpy:36
translate spanish vivi_hangout_2_3ae4add6:

    # vivi "Thank you, [player.n]. I already trust you enough, little by little you will get to know me for who I truly am!"
    vivi "Gracias, [player.n]. Ya confío lo suficiente en ti, ¡poco a poco me conocerás como realmente soy!"

