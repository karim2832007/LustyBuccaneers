translate spanish vivi_hangout_6_ad9c68b0:

    # player "If one day you wish to visit again, you will be able to do so without any problems!"
    player "¡Si algún día deseas volver a visitarnos podrás hacerlo sin problema!"

# game/scripts/Events/Vivi/Hangout/vivi_hangout_6.rpy:18
translate spanish vivi_hangout_6_33535bea:

    # player "You will always be part of this crew, no matter the distance."
    player "Siempre serás parte de esta tripulación, sin importar la distancia."

# game/scripts/Events/Vivi/Hangout/vivi_hangout_6.rpy:20
translate spanish vivi_hangout_6_c57c5417:

    # vivi "You are so good to me, [player.n], a few words and all my doubts disappear..."
    vivi "Eres tan bueno conmigo, [player.n], unas pocas palabras y todas mis dudas desaparecen..."

# game/scripts/Events/Vivi/Hangout/vivi_hangout_6.rpy:21
translate spanish vivi_hangout_6_fcd873f4:

    # vivi "I trust you so much after everything we went through in Arabasta..."
    vivi "Confío mucho en ti después de todo lo que pasamos en Arabasta..."

# game/scripts/Events/Vivi/Hangout/vivi_hangout_6.rpy:22
translate spanish vivi_hangout_6_ea4b7722:

    # vivi "I never stop thinking about the adventures I might miss if we are not together..."
    vivi "Nunca dejo de pensar en las aventuras que podría perderme si no estamos juntos..."

# game/scripts/Events/Vivi/Hangout/vivi_hangout_6.rpy:27
translate spanish vivi_hangout_6_970b4607:

    # player "I can think of many adventures we could have together... Just you and me!"
    player "Puedo pensar en muchas aventuras que podríamos tener juntos... ¡Solo tú y yo!"

# game/scripts/Events/Vivi/Hangout/vivi_hangout_6.rpy:28
translate spanish vivi_hangout_6_450de7e0:

    # player "But I'm especially interested in the ones just the two of us will have..."
    player "Pero me interesan especialmente los que tendremos sólo nosotros dos..."

# game/scripts/Events/Vivi/Hangout/vivi_hangout_6.rpy:29
translate spanish vivi_hangout_6_315b12bc:

    # player "Do you know what I mean?... I really want to get to know you even more beyond everything that happened in your kingdom"
    player "¿Sabes a qué me refiero?... Realmente quiero conocerte aún más más allá de todo lo que pasó en tu reino."

# game/scripts/Events/Vivi/Hangout/vivi_hangout_6.rpy:31
translate spanish vivi_hangout_6_50ceb19e:

    # vivi "I know exactly what you mean, Captain... It's not that I don't want us to get to know each other better..."
    vivi "Sé exactamente lo que quieres decir, Capitán... No es que no quiera que nos conozcamos mejor..."

# game/scripts/Events/Vivi/Hangout/vivi_hangout_6.rpy:32
translate spanish vivi_hangout_6_93e97141:

    # vivi "But I hope you will be patient with me, I don't want to rush things too much..."
    vivi "Pero espero que tengáis paciencia conmigo, no quiero apresurar demasiado las cosas..."

# game/scripts/Events/Vivi/Hangout/vivi_hangout_6.rpy:33
