# game/scripts/Events/Vivi/Hangout/vivi_hangout_3.rpy:5
translate spanish vivi_hangout_3_e93c38a0:

    # vivi "[player.n], I have noticed that the crew sees you as their leader, and I want to make something clear..."
    vivi "[player.n], he notado que la tripulación te ve como su líder, y quiero dejar algo claro..."

# game/scripts/Events/Vivi/Hangout/vivi_hangout_3.rpy:6
translate spanish vivi_hangout_3_2d2a1a4d:

    # vivi "You know how much I respect you and that I will be forever grateful to you all..."
    vivi "Ya sabéis lo mucho que os respeto y que os estaré eternamente agradecido a todos vosotros..."

# game/scripts/Events/Vivi/Hangout/vivi_hangout_3.rpy:7
translate spanish vivi_hangout_3_a7df3dba:

    # vivi "It's an unpayable debt I have with your group, I will surely figure out how to repay it over time..."
    vivi "Es una deuda impagable que tengo con vuestro grupo, seguramente encontraré la manera de saldarla con el tiempo..."

# game/scripts/Events/Vivi/Hangout/vivi_hangout_3.rpy:8
translate spanish vivi_hangout_3_63d0bd67:

    # player "(Hahaha, I'm sure you will!)"
    player "(¡Jajajaja! ¡Estoy seguro que lo harás!)"

# game/scripts/Events/Vivi/Hangout/vivi_hangout_3.rpy:9
translate spanish vivi_hangout_3_78e28f22:

    # vivi "But I must always act for the good of my people, and even though I trust you, I must do what I believe is best for Alabasta."
    vivi "Pero debo actuar siempre por el bien de mi pueblo, y aunque confío en ti, debo hacer lo que creo que es mejor para Arabasta."

# game/scripts/Events/Vivi/Hangout/vivi_hangout_3.rpy:10
translate spanish vivi_hangout_3_32ceaa4e:

    # vivi "I cannot allow anyone else to dictate my decisions, especially if they go against these interests."
    vivi "No puedo permitir que nadie más dicte mis decisiones, especialmente si van en contra de estos intereses."

# game/scripts/Events/Vivi/Hangout/vivi_hangout_3.rpy:15
translate spanish vivi_hangout_3_1ffcd9e7:

    # player "No one here is forcing you to do anything, we are a team."
    player "Aquí nadie te obliga a hacer nada, somos un equipo."

# game/scripts/Events/Vivi/Hangout/vivi_hangout_3.rpy:16
translate spanish vivi_hangout_3_70270753:

    # player "[vivi.n], there are no orders here, we all work together."
    player "[vivi.n] Aquí no hay órdenes, todos trabajamos juntos."

# game/scripts/Events/Vivi/Hangout/vivi_hangout_3.rpy:17
translate spanish vivi_hangout_3_d9b7906e:

    # player "You are part of the team, and your decisions will always be respected."
    player "Eres parte del equipo y tus decisiones siempre serán respetadas."

# game/scripts/Events/Vivi/Hangout/vivi_hangout_3.rpy:18
translate spanish vivi_hangout_3_347836df:

    # vivi "That's good to hear... It makes me feel more at home here."
    vivi "Me alegra escuchar eso. Me hace sentir más en casa aquí."

# game/scripts/Events/Vivi/Hangout/vivi_hangout_3.rpy:20
translate spanish vivi_hangout_3_20647bc3:

    # narrador "[vivi.n] love +1"
    narrador "[vivi.n] amor +1"

# game/scripts/Events/Vivi/Hangout/vivi_hangout_3.rpy:24
translate spanish vivi_hangout_3_313de103:

    # player "If you're in my crew, you follow my rules."
    player "Si estás en mi tripulación, sigues mis reglas."

# game/scripts/Events/Vivi/Hangout/vivi_hangout_3.rpy:26
translate spanish vivi_hangout_3_74a72ec7:

    # vivi "I don't know if I like that idea..."
    vivi "No sé si me guste esa idea..."

# game/scripts/Events/Vivi/Hangout/vivi_hangout_3.rpy:27
translate spanish vivi_hangout_3_8de4bf54:

    # player "In time, you'll see that it's not a bad thing… I'm sure you'll like it..."
    player "Con el tiempo verás que no es malo… Seguro que te gustará…"

# game/scripts/Events/Vivi/Hangout/vivi_hangout_3.rpy:28
translate spanish vivi_hangout_3_26302407:

    # vivi "We'll see... I'm not entirely comfortable with this conversation..."
    vivi "Ya veremos... No me siento del todo cómoda con esta conversación..."

# game/scripts/Events/Vivi/Hangout/vivi_hangout_3.rpy:29
translate spanish vivi_hangout_3_6cb3d1a3:

    # vivi "We'll talk later..."
    vivi "Hablaremos más tarde..."

