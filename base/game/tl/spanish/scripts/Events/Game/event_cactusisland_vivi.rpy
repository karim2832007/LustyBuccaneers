translate spanish event_cactusisland_vivi_6ffb00a1:

    # vivi "The people are preparing... I have information that the final uprising will break out at any moment!"
    vivi "El pueblo se está preparando... ¡Tengo información de que el levantamiento final estallará en cualquier momento!"

# game/scripts/Events/Game/event_cactusisland_vivi.rpy:434
translate spanish event_cactusisland_vivi_45927f8f:

    # vivi "I can't stand by and watch my kingdom destroy itself! I must stop it!"
    vivi "¡No puedo quedarme de brazos cruzados viendo cómo mi reino se destruye! ¡Debo detenerlo!"

# game/scripts/Events/Game/event_cactusisland_vivi.rpy:435
translate spanish event_cactusisland_vivi_93e066fb:

    # robin "But how could such a prosperous kingdom reach this point..."
    robin "Pero ¿cómo pudo un reino tan próspero llegar a este punto..."

# game/scripts/Events/Game/event_cactusisland_vivi.rpy:437
translate spanish event_cactusisland_vivi_78799191:

    # vivi "This is all the fault of Baroque Works... I don't know how, but they're manipulating the situation..."
    vivi "Todo esto es culpa de Baroque Works... No sé cómo, pero están manipulando la situación..."

# game/scripts/Events/Game/event_cactusisland_vivi.rpy:438
translate spanish event_cactusisland_vivi_3ca6dc77:

    # vivi "Gathering more information and finding those responsible was impossible, so I turned to [igaram.n]..."
    vivi "Reunir más información y encontrar a los responsables resultó imposible, por lo que recurrí a [igaram.n]..."

# game/scripts/Events/Game/event_cactusisland_vivi.rpy:439
translate spanish event_cactusisland_vivi_15064733:

    # vivi "He helped me infiltrate the organization to discover who was behind it all and why!"
    vivi "¡Me ayudó a infiltrarme en la organización para descubrir quién estaba detrás de todo y por qué!"

# game/scripts/Events/Game/event_cactusisland_vivi.rpy:444
translate spanish event_cactusisland_vivi_cc892720:

    # yamato "Looks like you're a very brave princess!"
    yamato "¡Parece que eres una princesa muy valiente!"

# game/scripts/Events/Game/event_cactusisland_vivi.rpy:445
translate spanish event_cactusisland_vivi_638c48c7:

    # yamato "Did you find out who's behind all this?"
    yamato "¿Descubriste quién está detrás de todo esto?"

# game/scripts/Events/Game/event_cactusisland_vivi.rpy:447
translate spanish event_cactusisland_vivi_8022e08b:

    # vivi "Yes, the one behind it all calls himself Mr. 0 within the organization!..."
    vivi "¡Sí, el que está detrás de todo se hace llamar Mr. 0 dentro de la organización!..."

# game/scripts/Events/Game/event_cactusisland_vivi.rpy:448
translate spanish event_cactusisland_vivi_483c284f:

    # vivi "But that's not all... His true identity makes the situation even worse... His real name is:"
    vivi "Pero eso no es todo... Su verdadera identidad empeora aún más la situación... Su verdadero nombre es:"

# game/scripts/Events/Game/event_cactusisland_vivi.rpy:452
translate spanish event_cactusisland_vivi_6504ed4a:

    # vivi "[crocodile.n]!!!!"
    vivi "[crocodile.n]!!!!"

# game/scripts/Events/Game/event_cactusisland_vivi.rpy:455
translate spanish event_cactusisland_vivi_34adefea:

    # yamato "You can't be serious!!!"
    yamato "¡¡¡No puedes hablar en serio!!!"

# game/scripts/Events/Game/event_cactusisland_vivi.rpy:461
translate spanish event_cactusisland_vivi_cd3ffc3f:

    # robin "What did you say!!?!!"
    robin "¡¡¿¡¡Qué dijiste!!?!!"

# game/scripts/Events/Game/event_cactusisland_vivi.rpy:464
translate spanish event_cactusisland_vivi_1fce563f:

    # nami "This can't be!! And on top of that, we let [mr5.n] escape!! How did we get ourselves into this..."
    nami "¡Esto no puede ser! ¡Y encima, dejamos escapar a [mr5.n]! ¿Cómo nos metimos en esto...?"

# game/scripts/Events/Game/event_cactusisland_vivi.rpy:465
translate spanish event_cactusisland_vivi_3a324973:

    # player "And who's that?... Why are you so worried, girls..."
    player "¿Y quién es esa?... ¿Por qué estáis tan preocupadas, chicas...?"

# game/scripts/Events/Game/event_cactusisland_vivi.rpy:466
translate spanish event_cactusisland_vivi_16899f55:

    # robin "[crocodile.n] isn't just a nobody in the seas, Captain... How did you even set sail without knowing so many things?"
    robin "[crocodile.n] No es nadie en los mares, Capitán... ¿Cómo pudiste zarpar sin saber tantas cosas?"

# game/scripts/Events/Game/event_cactusisland_vivi.rpy:467
translate spanish event_cactusisland_vivi_7d96e434:

    # player "That's why I have you, [robin.n]! Hahaha!"
    player "¡Por eso te tengo a ti, [robin.n]! ¡Jajaja!"

# game/scripts/Events/Game/event_cactusisland_vivi.rpy:469
translate spanish event_cactusisland_vivi_e903aa31:

    # vivi "I need to return and put a stop to his plan... I don't know if he wants to take over the kingdom of [Arabasta.n] or what he desires..."
    vivi "Necesito regresar y detener su plan... No sé si quiere apoderarse del reino de [Arabasta.n] o qué desea..."

# game/scripts/Events/Game/event_cactusisland_vivi.rpy:472
translate spanish event_cactusisland_vivi_3152ed93:

    # vivi "But I'll stop him!!"
    vivi "¡¡¡Pero lo detendré!!!"

# game/scripts/Events/Game/event_cactusisland_vivi.rpy:474
translate spanish event_cactusisland_vivi_2cc3ad02:

    # nami "If someone as dangerous as [crocodile.n] is involved, we won't get out of this easily!!!"
    nami "¡Si está involucrado alguien tan peligroso como [crocodile.n], no saldremos de esto fácilmente!"

# game/scripts/Events/Game/event_cactusisland_vivi.rpy:475
