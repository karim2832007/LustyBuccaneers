translate spanish event_cactusisland_vivi_6af50710:

    # vivi "As you know, I'm the princess of the kingdom of [Arabasta.n]."
    vivi "Como sabéis, soy la princesa del reino de [Arabasta.n]."

# game/scripts/Events/Game/event_cactusisland_vivi.rpy:424
translate spanish event_cactusisland_vivi_dd4eb4dd:

    # vivi "This was a prosperous and secure kingdom, a magnificent realm... It had been growing immeasurably compared to the rest of the region."
    vivi "Éste era un reino próspero y seguro, un reino magnífico... Había estado creciendo inconmensurablemente en comparación con el resto de la región."

# game/scripts/Events/Game/event_cactusisland_vivi.rpy:425
translate spanish event_cactusisland_vivi_de45c780:

    # vivi "But now, all of that has abruptly changed..."
    vivi "Pero ahora todo eso ha cambiado abruptamente..."

