    # vivi "I assure you, I'll compensate you as soon as I can... Your kindness will always be remembered by me and my kingdom..."
    vivi "Te aseguro que te compensaré tan pronto como pueda... Tu bondad siempre será recordada por mí y mi reino..."

# game/scripts/Events/Game/event_cactusisland_vivi.rpy:413
translate spanish event_cactusisland_vivi_e395040a:

    # vivi "But this situation is much graver than you imagine!"
    vivi "¡Pero esta situación es mucho más grave de lo que imaginas!"

