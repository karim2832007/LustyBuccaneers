translate spanish event_cactusisland_vivi_b800ff53:

    # vivi "The kingdom is currently going through a great civil war!"
    vivi "¡El reino está pasando actualmente por una gran guerra civil!"

# game/scripts/Events/Game/event_cactusisland_vivi.rpy:431
translate spanish event_cactusisland_vivi_3021e113:

    # vivi "The citizens are taking up arms against the current government, plunging the kingdom into complete chaos..."
    vivi "Los ciudadanos están tomando las armas contra el gobierno actual, sumiendo al reino en un caos total..."

