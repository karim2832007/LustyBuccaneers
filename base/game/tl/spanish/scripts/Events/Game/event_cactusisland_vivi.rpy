    # vivi "I'm so thankful!... I really thought this was the end..."
    vivi "¡Estoy tan agradecida!... Realmente pensé que este era el final..."

# game/scripts/Events/Game/event_cactusisland_vivi.rpy:381
translate spanish event_cactusisland_vivi_1265db69:

    # player "(Woooow!!! So this is what it means to be royalty. She's stunning!)"
    player "(¡Guau! ¡Esto es lo que significa ser de la realeza! ¡Es impresionante!)"

# game/scripts/Events/Game/event_cactusisland_vivi.rpy:392
