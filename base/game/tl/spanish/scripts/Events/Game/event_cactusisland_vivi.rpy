    # vivi "They could send reinforcements at any moment. Follow me, I'll take you somewhere safe..."
    vivi "Podrían enviar refuerzos en cualquier momento. Síganme, los llevaré a un lugar seguro..."

# game/scripts/Events/Game/event_cactusisland_vivi.rpy:377
translate spanish event_cactusisland_vivi_d0e33e49:

    # vivi "Alright... We should be safe here."
    vivi "Está bien... Deberíamos estar seguros aquí."

# game/scripts/Events/Game/event_cactusisland_vivi.rpy:379
