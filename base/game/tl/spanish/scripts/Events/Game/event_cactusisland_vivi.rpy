    # robin "We're sure it is, princess, but what's the situation... Why were you taken prisoner?"
    robin "Estamos seguros que sí, princesa, pero ¿cuál es la situación...? ¿Por qué te tomaron prisionera?"

# game/scripts/Events/Game/event_cactusisland_vivi.rpy:419
