# game/scripts/Events/Uta/Hangout/uta_hangout_1.rpy:6
translate spanish uta_hangout_1_6ff56bc8:

    # uta "[player.n], can I ask you something a bit personal?"
    uta "[player.n] ¿Puedo preguntarte algo un poco personal?"

# game/scripts/Events/Uta/Hangout/uta_hangout_1.rpy:7
translate spanish uta_hangout_1_df18fcbb:

    # player "Of course. What's on your mind?"
    player "Por supuesto. ¿Qué tienes en mente?"

# game/scripts/Events/Uta/Hangout/uta_hangout_1.rpy:11
translate spanish uta_hangout_1_9751fb37:

    # uta "...Have you ever spent years chasing someone, just to hear them say they care about you?"
    uta "...¿Alguna vez has pasado años persiguiendo a alguien, sólo para escucharle decir que se preocupa por ti?"

# game/scripts/Events/Uta/Hangout/uta_hangout_1.rpy:12
translate spanish uta_hangout_1_5cac933e:

    # uta "For me, that person was my adopted father. He raised me. Protected me. But one day, he just... left."
    uta "Para mí, esa persona fue mi padre adoptivo. Él me crio. Me protegió. Pero un día, simplemente... se fue."

# game/scripts/Events/Uta/Hangout/uta_hangout_1.rpy:13
translate spanish uta_hangout_1_7f3aac56:

    # uta "I know he had reasons, but all I wanted was to hear him say I mattered..."
    uta "Sé que tenía razones, pero lo único que quería era oírle decir que yo importaba..."

# game/scripts/Events/Uta/Hangout/uta_hangout_1.rpy:14
translate spanish uta_hangout_1_bfa2bf45:

    # uta "So I sang. I created. I want to made the whole world listen... hoping maybe he would."
    uta "Así que canté. Creé. Quiero que todo el mundo escuche... esperando que tal vez lo haga."

# game/scripts/Events/Uta/Hangout/uta_hangout_1.rpy:19
translate spanish uta_hangout_1_dda1625c:

    # player "You matter, [uta.n]. Even if he never says it, you always did."
    player "Tú importas, [uta.n]. Aunque él nunca lo diga, siempre lo hiciste."

# game/scripts/Events/Uta/Hangout/uta_hangout_1.rpy:20
translate spanish uta_hangout_1_6d2f8845:

    # player "Your adopted father may not have said it enough, but I'm sure you mattered deeply to him."
    player "Puede que tu padre adoptivo no lo haya dicho lo suficiente, pero estoy seguro de que le importabas mucho."

# game/scripts/Events/Uta/Hangout/uta_hangout_1.rpy:21
translate spanish uta_hangout_1_a35b8f23:

    # player "And you matter now. Not because of your voice, but because of who you are."
    player "Y ahora importas. No por tu voz, sino por quién eres."

# game/scripts/Events/Uta/Hangout/uta_hangout_1.rpy:23
translate spanish uta_hangout_1_320d254a:

    # uta "...That means more to me than I can say, [player.n]..."
    uta "...Eso significa más para mí de lo que puedo decir, [player.n]..."

# game/scripts/Events/Uta/Hangout/uta_hangout_1.rpy:24
translate spanish uta_hangout_1_20ed2a2e:

    # uta "Maybe I needed to hear that more than anything."
    uta "Quizás necesitaba escuchar eso más que cualquier otra cosa."

# game/scripts/Events/Uta/Hangout/uta_hangout_1.rpy:28
translate spanish uta_hangout_1_d51546ad:

    # narrador "[uta.n] Love +2"
    narrador "[uta.n] Amor +2"

# game/scripts/Events/Uta/Hangout/uta_hangout_1.rpy:31
translate spanish uta_hangout_1_2a7cc75c:

    # player "You don't need his approval. You're stronger than that."
    player "No necesitas su aprobación. Eres más fuerte que eso."

# game/scripts/Events/Uta/Hangout/uta_hangout_1.rpy:32
translate spanish uta_hangout_1_b03cd1be:

    # player "You built yourself. Your music, your world—it's yours. Not his."
    player "Te construiste a ti mismo. Tu música, tu mundo, es tuyo. No suyo."

# game/scripts/Events/Uta/Hangout/uta_hangout_1.rpy:33
translate spanish uta_hangout_1_30f0ad69:

    # uta "...I want to believe that. Maybe I can let go... a little."
    uta "Quiero creerlo. Quizás pueda soltarme un poco."

# game/scripts/Events/Uta/Hangout/uta_hangout_1.rpy:36
translate spanish uta_hangout_1_7c120b02:

    # narrador "[uta.n] love +1"
    narrador "[uta.n] amor +1"

# game/scripts/Events/Uta/Hangout/uta_hangout_1.rpy:39
translate spanish uta_hangout_1_04acab66:

    # player "Maybe he never deserved to be called your father"
    player "Tal vez nunca mereció ser llamado tu padre."

# game/scripts/Events/Uta/Hangout/uta_hangout_1.rpy:40
translate spanish uta_hangout_1_5b8396d2:

    # player "If he left you like that, maybe he doesn't deserve the title of 'dad'."
    player "Si te dejó así tal vez no merece el título de papá."

# game/scripts/Events/Uta/Hangout/uta_hangout_1.rpy:42
translate spanish uta_hangout_1_fc2589c5:

    # uta "Don't say that..."
    uta "No digas eso..."

# game/scripts/Events/Uta/Hangout/uta_hangout_1.rpy:43
translate spanish uta_hangout_1_1e125c09:

    # uta "I know he made mistakes, but... he was there for me. At least once."
    uta "Sé que cometió errores, pero... estuvo ahí para mí. Al menos una vez."

# game/scripts/Events/Uta/Hangout/uta_hangout_1.rpy:44
translate spanish uta_hangout_1_b32f963f:

    # uta "I can't erase that part of my heart, even if I tried..."
    uta "No puedo borrar esa parte de mi corazón, aunque lo intente..."

