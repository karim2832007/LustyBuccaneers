translate spanish hancock_hangout_1_ce96605b:

    # player "How about you tell me something from your past, [hancock.n], something significant that shaped you..."
    player "¿Qué tal si me cuentas algo de tu pasado, [hancock.n], algo significativo que te haya marcado...?"

# game/scripts/Events/Hancock/Hangout/hancock_hangout_1.rpy:6
translate spanish hancock_hangout_1_51a8b430:

    # player "I like to know the past or stories of the people I'm traveling with..."
    player "Me gusta conocer el pasado o las historias de las personas con las que viajo..."

# game/scripts/Events/Hancock/Hangout/hancock_hangout_1.rpy:8
translate spanish hancock_hangout_1_77af5e90:

    # hancock "Well, [player.n], I don't like talking about my past, to be honest..."
    hancock "Bueno, [player.n], no me gusta hablar de mi pasado, para ser honesto..."

# game/scripts/Events/Hancock/Hangout/hancock_hangout_1.rpy:9
translate spanish hancock_hangout_1_af7b3cb1:

    # hancock "Everyone always talks about the Kuja's hatred for men..."
    hancock "Todo el mundo siempre habla del odio de las Kuja hacia los hombres..."

# game/scripts/Events/Hancock/Hangout/hancock_hangout_1.rpy:10
translate spanish hancock_hangout_1_8e804b38:

    # hancock "And much of it has to do with what my sisters and I went through in the past..."
    hancock "Y mucho de ello tiene que ver con lo que mis hermanas y yo pasamos en el pasado..."

# game/scripts/Events/Hancock/Hangout/hancock_hangout_1.rpy:14
translate spanish hancock_hangout_1_4e333d87:

    # hancock "With you, though... I don't know why, but it's always different..."
    hancock "Contigo, sin embargo... no sé por qué, pero siempre es diferente..."

# game/scripts/Events/Hancock/Hangout/hancock_hangout_1.rpy:15
translate spanish hancock_hangout_1_b51be0f1:

    # hancock "Even though I don't usually share this, especially with men, it's different with you..."
    hancock "Aunque no suelo compartir esto, sobre todo con los hombres, contigo es diferente..."

# game/scripts/Events/Hancock/Hangout/hancock_hangout_1.rpy:16
translate spanish hancock_hangout_1_694196ce:

    # hancock "There's something that always makes me want to open up to you..."
    hancock "Hay algo que siempre me hace querer abrirme a ti..."

# game/scripts/Events/Hancock/Hangout/hancock_hangout_1.rpy:17
translate spanish hancock_hangout_1_e7489c3b:

    # hancock "It's quite strange, I don't know what it is, but it makes me want to tell you..."
    hancock "Es bastante extraño, no sé qué es, pero me dan ganas de decírtelo..."

# game/scripts/Events/Hancock/Hangout/hancock_hangout_1.rpy:18
translate spanish hancock_hangout_1_ff2a247c:

    # hancock "When I was 12, my sisters and I were enslaved by the World Nobles in the Holy Land of Mary Geoise..."
    hancock "Cuando tenía 12 años, mis hermanas y yo fuimos esclavizadas por los Nobles Mundiales en la Tierra Santa de María Geoise..."

# game/scripts/Events/Hancock/Hangout/hancock_hangout_1.rpy:19
translate spanish hancock_hangout_1_4f93a2b3:

    # hancock "That cursed land is a hell... I assure you, the worst crimes in the world happen there..."
    hancock "Esa tierra maldita es un infierno... Te aseguro que allí ocurren los peores crímenes del mundo..."

# game/scripts/Events/Hancock/Hangout/hancock_hangout_1.rpy:20
translate spanish hancock_hangout_1_79acf947:

    # hancock "In that place, that's supposed to be a paradise in the world..."
    hancock "En ese lugar se supone que hay un paraíso en el mundo..."

# game/scripts/Events/Hancock/Hangout/hancock_hangout_1.rpy:21
translate spanish hancock_hangout_1_2d74aa04:

    # hancock "Fortunately, a few years ago, there was an attack on the city, and many of us slaves managed to escape..."
    hancock "Afortunadamente, hace unos años hubo un ataque a la ciudad y muchos de nosotros, los esclavos, logramos escapar..."

# game/scripts/Events/Hancock/Hangout/hancock_hangout_1.rpy:22
translate spanish hancock_hangout_1_29803141:

    # hancock "Since then, I vowed never to be controlled by anyone ever again..."
    hancock "Desde entonces juré que nunca más volvería a ser controlado por nadie..."

# game/scripts/Events/Hancock/Hangout/hancock_hangout_1.rpy:23
translate spanish hancock_hangout_1_c6ad654c:

    # hancock "I will never allow men like the ones from Mary Geoise to lay a finger on me or have control over me again..."
    hancock "Nunca más permitiré que hombres como los de Mary Geoise me pongan un dedo encima o tengan control sobre mí..."

# game/scripts/Events/Hancock/Hangout/hancock_hangout_1.rpy:25
translate spanish hancock_hangout_1_78d74fff:

    # hancock "I will have my revenge someday..."
    hancock "Algún día tendré mi venganza..."

# game/scripts/Events/Hancock/Hangout/hancock_hangout_1.rpy:30
translate spanish hancock_hangout_1_c61bda2d:

    # player "I can't imagine how hard that must have been..."
    player "No puedo imaginarme lo difícil que debe haber sido..."

