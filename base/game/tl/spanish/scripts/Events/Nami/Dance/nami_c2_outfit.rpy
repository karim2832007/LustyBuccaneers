translate spanish nami_c2_outfit_e11ff575:

    # player "While we were walking around the city with the girls, I saw a very interesting shop..."
    player "Mientras caminábamos por la ciudad con las chicas, vi una tienda muy interesante..."

# game/scripts/Events/Nami/Dance/nami_c2_outfit.rpy:9
translate spanish nami_c2_outfit_6303ddf7:

    # nami "Oh really? What kind of shop, Captain?"
    nami "¿En serio? ¿Qué clase de tienda, capitán?"

# game/scripts/Events/Nami/Dance/nami_c2_outfit.rpy:10
translate spanish nami_c2_outfit_2f0edf99:

    # player "Well, something I'm sure you're going to love... Look, I got something for you, here you go, [nami.n]"
    player "Bueno, algo que seguro te va a encantar... Mira, tengo algo para ti, aquí tienes, [nami.n]"

# game/scripts/Events/Nami/Dance/nami_c2_outfit.rpy:12
translate spanish nami_c2_outfit_3540c4e8:

    # nami "Mmh? A gift for me? How generous, captain!!! You've never done something like this for me before!"
    nami "¿Mmm? ¿Un regalo para mí? ¡Qué generoso, capitán! ¡Nunca me habías hecho algo así!"

# game/scripts/Events/Nami/Dance/nami_c2_outfit.rpy:13
translate spanish nami_c2_outfit_6867a320:

    # nami "A bag!?!... What could it be... Clothes maybe?!?... Mnmnm how strange... Before I open it I was thinking..."
    nami "¡¿Una bolsa?!?... ¿Qué podría ser?... ¿Ropa quizás?!?... Mnmnm qué extraño... Antes de abrirla estaba pensando..."

# game/scripts/Events/Nami/Dance/nami_c2_outfit.rpy:15
translate spanish nami_c2_outfit_7aa5bd6a:

    # nami "This is the first gift of this kind you've given me... You don't want something in return, do you!!!"
    nami "Este es el primer regalo de este tipo que me has hecho... No quieres nada a cambio, ¿verdad?"

# game/scripts/Events/Nami/Dance/nami_c2_outfit.rpy:16
translate spanish nami_c2_outfit_73c34c0e:

    # player "Who, me? of course not!... No hidden intentions"
    player "¿Quién, yo? ¡Claro que no!... Sin intenciones ocultas."

# game/scripts/Events/Nami/Dance/nami_c2_outfit.rpy:17
translate spanish nami_c2_outfit_e4820458:

    # player "You know me [nami.n]!"
    player "¡Me conoces [nami.n]!"

# game/scripts/Events/Nami/Dance/nami_c2_outfit.rpy:19
translate spanish nami_c2_outfit_265254d1:

    # nami "Hhahaha that's exactly why I'm asking, Captain!!!"
    nami "Jajaja eso es exactamente por lo que estoy preguntando, ¡Capitán!!!"

# game/scripts/Events/Nami/Dance/nami_c2_outfit.rpy:20
translate spanish nami_c2_outfit_1fa64a90:

    # nami "You're always thinking about one thing!!"
    nami "¡¡¡Siempre estás pensando en una sola cosa!!!"

# game/scripts/Events/Nami/Dance/nami_c2_outfit.rpy:21
translate spanish nami_c2_outfit_63c9b639:

    # player "Hhaahah you know me well! and maybe you're not wrong!"
    player "¡Jajajajaja! ¡Me conoces bien! ¡Y quizá no te equivoques!"

# game/scripts/Events/Nami/Dance/nami_c2_outfit.rpy:22
translate spanish nami_c2_outfit_f358be02:

    # player "I just thought this dress would highlight your talents... especially if you decide to use it to entertain the crowd!"
    player "Pensé que este vestido resaltaría tus talentos... ¡especialmente si decides usarlo para entretener a la multitud!"

# game/scripts/Events/Nami/Dance/nami_c2_outfit.rpy:24
translate spanish nami_c2_outfit_1cf87581:

    # nami "Je... Sounds like you're offering me a business deal."
    nami "Je... Parece que me estás ofreciendo un trato comercial."

# game/scripts/Events/Nami/Dance/nami_c2_outfit.rpy:25
translate spanish nami_c2_outfit_b3048b98:

    # player "Why don't you try it on and we'll see if it's worth the investment?"
    player "¿Por qué no lo pruebas y vemos si vale la pena la inversión?"

# game/scripts/Events/Nami/Dance/nami_c2_outfit.rpy:39
translate spanish nami_c2_outfit_d4b8a9ee:

    # nami "Tadaaaa!"
    nami "¡Tadaaaa!"

# game/scripts/Events/Nami/Dance/nami_c2_outfit.rpy:40
translate spanish nami_c2_outfit_c3544c80:

    # nami "So, Captain? What do you think?"
    nami "¿Y bien, capitán? ¿Qué opina?"

# game/scripts/Events/Nami/Dance/nami_c2_outfit.rpy:41
translate spanish nami_c2_outfit_a194fead:

    # nami "Do you like what you see?"
    nami "¿Te gusta lo que ves?"

# game/scripts/Events/Nami/Dance/nami_c2_outfit.rpy:42
translate spanish nami_c2_outfit_c53043ef:

    # player "Wow... I didn't expect it to look this sexy. That dress was made for you!"
    player "¡Guau! No esperaba que se viera tan sexy. ¡Ese vestido está hecho para ti!"

# game/scripts/Events/Nami/Dance/nami_c2_outfit.rpy:44
translate spanish nami_c2_outfit_4d8944e7:

    # nami "hahaha I knew you'd say something like that Captain!"
    nami "¡Jajajajaja sabía que dirías algo así Capitán!"

# game/scripts/Events/Nami/Dance/nami_c2_outfit.rpy:46
translate spanish nami_c2_outfit_01d2f01e:

    # nami "I really like it too... Maybe you should buy me clothes more often... We'd both benefit!"
    nami "A mí también me gusta mucho... Quizás deberías comprarme ropa más a menudo... ¡Ambos saldríamos beneficiados!"

# game/scripts/Events/Nami/Dance/nami_c2_outfit.rpy:49
translate spanish nami_c2_outfit_1893bc92:

    # narrador "[nami.n] Love +2"
    narrador "[nami.n] Amor +2"

# game/scripts/Events/Nami/Dance/nami_c2_outfit.rpy:51
translate spanish nami_c2_outfit_cfeaee72:

    # player "Of course I will!"
    player "¡Por supuesto que lo haré!"

# game/scripts/Events/Nami/Dance/nami_c2_outfit.rpy:52
translate spanish nami_c2_outfit_20abe092:

    # player "(The rest of the girls would look amazing in similar outfits... I'll see what I can do with the others!)"
    player "(El resto de las chicas lucirían increíbles con atuendos similares... ¡Veré qué puedo hacer con las demás!)"

# game/scripts/Events/Nami/Dance/nami_c2_outfit.rpy:53
translate spanish nami_c2_outfit_9fdb8529:

    # nami "So... Did you just give it to me to score points or did you actually have a business idea in mind?"
    nami "Entonces... ¿Me lo diste simplemente para ganar puntos o realmente tenías una idea de negocio en mente?"

# game/scripts/Events/Nami/Dance/nami_c2_outfit.rpy:54
translate spanish nami_c2_outfit_8b6bbd30:

    # player "Hahah I like the way you think [nami.n], that's why you're in my crew!"
    player "Jajaja me gusta tu forma de pensar [nami.n], ¡por eso estás en mi equipo!"

# game/scripts/Events/Nami/Dance/nami_c2_outfit.rpy:55
translate spanish nami_c2_outfit_057d83cd:

    # player "With that hip movement you could raise more funds than an entire treasure!"
    player "¡Con ese movimiento de cadera podrías recaudar más fondos que todo un tesoro!"

# game/scripts/Events/Nami/Dance/nami_c2_outfit.rpy:56
translate spanish nami_c2_outfit_6a8b04b1:

    # nami "Are you suggesting I dance in this outfit to attract customers?"
    nami "¿Estás sugiriendo que baile con este atuendo para atraer clientes?"

# game/scripts/Events/Nami/Dance/nami_c2_outfit.rpy:57
translate spanish nami_c2_outfit_f3d4fd42:

    # player "I'm just saying... you could turn every night into gold, if you know what I mean."
    player "Sólo digo... que podrías convertir cada noche en oro, si sabes a qué me refiero."

# game/scripts/Events/Nami/Dance/nami_c2_outfit.rpy:59
translate spanish nami_c2_outfit_0551d528:

    # nami "Hehehe... I like the way you think. Easy money, and with my personal bodyguard by my side..."
    nami "Jejeje... Me gusta tu forma de pensar. Dinero fácil, y con mi guardaespaldas a mi lado..."

# game/scripts/Events/Nami/Dance/nami_c2_outfit.rpy:60
translate spanish nami_c2_outfit_59dd053a:

    # player "Exactly. I'll make sure to keep the drunks away... you just make sure they throw their [Berries.n]."
    player "Exactamente. Me aseguraré de mantener alejados a los borrachos... tú solo asegúrate de que tiren sus [Berries.n]."

# game/scripts/Events/Nami/Dance/nami_c2_outfit.rpy:61
translate spanish nami_c2_outfit_e5f31343:

    # nami "Then we have a deal, captain. But fair warning: I'm keeping the biggest share of the loot."
    nami "Entonces tenemos un trato, capitán. Pero le advierto: me quedo con la mayor parte del botín."

# game/scripts/Events/Nami/Dance/nami_c2_outfit.rpy:62
translate spanish nami_c2_outfit_63e0518f:

    # player "As always... but at least I'll have front row seats."
    player "Como siempre...pero al menos tendré asientos en primera fila."

# game/scripts/Events/Nami/Dance/nami_c2_outfit.rpy:64
translate spanish nami_c2_outfit_a07e2e8f:

    # nami "Hmph~ Only if you behave yourself..."
    nami "Hmph~ Sólo si te portas bien..."

# game/scripts/Events/Nami/Dance/nami_c2_outfit.rpy:65
translate spanish nami_c2_outfit_dcd2be44:

    # nami "Now all that's left is to find somewhere I can dance!"
    nami "¡Ahora sólo me queda encontrar un lugar donde pueda bailar!"

# game/scripts/Events/Nami/Dance/nami_c2_outfit.rpy:66
translate spanish nami_c2_outfit_b99c7a96:

    # player "I already have something in mind... Just leave it to me, we'll see what fate has in store..."
    player "Ya tengo algo en mente... Déjamelo a mí, veremos qué nos depara el destino..."

# game/scripts/Events/Nami/Dance/nami_c2_outfit.rpy:67
translate spanish nami_c2_outfit_df186455:

    # player "Yuba might be a good option!"
    player "¡Yuba podría ser una buena opción!"

