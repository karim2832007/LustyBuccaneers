    # nami "How are you, Captain?... Since we live together on this ship,"
    nami "¿Cómo está, Capitán?... Ya que vivimos juntos en este barco,"

# game/scripts/Events/Nami/Hangout/nami_hangout_1.rpy:6
translate spanish nami_hangout_1_dc6c1ae3:

    # nami "I imagine you've already learned a thing or two about me and my tastes..."
    nami "Imagino que ya has aprendido una cosa o dos sobre mí y mis gustos..."

# game/scripts/Events/Nami/Hangout/nami_hangout_1.rpy:7
translate spanish nami_hangout_1_d0a5e4b9:

    # player "Of course, I'm always very attentive to you and the rest of the girls."
    player "Por supuesto, siempre estoy muy atenta a ti y al resto de chicas."

# game/scripts/Events/Nami/Hangout/nami_hangout_1.rpy:8
translate spanish nami_hangout_1_6c200bea:

    # player "I always see you sunbathing, or looking for ways to make money... among many other things..."
    player "Siempre te veo tomando el sol, o buscando la manera de ganar dinero... entre muchas otras cosas..."

# game/scripts/Events/Nami/Hangout/nami_hangout_1.rpy:9
translate spanish nami_hangout_1_cd9569bd:

    # nami "Soo... you surely know what kind of islands I'd like to visit to relax, right?"
    nami "Bueno... seguramente sabes qué tipo de islas me gustaría visitar para relajarme, ¿verdad?"

# game/scripts/Events/Nami/Hangout/nami_hangout_1.rpy:13
translate spanish nami_hangout_1_cfcef3b1:

    # player "Umm... I suppose a winter island, right? To see its beautiful landscapes!"
    player "Umm... Supongo que una isla invernal, ¿no? ¡Para ver sus hermosos paisajes!"

# game/scripts/Events/Nami/Hangout/nami_hangout_1.rpy:15
translate spanish nami_hangout_1_5b3cdb91:

    # nami "I hate the cold, Captain... Two minutes ago, you said you always see me sunbathing..."
    nami "Odio el frío, Capitán... Hace dos minutos dijiste que siempre me veías tomando el sol..."

# game/scripts/Events/Nami/Hangout/nami_hangout_1.rpy:16
translate spanish nami_hangout_1_93c3147d:

    # nami "Now I see how much attention you pay to us girls and me..."
    nami "Ahora veo cuánta atención nos prestas a nosotras, las chicas, y a mí..."

# game/scripts/Events/Nami/Hangout/nami_hangout_1.rpy:17
translate spanish nami_hangout_1_2d906862:

    # nami "Not everything is adventures, Captain! Resting from time to time, enjoying and celebrating with friends, and recovering for the next adventures are very important..."
    nami "¡No todo son aventuras, Capitán! Descansar de vez en cuando, disfrutar y celebrar con amigos, y recuperarse para las próximas aventuras es muy importante..."

# game/scripts/Events/Nami/Hangout/nami_hangout_1.rpy:18
translate spanish nami_hangout_1_6b3c0fc0:

    # nami "I didn't realize you were so narrow-minded and carefree... I'll get back to my work..."
    nami "No me di cuenta de que eras tan estrecho de miras y despreocupado... Volveré a mi trabajo..."

# game/scripts/Events/Nami/Hangout/nami_hangout_1.rpy:21
translate spanish nami_hangout_1_2c6fc135:

    # narrador "[nami.n] Love -1"
    narrador "[nami.n] Amor -1"

# game/scripts/Events/Nami/Hangout/nami_hangout_1.rpy:24
translate spanish nami_hangout_1_9a7ae85c:

    # player "I'm sure you would love a summer island!... to enjoy its beaches and relax peacefully!"
    player "¡Seguro que te encantaría una isla de verano!... ¡para disfrutar de sus playas y relajarte tranquilamente!"

# game/scripts/Events/Nami/Hangout/nami_hangout_1.rpy:25
translate spanish nami_hangout_1_2ba48b4c:

    # nami "Captain!! Of course, I love warm places with beautiful beaches and stunning sunsets to see!"
    nami "¡Capitán! ¡Claro que me encantan los lugares cálidos con playas hermosas y atardeceres impresionantes!"

# game/scripts/Events/Nami/Hangout/nami_hangout_1.rpy:26
translate spanish nami_hangout_1_f6223d41:

    # nami "Any tropical island where I can relax, sunbathe, and enjoy something refreshing would be ideal!"
    nami "¡Cualquier isla tropical donde pueda relajarme, tomar el sol y disfrutar de algo refrescante sería ideal!"

# game/scripts/Events/Nami/Hangout/nami_hangout_1.rpy:27
translate spanish nami_hangout_1_f3e100f0:

    # player "Perfect, I'll keep that in mind. I'm sure we'll visit many on our journey!"
    player "Perfecto, lo tendré en cuenta. ¡Seguro que visitaremos muchos en nuestro viaje!"

# game/scripts/Events/Nami/Hangout/nami_hangout_1.rpy:29
translate spanish nami_hangout_1_ef8d0736:

    # nami "Thank you, Captain! I didn't realize you saw me that way... I'll get back to my duties now. See you later."
    nami "¡Gracias, capitán! No me había dado cuenta de que me veía así... Regresaré a mis tareas. Nos vemos luego."

# game/scripts/Events/Nami/Hangout/nami_hangout_1.rpy:30
