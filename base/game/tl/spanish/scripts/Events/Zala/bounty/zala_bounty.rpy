# game/scripts/Events/Zala/bounty/zala_bounty.rpy:16
translate spanish bounty_board_zala_e5ce54c7:

    # narrador "New mission: 'Defeat [zala.n]'"
    narrador "Nueva misión: 'Derrotar a [zala.n]'"

# game/scripts/Events/Zala/bounty/zala_bounty.rpy:21
translate spanish bounty_board_zala_62bcdae1:

    # nami "Captain, are you thinking about searching for [zala.n]?"
    nami "Capitán, ¿está pensando en buscar [zala.n]?"

# game/scripts/Events/Zala/bounty/zala_bounty.rpy:23
translate spanish bounty_board_zala_d7879eda:

    # nami "If we manage to defeat her in combat, we'll get a good reward!!"
    nami "¡Si logramos derrotarla en combate, obtendremos una buena recompensa!"

# game/scripts/Events/Zala/bounty/zala_bounty.rpy:24
translate spanish bounty_board_zala_d4dbb20e:

    # nami "To achieve this, we must find her first..."
    nami "Para lograr esto, primero debemos encontrarla..."

# game/scripts/Events/Zala/bounty/zala_bounty.rpy:25
translate spanish bounty_board_zala_9a59da9a:

    # nami "From the information provided by the poster, we'll find her on the nearby coast..."
    nami "Por la información que proporciona el cartel, la encontraremos en la costa cercana..."

# game/scripts/Events/Zala/bounty/zala_bounty.rpy:26
translate spanish bounty_board_zala_166646c8:

    # nami "We must travel and explore the seas, and then see what nearby ships we encounter..."
    nami "Debemos viajar y explorar los mares, y luego ver qué barcos cercanos encontramos..."

# game/scripts/Events/Zala/bounty/zala_bounty.rpy:27
translate spanish bounty_board_zala_b966db2f:

    # nami "But we must go prepared, having some cannonballs, wood, and food would be ideal..."
    nami "Pero debemos ir preparados, tener algunas balas de cañón, madera y comida sería lo ideal..."

# game/scripts/Events/Zala/bounty/zala_bounty.rpy:28
translate spanish bounty_board_zala_785f28ee:

    # nami "Because if we find her, we'll have to face her ship!!"
    nami "¡Porque si la encontramos, tendremos que enfrentarnos a su barco!"

# game/scripts/Events/Zala/bounty/zala_bounty.rpy:32
translate spanish bounty_board_zala_cd77de0a:

    # robin "[zala.n]... Mnmnmg..."
    robin "[zala.n]... Mmm..."

# game/scripts/Events/Zala/bounty/zala_bounty.rpy:33
translate spanish bounty_board_zala_187f3f9d:

    # robin "I think I remember this name... There are many rumors about her..."
    robin "Creo recordar este nombre... Hay muchos rumores sobre ella..."

# game/scripts/Events/Zala/bounty/zala_bounty.rpy:34
translate spanish bounty_board_zala_ef91f6df:

    # robin "From what I've heard, she belongs to a strange group, most likely linked to the criminal underworld..."
    robin "Por lo que he oído, pertenece a un grupo extraño, probablemente vinculado al submundo criminal..."

# game/scripts/Events/Zala/bounty/zala_bounty.rpy:35
translate spanish bounty_board_zala_cda97176:

    # robin "But there's little reliable information."
    robin "Pero hay poca información confiable."

# game/scripts/Events/Zala/bounty/zala_bounty.rpy:36
translate spanish bounty_board_zala_e585feaf:

    # robin "It seems this group wants to stay in the shadows, so they usually eliminate anyone who has information about them."
    robin "Parece que este grupo quiere permanecer en las sombras, por lo que normalmente eliminan a cualquiera que tenga información sobre ellos."

# game/scripts/Events/Zala/bounty/zala_bounty.rpy:37
translate spanish bounty_board_zala_050eeff0:

    # robin "We should be careful, we might be inviting trouble with her organization if we get involved with her."
    robin "Debemos tener cuidado, podríamos estar invitando a problemas con su organización si nos involucramos con ella."

