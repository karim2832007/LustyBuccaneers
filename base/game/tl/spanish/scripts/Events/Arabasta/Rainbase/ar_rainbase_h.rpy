translate spanish ar_rainbase_h_bed52e1e:

    # nami "Well done Capitan!!"
    nami "¡¡¡Bien hecho Capitán!!!"

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:194
