    # vivi "He's considered one of the strongest warriors of [Arabasta.n]."
    vivi "Se le considera uno de los guerreros más fuertes de [Arabasta.n]."

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:156
