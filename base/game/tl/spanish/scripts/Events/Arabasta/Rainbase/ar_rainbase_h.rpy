translate spanish ar_rainbase_h_67e457e7:

    # vivi "It's a Bananawani, it must be the pet [crocodile.n] was talking about!!"
    vivi "Es un Bananawani, ¡debe ser la mascota de la que hablaba [crocodile.n]!"

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:174
