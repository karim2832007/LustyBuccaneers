translate spanish ar_rainbase_h_c21711a6:

    # crocodile "I want to get there in time and enjoy the spectacle!"
    crocodile "¡Quiero llegar a tiempo y disfrutar del espectáculo!"

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:132
translate spanish ar_rainbase_h_d5e001f3:

    # unknown "I will kill you!"
    unknown "¡Voy a matarte!"

