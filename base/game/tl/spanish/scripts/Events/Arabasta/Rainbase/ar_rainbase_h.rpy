    robin "Sería mejor observar cuidadosamente lo que sucede antes de involucrarse."

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:56
translate spanish ar_rainbase_h_7dd3074e:

    # yamato "Right, the element of surprise is important..."
    yamato "Bueno, el elemento sorpresa es importante..."

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:72
translate spanish ar_rainbase_h_2cadb5ef:

    # crocodile "Ha ha ha, filthy rat, did you really think you could stop me?"
    crocodile "Jajaja, rata sucia, ¿de verdad creíste que podrías detenerme?"

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:73
translate spanish ar_rainbase_h_6b86d634:

    # crocodile "Or should I say... filthy eagle..."
    crocodile "¿O debería decir... águila sucia...?"

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:74
translate spanish ar_rainbase_h_0e713520:

    # crocodile "What was your mission here? Were you sent to scout the enemy?"
    crocodile "¿Cuál era tu misión aquí? ¿Te enviaron a explorar al enemigo?"

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:75
translate spanish ar_rainbase_h_0f4226b7:

    # crocodile "It seems you placed too much trust in your ability... You overestimate yourself!"
    crocodile "Parece que confiaste demasiado en tu habilidad... ¡Te sobreestimas!"

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:76
translate spanish ar_rainbase_h_a43a517e:

    # crocodile "Confidence, hahaha, that's the most useless thing in this world."
    crocodile "La confianza, jajajaja, es lo más inútil de este mundo."

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:78
translate spanish ar_rainbase_h_9e8e03cc:

    # unknown "You may have me imprisoned, but you will never conquer [Arabasta.n]!"
    unknown "Podrás encarcelarme, pero jamás podrás vencerme [Arabasta.n]!"

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:80
translate spanish ar_rainbase_h_3304c9bd:

    # crocodile "Conquer [Arabasta.n]?? Is that really what you think I want... You are truly lost..."
    crocodile "¿Conquistar [Arabasta.n]? ¿De verdad crees que eso es lo que quiero? Estás perdido."

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:81
translate spanish ar_rainbase_h_eb00a3af:

    # crocodile "Years without suspicion of me... And suddenly, you come to infiltrate my casino..."
    crocodile "Años sin sospechar de mí... Y de repente, vienes a infiltrarte en mi casino..."

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:82
translate spanish ar_rainbase_h_19390fd8:

    # crocodile "It seems the king managed to gather some valuable information... But it's too late..."
    crocodile "Parece que el rey logró reunir información valiosa... Pero es demasiado tarde..."

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:83
translate spanish ar_rainbase_h_f21d4627:

    # crocodile "Hahaha, my plan is already in motion..."
    crocodile "Jajajaja, mi plan ya está en marcha..."

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:84
translate spanish ar_rainbase_h_f64b26ab:

    # crocodile "Operation Utopia is about to begin!"
    crocodile "¡La Operación Utopía está por comenzar!"

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:86
translate spanish ar_rainbase_h_da5d88d6:

    # unknown "Operation Utopia?!?"
    unknown "¿¡Operación Utopía?!?"

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:88
translate spanish ar_rainbase_h_852f81d8:

    # crocodile "I suppose I can tell you... You'll die here anyway..."
    crocodile "Supongo que puedo decírtelo... Morirás aquí de todas formas..."

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:89
translate spanish ar_rainbase_h_bcd5c146:

    # crocodile "It will be the end of this pathetic kingdom."
    crocodile "Será el fin de este patético reino."

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:90
translate spanish ar_rainbase_h_b4917697:

    # crocodile "I will erase [Arabasta.n] from the face of the earth!"
    crocodile "¡Borraré [Arabasta.n] de la faz de la tierra!"

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:91
translate spanish ar_rainbase_h_090cd35b:

    # crocodile "All its inhabitants will sink into eternal darkness."
    crocodile "Todos sus habitantes se hundirán en la oscuridad eterna."

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:92
translate spanish ar_rainbase_h_b5040524:

    # crocodile "Hahahaha!"
    crocodile "¡Jajajaja!"

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:94
translate spanish ar_rainbase_h_8c6f103c:

    # unknown "What do you want?!? What are you planning to do to the kingdom of [Arabasta.n]!?!"
    unknown "¿¡Qué quieres!? ¿¡Qué planeas hacerle al reino de [Arabasta.n]!?"

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:96
translate spanish ar_rainbase_h_fbed8f40:

    # crocodile "By now, the King must have already been captured..."
    crocodile "A estas alturas, el Rey ya debe haber sido capturado..."

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:98
translate spanish ar_rainbase_h_531ebe1d:

    # unknown "You want to kill the King?"
    unknown "¿Quieres matar al Rey?"

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:100
translate spanish ar_rainbase_h_7de0c2f3:

    # crocodile "At this moment, my intention is not to kill him, he's not worth it."
    crocodile "En este momento mi intención no es matarlo, no vale la pena."

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:101
translate spanish ar_rainbase_h_b006a741:

    # crocodile "I will make him suffer a humiliation far crueler than death itself..."
    crocodile "Le haré sufrir una humillación mucho más cruel que la muerte misma..."

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:103
translate spanish ar_rainbase_h_5b8fb585:

    # unknown "If you don't want to kill him, then what is the purpose of your operation?!?"
    unknown "Si no quieres matarlo, ¿entonces cuál es el propósito de tu operación?"

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:105
translate spanish ar_rainbase_h_5bd57b37:

    # crocodile "Even though you're about to die, there's no need to tell you the details... I won't waste any more time..."
    crocodile "Aunque estés a punto de morir, no hay necesidad de contarte los detalles... No perderé más tiempo..."

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:106
translate spanish ar_rainbase_h_b03ae96a:

    # crocodile "But the people's respect for the King will be lost."
    crocodile "Pero el respeto del pueblo hacia el Rey se perderá."

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:107
translate spanish ar_rainbase_h_65b0b519:

    # crocodile "And with that, the rebel army will attack the palace, hahaha."
    crocodile "Y con eso, el ejército rebelde atacará el palacio, jajaja."

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:108
translate spanish ar_rainbase_h_fcb66dcd:

    # crocodile "Everyone will think they are protecting the kingdom of [Arabasta.n], but they will only lead it to its self-destruction, hahaha."
    crocodile "Todos pensarán que están protegiendo el reino de [Arabasta.n], pero solo lo conducirán a su autodestrucción, jajaja."

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:110
translate spanish ar_rainbase_h_2e436bd2:

    # unknown "Why are you doing all this?"
    unknown "¿Por qué haces todo esto?"

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:112
translate spanish ar_rainbase_h_bb6d84ce:

    # crocodile "I had to do a lot to make this day happen."
    crocodile "Tuve que hacer mucho para que este día llegara."

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:113
translate spanish ar_rainbase_h_b962e1d1:

    # crocodile "The shipments of Dance Powder, redirecting the rebel army, the King's abduction..."
    crocodile "Los envíos de Polvo de Baile, la redirección del ejército rebelde, el secuestro del Rey..."

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:114
translate spanish ar_rainbase_h_0f6c19d3:

    # crocodile "Everything that has happened was planned in detail!"
    crocodile "¡Todo lo que sucedió fue planeado al detalle!"

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:116
translate spanish ar_rainbase_h_baf077d2:

    # unknown "I'll get out of here and kill you first!"
    unknown "¡Saldré de aquí y te mataré primero!"

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:118
translate spanish ar_rainbase_h_24d4921a:

    # crocodile "Hahaha, remember that this cage is made of Kairōseki, how will you escape?"
    crocodile "Jajaja, recuerda que esta jaula está hecha de Kairōseki, ¿cómo escaparás?"

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:119
translate spanish ar_rainbase_h_542f9e14:

    # crocodile "To do that, you'd need to get the key... But I already fed it to my pet!"
    crocodile "Para hacer eso, necesitarías conseguir la llave... ¡Pero ya se la di a mi mascota!"

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:120
translate spanish ar_rainbase_h_bf2804ae:

    # crocodile "But don't worry, soon enough you'll reunite with that key when he eats you too, hahaha!"
    crocodile "Pero no te preocupes, pronto te reunirás con esa llave cuando él te coma también, jajaja!"

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:121
translate spanish ar_rainbase_h_41c4ca1c:

    # crocodile "Well, it's late... I still have a lot to do in Alubarna."
    crocodile "Bueno, ya es tarde... Todavía tengo mucho que hacer en Alubarna."

