translate spanish ar_rainbase_h_6f8cb6cc:

    # vivi "With his help, we could communicate with the entire kingdom easily, and we'd have the advantage..."
    vivi "Con su ayuda, podríamos comunicarnos fácilmente con todo el reino y tendríamos la ventaja..."

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:154
translate spanish ar_rainbase_h_80d6f5cd:

    # vivi "That man is [pell.n], one of the two royal guards."
    vivi "Ese hombre es [pell.n], uno de los dos guardias reales."

