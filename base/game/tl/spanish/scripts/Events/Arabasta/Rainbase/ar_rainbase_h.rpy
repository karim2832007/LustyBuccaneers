    player "(¡No hay duda! ¡La decisión es obvia!)"

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:38
translate spanish ar_rainbase_h_9566a028:

    # player "Let's go down the VIP path!!"
    player "¡¡¡Vamos por el camino VIP!!!"

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:40
