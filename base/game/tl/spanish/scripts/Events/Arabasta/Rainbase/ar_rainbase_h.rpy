    # robin "We need to get that key it swallowed if we want to free [pell.n] from there!"
    robin "¡Necesitamos recuperar esa llave que se tragó si queremos liberar a [pell.n] de allí!"

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:178
