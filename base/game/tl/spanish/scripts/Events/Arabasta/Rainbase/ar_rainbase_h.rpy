    # vivi "Quiet, I hear a voice coming from below..."
    vivi "Silencio, escucho una voz que viene de abajo..."

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:55
translate spanish ar_rainbase_h_8aa62fba:

