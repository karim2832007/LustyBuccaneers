    # player "Wow, he turned into a falcon and flew off, AMAZING!"
    player "¡Guau! Se convirtió en halcón y salió volando. ¡INCREÍBLE!"

# game/scripts/Events/Arabasta/Rainbase/ar_rainbase_h.rpy:233
