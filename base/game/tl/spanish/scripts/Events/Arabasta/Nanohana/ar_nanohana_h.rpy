translate spanish ar_nanohana_h_933bc284:

    # vivi "Then we'll head to where [crocodile.n] is!"
    vivi "¡Luego nos dirigiremos a donde está [crocodile.n]!"

# game/scripts/Events/Arabasta/Nanohana/ar_nanohana_h.rpy:283
translate spanish ar_nanohana_h_602acca9:

    # koza "I believe in you... I'll calm things down here and then head to Alubarna to protect the king."
    koza "Creo en ti... Calmaré las cosas aquí y luego me dirigiré a Alubarna para proteger al rey."

# game/scripts/Events/Arabasta/Nanohana/ar_nanohana_h.rpy:284
translate spanish ar_nanohana_h_c1d15d7b:

    # koza "When the time comes, I'll help you face [crocodile.n]. Together, we'll stop him!"
    koza "Cuando llegue el momento, te ayudaré a enfrentar a [crocodile.n]. ¡Juntos, lo detendremos!"

# game/scripts/Events/Arabasta/Nanohana/ar_nanohana_h.rpy:289
translate spanish ar_nanohana_h_3dbe4e02:

    # vivi "Perfect! We will go ahead to Alubarna to stop [crocodile.n]."
    vivi "¡Perfecto! Seguiremos hasta Alubarna para parar en [crocodile.n]."

# game/scripts/Events/Arabasta/Nanohana/ar_nanohana_h.rpy:292
translate spanish ar_nanohana_h_ef5c1ef1:

    # vivi "Perfect! Go and help the king!"
    vivi "¡Perfecto! ¡Ve a ayudar al rey!"

# game/scripts/Events/Arabasta/Nanohana/ar_nanohana_h.rpy:293
translate spanish ar_nanohana_h_58f02daa:

    # vivi "Meanwhile, we will head to Rainbase, where we can stop [crocodile.n]!"
    vivi "Mientras tanto, nos dirigiremos a Rainbase, ¡donde podremos parar [crocodile.n]!"

