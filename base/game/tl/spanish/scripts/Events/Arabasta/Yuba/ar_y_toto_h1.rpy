# game/scripts/Events/Arabasta/Yuba/ar_y_toto_h1.rpy:8
translate spanish ar_y_toto_h1_1b17142a:

    # toto "[player.n]! You're back!"
    toto "[player.n]! ¡Has vuelto!"

# game/scripts/Events/Arabasta/Yuba/ar_y_toto_h1.rpy:9
translate spanish ar_y_toto_h1_e45fae85:

    # toto "I heard that thanks to your help the kingdom of [Arabasta.n] is at peace!"
    toto "He oído que gracias a vuestra ayuda el reino de [Arabasta.n] ¡está en paz!"

# game/scripts/Events/Arabasta/Yuba/ar_y_toto_h1.rpy:10
translate spanish ar_y_toto_h1_f19251b1:

    # toto "Thank you so much, [player.n]! The kingdom of [Arabasta.n] will be forever in your debt!"
    toto "¡Muchas gracias, [player.n]! ¡El reino de [Arabasta.n] estará eternamente en deuda contigo!"

# game/scripts/Events/Arabasta/Yuba/ar_y_toto_h1.rpy:11
translate spanish ar_y_toto_h1_16846b96:

    # toto "Everything has improved here since you defeated [crocodile.n]... He was obviously the one behind all the troubles!"
    toto "Todo ha mejorado aquí desde que derrotaste a [crocodile.n]... ¡Obviamente él era el que estaba detrás de todos los problemas!"

# game/scripts/Events/Arabasta/Yuba/ar_y_toto_h1.rpy:12
translate spanish ar_y_toto_h1_b0562695:

    # toto "The sandstorms have disappeared... They're a thing of the past now..."
    toto "Las tormentas de arena han desaparecido... Son cosa del pasado ahora..."

# game/scripts/Events/Arabasta/Yuba/ar_y_toto_h1.rpy:13
translate spanish ar_y_toto_h1_26b01deb:

    # player "I'm glad to hear that, [toto.n]. This land deserved a better future!"
    player "Me alegra oír eso, [toto.n]. ¡Esta tierra merecía un futuro mejor!"

# game/scripts/Events/Arabasta/Yuba/ar_y_toto_h1.rpy:14
translate spanish ar_y_toto_h1_4e20221f:

    # player "Now that the problems are solved, it's time to think ahead and move on!"
    player "¡Ahora que los problemas están resueltos, es hora de pensar en el futuro y seguir adelante!"

# game/scripts/Events/Arabasta/Yuba/ar_y_toto_h1.rpy:15
translate spanish ar_y_toto_h1_26a79a37:

    # toto "Exactly, young man!! This is the beginning of a new Yuba!!"
    toto "¡Exacto, jovencito! ¡Este es el comienzo de una nueva Yuba!"

# game/scripts/Events/Arabasta/Yuba/ar_y_toto_h1.rpy:16
translate spanish ar_y_toto_h1_63549ba3:

    # toto "Speaking of that... As you already know, I have everything planned..."
    toto "Hablando de eso... Como ya sabéis, tengo todo planeado..."

# game/scripts/Events/Arabasta/Yuba/ar_y_toto_h1.rpy:18
translate spanish ar_y_toto_h1_f5996b32:

    # toto "Do you remember my dream? Turning this oasis into a paradise filled with women from all over the seas!"
    toto "¿Recuerdas mi sueño? ¡Convertir este oasis en un paraíso lleno de mujeres de todos los mares!"

# game/scripts/Events/Arabasta/Yuba/ar_y_toto_h1.rpy:19
translate spanish ar_y_toto_h1_5c7a5f1a:

    # player "How could I forget!! It's a great idea!!!"
    player "¡Cómo podría olvidarlo! ¡Es una idea genial!"

# game/scripts/Events/Arabasta/Yuba/ar_y_toto_h1.rpy:20
translate spanish ar_y_toto_h1_822ea29d:

    # toto "Hahaha that's right!!"
    toto "¡Jajajajajaja! ¡Es cierto!"

# game/scripts/Events/Arabasta/Yuba/ar_y_toto_h1.rpy:22
translate spanish ar_y_toto_h1_d75ea0d6:

    # toto "Now that the country is calm... I think it's time to make it a reality."
    toto "Ahora que el país está tranquilo... creo que es hora de hacerlo realidad."

# game/scripts/Events/Arabasta/Yuba/ar_y_toto_h1.rpy:23
translate spanish ar_y_toto_h1_9e64f821:

    # player "Do you have something in mind?"
    player "¿Tienes algo en mente?"

# game/scripts/Events/Arabasta/Yuba/ar_y_toto_h1.rpy:24
translate spanish ar_y_toto_h1_3a5a0146:

    # toto "Of course! First I have to make Yuba grow... I need the city to flourish with activity..."
    toto "¡Claro! Primero tengo que hacer que Yuba crezca... Necesito que la ciudad florezca con actividad..."

# game/scripts/Events/Arabasta/Yuba/ar_y_toto_h1.rpy:25
translate spanish ar_y_toto_h1_c2945b47:

    # toto "To attract cheerful and thirsty tourists, the first thing we need is a bar...."
    toto "Para atraer a turistas alegres y sedientos, lo primero que necesitamos es un bar...."

# game/scripts/Events/Arabasta/Yuba/ar_y_toto_h1.rpy:26
translate spanish ar_y_toto_h1_898480ef:

    # player "A bar?!"
    player "¿Un bar?"

# game/scripts/Events/Arabasta/Yuba/ar_y_toto_h1.rpy:28
translate spanish ar_y_toto_h1_2d57acd3:

    # toto "Exactly, young man... A good bar... with music, laughter... and a little show to spice up the mood, you know what I mean jejeje."
    toto "Exacto, joven... Un buen bar... con música, risas... y un poco de espectáculo para animar el ambiente, ya sabes a qué me refiero jejeje."

# game/scripts/Events/Arabasta/Yuba/ar_y_toto_h1.rpy:29
translate spanish ar_y_toto_h1_7e94b980:

    # player "Hahah I think I'm following you... You're a damn genius [toto.n]..."
    player "Jajaja creo que te estoy siguiendo... Eres un maldito genio [toto.n]..."

# game/scripts/Events/Arabasta/Yuba/ar_y_toto_h1.rpy:30
translate spanish ar_y_toto_h1_e9e7fe9e:

    # player "A show, you say? Really?..."
    player "¿Un espectáculo, dices? ¿En serio?"

# game/scripts/Events/Arabasta/Yuba/ar_y_toto_h1.rpy:32
translate spanish ar_y_toto_h1_127427af:

    # toto "Exactly... a dancer! With an outfit... eye-catching, if you know what I mean, hehehe."
    toto "Exactamente... ¡una bailarina! Con un atuendo... llamativo, si me entiendes, jejeje."

# game/scripts/Events/Arabasta/Yuba/ar_y_toto_h1.rpy:33
translate spanish ar_y_toto_h1_38bf0752:

    # toto "And that's exactly where you can help me..."
    toto "Y es ahí precisamente donde puedes ayudarme..."

# game/scripts/Events/Arabasta/Yuba/ar_y_toto_h1.rpy:34
translate spanish ar_y_toto_h1_779ab0af:

    # toto "If one of your beautiful girls wants to dance... I'll pay her!!"
    toto "Si una de tus lindas chicas quiere bailar...¡yo le pago!!"

# game/scripts/Events/Arabasta/Yuba/ar_y_toto_h1.rpy:36
translate spanish ar_y_toto_h1_cdee013e:

    # toto "Just so you know... they say in Nanohana you can find all kinds of interesting clothes"
    toto "Sólo para que lo sepas... dicen que en Nanohana puedes encontrar todo tipo de ropa interesante."

# game/scripts/Events/Arabasta/Yuba/ar_y_toto_h1.rpy:37
translate spanish ar_y_toto_h1_dd2bffbc:

    # toto "You could check it out when you have time!"
    toto "¡Podrías echarle un vistazo cuando tengas tiempo!"

# game/scripts/Events/Arabasta/Yuba/ar_y_toto_h1.rpy:39
translate spanish ar_y_toto_h1_0d6579d3:

    # player "Sounds like an ambitious plan, [toto.n]. A solid plan!"
    player "Parece un plan ambicioso, [toto.n]. ¡Un plan sólido!"

# game/scripts/Events/Arabasta/Yuba/ar_y_toto_h1.rpy:41
translate spanish ar_y_toto_h1_3d79b9cf:

    # toto "And you could work here too! Earn some coins, and alcohol would be half-price!"
    toto "¡Y tú también podrías trabajar aquí! ¡Gana monedas y el alcohol te saldrá a mitad de precio!"

# game/scripts/Events/Arabasta/Yuba/ar_y_toto_h1.rpy:42
translate spanish ar_y_toto_h1_af794b83:

    # toto "What do you say? Will you help me build this place?"
    toto "¿Qué dices? ¿Me ayudas a construir este lugar?"

# game/scripts/Events/Arabasta/Yuba/ar_y_toto_h1.rpy:44
translate spanish ar_y_toto_h1_89f63b4f:

    # player "(Beautiful women and half-price alcohol... this old man knows how to convince me)"
    player "(Mujeres hermosas y alcohol a mitad de precio... este viejo sabe cómo convencerme)"

# game/scripts/Events/Arabasta/Yuba/ar_y_toto_h1.rpy:45
translate spanish ar_y_toto_h1_c74abdea:

    # player "Well obviously I'm in!!!"
    player "¡¡¡Por supuesto que estoy dentro!!!"

# game/scripts/Events/Arabasta/Yuba/ar_y_toto_h1.rpy:46
translate spanish ar_y_toto_h1_3b5cbc22:

    # player "Count me in. What do you need to get started?"
    player "Cuente conmigo. ¿Qué necesita para comenzar?"

# game/scripts/Events/Arabasta/Yuba/ar_y_toto_h1.rpy:47
translate spanish ar_y_toto_h1_86069ced:

    # toto "Obviously I already have everything planned and sketched out, young man..."
    toto "Obviamente ya tengo todo planeado y esquematizado, jovencito..."

# game/scripts/Events/Arabasta/Yuba/ar_y_toto_h1.rpy:48
translate spanish ar_y_toto_h1_24bdc389:

    # toto "We'll need wood... some berries for the repairs... And of course, alcohol to open."
    toto "Necesitaremos madera... algo de berries para las reparaciones... Y por supuesto, alcohol para abrir."

# game/scripts/Events/Arabasta/Yuba/ar_y_toto_h1.rpy:49
translate spanish ar_y_toto_h1_3f12d5e6:

    # toto "I'll take care of the labor myself..."
    toto "Yo me encargaré del trabajo yo mismo..."

# game/scripts/Events/Arabasta/Yuba/ar_y_toto_h1.rpy:50
translate spanish ar_y_toto_h1_236cd556:

    # toto "Once it's up and running, I'll personally handle restocking the drinks. I don't want to see those shelves empty!"
    toto "Una vez que esté funcionando, me encargaré personalmente de reponer las bebidas. ¡No quiero ver esos estantes vacíos!"

# game/scripts/Events/Arabasta/Yuba/ar_y_toto_h1.rpy:52
translate spanish ar_y_toto_h1_8ceedb8a:

    # player "Perfect. I'll get started on the supplies right away."
    player "Perfecto. Empezaré con los suministros ahora mismo."

# game/scripts/Events/Arabasta/Yuba/ar_y_toto_h1.rpy:54
translate spanish ar_y_toto_h1_e037863e:

    # toto "That's the spirit, young man! Before long this oasis will be full of beautiful women!"
    toto "¡Ese es el espíritu, jovencito! ¡Dentro de poco, este oasis estará lleno de mujeres hermosas!"

# game/scripts/Events/Arabasta/Yuba/ar_y_toto_h1.rpy:55
translate spanish ar_y_toto_h1_cd7874db:

    # player "Of course! we can't forget about that"
    player "¡Por supuesto! No podemos olvidarnos de eso."

# game/scripts/Events/Arabasta/Yuba/ar_y_toto_h1.rpy:56
translate spanish ar_y_toto_h1_a272ce45:

    # toto "Of course! This is just the first step!"
    toto "¡Claro! ¡Este es solo el primer paso!"

