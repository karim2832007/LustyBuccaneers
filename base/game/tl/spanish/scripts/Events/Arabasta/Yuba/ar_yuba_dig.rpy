# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:11
translate spanish ar_yuba_dig_d11e52e5:

    # toto "Ohhh, it's you, young one. [player.n], right?... What are you doing here?"
    toto "Ohhh, eres tú, jovencito. [player.n], ¿verdad?... ¿Qué estás haciendo aquí?"

# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:14
translate spanish ar_yuba_dig_cb78c551:

    # toto "Where are the rest of the girls, resting?"
    toto "¿Dónde están el resto de las chicas, descansando?"

# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:15
translate spanish ar_yuba_dig_e6cb2207:

    # player "Hey old man, I came to help you dig..."
    player "Oye viejo, vine a ayudarte a cavar..."

# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:20
translate spanish ar_yuba_dig_d667ea56:

    # toto "I won't deny that a bit of youthful energy would be useful... And you even have your own shovel..."
    toto "No niego que un poco de energía juvenil no vendría mal... Y hasta tienes tu propia pala..."

# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:21
translate spanish ar_yuba_dig_c7043cde:

    # toto "Help is always appreciated!"
    toto "¡La ayuda siempre es apreciada!"

# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:22
translate spanish ar_yuba_dig_abf2d3ac:

    # player "I've been watching you for a while as the girls rest..."
    player "Te he estado observando por un rato mientras las chicas descansan..."

# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:23
translate spanish ar_yuba_dig_7d0cfbad:

    # player "Honestly, I'm surprised you can live like this... You barely have water, you're alone... But you keep digging."
    player "Sinceramente me sorprende que puedas vivir así... Apenas tienes agua, estás solo... Pero sigues cavando."

# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:24
translate spanish ar_yuba_dig_e6b868d2:

    # player "Tell me, what's the secret? What keeps you going?"
    player "Dime, ¿cuál es el secreto? ¿Qué te motiva a seguir adelante?"

# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:26
translate spanish ar_yuba_dig_3dabef60:

    # toto "Yuba's oasis is still alive and won't be defeated by the sand, young one!"
    toto "¡El oasis de Yuba sigue vivo y no será derrotado por la arena, joven!"

# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:27
translate spanish ar_yuba_dig_af34adc9:

    # toto "This oasis is very important for the kingdom, that's why the king entrusted it to me!"
    toto "¡Este oasis es muy importante para el reino, por eso el rey me lo confió!"

# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:29
translate spanish ar_yuba_dig_3a923945:

    # player "So you're just following the king's orders?"
    player "¿Entonces sólo estás siguiendo las órdenes del rey?"

# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:31
translate spanish ar_yuba_dig_1bc8235f:

    # toto "This isn't just about following orders!"
    toto "¡No se trata sólo de seguir órdenes!"

# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:32
translate spanish ar_yuba_dig_3da9119e:

    # toto "He entrusted this land to me, but I have my own goals to achieve!"
    toto "Él me confió esta tierra, ¡pero yo tengo mis propios objetivos que alcanzar!"

# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:33
translate spanish ar_yuba_dig_be09cb3a:

    # toto "..."
    toto "..."

# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:34
translate spanish ar_yuba_dig_6c408d3c:

    # toto "You're a smart young man... You remind me of myself when I was younger..."
    toto "Eres un joven inteligente... Me recuerdas a mí mismo cuando era más joven..."

# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:37
translate spanish ar_yuba_dig_92c5a66e:

    # toto "Surrounded by women! Life was beautiful back then!"
    toto "¡Rodeado de mujeres! ¡Qué hermosa era la vida en aquel entonces!"

# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:38
translate spanish ar_yuba_dig_33d3c59c:

    # toto "That's exactly my dream... I'll make Yuba an oasis full of beautiful women!"
    toto "Ese es exactamente mi sueño... ¡Haré de Yuba un oasis lleno de mujeres hermosas!"

# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:39
translate spanish ar_yuba_dig_0b376c98:

    # toto "Women from all over Alabasta will come to visit!"
    toto "¡Mujeres de todo Arabasta vendrán a visitarnos!"

# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:40
translate spanish ar_yuba_dig_2ecb201f:

    # toto "And not just from Alabasta, women from neighboring islands and all over the seas will come!"
    toto "¡Y no sólo de Arabasta, vendrán mujeres de las islas vecinas y de todos los mares!"

# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:41
translate spanish ar_yuba_dig_2350c509:

    # toto "Hahaha, a paradise on earth!!!"
    toto "Jajajaja, un paraíso en la tierra!!!"

# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:43
translate spanish ar_yuba_dig_bfa4c845:

    # player "Wow, a city full of women from all the seas?! You're a genius!!"
    player "¡Guau! ¿Una ciudad llena de mujeres de todos los mares? ¡Eres un genio!"

# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:44
translate spanish ar_yuba_dig_16e7162e:

    # player "You have a great idea! Now I'm really motivated to dig!"
    player "¡Tienes una gran idea! ¡Ahora tengo muchas ganas de excavar!"

# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:46
translate spanish ar_yuba_dig_963b268f:

    # toto "That's the spirit, young one!!"
    toto "¡¡¡Ese es el espíritu, joven!!!"

# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:47
translate spanish ar_yuba_dig_74e72dae:

    # player "[toto.n], I will help you achieve your dream!"
    player "[toto.n] ¡Te ayudaré a alcanzar tu sueño!"

# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:49
translate spanish ar_yuba_dig_3197550f:

    # toto "Thank you, young one, I knew you would understand me!"
    toto "¡Gracias joven! ¡Sabía que me entenderías!"

# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:50
translate spanish ar_yuba_dig_5743715d:

    # toto "The first step is to recover the water, we must keep digging!"
    toto "El primer paso es recuperar el agua, ¡hay que seguir cavando!"

# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:52
translate spanish ar_yuba_dig_909282d7:

    # narrador "You spend time digging"
    narrador "Pasas tiempo cavando"

# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:63
translate spanish ar_yuba_dig_cdfba48e:

    # narrador "The hole in Yuba is now bigger..."
    narrador "El agujero en Yuba ahora es más grande..."

# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:65
translate spanish ar_yuba_dig_24e484ad:

    # toto "Wow, we've made so much progress in such a short time... And most of the work was done by you, youth is incredible..."
    toto "Vaya, hemos avanzado tanto en tan poco tiempo... Y la mayor parte del trabajo lo hiciste tú, la juventud es increíble..."

# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:66
translate spanish ar_yuba_dig_1a431884:

    # toto "With your help, we will surely make it!"
    toto "¡Con vuestra ayuda seguro que lo lograremos!"

# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:70
translate spanish ar_yuba_dig_ca18ba48:

    # narrador "You begin to feel the soil getting moist."
    narrador "Empiezas a sentir que la tierra se humedece."

# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:72
translate spanish ar_yuba_dig_901b8710:

    # player "Old man, there's still no water..."
    player "Viejo, todavía no hay agua..."

# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:73
translate spanish ar_yuba_dig_a49f6a7d:

    # toto "You must have faith, young one... We have a great goal, we can't give up halfway."
    toto "Debes tener fe, jovencito... Tenemos un gran objetivo, no podemos rendirnos a mitad de camino."

# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:74
translate spanish ar_yuba_dig_0123707b:

    # toto "The soil is moist and easier to dig through, that's a big step... The goal is near!"
    toto "La tierra está húmeda y es más fácil cavar, ese es un gran paso... ¡La meta está cerca!"

# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:79
translate spanish ar_yuba_dig_64c46a31:

    # toto "It's water! We've reached the water!!!"
    toto "¡Es agua! ¡Llegamos al agua!"

# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:80
translate spanish ar_yuba_dig_4af11d73:

    # toto "Look, there's so much!!!"
    toto "¡Mira, hay tanto!!!"

# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:81
translate spanish ar_yuba_dig_2338e2b7:

    # toto "Look... The water is flowing!!!"
    toto "Mira... ¡¡¡El agua está fluyendo!!!"

# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:82
translate spanish ar_yuba_dig_d66265d3:

    # toto "Didn't I tell you, [player.n]?"
    toto "¿No te lo dije, [player.n]?"

# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:83
translate spanish ar_yuba_dig_4caeb97f:

    # toto "This land is strong... Yuba is still alive!"
    toto "Esta tierra es fuerte... ¡Yuba sigue viva!"

# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:95
translate spanish ar_yuba_dig_7299c74c:

    # player "Awesome! Now what?"
    player "¡Genial! ¿Y ahora qué?"

# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:96
translate spanish ar_yuba_dig_30351acc:

    # toto "Now anything I set my mind to is possible, I have to start making preparations!"
    toto "Ahora todo lo que me propongo es posible, ¡tengo que empezar a hacer preparativos!"

# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:97
translate spanish ar_yuba_dig_2fefa07b:

    # toto "Come see me later, I have things to get ready!"
    toto "¡Ven a verme más tarde, tengo cosas que preparar!"

# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:98
translate spanish ar_yuba_dig_a3081cf0:

    # player "Got it, see you later, old man!"
    player "¡Entendido, hasta luego, viejo!"

# game/scripts/Events/Arabasta/Yuba/ar_yuba_dig.rpy:105
translate spanish ar_yuba_dig_b5908863:

    # narrador "It got late, and you preferred to return to your cabin."
    narrador "Se hizo tarde y preferiste regresar a tu camarote."

