# game/scripts/Events/Alvida/bounty/alvida_bounty.rpy:14
translate spanish bounty_board_alvida_391fbd71:

    # nami "Captain, are you thinking about searching for [alvida.n]?"
    nami "Capitán, ¿está pensando en buscar [alvida.n]?"

# game/scripts/Events/Alvida/bounty/alvida_bounty.rpy:16
translate spanish bounty_board_alvida_d7879eda:

    # nami "If we manage to defeat her in combat, we'll get a good reward!!"
    nami "¡Si logramos derrotarla en combate, obtendremos una buena recompensa!"

# game/scripts/Events/Alvida/bounty/alvida_bounty.rpy:17
translate spanish bounty_board_alvida_0ced1b37:

    # nami "Plus, I'm sure the crew will be motivated by this!!"
    nami "¡Además, estoy seguro de que la tripulación estará motivada por esto!"

# game/scripts/Events/Alvida/bounty/alvida_bounty.rpy:18
translate spanish bounty_board_alvida_d4dbb20e:

    # nami "To achieve this, we must find her first..."
    nami "Para lograr esto, primero debemos encontrarla..."

# game/scripts/Events/Alvida/bounty/alvida_bounty.rpy:19
translate spanish bounty_board_alvida_9a59da9a:

    # nami "From the information provided by the poster, we'll find her on the nearby coast..."
    nami "Por la información que proporciona el cartel, la encontraremos en la costa cercana..."

# game/scripts/Events/Alvida/bounty/alvida_bounty.rpy:20
translate spanish bounty_board_alvida_166646c8:

    # nami "We must travel and explore the seas, and then see what nearby ships we encounter..."
    nami "Debemos viajar y explorar los mares, y luego ver qué barcos cercanos encontramos..."

# game/scripts/Events/Alvida/bounty/alvida_bounty.rpy:21
translate spanish bounty_board_alvida_b966db2f:

    # nami "But we must go prepared, having some cannonballs, wood, and food would be ideal..."
    nami "Pero debemos ir preparados, tener algunas balas de cañón, madera y comida sería lo ideal..."

# game/scripts/Events/Alvida/bounty/alvida_bounty.rpy:22
translate spanish bounty_board_alvida_785f28ee:

    # nami "Because if we find her, we'll have to face her ship!!"
    nami "¡Porque si la encontramos, tendremos que enfrentarnos a su barco!"

# game/scripts/Events/Alvida/bounty/alvida_bounty.rpy:26
translate spanish bounty_board_alvida_db02b643:

    # yamato "Yesssssss! A fight at sea!"
    yamato "¡Síííííí! ¡Una pelea en el mar!"

# game/scripts/Events/Alvida/bounty/alvida_bounty.rpy:27
translate spanish bounty_board_alvida_80a46159:

    # yamato "If we weaken her ship enough, they won't be able to move quickly, and we can board them."
    yamato "Si debilitamos lo suficiente su nave, no podrán moverse rápidamente y podremos abordarlos."

# game/scripts/Events/Alvida/bounty/alvida_bounty.rpy:28
translate spanish bounty_board_alvida_359e352e:

    # yamato "And then we can fight against [alvida.n]!!!"
    yamato "¡¡¡Y luego podremos luchar contra [alvida.n]!!!"

# game/scripts/Events/Alvida/bounty/alvida_bounty.rpy:29
translate spanish bounty_board_alvida_63e9e1f5:

    # yamato "Maybe it's better to train on the ship before going to face her..."
    yamato "Quizás sea mejor entrenar en el barco antes de ir a enfrentarla..."

# game/scripts/Events/Alvida/bounty/alvida_bounty.rpy:31
translate spanish bounty_board_alvida_3fd282ec:

    # nami "At that moment, it will all depend on you, Captain! If you defeat her, we'll receive the reward!"
    nami "En ese momento, ¡todo dependerá de ti, Capitán! Si la derrotas, ¡recibiremos la recompensa!"

# game/scripts/Events/Alvida/bounty/alvida_bounty.rpy:32
translate spanish bounty_board_alvida_01c39a31:

    # yamato "So it is, Captain!!!... So, what do you say?"
    yamato "¡Así es, Capitán!!!... ¿Y qué dices?"

# game/scripts/Events/Alvida/bounty/alvida_bounty.rpy:35
translate spanish bounty_board_alvida_b8ffd60d:

    # narrador "Are you sure you want to accept this mission?" nointeract
    narrador "¿Estás seguro que deseas aceptar esta misión?" nointeract

# game/scripts/Events/Alvida/bounty/alvida_bounty.rpy:40
translate spanish bounty_board_alvida_4c7fd1e5:

    # narrador "New mission: 'Defeat [alvida.n]'"
    narrador "Nueva misión: 'Derrota a [alvida.n]'"

