translate spanish dressrosa_h7_de6f0087:

    # player "(Yeah, I knew you'd be here... My angel in armor!)"
    player "(Sí, sabía que estarías aquí... ¡Mi ángel en armadura!)"

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:12
translate spanish dressrosa_h7_1623a74b:

    # player "Hey [rebecca.n]!!! How's everything going!?!"
    player "¡Hola [rebecca.n]! ¿Cómo va todo?"

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:14
translate spanish dressrosa_h7_08580400:

    # rebecca "Hi [player.n], I was just here warming up, I'm about to head back into the arena!"
    rebecca "Hola [player.n], estuve aquí calentando, ¡estoy a punto de regresar a la arena!"

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:15
translate spanish dressrosa_h7_c72722dc:

    # rebecca "I saw your last fight... You were really amazing!"
    rebecca "Vi tu última pelea... ¡Estuviste realmente increíble!"

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:16
translate spanish dressrosa_h7_7ed15d1d:

    # rebecca "[lepanto.n] was a very experienced fighter... Really tough..."
    rebecca "[lepanto.n] era un luchador muy experimentado... Realmente duro..."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:18
translate spanish dressrosa_h7_c117b2c4:

    # rebecca "You really surprised me... It was like it didn't take you much effort to defeat him..."
    rebecca "Realmente me sorprendiste... Fue como si no te hubiera costado mucho esfuerzo derrotarlo..."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:22
translate spanish dressrosa_h7_38c5f98c:

    # player "It was, wasn't it? I felt it was easy too..."
    player "¿Lo fue, verdad? A mí también me pareció fácil..."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:23
translate spanish dressrosa_h7_8a77a24f:

    # player "It was an easy fight, honestly."
    player "Fue una pelea fácil, honestamente."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:26
translate spanish dressrosa_h7_5399a58c:

    # player "The guy was tough, you could see his experience..."
    player "El tipo era duro, se le notaba la experiencia..."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:27
translate spanish dressrosa_h7_5d69ba87:

    # player "Maybe it looked easy, but he was a worthy opponent..."
    player "Quizás parecía fácil, pero era un digno oponente..."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:28
translate spanish dressrosa_h7_92f57204:

    # player "It was an interesting fight."
    player "Fue una pelea interesante."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:31
translate spanish dressrosa_h7_1d76915e:

    # narrador "[rebecca.n] love +1"
    narrador "[rebecca.n] amor +1"

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:33
translate spanish dressrosa_h7_5197e2cd:

    # rebecca "You were really great, you surprised everyone out there!"
    rebecca "¡Estuviste realmente genial, sorprendiste a todos!"

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:34
translate spanish dressrosa_h7_972deb4e:

    # rebecca "Even [lepanto.n] himself was surprised, I'm sure..."
    rebecca "Incluso el mismo [lepanto.n] se sorprendió, estoy seguro..."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:35
translate spanish dressrosa_h7_645787bd:

    # player "Thanks, I appreciate the compliment!"
    player "¡Gracias, aprecio el cumplido!"

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:36
translate spanish dressrosa_h7_ed459053:

    # player "That guy... [lepanto.n]... In the end he told me some rather interesting last words before he fell..."
    player "Ese tipo... [lepanto.n]... Al final me dijo unas últimas palabras bastante interesantes antes de caer..."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:37
translate spanish dressrosa_h7_67ddf7e3:

    # rebecca "Oh yeah?!? With the crowd, you couldn't hear much of what you two said..."
    rebecca "¿Ah, sí? Con la multitud, no se oía mucho lo que decían..."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:38
translate spanish dressrosa_h7_6e7a4b26:

    # rebecca "What did he say?"
    rebecca "¿Qué dijo?"

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:39
translate spanish dressrosa_h7_a2043d8c:

    # player "He told me about his past, apparently... obviously closely tied to [Dressrosa.n]..."
    player "Me contó sobre su pasado, aparentemente... obviamente muy ligado a [Dressrosa.n]..."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:41
translate spanish dressrosa_h7_1e63b009:

    # rebecca "..."
    rebecca "..."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:42
translate spanish dressrosa_h7_5ec60ed6:

    # player "Apparently the former king died, and he was in his service... Now he serves the current king, but it seems he doesn't do it willingly."
    player "Al parecer el rey anterior murió, y él estaba a su servicio... Ahora sirve al rey actual, pero parece que no lo hace por voluntad propia."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:43
translate spanish dressrosa_h7_9a28fa74:

    # player "He said he no longer had honor... He'd failed his previous master and now had no hope..."
    player "Dijo que ya no tenía honor... Le había fallado a su anterior amo y ahora no tenía esperanza..."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:44
translate spanish dressrosa_h7_29d616b4:

    # player "Supposedly he's protecting a princess... But it was all very strange; he didn't say much."
    player "Supuestamente estaba protegiendo a una princesa... Pero todo era muy extraño; no dijo mucho."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:45
translate spanish dressrosa_h7_92f42122:

    # player "Do you know anything about all this, [rebecca.n]?"
    player "¿Sabes algo de todo esto, [rebecca.n]?"

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:46
translate spanish dressrosa_h7_ae28ca35:

    # rebecca "Mmm..."
    rebecca "Mmm..."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:47
translate spanish dressrosa_h7_1526bcfc:

    # rebecca "No... I don't know... I don't know exactly what you're talking about..."
    rebecca "No... no sé... no sé exactamente de qué estás hablando..."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:49
translate spanish dressrosa_h7_7d171506:

    # player "(She doesn't sound very convinced...)"
    player "(No parece muy convencida...)"

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:50
translate spanish dressrosa_h7_9c07ab73:

    # rebecca "From what you're saying, it seems [lepanto.n] is still loyal to the former king..."
    rebecca "Por lo que dices, parece que [lepanto.n] sigue siendo leal al antiguo rey..."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:51
translate spanish dressrosa_h7_af2c0727:

    # rebecca "If he fought in the name of the old king... then he must have been someone with a noble heart."
    rebecca "Si luchó en nombre del viejo rey... entonces debe haber sido alguien con un corazón noble."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:52
translate spanish dressrosa_h7_15666c6e:

    # rebecca "Although in here, in this coliseum... noble hearts usually end up broken..."
    rebecca "Aunque aquí, en este coliseo... los corazones nobles suelen acabar rotos..."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:53
translate spanish dressrosa_h7_33674600:

    # player "You talk like you know what you're talking about."
    player "Hablas como si supieras de lo que estás hablando."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:54
translate spanish dressrosa_h7_9f2ef905:

    # rebecca "Let's say... I've heard many stories about the old kingdom, about what [Dressrosa.n] was like before all this."
    rebecca "Digamos... He oído muchas historias sobre el antiguo reino, sobre cómo era [Dressrosa.n] antes de todo esto."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:55
translate spanish dressrosa_h7_8738b16f:

    # rebecca "Some say the former king was a just man... others that he was deceived."
    rebecca "Algunos dicen que el rey anterior era un hombre justo... otros que estaba engañado."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:56
translate spanish dressrosa_h7_0687280f:

    # rebecca "But no one dares to speak about that out loud. It could cost you more than just a fight in the arena..."
    rebecca "Pero nadie se atreve a hablar de eso en voz alta. Podría costarle más que una simple pelea en la arena..."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:57
translate spanish dressrosa_h7_574b0ea7:

    # player "And what do you think?"
    player "¿Y tú qué opinas?"

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:58
translate spanish dressrosa_h7_a0e01421:

    # rebecca "I think the truth is buried beneath many lies... and only fools try to unearth it."
    rebecca "Creo que la verdad está enterrada bajo muchas mentiras... y sólo los tontos intentan desenterrarla."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:59
translate spanish dressrosa_h7_982fc81a:

    # rebecca "You should focus on the tournament. Here, secrets don't help you survive."
    rebecca "Deberías concentrarte en el torneo. Aquí, los secretos no te ayudan a sobrevivir."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:60
translate spanish dressrosa_h7_e01d2d97:

    # player "Maybe... but sometimes understanding the past helps win the present."
    player "Tal vez... pero a veces entender el pasado ayuda a ganar el presente."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:61
translate spanish dressrosa_h7_a5cd1e8f:

    # rebecca "Hmph... maybe you're right... You're really interesting, [player.n]..."
    rebecca "Hmph... tal vez tengas razón... Eres realmente interesante, [player.n]..."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:66
translate spanish dressrosa_h7_35f9bfec:

    # player "Well, we've talked plenty about history..."
    player "Bueno, hemos hablado mucho sobre historia..."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:67
translate spanish dressrosa_h7_3ea0cce3:

    # player "Maybe we could change the subject..."
    player "Quizás podríamos cambiar de tema..."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:70
translate spanish dressrosa_h7_edb781f2:

    # player "And about the matter of the princess..."
    player "Y sobre el asunto de la princesa..."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:71
translate spanish dressrosa_h7_1ef7313c:

    # player "(I'm sure she must be a beauty too!)"
    player "(¡Estoy seguro de que ella también debe ser una belleza!)"

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:73
translate spanish dressrosa_h7_1e63b009_1:

    # rebecca "..."
    rebecca "..."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:74
translate spanish dressrosa_h7_f8127d82:

    # rebecca "You ask too many questions... You're very interested in knowing about [Dressrosa.n] and its history, haha"
    rebecca "Haces demasiadas preguntas... Te interesa mucho saber sobre [Dressrosa.n] y su historia, jaja"

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:77
translate spanish dressrosa_h7_1d76915e_1:

    # narrador "[rebecca.n] love +1"
    narrador "[rebecca.n] amor +1"

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:79
translate spanish dressrosa_h7_5e366240:

    # rebecca "But here, names carry weight. Don't ask about royalty out loud without thinking."
    rebecca "Pero aquí, los nombres tienen peso. No preguntes sobre la realeza en voz alta sin pensar."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:80
translate spanish dressrosa_h7_af6546a6:

    # player "Does that woman have some kind of problem?"
    player "¿Esa mujer tiene algún tipo de problema?"

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:81
translate spanish dressrosa_h7_dd3cf829:

    # rebecca "... They say she's a dancer with eyes that pierce through lies."
    rebecca "...Dicen que es una bailarina con ojos que atraviesan las mentiras."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:82
translate spanish dressrosa_h7_2d94bac9:

    # player "Wow, is she a witch or something?!?..."
    player "Vaya, ¿es una bruja o algo así?"

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:84
translate spanish dressrosa_h7_41bf53de:

    # rebecca "Hahaha no, no, nothing like that..."
    rebecca "Jajajaja no, no, nada de eso..."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:85
translate spanish dressrosa_h7_444ddb95:

    # player "And what's her name?!?"
    player "¡¿Y cómo se llama?!?"

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:88
translate spanish dressrosa_h7_19860163:

    # rebecca "Her name is not important.. But don't ask too loudly about her..."
    rebecca "Su nombre no es importante... Pero no preguntes demasiado por ella..."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:90
translate spanish dressrosa_h7_ce122395:

    # rebecca "Apparently she betrayed the former king... Or that's what everyone says..."
    rebecca "Al parecer traicionó al antiguo rey... O eso es lo que dicen todos..."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:93
translate spanish dressrosa_h7_6c9830bd:

    # rebecca "But I don't know... My heart tells me I'm wrong..."
    rebecca "Pero no sé... Mi corazón me dice que estoy equivocado..."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:94
translate spanish dressrosa_h7_428eecdf:

    # player "(What does she mean? Do they know each other?)"
    player "(¿Qué quiere decir? ¿Se conocen?)"

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:95
translate spanish dressrosa_h7_684bf2b4:

    # rebecca "Either way, that doesn't change reality..."
    rebecca "De cualquier manera, eso no cambia la realidad..."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:96
translate spanish dressrosa_h7_8498bb13:

    # rebecca "Her power is real... so she can see who's asking and why."
    rebecca "Su poder es real... así que puede ver quién pregunta y por qué."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:97
translate spanish dressrosa_h7_cd9032db:

    # rebecca "She's with the Donquixote family now..."
    rebecca "Ella está con la familia Donquixote ahora..."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:98
translate spanish dressrosa_h7_15077f9f:

    # rebecca "If anyone were aware of movements in the shadows, it would be someone with her eyes."
    rebecca "Si alguien fuera consciente de los movimientos en las sombras, sería alguien con sus ojos."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:99
translate spanish dressrosa_h7_fc5e822d:

    # rebecca "Knowing too much in [Dressrosa.n] can turn you into another piece on the board. Or worse..."
    rebecca "Saber demasiado en [Dressrosa.n] puede convertirte en una pieza más del tablero. O peor aún..."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:100
translate spanish dressrosa_h7_83296b59:

    # player "Do you know her?"
    player "¿La conoces?"

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:101
translate spanish dressrosa_h7_1e63b009_2:

    # rebecca "..."
    rebecca "..."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:102
translate spanish dressrosa_h7_2030fef0:

    # rebecca "I've seen her from afar... enough to understand that not everyone chooses where they end up."
    rebecca "La he visto desde lejos... lo suficiente para entender que no todos eligen dónde terminan."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:103
translate spanish dressrosa_h7_bef43ae0:

    # rebecca "If you cross paths with her, respond with sincerity. She hates lies more than swords."
    rebecca "Si te cruzas con ella, responde con sinceridad. Odia las mentiras más que las espadas."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:104
translate spanish dressrosa_h7_8d1c6665:

    # rebecca "But anyway... That'll be another story..."
    rebecca "Pero bueno...esa será otra historia..."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:108
translate spanish dressrosa_h7_ab2e2814:

    # rebecca "Maybe another time we can keep talking... it's getting late... But promise me something..."
    rebecca "Quizás en otro momento podamos seguir hablando... se está haciendo tarde... Pero prométeme algo..."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:109
translate spanish dressrosa_h7_b4cc0c38:

    # player "What is it?"
    player "¿Qué es?"

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:110
translate spanish dressrosa_h7_0e2a2fdc:

    # rebecca "That if you manage to reach the end... don't forget what you saw in the eyes of those who fall."
    rebecca "Que si logras llegar al final... no olvides lo que viste en los ojos de los que caen."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:111
translate spanish dressrosa_h7_a0acd847:

    # rebecca "Many of them don't fight for glory or gold... but for something they lost long ago."
    rebecca "Muchos de ellos no luchan por la gloria ni por el oro... sino por algo que perdieron hace mucho tiempo."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:112
translate spanish dressrosa_h7_5e4a0d29:

    # rebecca "And not everyone is lucky enough to keep searching."
    rebecca "Y no todos tienen la suerte de seguir buscando."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:113
translate spanish dressrosa_h7_3d824e84:

    # player "You speak with great passion, [rebecca.n]. Who do you fight for? You never quite tell me everything..."
    player "Hablas con gran pasión, [rebecca.n]. ¿Por quién luchas? Nunca me lo cuentas todo..."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:114
translate spanish dressrosa_h7_c3810acb:

    # rebecca "...that... maybe I'll tell you when all this is over."
    rebecca "...que...tal vez te lo cuente cuando todo esto termine."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:115
translate spanish dressrosa_h7_43f9c3b0:

    # rebecca "If we're still alive, of course."
    rebecca "Si todavía estamos vivos, claro."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:120
translate spanish dressrosa_h7_a8940396:

    # rebecca "We'll see each other again..."
    rebecca "Nos volveremos a ver..."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:121
translate spanish dressrosa_h7_79bfacc2:

    # rebecca "These fights aren't like the preliminary ones anymore... It should be full of powerful enemies."
    rebecca "Estas peleas ya no son como las preliminares... Deberían estar llenas de enemigos poderosos."

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:122
translate spanish dressrosa_h7_f1412da8:

    # rebecca "I'm off to fight!"
    rebecca "¡Me voy a pelear!"

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:123
translate spanish dressrosa_h7_be6d67ee:

    # player "I trust you!"
    player "¡Confío en ti!"

# game/scripts/Events/locations/dressrosa/dressrosa_h7.rpy:124
translate spanish dressrosa_h7_027f2970:

    # rebecca "Thanks... Goodbye [player.n]"
    rebecca "Gracias... Adios [player.n]"

