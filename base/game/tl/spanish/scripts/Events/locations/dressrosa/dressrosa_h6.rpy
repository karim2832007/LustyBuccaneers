# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:14
translate spanish dressrosa_h6_383e6864:

    # gatz "{size=40}Weeeeeeeeeelcome, ladies and gentlemen, toys and dolls!{/size}"
    gatz "{size=40}¡Bienvenidooos, damas y caballeros, juguetes y muñecas!{/size}"

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:15
translate spanish dressrosa_h6_f975fce0:

    # gatz "{size=40}Welcome everyone to the Corrida Coliseum!{/size}"
    gatz "{size=40}¡Bienvenidos todos al Coliseo Corrida!{/size}"

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:19
translate spanish dressrosa_h6_a3f089ec:

    # gatz "Thanks to the great kindness and benevolence of our young king..."
    gatz "Gracias a la gran bondad y benevolencia de nuestro joven rey..."

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:20
translate spanish dressrosa_h6_60ad87f6:

    # gatz "Today we are all gathered here to enjoy a one-of-a-kind event in history!!"
    gatz "¡¡¡Hoy estamos todos reunidos aquí para disfrutar de un acontecimiento único en la historia!!!"

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:21
translate spanish dressrosa_h6_af1d9178:

    # gatz "{size=40}What you will see today will be the event of the century!!!{/size}"
    gatz "{size=40}¡Lo que veréis hoy será el acontecimiento del siglo!{/size}"

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:22
translate spanish dressrosa_h6_a8a3e039:

    # gatz "Fighters from all the seas have gathered today with a single goal..."
    gatz "Luchadores de todos los mares se han reunido hoy con un único objetivo..."

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:23
translate spanish dressrosa_h6_80e92c5f:

    # gatz "To emerge victorious from today's grand tournament and take home a unique, unmatched prize!!"
    gatz "¡Para salir victorioso del gran torneo de hoy y llevarte a casa un premio único e inigualable!"

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:25
translate spanish dressrosa_h6_046ffca6:

    # gatz "I am [gatz.n], and I'll be your commentator and host for this tournament!!"
    gatz "¡Soy [gatz.n] y seré su comentarista y anfitrión en este torneo!"

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:27
translate spanish dressrosa_h6_c01d101f:

    # gatz "With the qualifying matches concluded, only the best fighters remain..."
    gatz "Concluidos los partidos clasificatorios, sólo quedan los mejores luchadores..."

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:28
translate spanish dressrosa_h6_d754cfb9:

    # gatz "These contenders will face off in 1 vs 1 battles until only one winner is left, who will then face the one and only..."
    gatz "Estos contendientes se enfrentarán en batallas 1 contra 1 hasta que solo quede un ganador, quien luego se enfrentará al único..."

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:29
translate spanish dressrosa_h6_edc69ca8:

    # gatz "The historic champion of the Coliseum, the hero of the Corrida Coliseum, and the great champion of the Donquixote family..."
    gatz "El campeón histórico del Coliseo, el héroe de la Corrida Coliseum y el gran campeón de la familia Donquixote..."

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:30
translate spanish dressrosa_h6_c08d0fdb:

    # gatz "{size=40}{outlinecolor=#8b0000}{color=#ff6666}Diamanteeeeeeee{/color}{/outlinecolor}!{/size}"
    gatz "{size=40}{outlinecolor=#8b0000}{color=#ff6666}¡Diamanteeeeeeee{/color}{/outlinecolor}!{/size}"

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:32
translate spanish dressrosa_h6_135b1a81:

    # gatz "As you already know, the king entrusted us with an invaluable treasure..."
    gatz "Como ya sabéis, el rey nos confió un tesoro inestimable..."

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:33
translate spanish dressrosa_h6_cfde4de8:

    # gatz "Which will be awarded today to whoever wins this tournament."
    gatz "El cual se entregará hoy a quien gane este torneo."

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:34
translate spanish dressrosa_h6_a37d807c:

    # gatz "Today it is here, before you, in its original form..."
    gatz "Hoy está aquí, ante vosotros, en su forma original..."

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:35
translate spanish dressrosa_h6_c4bd4ebe:

    # gatz "The Devil Fruit... {outlinecolor=#a85d74}{color=#ffc0cb}Hana Hana Fruit!{/color}{/outlinecolor}!"
    gatz "La Fruta del Diablo... ¡{outlinecolor=#a85d74}{color=#ffc0cb}Fruta Hana Hana!{/color}{/outlinecolor}!"

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:36
translate spanish dressrosa_h6_1af0f673:

    # gatz "Observe..."
    gatz "Observar..."

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:42
translate spanish dressrosa_h6_dc5d46de:

    # gatz "Isn't it wonderful!?!"
    gatz "¿¡No es maravilloso!?"

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:43
translate spanish dressrosa_h6_6254e5de:

    # gatz "{size=40}First place in the tournament will receive the fruit as the prize!!{/size}"
    gatz "{size=40}¡El primer lugar en el torneo recibirá la fruta como premio!{/size}"

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:50
translate spanish dressrosa_h6_3057b98c:

    # gatz "Without further ado, let's go to the first matchup of the day!!"
    gatz "¡Sin más preámbulos, vamos al primer enfrentamiento del día!"

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:51
translate spanish dressrosa_h6_041ecefe:

    # gatz "On one side we have a tough, veteran contender... known to all the locals on the island..."
    gatz "Por un lado tenemos a un contendiente duro y veterano... conocido por todos los lugareños de la isla..."

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:52
translate spanish dressrosa_h6_add12604:

    # gatz "The captain of the Dressrosa army"
    gatz "El capitán del ejército de Dressrosa"

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:53
translate spanish dressrosa_h6_b6cf961e:

    # gatz "Captain Tank [lepanto.n]!!!!"
    gatz "¡¡¡Capitán Tanque [lepanto.n]!!!"

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:61
translate spanish dressrosa_h6_044bccf8:

    # gatz "And on the other side... a young complete unknown, but we shouldn't underestimate him if he's here!"
    gatz "Y al otro lado... un joven totalmente desconocido, ¡pero no debemos subestimarlo si está aquí!"

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:62
translate spanish dressrosa_h6_d4a2f71a:

    # gatz "The last person to register for this wonderful tournament—give a big round of applause to..."
    gatz "La última persona en inscribirse para este maravilloso torneo: un gran aplauso para..."

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:63
translate spanish dressrosa_h6_bbfe0aec:

    # gatz "{size=40}[player.n]!!!!{/size}"
    gatz "{size=40}[player.n]!!!!{/size}"

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:65
translate spanish dressrosa_h6_a91d5f54:

    # gatz "[lepanto.n] versus [player.n]!!!"
    gatz "[lepanto.n] contra [player.n]!!!"

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:66
translate spanish dressrosa_h6_2ff8ccfc:

    # gatz "Who will be the winner?!? The bets seem to have a clear favorite... but don't count the kid out yet!"
    gatz "¿Quién será el ganador? Las apuestas parecen tener un claro favorito... ¡pero no descarten al niño todavía!"

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:68
translate spanish dressrosa_h6_aecfd2b8:

    # gatz "!!?!"
    gatz "!!?!"

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:69
translate spanish dressrosa_h6_8bed82fa:

    # gatz "It seems both fighters are striking up a chat before the bout..."
    gatz "Parece que ambos peleadores están entablando una charla antes de la pelea..."

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:70
translate spanish dressrosa_h6_07977ed0:

    # gatz "What could they be saying? It's hard to hear with how lively today's crowd is!!"
    gatz "¿Qué estarán diciendo? ¡Es difícil oírlo con lo animada que está la gente hoy!"

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:72
translate spanish dressrosa_h6_9d3fc547:

    # lepanto "What is a youngster like you doing here!?!"
    lepanto "¡¿Qué hace un joven como tú aquí?!"

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:73
translate spanish dressrosa_h6_ba1b8ac3:

    # player "Well, I came to enter the tournament, big guy..."
    player "Bueno, vine a entrar al torneo, grandullón..."

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:74
translate spanish dressrosa_h6_43b8fe32:

    # lepanto "You?!?!... You should train many more years before coming to participate in this tournament..."
    lepanto "¡¿Tú?!?!... Deberías entrenar muchos años más antes de venir a participar en este torneo..."

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:75
translate spanish dressrosa_h6_5f80b6e5:

    # lepanto "Don't you know how dangerous it is!?!"
    lepanto "¿¡No sabes lo peligroso que es!?"

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:76
translate spanish dressrosa_h6_6fbaa294:

    # player "Everyone says the same thing... What's with you all..."
    player "Todo el mundo dice lo mismo... ¿Qué pasa con todos ustedes?"

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:77
translate spanish dressrosa_h6_53b88ee3:

    # lepanto "Why don't you get out of here right now... for your own good..."
    lepanto "¿Por qué no sales de aquí ahora mismo... por tu propio bien...?"

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:78
translate spanish dressrosa_h6_b1e10144:

    # player "Mmm..."
    player "Mmm..."

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:79
translate spanish dressrosa_h6_7011edca:

    # player "You're trying to act tough, but you're a terrible actor..."
    player "Intentas hacerte el duro, pero eres un actor terrible..."

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:80
translate spanish dressrosa_h6_21fa0bb6:

    # player "Aren't you the commander of the current king's army?!? You should be a bit more respectful.."
    player "¿No eres tú el comandante del ejército del rey actual? Deberías ser un poco más respetuoso."

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:81
translate spanish dressrosa_h6_f430e082:

    # lepanto "Hah!"
    lepanto "¡Ja!"

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:82
translate spanish dressrosa_h6_3cf96d31:

    # lepanto "The current king... It's not even worth discussing the matter with a foreigner..."
    lepanto "El rey actual... Ni siquiera vale la pena discutir el asunto con un extranjero..."

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:83
translate spanish dressrosa_h6_636164f0:

    # lepanto "You have no idea how much is happening here..."
    lepanto "No tienes idea de todo lo que está pasando aquí..."

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:84
translate spanish dressrosa_h6_fd89e81d:

    # lepanto "I'm loyal to only one king... but it's too late for that..."
    lepanto "Soy leal a un solo rey... pero ya es demasiado tarde para eso..."

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:85
translate spanish dressrosa_h6_dbc222c7:

    # lepanto "They asked me to clean the tournament of competitors... and that's exactly what I'll do..."
    lepanto "Me pidieron que limpiara el torneo de competidores... y eso es exactamente lo que haré..."

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:86
translate spanish dressrosa_h6_af0882eb:

    # lepanto "I prefer making money to chasing an unrealistic dream"
    lepanto "Prefiero ganar dinero a perseguir un sueño poco realista."

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:87
translate spanish dressrosa_h6_dc7f75ec:

    # lepanto "Get ready, kid!!!"
    lepanto "¡¡¡Prepárate, niño!!!"

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:92
translate spanish dressrosa_h6_71c8bfbc:

    # lepanto "Ughhh... damn... I underestimated you way too much..."
    lepanto "Ughhh... maldita sea... te subestimé demasiado..."

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:93
translate spanish dressrosa_h6_02a87a46:

    # lepanto "You're really strong, kid..."
    lepanto "Eres realmente fuerte, niño..."

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:94
translate spanish dressrosa_h6_499d3713:

    # lepanto "I hope you achieve your goal... and get what you're looking for..."
    lepanto "Espero que logres tu objetivo...y consigas lo que buscas..."

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:95
translate spanish dressrosa_h6_27ffa9dc:

    # lepanto "You're young... you still have hope..."
    lepanto "Eres joven... todavía tienes esperanza..."

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:96
translate spanish dressrosa_h6_451de321:

    # lepanto "I've failed as a commander... I've disappointed my king, and he's dead now..."
    lepanto "He fracasado como comandante... He decepcionado a mi rey, y ahora está muerto..."

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:97
translate spanish dressrosa_h6_27f482ac:

    # player "(!!!)"
    player "(!!!)"

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:98
translate spanish dressrosa_h6_74fa18d8:

    # lepanto "Now I work for a false king... my life has no honor..."
    lepanto "Ahora trabajo para un falso rey... mi vida no tiene honor..."

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:99
translate spanish dressrosa_h6_482e1bec:

    # lepanto "I've tried for so many years... to protect my princess... but..."
    lepanto "He intentado durante tantos años... proteger a mi princesa... pero..."

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:100
translate spanish dressrosa_h6_5f3a4d50:

    # lepanto "But in the end, I've failed here too..."
    lepanto "Pero al final, también he fracasado aquí..."

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:108
translate spanish dressrosa_h6_89b0a0ab:

    # gatz "Ohhhh!! No way, Captain Tank has fallen?!?"
    gatz "¡¡¡Ohhh!! ¡¡¡De ninguna manera, el Capitán Tanque se ha caído!!!"

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:109
translate spanish dressrosa_h6_9cc419ca:

    # gatz "The crowd is going wild!!!! [player.n] wiiins!"
    gatz "¡La multitud se está volviendo loca! [player.n] ¡wiiins!"

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:110
translate spanish dressrosa_h6_6e8bcb50:

    # gatz "Incredible!! Against all odds, [player.n] proved we shouldn't judge by appearances!"
    gatz "¡Increíble! Contra todo pronóstico, [player.n] demostró que no debemos juzgar por las apariencias."

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:111
translate spanish dressrosa_h6_52864c18:

    # gatz "What a spectacular first match we've had!!"
    gatz "¡¡¡Qué primer partido más espectacular hemos tenido!!!"

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:112
translate spanish dressrosa_h6_d77f362a:

    # gatz "[player.n], please return to the fighters's preparation room and recover until your next fight!!"
    gatz "[player.n] ¡Por favor regresa a la sala de preparación de los luchadores y recupérate hasta tu próxima pelea!"

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:113
translate spanish dressrosa_h6_4587ba98:

    # player "Alright!!"
    player "¡¡Está bien!!"

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:114
translate spanish dressrosa_h6_df4e791a:

    # player "(Looks like I have to wait now...)"
    player "(Parece que ahora tengo que esperar...)"

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:115
translate spanish dressrosa_h6_2c16fbc8:

    # player "(Maybe I can spend some time with that beautiful warrior angel!!)"
    player "(¡¡Tal vez pueda pasar algún tiempo con ese hermoso ángel guerrero!!)"

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:116
translate spanish dressrosa_h6_f8b311d2:

    # gatz "Let's take a short break while the next competitors prepare and head to the arena!!"
    gatz "¡Tomemos un breve descanso mientras los próximos competidores se preparan y se dirigen a la arena!"

# game/scripts/Events/locations/dressrosa/dressrosa_h6.rpy:117
translate spanish dressrosa_h6_4f16f7ba:

    # gatz "We'll be back shortly, stay tuned!"
    gatz "Regresaremos en breve, ¡estad atentos!"

