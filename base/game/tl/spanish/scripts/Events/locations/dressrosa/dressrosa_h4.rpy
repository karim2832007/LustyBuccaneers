# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:99
translate spanish dressrosa_h4_c12e15e3:

    # nami "Alright, Captain, you can do it!"
    nami "¡Está bien, Capitán, puedes hacerlo!"

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:100
translate spanish dressrosa_h4_6e5329f4:

    # nami "We'll be watching and cheering for you from the stands! The rounds will probably start soon!"
    nami "¡Los estaremos viendo y animando desde las gradas! ¡Probablemente las rondas comiencen pronto!"

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:102
translate spanish dressrosa_h4_256e5ae0:

    # yamato "Hahaha, good luck, Captain, show everyone here how strong you are!"
    yamato "Jajajaja, buena suerte Capitán, ¡muéstrale a todos aquí lo fuerte que eres!"

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:103
translate spanish dressrosa_h4_1c266a6f:

    # yamato "And don't forget, [player.n], don't draw too much attention..."
    yamato "Y no lo olvides, [player.n], no llames demasiado la atención..."

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:104
translate spanish dressrosa_h4_06252cf0:

    # yamato " {size=25}Remember we're pirates!{/size}"
    yamato "{size=25}¡Recuerda que somos piratas!{/size}"

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:105
translate spanish dressrosa_h4_9818ebb6:

    # player "Don't worry, when you come back you'll see me with the Devil Fruit for [robin.n]!!"
    player "¡No te preocupes, cuando regreses me verás con la Fruta del Diablo por [robin.n]!"

