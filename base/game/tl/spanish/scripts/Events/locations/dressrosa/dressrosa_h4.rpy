# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:16
translate spanish dressrosa_h4_210253cc:

    # police1 "That toy soldier causing trouble again..."
    police1 "Ese soldadito de juguete vuelve a causar problemas..."

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:17
translate spanish dressrosa_h4_90320207:

    # police1 "He won't give up... We'll catch you, toy soldier!!"
    police1 "Él no se rendirá... ¡Te atraparemos, soldadito de juguete!"

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:18
translate spanish dressrosa_h4_7e59c529:

    # unknown "Hahah I'd like to see you try!!"
    unknown "¡Jajajajajajajajajajajajaja! ¡Me gustaría verte intentarlo!"

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:19
translate spanish dressrosa_h4_0e205daf:

    # police2 "Stay away from the colosseum and come back here!!"
    police2 "¡Aléjate del Coliseo y vuelve aquí!"

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:20
translate spanish dressrosa_h4_605a0600:

    # police2 "Stop right now!!"
    police2 "¡¡¡Detente ahora mismo!!!"

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:28
translate spanish dressrosa_h4_b763ae13:

    # kyros "Hahaha you're too slow!!"
    kyros "¡¡¡Jajajaja eres demasiado lento!!!"

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:29
translate spanish dressrosa_h4_0c34bcc9:

    # kyros "Look... I've got one foot in the colosseum, and you know the law here well!"
    kyros "Mira... tengo un pie en el coliseo, ¡y conoces bien la ley aquí!"

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:30
translate spanish dressrosa_h4_0c7cc28a:

    # kyros "From this point on it's completely forbidden for the Marines or the police to enter!"
    kyros "¡A partir de este momento queda totalmente prohibido el acceso a los marines y a la policía!"

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:31
translate spanish dressrosa_h4_79774a4e:

    # kyros "It doesn't matter if a criminal goes in... you can't!"
    kyros "No importa si entra un criminal... ¡no puedes!"

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:32
translate spanish dressrosa_h4_d00aac62:

    # kyros "No matter how much you want to, you won't be able to go in after him!"
    kyros "¡Por mucho que quieras no podrás entrar tras él!"

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:33
translate spanish dressrosa_h4_51ae9ca8:

    # kyros "You already know that inside the colosseum only the Donquixote family is in charge."
    kyros "Ya sabéis que dentro del coliseo sólo manda la familia Donquixote."

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:34
translate spanish dressrosa_h4_481ecdcb:

    # kyros "If you enter or dare to fire, you'll be hunted down and sent to prison, so leave now!"
    kyros "Si entras o te atreves a disparar, serás perseguido y enviado a prisión, ¡así que vete ahora!"

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:35
translate spanish dressrosa_h4_b2579165:

    # police1 "Damn it... We'd better go for now..."
    police1 "Maldita sea... Será mejor que nos vayamos ahora..."

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:36
translate spanish dressrosa_h4_ffca32f9:

    # police2 "You won't be so lucky next time..."
    police2 "La próxima vez no tendrás tanta suerte..."

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:43
translate spanish dressrosa_h4_a0173696:

    # yamato "What a strange island... the police chasing a toy is something I never would've believed I'd see..."
    yamato "¡Qué isla más extraña... la policía persiguiendo un juguete es algo que nunca hubiera creído que vería..."

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:44
translate spanish dressrosa_h4_abac9501:

    # yamato "Though I have to admit that toy's got some attitude!!"
    yamato "Aunque tengo que admitir que ¡ese juguete tiene cierta actitud!"

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:45
translate spanish dressrosa_h4_8fd3cba4:

    # yamato "He made those cops look completely ridiculous!"
    yamato "¡Hizo que esos policías parecieran completamente ridículos!"

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:47
translate spanish dressrosa_h4_23cd0363:

    # narrator "A moment later, the police officers walk away furious and frustrated."
    narrator "Un momento después, los policías se alejan furiosos y frustrados."

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:48
translate spanish dressrosa_h4_7f1e54f1:

    # narrator "Then the toy soldier jumps, landing right in front of you."
    narrator "Entonces el soldadito de juguete salta y aterriza justo frente a ti."

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:60
translate spanish dressrosa_h4_28818bf8:

    # kyros "Damn it... Those cops made me waste my time, she's surely already registered... I should've stopped her!"
    kyros "Maldita sea... Esos policías me hicieron perder el tiempo, seguramente ya está registrada... ¡Debería haberla detenido!"

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:61
translate spanish dressrosa_h4_82cab370:

    # player "Hahah you did great, kid!! You made those cops look ridiculous hahaha!"
    player "¡Jajaja, lo hiciste genial, chico! ¡Hiciste que esos policías quedaran en ridículo, jajaja!"

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:62
translate spanish dressrosa_h4_e4788f9e:

    # kyros "Mnm?! Who are you calling kid!! I'm a grown man, you know!!"
    kyros "¡¿Mmm?! ¿A quién llamas, niño? ¡Soy un hombre adulto, ya lo sabes!"

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:63
translate spanish dressrosa_h4_96f843f5:

    # player "Hahah sorry, sorry! You're very small and I assumed wrong..."
    player "Jajaja, perdón, perdón. Eres muy pequeño y supuse mal..."

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:64
translate spanish dressrosa_h4_d1bbe0be:

    # player "We're still not used to seeing so many toys walking around here!"
    player "¡Todavía no nos acostumbramos a ver tantos juguetes andando por aquí!"

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:65
translate spanish dressrosa_h4_2b06dbc0:

    # kyros "So you're tourists!! Sorry for scaring you—do you need me to guide you or recommend somewhere to go?!"
    kyros "¡Así que son turistas! Disculpen el susto. ¿Necesitan que los guíe o les recomiende algún sitio?"

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:71
translate spanish dressrosa_h4_fa755f63:

    # nami "Hahaha suddenly he's very polite!"
    nami "¡Jajajaja! ¡De repente es muy educado!"

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:72
translate spanish dressrosa_h4_be0f89eb:

    # player "Hahaha you're very funny!!"
    player "Jajajaja eres muy gracioso!!"

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:73
translate spanish dressrosa_h4_c639931b:

    # kyros "Well of course I am!!! I seem funny to you, don't I?!"
    kyros "¡Claro que sí! ¡Te parezco gracioso, ¿verdad?!"

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:74
translate spanish dressrosa_h4_505361b6:

    # kyros "I'm a toy after all!! And toys are for making people smile!"
    kyros "¡Soy un juguete después de todo! ¡Y los juguetes son para hacer sonreír a la gente!"

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:75
translate spanish dressrosa_h4_372db598:

    # player "Hahaha well, you sure are!"
    player "Jajajaja, ¡seguro que lo eres!"

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:81
translate spanish dressrosa_h4_7850acb8:

    # yamato "Tell us, sir... Are you part of the colosseum? You seemed very well informed about the rules..."
    yamato "Díganos, señor... ¿Es usted parte del Coliseo? Parecía estar muy bien informado sobre las reglas..."

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:82
translate spanish dressrosa_h4_18790800:

    # kyros "Well... let's say I was once part of all this, but it's been a long time, you know... I'm away from the administration now."
    kyros "Bueno... digamos que alguna vez fui parte de todo esto, pero ya ha pasado mucho tiempo, ya sabes... ya estoy alejado de la administración."

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:83
translate spanish dressrosa_h4_ec58bcd4:

    # yamato "Uh, what a shame—the captain just signed up, a bit of information would be useful to us."
    yamato "Uh, qué pena, el capitán acaba de apuntarse, un poco de información nos vendría bien."

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:84
translate spanish dressrosa_h4_55003e5e:

    # kyros "You, kid, you signed up for the tournament?!?"
    kyros "¡¿Tú, chico, te inscribiste para el torneo?!?"

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:85
translate spanish dressrosa_h4_41aa145c:

    # kyros "Don't you know what's at stake?!? A large number of strong fighters from all over the world have come..."
    kyros "¿No sabes lo que está en juego? ¡Un gran número de luchadores fuertes de todo el mundo han venido!"

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:86
translate spanish dressrosa_h4_0317f59d:

    # kyros "It's really dangerous for you to take part!!"
    kyros "¡¡¡Es realmente peligroso para ti participar!!!"

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:87
translate spanish dressrosa_h4_84ce84e3:

    # kyros "You should rethink it right now while you still can..."
    kyros "Deberías repensarlo ahora mismo mientras todavía puedas..."

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:88
translate spanish dressrosa_h4_c2ca4294:

    # nami "Hahah don't worry, soldier, our captain is really strong!!"
    nami "¡Jajajaja no te preocupes soldado, nuestro capitán es realmente fuerte!"

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:89
translate spanish dressrosa_h4_fddae2f8:

    # player "Hahaha that's right, I've got it under control!"
    player "Jajajaja es cierto, ¡lo tengo bajo control!"

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:90
translate spanish dressrosa_h4_3707a2f0:

    # kyros "Mnmnm... Well, I suppose there's nothing I can do to stop it..."
    kyros "Mnmnm... Bueno, supongo que no hay nada que pueda hacer para detenerlo..."

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:91
translate spanish dressrosa_h4_63330130:

    # kyros "Please be careful—there are very dangerous people, don't overexert yourself!"
    kyros "¡Ten cuidado, hay gente muy peligrosa, no te esfuerces demasiado!"

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:92
translate spanish dressrosa_h4_2bfbfad7:

    # kyros "Ah... and one more thing, if I may ask you..."
    kyros "Ah...y una cosa más, si me permites preguntarte..."

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:93
translate spanish dressrosa_h4_cb2fcee0:

    # kyros "If you see a pink-haired gladiator, please tell her the same thing!"
    kyros "Si ves a un gladiador de cabello rosa, ¡dile lo mismo!"

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:94
translate spanish dressrosa_h4_d019e784:

    # kyros "She has nothing to prove or to push herself for... the main thing is that she takes care of herself!"
    kyros "Ella no tiene nada que demostrar ni que exigirse... ¡lo principal es que se cuide!"

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:95
translate spanish dressrosa_h4_2842228a:

    # player "(A pink-haired girl... Could that be [rebecca.n]?!?)"
    player "(Una chica de cabello rosa... ¿¡podría ser [rebecca.n]?!?)"

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:96
translate spanish dressrosa_h4_62d9c603:

    # player "Alright... No problem, I'll pass along your message!"
    player "Está bien... No hay problema, ¡le transmitiré tu mensaje!"

# game/scripts/Events/locations/dressrosa/dressrosa_h4.rpy:97
translate spanish dressrosa_h4_bed62aa8:

    # player "Well then, that's all—see later girls, toy soldier... I'm going in!"
    player "Bueno, eso es todo, nos vemos luego chicas, soldadito de juguete... ¡Voy a entrar!"

