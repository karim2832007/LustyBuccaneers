# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:13
translate spanish dressrosa_h13_daf5c4aa:

    # gatz "{size=40}Weeeeeeeeeelcome back, ladies and gentlemen, toys and dolls!{/size}"
    gatz "{size=40}¡Bienvenid@s de nuevo, damas y caballeros, juguetes y muñecas!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:14
translate spanish dressrosa_h13_26246797:

    # gatz "{size=40}Welcome everyone once again to the Corrida Coliseum!{/size}"
    gatz "{size=40}¡Bienvenidos todos una vez más al Coliseo Corrida!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:16
translate spanish dressrosa_h13_1d315f6d:

    # gatz "Tonight, two warriors will clash in an earth-shaking duel!"
    gatz "¡Esta noche, dos guerreros se enfrentarán en un duelo que sacudirá la tierra!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:17
translate spanish dressrosa_h13_b1b8ade7:

    # gatz "In the west corner, a brave newcomer who's captured all our hearts with his incredible victories!"
    gatz "¡En la esquina oeste, un valiente recién llegado que ha capturado todos nuestros corazones con sus increíbles victorias!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:18
translate spanish dressrosa_h13_583fb35c:

    # gatz "A champion of the people, undefeated so far, give it up for the fearless [player.n]!!!"
    gatz "Un campeón del pueblo, invicto hasta ahora, ¡¡¡un aplauso para los intrépidos [player.n]!!!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:21
translate spanish dressrosa_h13_3398aa7c:

    # unknown "{size=40}[player.n]!! [player.n]!! [player.n]!!{/size}"
    unknown "{size=40}[player.n]!! [player.n]!! [player.n]!!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:23
translate spanish dressrosa_h13_7ba99b2d:

    # gatz "And in the east corner, a fearsome veteran from the Majiatsuka Kingdom!"
    gatz "¡Y en la esquina este, un temible veterano del Reino Majiatsuka!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:24
translate spanish dressrosa_h13_6a5221c7:

    # gatz "A man with a reputation as a bone-crushing brute, who leaves only broken bodies in his wake!"
    gatz "¡Un hombre con reputación de ser un bruto aplastante que solo deja cuerpos rotos a su paso!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:25
translate spanish dressrosa_h13_d253f45b:

    # gatz "He's big, he's bad, he's hungry for glory, the one and only {size=40}{outlinecolor=#8b0000}{color=#ff6666}Roooollin Loooogan{/color}{/outlinecolor}!!!{/size}"
    gatz "Es grande, es malo, tiene hambre de gloria, el único e inigualable {size=40}{outlinecolor=#8b0000}{color=#ff6666}¡Roooollin Loooogan{/color}{/outlinecolor}!!!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:27
translate spanish dressrosa_h13_6d4315c5:

    # unknown "[logan.n]!! [logan.n]!! [logan.n]!!"
    unknown "[logan.n]!! [logan.n]!! [logan.n]!!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:41
translate spanish dressrosa_h13_860f6b32:

    # gatz "[logan.n] versus [player.n]!!!"
    gatz "¡[logan.n] contra [player.n]!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:42
translate spanish dressrosa_h13_5d73d8df:

    # gatz "Our Colosseum shakes with excitement! Two titans, one arena, this is what we've been waiting for!"
    gatz "¡Nuestro Coliseo tiembla de emoción! Dos titanes, una arena, ¡esto es lo que hemos estado esperando!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:43
translate spanish dressrosa_h13_5d087d79:

    # gatz "Only one will walk out victorious and claim eternal glory this day!"
    gatz "¡Sólo uno saldrá victorioso y reclamará la gloria eterna este día!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:44
translate spanish dressrosa_h13_715800a4:

    # gatz "So without further ado..."
    gatz "Así que sin más preámbulos..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:45
translate spanish dressrosa_h13_c56eb200:

    # gatz "Let the battle... BEGIN!!!"
    gatz "¡Que la batalla... COMIENCE!!!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:47
translate spanish dressrosa_h13_c8f1263d:

    # logan "Heh heh... Look at you, all fired up. Enjoy the cheers while they last, kid."
    logan "Je, je... Mírate, qué entusiasmado. Disfruta de las ovaciones mientras duren, chico."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:48
translate spanish dressrosa_h13_30548b38:

    # logan "These people love a hero now, but just wait till they see me snap you like a twig!"
    logan "A esta gente ahora le encantan los héroes, ¡pero esperen a que me vean partirlos como a una ramita!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:50
translate spanish dressrosa_h13_cf8154e4:

    # player "Big talk for someone who's about to eat dirt."
    player "Grandes palabras para alguien que está a punto de comer tierra."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:52
translate spanish dressrosa_h13_219b126d:

    # logan "Oh? The little hero has some bite! I remember seeing you earlier... sneaking around with that pretty little girl, [rebecca.n]."
    logan "¿Ah, sí? ¡Qué mordaza tiene el pequeño héroe! Recuerdo haberte visto antes... escabulléndote con esa niñita tan guapa, [rebecca.n]."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:53
translate spanish dressrosa_h13_f73b78c5:

    # logan "You two looked cozy in the hallway. What were you whispering, sweet nothings before the big fight?"
    logan "Se veían muy cómodos en el pasillo. ¿Qué susurraban? ¿Palabras dulces antes de la gran pelea?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:54
translate spanish dressrosa_h13_9be391f0:

    # player "Leave her out of this, [logan.n]! I'm warning you..."
    player "¡Déjala fuera de esto, [logan.n]! Te lo advierto..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:56
translate spanish dressrosa_h13_e47b027a:

    # logan "Heh heh..."
    logan "Je, je..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:57
translate spanish dressrosa_h13_b6a02540:

    # logan "Why? Afraid the crowd will learn how soft you really are? That you're fighting for a girl's favor?"
    logan "¿Por qué? ¿Tienes miedo de que la multitud se entere de lo blando que eres en realidad? ¿De que estás luchando por el favor de una chica?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:58
translate spanish dressrosa_h13_f16c8766:

    # logan "Pathetic! A real warrior should focus on the fight, not on pretty dolls."
    logan "¡Patético! Un verdadero guerrero debería centrarse en la lucha, no en las muñecas bonitas."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:59
translate spanish dressrosa_h13_2cb96b0a:

    # player "[rebecca.n] is twice the warrior you'll ever be! And she's got more honor in her little finger than you do in your whole body!"
    player "[rebecca.n] ¡Serás el doble de guerrera! ¡Y tiene más honor en su meñique que tú en todo tu cuerpo!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:60
translate spanish dressrosa_h13_0ad32c05:

    # logan "Ha! Honor won't save her or you. After I'm done here, maybe I'll pay dear [rebecca.n] a visit."
    logan "¡Ja! El honor no los salvará ni a ellos ni a ti. Cuando termine aquí, quizá le haga una visita a [rebecca.n]."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:61
translate spanish dressrosa_h13_b057ef02:

    # logan "She'll be heartbroken seeing you in pieces... but don't worry. I'll console her for you."
    logan "Se le romperá el corazón al verte hecho pedazos... pero no te preocupes. La consolaré por ti."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:62
translate spanish dressrosa_h13_d561ee85:

    # logan "Perhaps I'll wrap these arms around her delicate frame, the same way I'm about to crush you!"
    logan "¡Tal vez envuelva estos brazos alrededor de su delicado cuerpo, de la misma manera en que estoy a punto de aplastarte!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:64
translate spanish dressrosa_h13_aabd3abb:

    # player "He... You bastard...!"
    player "Él... ¡Bastardo...!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:65
translate spanish dressrosa_h13_a4b81832:

    # player "Look, I wasn't going to forgive you anyway... but it seems you want to suffer."
    player "Mira, no te iba a perdonar de todos modos... pero parece que quieres sufrir"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:66
translate spanish dressrosa_h13_fe299d31:

    # player "Say another word about [rebecca.n], and I swear you won't leave this arena conscious!"
    player "¡Di una palabra más sobre [rebecca.n] y te juro que no saldrás de esta arena consciente!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:68
translate spanish dressrosa_h13_e0f2ad3d:

    # logan "Heh heh heh..."
    logan "Je, je, je..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:69
translate spanish dressrosa_h13_1df89a3f:

    # logan "Hit a nerve, did I? Good! Get mad! It won't help you, but at least you'll scream loud before I break you."
    logan "¿Toqué la fibra sensible? ¡Bien! ¡Enfádate! No te servirá de nada, pero al menos gritarás fuerte antes de que te rompa"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:70
translate spanish dressrosa_h13_4a334ba0:

    # logan "I can already see it... you on the ground, begging for mercy, while [rebecca.n] watches."
    logan "Ya lo puedo ver... a ti en el suelo, rogando por misericordia, mientras [rebecca.n] observa."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:71
translate spanish dressrosa_h13_e0de7449:

    # logan "Maybe I'll make her watch up close. I'll have her kneel by your broken body as I finish you off!"
    logan "Quizás la obligue a mirar de cerca. ¡Haré que se arrodille junto a tu cuerpo destrozado mientras te acabo!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:72
translate spanish dressrosa_h13_b39441a9:

    # player "[logan.n], you're digging your own grave."
    player "[logan.n] Estás cavando tu propia tumba."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:73
translate spanish dressrosa_h13_4f890e6e:

    # logan "Bold words from a dead man walking."
    logan "Palabras atrevidas de un hombre muerto caminando."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:74
translate spanish dressrosa_h13_b0fed0ee:

    # logan "Face it, 'hero', you're outmatched. I'm going to enjoy every second of this."
    logan "Acéptalo, \"héroe\", estás superado. Voy a disfrutar cada segundo de esto."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:75
translate spanish dressrosa_h13_ff40c4df:

    # player "The only one who'll be broken today is you."
    player "El único que estará roto hoy serás tú."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:76
translate spanish dressrosa_h13_9a500fb4:

    # logan "Talk is cheap. Let's see you try! I'll throw you around like a rag doll."
    logan "Hablar es fácil. ¡A ver si lo intentas! Te voy a tirar por ahí como a un muñeco de trapo."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:77
translate spanish dressrosa_h13_6616fb2b:

    # player "I've heard enough. You're going to regret every word."
    player "Ya escuché suficiente. Te vas a arrepentir de cada palabra."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:78
translate spanish dressrosa_h13_3b947a49:

    # logan "Hah! Show me what you've got, little champion! I'll show [rebecca.n] who the real man is!"
    logan "¡Ja! ¡Muéstrame lo que tienes, pequeño campeón! ¡Yo le mostraré a [rebecca.n] quién es el verdadero hombre!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:79
translate spanish dressrosa_h13_220a1259:

    # player "I'm going to shut that filthy mouth of yours right here and now!"
    player "¡Voy a cerrar esa sucia boca tuya ahora mismo!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:80
translate spanish dressrosa_h13_5dabc296:

    # logan "Come on then! Let's dance, hero!"
    logan "¡Vamos! ¡A bailar, héroe!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:81
translate spanish dressrosa_h13_01fb1c97:

    # player "With pleasure!"
    player "¡Con mucho gusto!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:85
translate spanish dressrosa_h13_5df3f96f:

    # gatz "[player.n] won't stop hitting [logan.n]!"
    gatz "¡[player.n] no dejará de golpear a [logan.n]!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:86
translate spanish dressrosa_h13_93661a92:

    # gatz "{size=40}This is a massacre!{/size}"
    gatz "{size=40}¡Esto es una masacre!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:88
translate spanish dressrosa_h13_1d57d7c2:

    # logan "Gahh—!"
    logan "¡Ay!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:89
translate spanish dressrosa_h13_3ab6d6eb:

    # logan "You little... I'll crush you! Rolling Cradle!"
    logan "¡Pequeño... te aplastaré! ¡Cuna rodante!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:90
translate spanish dressrosa_h13_8fe542ec:

    # player "Ha! Not today!"
    player "¡Ja! ¡Hoy no!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:91
translate spanish dressrosa_h13_df3638d8:

    # logan "OOGH!"
    logan "¡OOGH!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:92
translate spanish dressrosa_h13_0b6e492d:

    # player "Get up, [logan.n]. I'm not done making you pay."
    player "Levántate, [logan.n]. No he terminado de hacerte pagar."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:93
translate spanish dressrosa_h13_4fc04308:

    # gatz "Another direct hit!! It looks like [logan.n] can't take it anymore!"
    gatz "¡Otro golpe directo! ¡Parece que [logan.n] no puede soportarlo más!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:94
translate spanish dressrosa_h13_95fc5922:

    # logan "W-wait... I—"
    logan "E-espera... Yo..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:95
translate spanish dressrosa_h13_d4016507:

    # logan "Please stop!"
    logan "¡Por favor, detente!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:96
translate spanish dressrosa_h13_ca18ab31:

    # player "What's wrong? Weren't you going to break me? Show me that 'strength' of yours!"
    player "¿Qué pasa? ¿No ibas a romperme? ¡Muéstrame esa 'fuerza' tuya!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:97
translate spanish dressrosa_h13_4f3e8750:

    # logan "I surrender... I can't go on..."
    logan "Me rindo... no puedo seguir..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:98
translate spanish dressrosa_h13_03775ec8:

    # player "..."
    player "..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:99
translate spanish dressrosa_h13_52532009:

    # player "{size=40}This is for [rebecca.n]!{/size}"
    player "{size=40}¡Esto es para [rebecca.n]!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:100
translate spanish dressrosa_h13_f485f654:

    # logan "OOF—!"
    logan "¡Uf!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:101
translate spanish dressrosa_h13_41e797d7:

    # logan "N-no more... I... I surrender!"
    logan "N-no más... ¡Yo... me rindo!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:102
translate spanish dressrosa_h13_fc2b6c68:

    # logan "I quit! I QUIT!!"
    logan "¡Me rindo! ¡Me rindo!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:106
translate spanish dressrosa_h13_d9d31f45:

    # gatz "This battle seems to be over!"
    gatz "¡Esta batalla parece haber terminado!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:107
translate spanish dressrosa_h13_53bca140:

    # gatz "Even though [logan.n] has begged for mercy repeatedly, [player.n] doesn't want to let him go and keeps punishing him!"
    gatz "A pesar de que [logan.n] ha pedido misericordia repetidamente, [player.n] no quiere dejarlo ir y sigue castigándolo."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:108
translate spanish dressrosa_h13_24828b0a:

    # gatz "!!!"
    gatz "!!!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:109
translate spanish dressrosa_h13_5de3d7a7:

    # gatz "But wait! With his last bit of strength, [logan.n] tries to escape!"
    gatz "¡Pero espera! ¡Con sus últimas fuerzas, [logan.n] intenta escapar!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:110
translate spanish dressrosa_h13_9ac0af8a:

    # gatz "He's running toward the edge of the platform!"
    gatz "¡Está corriendo hacia el borde de la plataforma!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:111
translate spanish dressrosa_h13_b4d70c04:

    # gatz "[logan.n] is desperate and it looks like he wants to jump into the water with the Little Fighting Fish!!"
    gatz "[logan.n] ¡Está desesperado y parece que quiere saltar al agua con el pequeño pez luchador!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:112
translate spanish dressrosa_h13_16d17f81:

    # logan "(He'll kill me if I don't jump)"
    logan "(Me matará si no salto)"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:116
translate spanish dressrosa_h13_cfc3d957:

    # gatz "Desperate and with no chance at all..."
    gatz "Desesperado y sin ninguna posibilidad..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:117
translate spanish dressrosa_h13_da9c9092:

    # gatz "[logan.n] just jumped into the water!!"
    gatz "[logan.n] ¡¡¡acabo de saltar al agua!!!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:118
translate spanish dressrosa_h13_b87e27c8:

    # player "(Damn... He runs fast for such a big guy...)"
    player "(Maldita sea... ¡Corre rápido para ser un tipo tan grande...!)"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:120
translate spanish dressrosa_h13_cceeefd8:

    # gatz "{size=40}He's definitely not thinking straight!!{/size}"
    gatz "{size=40}¡¡Definitivamente no está pensando con claridad!!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:125
translate spanish dressrosa_h13_0971755e:

    # player "Get back here, you coward, don't run away!!!"
    player "¡Vuelve aquí, cobarde, no huyas!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:126
translate spanish dressrosa_h13_d16dcdbf:

    # gatz "Hahaha, look at the dive he just took!"
    gatz "¡Jajajaja, mira la zambullida que acaba de hacer!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:127
translate spanish dressrosa_h13_1d8c5dea:

    # gatz "As small waves start to form, the Little Fighting Fish surround him quickly!!"
    gatz "¡Mientras pequeñas olas comienzan a formarse, los pequeños peces luchadores lo rodean rápidamente!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:131
translate spanish dressrosa_h13_cd100172:

    # gatz "The waters look calm... but from here you can see what's happening down below!!"
    gatz "Las aguas parecen tranquilas... pero desde aquí se puede ver lo que ocurre abajo!!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:132
translate spanish dressrosa_h13_aa82c6d4:

    # gatz "There's no way [logan.n] should've done that!"
    gatz "¡No había manera de que [logan.n] hubiera hecho eso!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:133
translate spanish dressrosa_h13_5f288395:

    # gatz "Send the guards in right now!!"
    gatz "¡¡¡Envíen a los guardias ahora mismo!!!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:134
translate spanish dressrosa_h13_a6a8256e:

    # gatz "[logan.n] can't go on anymore!!!"
    gatz "[logan.n] ¡¡¡No puedo seguir más!!!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:135
translate spanish dressrosa_h13_66e876b9:

    # gatz "[player.n] has done the impossible again!! [player.n] is truly unstoppable!!!"
    gatz "[player.n] ¡ha vuelto a hacer lo imposible! ¡[player.n] es realmente imparable!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:136
translate spanish dressrosa_h13_f5b288cf:

    # unknown "{size=40}[player.n]!! [player.n]!! [player.n]!! [player.n]!!{/size}"
    unknown "{size=40}[player.n]!! [player.n]!! [player.n]!! [player.n]!!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:144
