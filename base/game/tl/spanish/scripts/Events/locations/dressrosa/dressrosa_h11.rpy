# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:8
translate spanish dressrosa_h11_8c43a608:

    # narrador "While you were wandering around the Colosseum after your last battle, you ran into an old acquaintance who was gravely injured."
    narrador "Mientras paseabas por el Coliseo después de tu última batalla, te encontraste con un viejo conocido que estaba gravemente herido."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:14
translate spanish dressrosa_h11_daab7435:

    # player "[riku.n]!!!"
    player "[riku.n]!!!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:15
translate spanish dressrosa_h11_d9d8af7f:

    # player "But what the hell happened to you!!"
    player "¡¡¡Pero qué carajo te pasó!!!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:16
translate spanish dressrosa_h11_9a868ddb:

    # player "It looks like a train ran you over!"
    player "¡Parece como si te hubiera atropellado un tren!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:17
translate spanish dressrosa_h11_2945026c:

    # riku "Hehe... Cough cough, koff— splurt..."
    riku "Jeje... Tos, tos, koff— ¡chorro!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:18
translate spanish dressrosa_h11_12438671:

    # riku "I don't think I look as bad as I actually feel..."
    riku "No creo que me vea tan mal como realmente me siento..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:19
translate spanish dressrosa_h11_f1c0c441:

    # riku "I can barely remember the times I've ended up in this state!"
    riku "¡Apenas puedo recordar las veces que terminé en este estado!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:20
translate spanish dressrosa_h11_2d6d312c:

    # player "Well, you look... really bad..."
    player "Bueno, te ves... realmente mal..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:21
translate spanish dressrosa_h11_bdbaf953:

    # riku "I tried to give it my all... but it still wasn't enough..."
    riku "Intenté darlo todo... pero aún así no fue suficiente..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:22
translate spanish dressrosa_h11_6e7d9cfb:

    # riku "Hahaha no one can't say this old man didn't try!!"
    riku "¡Jajajajajaja! ¡Nadie puede decir que este viejo no lo intentó!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:24
translate spanish dressrosa_h11_aa53ef05:

    # riku "My rival... A grumpy, pointy-headed old man I met long ago... He gave me a good beating..."
    riku "Mi rival... Un viejo gruñón y de cabeza puntiaguda que conocí hace mucho tiempo... Me dio una buena paliza..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:25
translate spanish dressrosa_h11_072ce39f:

    # riku "He showed no mercy, he was pretty angry about something involving his grandkids apparently..."
    riku "No mostró piedad, estaba bastante enojado por algo que involucraba a sus nietos aparentemente..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:26
translate spanish dressrosa_h11_2506afbd:

    # riku "Either way, if I can't even beat someone like that... How far out of my reach is [donflamingo.n]..."
    riku "De cualquier manera, si ni siquiera puedo vencer a alguien así... ¿Qué tan fuera de mi alcance está [donflamingo.n]...?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:27
translate spanish dressrosa_h11_6f8d6d0a:

    # player "You're after [donflamingo.n] too?!"
    player "¿También estás detrás de [donflamingo.n]?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:28
translate spanish dressrosa_h11_44585b35:

    # player "Looks like this guy has a fan club, and not the good kind..."
    player "Parece que este tipo tiene un club de fans, y no del tipo bueno..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:29
translate spanish dressrosa_h11_9491a5f5:

    # riku "Anyone who knows what this guy did to the kingdom should be displeased with him, to say the least!"
    riku "¡Cualquiera que sepa lo que este hombre le hizo al reino debería estar disgustado con él, por decir lo menos!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:30
translate spanish dressrosa_h11_42096fee:

    # riku "Guhh—koff... koff... koff..."
    riku "Guhh—koff... koff... koff..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:32
translate spanish dressrosa_h11_c322a0cc:

    # narrador "You see [riku.n] wobble and lose his balance for a few seconds, but he recovers quickly."
    narrador "Ves a [riku.n] tambalearse y perder el equilibrio durante unos segundos, pero se recupera rápidamente."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:34
translate spanish dressrosa_h11_03027945:

    # riku "Damn... These wounds seem worse than I thought..."
    riku "Maldita sea... Estas heridas parecen peores de lo que pensaba..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:35
translate spanish dressrosa_h11_3e03809d:

    # player "Why don't you rest a bit, man..."
    player "¿Por qué no descansas un poco, hombre?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:36
translate spanish dressrosa_h11_ed29b515:

    # riku "Heh... There'll be time for this old man to rest later..."
    riku "Jeje... Ya habrá tiempo para que este viejo descanse más tarde..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:37
translate spanish dressrosa_h11_aa349038:

    # player "You should eat a lot, that's how I usually heal my wounds"
    player "Deberías comer mucho, así suelo curar mis heridas."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:38
translate spanish dressrosa_h11_333add06:

    # riku "Hahaha... I don't know what kind of medicine you trust in, but I don't think that'll work for this old body..."
    riku "Jajaja... No sé en qué tipo de medicina confías, pero no creo que eso funcione para este viejo cuerpo..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:39
translate spanish dressrosa_h11_5a38c2b7:

    # player "If not, I think I heard there's an infirmary in the basement, maybe they could give you a quick check-up"
    player "Si no, creo que escuché que hay una enfermería en el sótano, tal vez podrían hacerte un chequeo rápido."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:40
translate spanish dressrosa_h11_63969cd4:

    # riku "Mnmn... Koff... koff... The infirmary..."
    riku "Mnmn... Koff... koff... La enfermería..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:41
translate spanish dressrosa_h11_01ef1718:

    # riku "I should investigate a bit... But I haven't had the chance, they don't let anyone in unless they're hurt."
    riku "Debería investigar un poco... Pero no he tenido la oportunidad, no dejan entrar a nadie a menos que esté herido."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:42
translate spanish dressrosa_h11_e0b482f9:

    # riku "I've heard strange things from the gladiators about that place... Apparently something weird is going on there..."
    riku "He oído cosas extrañas de los gladiadores sobre ese lugar... Al parecer algo raro está pasando allí..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:43
translate spanish dressrosa_h11_c2b783ca:

    # player "Strange things?! What are you implying?"
    player "¡¿Cosas raras?! ¿Qué insinúas?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:44
translate spanish dressrosa_h11_92bf307c:

    # riku "I don't know, it doesn't matter now... I was heading to the arena, someone important to me should be about to fight!"
    riku "No sé, eso no importa ahora... Me dirigía a la arena, ¡alguien importante para mí debería estar a punto de pelear!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:46
translate spanish dressrosa_h11_3cfd3a11:

    # narrador "You see [riku.n] stumble again, almost collapsing to the floor; he's gravely injured..."
    narrador "Ves a [riku.n] tropezar de nuevo, casi desplomándose en el suelo; está gravemente herido..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:47
translate spanish dressrosa_h11_e282f5c1:

    # player "Hey hey, you'd better rest a bit in a corner... You won't last much longer..."
    player "Oye, oye, será mejor que descanses un poco en un rincón... No durarás mucho más..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:48
translate spanish dressrosa_h11_1109ce84:

    # riku "Ufff... You might be right..."
    riku "Ufff... Puede que tengas razón..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:50
translate spanish dressrosa_h11_849306fd:

    # riku "..."
    riku "..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:51
translate spanish dressrosa_h11_3fec95a6:

    # riku "Tell me [player.n]... you're a good person, I'm sure you can help me"
    riku "Dime [player.n]...eres buena persona, seguro puedes ayudarme."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:52
translate spanish dressrosa_h11_38242c14:

    # player "Of course, we're friends remember..."
    player "Por supuesto que somos amigos, recuerda..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:53
translate spanish dressrosa_h11_2a6705bc:

    # riku "Good... The next fight... You must stop it, or at least try..."
    riku "Bien... La próxima pelea... Debes detenerla, o al menos intentarlo..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:54
translate spanish dressrosa_h11_56ef38cc:

    # player "Why? Is something specific about to happen?"
    player "¿Por qué? ¿Está a punto de ocurrir algo específico?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:55
translate spanish dressrosa_h11_1567533d:

    # riku "One of the fighters is a gladiator named [rebecca.n]... She's a young girl taking on way more responsibility than she should..."
    riku "Una de las luchadoras es una gladiadora llamada [rebecca.n]... Es una chica joven que asume mucha más responsabilidad de la que debería..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:56
translate spanish dressrosa_h11_16c705d0:

    # player "(My warrior angel!)"
    player "(¡Mi ángel guerrero!)"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:57
translate spanish dressrosa_h11_69a2e3dc:

    # riku "She's taking responsibility for things that aren't hers, it's a long story... But you have to stop her."
    riku "Ella se está haciendo responsable de cosas que no son suyas, es una larga historia... Pero tienes que detenerla."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:58
translate spanish dressrosa_h11_29516fa1:

    # riku "She's come very far and has proven her worth... But we're at the end now, the opponents are fearsome..."
    riku "Ha llegado muy lejos y ha demostrado su valía... Pero ahora estamos al final, los oponentes son temibles..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:59
translate spanish dressrosa_h11_1b5dfe81:

    # riku "Look at how this old man ended up..."
    riku "Mira cómo terminó este anciano..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:60
translate spanish dressrosa_h11_0d3f8e95:

    # riku "I'm afraid I can't protect her anymore... All I can do now is try to stop her..."
    riku "Me temo que ya no puedo protegerla más... Lo único que puedo hacer ahora es intentar detenerla..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:61
translate spanish dressrosa_h11_693aac1f:

    # riku "We have to make her listen to reason..."
    riku "Tenemos que hacerle entrar en razón..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:62
translate spanish dressrosa_h11_06e180e8:

    # player "Mnmm... I've run into [rebecca.n] before, she's a good girl... Very determined."
    player "Mnmm... Me he encontrado con [rebecca.n] antes, es una buena chica... Muy decidida."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:63
translate spanish dressrosa_h11_4b1ea739:

    # player "I doubt I can convince her to stop..."
    player "Dudo que pueda convencerla de que se detenga..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:64
translate spanish dressrosa_h11_4f146eeb:

    # player "She has a clear goal to fulfill!"
    player "¡Tiene un objetivo claro que cumplir!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:65
translate spanish dressrosa_h11_72c1b2e3:

    # riku "I know! I know it well!!"
    riku "¡Lo sé! ¡Lo sé bien!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:66
translate spanish dressrosa_h11_b9839f4d:

    # riku "But she's young, it's an old man's duty to try to guide our young ones, you understand?!"
    riku "Pero ella es joven, es el deber de un anciano tratar de guiar a nuestros jóvenes, ¿entiendes?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:67
translate spanish dressrosa_h11_0e404857:

    # riku "Her next opponent is a brute, a disgusting person, a monster!!"
    riku "¡Su próximo oponente es un bruto, una persona repugnante, un monstruo!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:69
translate spanish dressrosa_h11_3afcb18d:

    # riku "I've seen what this criminal does to his opponents, he enjoys others' pain..."
    riku "He visto lo que este criminal hace con sus oponentes, disfruta del dolor ajeno..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:70
translate spanish dressrosa_h11_08ada099:

    # riku "[rebecca.n] could get seriously hurt... Or worse..."
    riku "[rebecca.n] Podría resultar gravemente herido... O peor..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:71
translate spanish dressrosa_h11_03775ec8:

    # player "..."
    player "..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:72
translate spanish dressrosa_h11_5b95b65d:

    # player "I can't promise anything, but I'll try!"
    player "¡No puedo prometer nada, pero lo intentaré!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:73
translate spanish dressrosa_h11_2f2c50ec:

    # player "I'll go look for her right now!"
    player "¡Iré a buscarla ahora mismo!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:75
translate spanish dressrosa_h11_ab1a9e3e:

    # riku "Good... Koff, koff... Hraaagh!"
    riku "Bien... Koff, koff... ¡Hraaagh!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:76
translate spanish dressrosa_h11_ba752e57:

    # riku "I'm counting on you, please try to make her listen to reason!"
    riku "Cuento contigo, ¡intenta hacerla entrar en razón!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:77
translate spanish dressrosa_h11_0d75ee25:

    # riku "I'll see if I rest here or head to the infirmary!"
    riku "¡Veré si descanso aquí o me dirijo a la enfermería!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:78
translate spanish dressrosa_h11_9649600b:

    # player "Get better old man, see you!"
    player "Mejórate viejo, ¡nos vemos!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:89
translate spanish dressrosa_h11_4452c3fd:

    # narrador "You run toward the arena entrance and manage to catch up to [rebecca.n] just in time."
    narrador "Corres hacia la entrada de la arena y logras alcanzar a [rebecca.n] justo a tiempo."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:91
translate spanish dressrosa_h11_e467f141:

    # player "[rebecca.n]!!!"
    player "[rebecca.n]!!!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:95
translate spanish dressrosa_h11_bd249d94:

    # rebecca "!!!"
    rebecca "!!!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:96
translate spanish dressrosa_h11_6e9a6f59:

    # rebecca "[player.n] It's great to see you safe! I saw your last fight, you're really incredible..."
    rebecca "[player.n] ¡Qué bueno verte a salvo! Vi tu última pelea, eres increíble..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:97
translate spanish dressrosa_h11_2b3254d9:

    # player "Heh thanks, I'm glad to see you're alright too, looks like I made it in time."
    player "Jeje, gracias, me alegro de ver que estás bien también, parece que llegué a tiempo."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:98
translate spanish dressrosa_h11_8d58f8cc:

    # rebecca "In time for what?"
    rebecca "¿A tiempo para qué?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:99
translate spanish dressrosa_h11_35e5d0a3:

    # player "You're about to fight, right... I was asked to talk to you and make you reconsider..."
    player "Estás a punto de pelear, ¿verdad? Me pidieron que hablara contigo y te hiciera reconsiderar..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:100
translate spanish dressrosa_h11_e020e03e:

    # player "It's not something I'd normally say, but I understand the old man..."
    player "No es algo que normalmente diría, pero entiendo al anciano..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:101
translate spanish dressrosa_h11_54d64e8b:

    # player "You need to stop, don't face your next opponent..."
    player "Tienes que parar, no te enfrentes a tu próximo oponente..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:102
translate spanish dressrosa_h11_bd249d94_1:

    # rebecca "!!!"
    rebecca "!!!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:103
translate spanish dressrosa_h11_456fbf57:

    # rebecca "You know very well I can't do that..."
    rebecca "Sabes muy bien que no puedo hacer eso..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:104
translate spanish dressrosa_h11_06c60f8a:

    # player "I know, and you know I'm not the one who'd try to stop you..."
    player "Lo sé, y tú sabes que no soy yo quien intentaría detenerte..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:105
translate spanish dressrosa_h11_e7e6a25b:

    # rebecca "Hehe... I don't know you much, but I understand what kind of person you are... I know this isn't your idea..."
    rebecca "Jeje... No te conozco mucho, pero entiendo qué tipo de persona eres... Sé que esta no es tu idea..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:106
translate spanish dressrosa_h11_7f7ca45d:

    # rebecca "Alright then, tell me... Who asked you to do that?"
    rebecca "Bueno entonces dime... ¿Quién te pidió que hicieras eso?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:107
translate spanish dressrosa_h11_4b2b99a0:

    # player "An old gladiator... [riku.n]!"
    player "Un viejo gladiador...[riku.n]!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:108
translate spanish dressrosa_h11_f7bb51a8:

    # rebecca "[riku.n]?? I don't know anyone by that name... And besides, I know every gladiator here..."
    rebecca "[riku.n]?? No conozco a nadie con ese nombre... Y además, conozco a todos los gladiadores de aquí..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:109
translate spanish dressrosa_h11_4307a4a2:

    # rebecca "I've been here for years, and there's no one who goes by that name..."
    rebecca "Llevo aquí años y no hay nadie que lleve ese nombre..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:110
translate spanish dressrosa_h11_6fc7e91b:

    # rebecca "It's pretty strange, I haven't seen him in the locker rooms either..."
    rebecca "Es bastante extraño, tampoco lo he visto en los vestuarios..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:111
translate spanish dressrosa_h11_2aed399d:

    # player "Well... that does surprise me..."
    player "Bueno... eso me sorprende..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:112
translate spanish dressrosa_h11_c716aeec:

    # player "He talked like he was close to you..."
    player "Hablaba como si estuviera cerca de ti..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:113
translate spanish dressrosa_h11_cdb983c8:

    # rebecca "Heh... Well, that doesn't matter, because my answer wouldn't have changed anyway..."
    rebecca "Jeje... Bueno, eso no importa, porque de todos modos mi respuesta no habría cambiado..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:114
translate spanish dressrosa_h11_9bbf8b3c:

    # rebecca "I've already told you, [Dressrosa.n] is wrapped in a cold darkness that's slowly devouring the nation..."
    rebecca "Ya os lo he dicho, [Dressrosa.n] está envuelto en una oscuridad fría que poco a poco va devorando a la nación..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:115
translate spanish dressrosa_h11_48c54790:

    # rebecca "There's little time left before the last of us still fighting finally fall..."
    rebecca "Queda poco tiempo antes de que el último de nosotros que aún luchamos finalmente caiga..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:116
translate spanish dressrosa_h11_b8d37f95:

    # rebecca "There are many others like me who are sacrificing themselves to save [Dressrosa.n]... And to save ourselves..."
    rebecca "Hay muchos otros como yo que se están sacrificando para salvar [Dressrosa.n]... Y para salvarnos a nosotros mismos..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:117
translate spanish dressrosa_h11_40da1ec3:

    # rebecca "I can't let them down now... I have to win and obtain the [HanaHanaFruit.n]..."
    rebecca "No puedo defraudarlos ahora... Tengo que ganar y obtener el [HanaHanaFruit.n]..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:118
translate spanish dressrosa_h11_53a7b154:

    # rebecca "Become stronger and defeat [donflamingo.n]"
    rebecca "Hazte más fuerte y vence [donflamingo.n]"

