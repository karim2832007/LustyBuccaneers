# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:6
translate spanish dressrosa_h17_if_aa88d53e:

    # player "The last fight left me feeling a bit tired. I should recover some energy before the battle."
    player "La última pelea me dejó un poco cansado. Debería recuperar energías antes de la batalla."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:8
translate spanish dressrosa_h17_if_f2ab3f85:

    # player "The last fight wounded me. It would be a good idea to eat something before the final battle and regain my strength."
    player "La última pelea me hirió. Sería buena idea comer algo antes de la batalla final y recuperar fuerzas."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:14
translate spanish dressrosa_h17_if_136bef6b:

    # player "([diamante.n] is a pretty powerful enemy. Even if I have {outlinecolor=#a85d74}{color=#ffffff}Haki{/color}{/outlinecolor}, I should train my strength more.)"
    player "([diamante.n] es un enemigo bastante poderoso. Incluso si tengo {outlinecolor=#a85d74}{color=#ffffff}Haki{/color}{/outlinecolor}, debería entrenar más mi fuerza.)"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:21
translate spanish dressrosa_h17_if_2a24203a:

    # player "(Among the last fighters, I've heard rumors about an ability called {outlinecolor=#a85d74}{color=#ffffff}Haki{/color}{/outlinecolor})"
    player "(Entre los últimos luchadores, he escuchado rumores sobre una habilidad llamada {outlinecolor=#a85d74}{color=#ffffff}Haki{/color}{/outlinecolor})"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:22
translate spanish dressrosa_h17_if_8f6b52b5:

    # player "(Maybe before fighting, I should investigate that a bit more...)"
    player "(Quizás antes de pelear, debería investigar eso un poco más...)"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:23
translate spanish dressrosa_h17_if_03bf1381:

    # player "(I should stop by the Shell Town bar to get some information about it)"
    player "(Debería pasar por el bar Shell Town para obtener algo de información al respecto)"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:26
translate spanish dressrosa_h17_if_0f7dacc1:

    # player "(I should continue training with old [rayleigh.n] in Shell Town)"
    player "(Debería seguir entrenando con el viejo [rayleigh.n] en Shell Town)"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:29
translate spanish dressrosa_h17_if_93d4990a:

    # narrador "Are you sure you want to start the fight?" nointeract
    narrador "¿Estás seguro que deseas iniciar la pelea?" nointeract

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:35
translate spanish dressrosa_h17_if_14a845e2:

    # player "(I can still prepare a bit more before fighting...)"
    player "(Aún puedo prepararme un poco más antes de pelear...)"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:36
translate spanish dressrosa_h17_if_a53cca3b:

    # player "(I'll come back later)"
    player "(Volveré más tarde)"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:50
translate spanish dressrosa_h17_daf5c4aa:

    # gatz "{size=40}Weeeeeeeeeelcome back, ladies and gentlemen, toys and dolls!{/size}"
    gatz "{size=40}¡Bienvenid@s de nuevo, damas y caballeros, juguetes y muñecas!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:51
translate spanish dressrosa_h17_26246797:

    # gatz "{size=40}Welcome everyone once again to the Corrida Coliseum!{/size}"
    gatz "{size=40}¡Bienvenidos a todos una vez más al Coliseo Corrida!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:57
translate spanish dressrosa_h17_cfe4495f:

    # gatz "After a series of breathtaking battles, bone-crushing blows, and roaring crowd chants..."
    gatz "Después de una serie de batallas impresionantes, golpes aplastantes y cánticos de multitud rugientes..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:58
translate spanish dressrosa_h17_dca7d3ce:

    # gatz "We have finally arrived at the moment you've all been waiting for!"
    gatz "¡Por fin hemos llegado al momento que todos estabais esperando!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:59
translate spanish dressrosa_h17_bde525c0:

    # gatz "{size=40}The GRAND FINALE of the Corrida Coliseum Tournament!{/size}"
    gatz "{size=40}¡La GRAN FINAL del Torneo Corrida Coliseum!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:61
translate spanish dressrosa_h17_4e091e32:

    # gatz "Only one will claim the ultimate glory..."
    gatz "Sólo uno podrá obtener la gloria máxima..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:62
translate spanish dressrosa_h17_74c715f1:

    # gatz "Only one will walk away holding the mysterious and coveted prize..."
    gatz "Sólo uno saldrá con el misterioso y codiciado premio..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:63
translate spanish dressrosa_h17_c267b85f:

    # gatz "The legendary, {outlinecolor=#a85d74}{color=#ffc0cb}Hana Hana Fruit!{/color}{/outlinecolor}!"
    gatz "¡La legendaria {outlinecolor=#a85d74}{color=#ffc0cb}Fruta Hana Hana!{/color}{/outlinecolor}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:64
translate spanish dressrosa_h17_2cdb6128:

    # gatz "The Devil Fruit of blossoming limbs! A power so rare... so deliciously dangerous..."
    gatz "¡La Fruta del Diablo de las ramas florecientes! Un poder tan raro... tan deliciosamente peligroso..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:65
translate spanish dressrosa_h17_e3e083be:

    # gatz "It will belong to ONE of these two incredible fighters!"
    gatz "¡Pertenecerá a UNO de estos dos increíbles luchadores!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:68
translate spanish dressrosa_h17_7249133a:

    # gatz "Standing in the left corner, with the swagger of a champion and a heart that never quits..."
    gatz "De pie en la esquina izquierda, con la arrogancia de un campeón y un corazón que nunca se rinde..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:69
translate spanish dressrosa_h17_e0949867:

    # gatz "The underdog who silenced giants, turned heads, and stole the crowd's hearts!"
    gatz "¡El desvalido que silenció a los gigantes, llamó la atención y se robó los corazones de la multitud!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:70
translate spanish dressrosa_h17_a3e3a32f:

    # gatz "Give it up for the crowd's new favorite, [player.n]!!!!"
    gatz "¡Un aplauso para el nuevo favorito del público, [player.n]!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:72
translate spanish dressrosa_h17_3398aa7c:

    # unknown "{size=40}[player.n]!! [player.n]!! [player.n]!!{/size}"
    unknown "{size=40}[player.n]!! [player.n]!! [player.n]!!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:74
translate spanish dressrosa_h17_c7c821a0:

    # gatz "And in the right corner..."
    gatz "Y en la esquina derecha..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:75
translate spanish dressrosa_h17_e98e994a:

    # gatz "The man who needs no introduction..."
    gatz "El hombre que no necesita presentación..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:76
translate spanish dressrosa_h17_651cdb65:

    # gatz "A member of the elite Donquixote Family!"
    gatz "¡Un miembro de la élite de la familia Donquixote!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:77
translate spanish dressrosa_h17_bc8e0bb7:

    # gatz "The Hero of the Arena! The Flagbearer of Destruction!"
    gatz "¡El héroe de la arena! ¡El abanderado de la destrucción!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:78
translate spanish dressrosa_h17_f813474b:

    # gatz "The living embodiment of cruelty and spectacle..."
    gatz "La encarnación viviente de la crueldad y el espectáculo..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:79
translate spanish dressrosa_h17_70dff5c2:

    # gatz "Make way for the one and only... {size=40}{outlinecolor=#8b0000}{color=#ff6666}Diamanteeeeeeee{/color}{/outlinecolor}!{/size}"
    gatz "Abran paso al único e inigualable... {size=40}{outlinecolor=#8b0000}{color=#ff6666}¡Diamanteeeeeeee{/color}{/outlinecolor}!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:81
translate spanish dressrosa_h17_dceb7ff5:

    # unknown "{size=40}[diamante.n]!! [diamante.n]!! [diamante.n]!!{/size}"
    unknown "{size=40}[diamante.n]!! [diamante.n]!! [diamante.n]!!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:88
translate spanish dressrosa_h17_7c08e8f0:

    # gatz "Diamante has been undefeated in the ring for years!"
    gatz "¡Diamante ha estado invicto en el ring durante años!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:89
translate spanish dressrosa_h17_18d4cd09:

    # gatz "His swordplay? Deadly. His cape? Unpredictable. His cruelty? Unmatched!"
    gatz "¿Su manejo de la espada? Mortal. ¿Su capa? Impredecible. ¿Su crueldad? ¡Inigualable!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:90
translate spanish dressrosa_h17_8914efc6:

    # gatz "He represents not just power, but the iron rule of the Donquixote Family!"
    gatz "¡Él representa no sólo el poder, sino el gobierno de hierro de la familia Donquixote!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:91
translate spanish dressrosa_h17_9a51d2b0:

    # gatz "And tonight... he faces a new challenger."
    gatz "Y esta noche... se enfrenta a un nuevo retador."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:92
translate spanish dressrosa_h17_1778583e:

    # gatz "One who's climbed through the ranks, torn through warriors, and earned every drop of applause!"
    gatz "¡Alguien que ha ascendido en las filas, ha arrasado entre guerreros y se ha ganado cada gota de aplauso!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:93
translate spanish dressrosa_h17_5f3408c6:

    # gatz "{size=40}Tonight is the night legends are written in blood and glory!{/size}"
    gatz "{size=40}¡Esta noche es la noche en que las leyendas se escriben con sangre y gloria!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:95
translate spanish dressrosa_h17_80c296a8:

    # gatz "And what's more..."
    gatz "Y lo que es más..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:96
translate spanish dressrosa_h17_bf9244ba:

    # gatz "The winner won't just walk away with the Hana Hana no Mi..."
    gatz "El ganador no sólo se irá con la Hana Hana no Mi..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:97
translate spanish dressrosa_h17_603df856:

    # gatz "They will have proven themselves worthy of standing atop this coliseum's brutal legacy!"
    gatz "¡Habrán demostrado que son dignos de estar en la cima del brutal legado de este coliseo!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:98
translate spanish dressrosa_h17_f7df17d0:

    # gatz "This isn't just a fight... it's a moment carved into the history of [Dressrosa.n]!"
    gatz "Esto no es sólo una pelea... ¡es un momento grabado en la historia de [Dressrosa.n]!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:100
translate spanish dressrosa_h17_dc968328:

    # gatz "Let the ground tremble under the weight of your will!"
    gatz "¡Deja que la tierra tiemble bajo el peso de tu voluntad!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:101
translate spanish dressrosa_h17_bb151a2c:

    # gatz "Let steel clash, let pain sing—this is your final test, warriors!"
    gatz "Dejad que el acero choque, dejad que el dolor cante: ¡ésta es vuestra prueba final, guerreros!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:105
translate spanish dressrosa_h17_35fe23f6:

    # diamante "So... you're the little star everyone's been cheering for..."
    diamante "Entonces... eres la pequeña estrella que todos han estado animando..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:106
translate spanish dressrosa_h17_3839d2cd:

    # narrador "Without continuing what he was saying, [diamante.n] stops and watches you for a moment... Noticing something that wasn't part of his plans."
    narrador "Sin continuar lo que decía, [diamante.n] se detiene y te observa por un momento... Notando algo que no estaba dentro de sus planes."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:107
translate spanish dressrosa_h17_54171a8a:

    # diamante "What the...?! You're still standing?!"
    diamante "¡¿Qué...?! ¡¿Sigues en pie?!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:108
translate spanish dressrosa_h17_4179b52c:

    # diamante "You should be half-dead after that little 'surprise' backstage..."
    diamante "Deberías estar medio muerto después de esa pequeña \"sorpresa\" detrás del escenario..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:109
translate spanish dressrosa_h17_ffd0a098:

    # player "Yeah... someone forgot to tell your goons I'm allergic to cheap tricks."
    player "Sí... alguien se olvidó de decirles a tus matones que soy alérgico a los trucos baratos."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:110
translate spanish dressrosa_h17_7e787108:

    # diamante "Tch... those imbeciles promised you'd be broken before stepping in here."
    diamante "Tch... esos imbéciles te prometieron que estarías destrozado antes de entrar aquí."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:111
translate spanish dressrosa_h17_7733ecaf:

    # player "Well, I stepped in, stretched a bit, and now I'm warmed up for *you*."
    player "Bueno, entré, me estiré un poco y ahora estoy calentado para *ti*."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:112
translate spanish dressrosa_h17_d5554017:

    # diamante "Heh... cocky till the end. I admire that... in a corpse."
    diamante "Je... arrogante hasta el final. Admiro eso... en un cadáver."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:113
translate spanish dressrosa_h17_a52814c5:

    # player "Better get used to disappointment, shiny boy."
    player "Será mejor que te acostumbres a la decepción, muchacho brillante."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:114
translate spanish dressrosa_h17_496765eb:

    # diamante "Damn it... I'm surrounded by incompetents!"
    diamante "Maldita sea... ¡Estoy rodeado de incompetentes!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:115
translate spanish dressrosa_h17_01e4292e:

    # diamante "If you want something done right... you do it yourself!"
    diamante "Si quieres que algo se haga bien... ¡hazlo tú mismo!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:116
translate spanish dressrosa_h17_bfcfc5e2:

    # player "Finally something smart came out of your mouth."
    player "Por fin salió algo inteligente de tu boca."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:117
translate spanish dressrosa_h17_164f050c:

    # diamante "Uhahahaha! I've crushed tougher men than you while fixing my hair in the reflection of my sword."
    diamante "¡Jajajaja! He aplastado a hombres más duros que tú mientras me arreglaba el pelo con el reflejo de mi espada."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:118
translate spanish dressrosa_h17_b72033f5:

    # player "Guess I'll be the first to mess up that pretty reflection then."
    player "Supongo que seré el primero en estropear ese bonito reflejo."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:119
translate spanish dressrosa_h17_f3d0430c:

    # diamante "Big words for a nobody. Do you even understand who you're talking to?"
    diamante "Palabras mayores para un don nadie. ¿Entiendes siquiera con quién estás hablando?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:120
translate spanish dressrosa_h17_31021f47:

    # player "The clown standing between me and the Hana Hana no Mi? Yeah, I got that part."
    player "¿El payaso que se interpone entre la fruta Hana Hana y yo? Sí, ya entendí esa parte."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:121
translate spanish dressrosa_h17_9e1a5198:

    # diamante "You're in way over your head, rookie. This ring is MY kingdom."
    diamante "Estás en un lío que te supera, novato. Este ring es MI reino."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:122
translate spanish dressrosa_h17_18a45ec6:

    # diamante "I'm not just a gladiator. I am the standard of pain. The art of torment!"
    diamante "No soy solo un gladiador. Soy el estandarte del dolor. ¡El arte del tormento!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:123
translate spanish dressrosa_h17_70b307bc:

    # player "You talk a lot. Maybe if you screamed that at [donflamingo.n] loud enough, he'd finally respect you."
    player "Hablas mucho. Quizás si le gritaras eso a [donflamingo.n] lo suficientemente fuerte, por fin te respetaría."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:124
translate spanish dressrosa_h17_83f4d5e1:

    # diamante "You insolent brat... You DARE speak his name like that?"
    diamante "¡Mocoso insolente! ¿Te atreves a pronunciar su nombre así?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:125
translate spanish dressrosa_h17_654bc5f0:

    # player "I'll speak it again after I defeat you... and tear down everything you stand for."
    player "Lo diré de nuevo después de derrotarte... y derribar todo lo que representas."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:126
translate spanish dressrosa_h17_9d054834:

    # diamante "This isn't some fairytale, you fool. People like you don't win in real life."
    diamante "Esto no es un cuento de hadas, tonto. La gente como tú no gana en la vida real."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:127
translate spanish dressrosa_h17_c4d3ae3a:

    # player "Then maybe it's time to rewrite the ending."
    player "Entonces tal vez sea hora de reescribir el final."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:128
translate spanish dressrosa_h17_bbd811f8:

    # diamante "Oh? Planning to be the hero now?"
    diamante "¿Ah, sí? ¿Planeas ser el héroe ahora?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:129
translate spanish dressrosa_h17_f9b73e6b:

    # player "No. Just the guy who knocks your teeth out in front of thousands."
    player "No. Sólo el tipo que te deja sin dientes delante de miles de personas."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:130
translate spanish dressrosa_h17_98f05f0f:

    # diamante "You're making a huge mistake... This arena is built to glorify warriors like ME!"
    diamante "Estás cometiendo un gran error... ¡Esta arena está construida para glorificar a guerreros como YO!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:131
translate spanish dressrosa_h17_1550992e:

    # player "Then tonight it's under construction, cause I'm about to wreck everything."
    player "Entonces esta noche está en construcción, porque estoy a punto de arruinarlo todo."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:132
translate spanish dressrosa_h17_131dafa4:

    # diamante "You're confident. I'll give you that. Arrogance makes your fall even more satisfying."
    diamante "Tienes confianza. Te lo concedo. La arrogancia hace que tu caída sea aún más satisfactoria."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:133
translate spanish dressrosa_h17_977c257b:

    # player "I'm not here for satisfaction. I'm here to win."
    player "No estoy aquí para la satisfacción. Estoy aquí para ganar."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:134
translate spanish dressrosa_h17_5d356978:

    # diamante "Let's see if you still talk that big after I make you crawl."
    diamante "Veamos si sigues hablando tan grande después de que te haga gatear."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:135
translate spanish dressrosa_h17_f1fb6d38:

    # player "Let's see if you still smirk after you taste the dirt."
    player "Veamos si todavía sonríes después de probar la tierra."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:139
translate spanish dressrosa_h17_84b9b280:

    # gatz "Well... It seems everything has been said... The contenders are about to face each other..."
    gatz "Bueno... Parece que todo está dicho... Los contendientes están a punto de enfrentarse..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:140
translate spanish dressrosa_h17_b8bcba0a:

    # gatz "[player.n]! [diamante.n]!"
    gatz "[player.n]! [diamante.n]!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:141
translate spanish dressrosa_h17_26626969:

    # gatz "Give the crowd a show they'll never forget!"
    gatz "¡Ofrécele al público un espectáculo que nunca olvidarán!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:142
translate spanish dressrosa_h17_a660ece8:

    # gatz "{size=40}Crowd, are you ready?!{/size}"
    gatz "{size=40}¡Multitud, ¿están listos?!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:143
translate spanish dressrosa_h17_88031e87:

    # gatz "Let's count it down together!"
    gatz "¡Hagamos una cuenta regresiva juntos!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:144
translate spanish dressrosa_h17_c42e5fc0:

    # gatz "{size=40}THREE!!{/size}"
    gatz "{size=40}¡¡TRES!!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:145
translate spanish dressrosa_h17_d5a4731d:

    # gatz "{size=40}TWO!!{/size}"
    gatz "{size=40}¡DOS!!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:146
translate spanish dressrosa_h17_f9d375f0:

    # gatz "{size=40}ONE!!{/size}"
    gatz "{size=40}¡¡UNO!!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:147
translate spanish dressrosa_h17_8d46ace2:

    # gatz "{size=40}FIGHTTTTTTTTTTTTTTT!!!{/size}"
    gatz "{size=40}¡¡¡LUCHAAAAAAAAAAAAA!!!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:152
translate spanish dressrosa_h17_173d7443:

    # diamante "Urgh... This... can't be..."
    diamante "Urgh... Esto... no puede ser..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:153
translate spanish dressrosa_h17_9b99fcfb:

    # diamante "How did a no-name... beat me?!"
    diamante "¿Cómo pudo un desconocido... vencerme?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:154
translate spanish dressrosa_h17_5596033c:

    # diamante "You're nothing but a street rat with lucky punches..."
    diamante "No eres más que una rata callejera con golpes de suerte..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:155
translate spanish dressrosa_h17_e2767c7b:

    # diamante "Doffy... forgive me..."
    diamante "Doffy... perdóname..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:157
translate spanish dressrosa_h17_dfef80cc:

    # diamante "Tch... this arena... no longer deserves my elegance..."
    diamante "Tch... esta arena... ya no merece mi elegancia..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:169
translate spanish dressrosa_h17_7cecf841:

    # gatz "{size=40}UNBELIEVABLE!! IT'S OVER!!!{/size}"
    gatz "{size=40}¡INCREÍBLE! ¡SE ACABÓ!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:170
translate spanish dressrosa_h17_50ec9d53:

    # gatz "Ladies and gentlemen, hold onto your seats!"
    gatz "Damas y caballeros, ¡agárrense a sus asientos!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:171
translate spanish dressrosa_h17_e4ce770b:

    # gatz "The undefeated champion of the Corrida Colosseum has fallen!"
    gatz "¡El campeón invicto de la Corrida Coliseum ha caído!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:172
translate spanish dressrosa_h17_79093c2b:

    # gatz "{size=40}[diamante.n]... has been DEFEATED!!{/size}"
    gatz "{size=40}[diamante.n]... ¡ha sido DERROTADO!!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:173
translate spanish dressrosa_h17_ff9532e2:

    # gatz "And rising from the dust of combat, emerging as the true warrior of [Dressrosa.n]..."
    gatz "Y surgiendo del polvo del combate, emergiendo como el verdadero guerrero de [Dressrosa.n]..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:174
translate spanish dressrosa_h17_de9fa906:

    # gatz "We have a NEW champion!! A name we will never forget..."
    gatz "¡Tenemos un NUEVO campeón! Un nombre que jamás olvidaremos..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:175
translate spanish dressrosa_h17_d655c020:

    # gatz "{size=40}Give it up for the one... the only... [player.n]!!!{/size}"
    gatz "{size=40}¡Dale un aplauso al único... al único... [player.n]!!!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:176
translate spanish dressrosa_h17_03815cbb:

    # gatz "From unknown contender to living legend, this fighter has conquered every obstacle!"
    gatz "De contendiente desconocido a leyenda viviente, ¡este luchador ha conquistado todos los obstáculos!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:177
translate spanish dressrosa_h17_a05f8947:

    # gatz "From the shadows of obscurity to the very top of the arena!"
    gatz "¡De las sombras de la oscuridad a lo más alto de la arena!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:178
translate spanish dressrosa_h17_ab77132b:

    # gatz "No trick, no trap, no tyrant could stop him!"
    gatz "¡Ningún truco, ninguna trampa, ningún tirano podría detenerlo!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:179
translate spanish dressrosa_h17_eec16788:

    # gatz "And now, the coveted prize... the {outlinecolor=#a85d74}{color=#ffc0cb}Hana Hana Fruit!{/color}{/outlinecolor}..."
    gatz "Y ahora, el codiciado premio... ¡la {outlinecolor=#a85d74}{color=#ffc0cb}Fruta Hana Hana!{/color}{/outlinecolor}..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:180
translate spanish dressrosa_h17_760e3430:

    # gatz "Will be officially awarded to [player.n] at the administration office shortly after this match!"
    gatz "¡El premio se entregará oficialmente a [player.n] en la oficina de administración poco después de este partido!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:181
translate spanish dressrosa_h17_e8472bdb:

    # gatz "But that's not all, folks!"
    gatz "¡Pero eso no es todo, amigos!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:182
translate spanish dressrosa_h17_99accd3c:

    # gatz "A press conference will be held after the ceremony to celebrate this monumental victory!"
    gatz "¡Después de la ceremonia se celebrará una conferencia de prensa para celebrar esta monumental victoria!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:183
translate spanish dressrosa_h17_377c8726:

    # gatz "[Dressrosa.n], let the cheers echo across the island — your new hero has arrived!!"
    gatz "[Dressrosa.n] ¡Que los vítores resuenen en toda la isla! ¡Tu nuevo héroe ha llegado!"

translate spanish strings:

    # game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:28
    old "Yes, I'm ready to fight."
    new "Sí, estoy listo para luchar."

    # game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:28
    old "No, I need more time to prepare."
    new "No, necesito más tiempo para prepararme."

