# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:10
translate spanish dressrosa_h14_124d1b06:

    # rebecca "[player.n]!!!"
    rebecca "[player.n]!!!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:11
translate spanish dressrosa_h14_ab931a51:

    # rebecca "You... you're back! And in one piece!"
    rebecca "¡Has vuelto! ¡Y de una pieza!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:13
translate spanish dressrosa_h14_b1feba97:

    # rebecca "How are you?! Are you hurt?! Let me check you..."
    rebecca "¿Cómo estás? ¿Te lastimaste? Déjame revisarte..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:14
translate spanish dressrosa_h14_f226b694:

    # player "Don't worry, I'm fine hahaha. Didn't you see the fight?"
    player "No te preocupes, estoy bien jajaja. ¿No viste la pelea?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:19
translate spanish dressrosa_h14_f0f82122:

    # rebecca "I... I still can't believe how easily you defeated [logan.n] out there."
    rebecca "Yo... yo todavía no puedo creer lo fácil que fue derrotar a [logan.n] ahí afuera."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:20
translate spanish dressrosa_h14_6d308380:

    # rebecca "He was one of the most feared fighters in the Colosseum, but you beat him like it was nothing..."
    rebecca "Era uno de los luchadores más temidos del Coliseo, pero lo venciste como si fuera nada..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:21
translate spanish dressrosa_h14_a38e5b29:

    # rebecca "You were so brave... So determined... And ruthless... You didn't give him any chance... I liked how you handled him at the end..."
    rebecca "Fuiste tan valiente... Tan decidido... Y despiadado... No le diste ninguna oportunidad... Me gustó cómo lo manejaste al final..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:22
translate spanish dressrosa_h14_8399708e:

    # player "Haha, all of that was for you..."
    player "Jaja, todo eso fue para ti..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:23
translate spanish dressrosa_h14_1e63b009:

    # rebecca "..."
    rebecca "..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:25
translate spanish dressrosa_h14_6cc3cecc:

    # rebecca "In my fight..."
    rebecca "En mi lucha..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:26
translate spanish dressrosa_h14_78b7901f:

    # rebecca "In my fight, everyone was cheering for him to kill me... I felt so alone."
    rebecca "En mi pelea todos lo animaban a matarme... Me sentí tan sola."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:30
translate spanish dressrosa_h14_4efea117:

    # player "Hey... It's okay. Come here."
    player "Oye... Está bien. Ven aquí."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:31
translate spanish dressrosa_h14_c53c8227:

    # narrador "You gently pull [rebecca.n] into a warm embrace."
    narrador "Atraes suavemente a [rebecca.n] hacia un cálido abrazo."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:32
translate spanish dressrosa_h14_a96fe5f7:

    # player "You're not alone anymore, [rebecca.n]. I promise."
    player "Ya no estás solo, [rebecca.n]. Te lo prometo."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:33
translate spanish dressrosa_h14_9a6f1c73:

    # rebecca "*sniff* Th-Thank you... I..."
    rebecca "*sniff* Gra-gracias... Yo..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:36
translate spanish dressrosa_h14_632aef7a:

    # narrador "[rebecca.n] love +2"
    narrador "[rebecca.n] amor +2"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:39
translate spanish dressrosa_h14_5c4fdb90:

    # player "Listen to me, [rebecca.n]. We will defeat [donflamingo.n]!"
    player "Escúchame, [rebecca.n]. ¡Derrotaremos a [donflamingo.n]!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:40
translate spanish dressrosa_h14_7f64d48f:

    # player "I swear I'll protect you and [Dressrosa.n], no matter what."
    player "Juro que te protegeré a ti y a [Dressrosa.n], pase lo que pase."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:41
translate spanish dressrosa_h14_813de1f4:

    # narrador "You place a steady hand on her shoulder, looking into her eyes with resolve."
    narrador "Colocas una mano firme sobre su hombro y la miras a los ojos con determinación."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:42
translate spanish dressrosa_h14_82493f5e:

    # player "You're not alone in this fight anymore."
    player "Ya no estás solo en esta lucha."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:43
translate spanish dressrosa_h14_f7c283e8:

    # rebecca "*sniff* O-Okay... I trust you..."
    rebecca "*sniff* E-Está bien... Confío en ti..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:46
translate spanish dressrosa_h14_1d76915e:

    # narrador "[rebecca.n] love +1"
    narrador "[rebecca.n] amor +1"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:48
translate spanish dressrosa_h14_a16d8e60:

    # rebecca "You don't know how much that means to me."
    rebecca "No sabes lo mucho que eso significa para mí."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:49
translate spanish dressrosa_h14_aa346b0c:

    # player "I meant every word."
    player "Quise decir cada palabra."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:52
translate spanish dressrosa_h14_43ad5b38:

    # rebecca "I-I'm sorry... I just... I wanted to..."
    rebecca "Lo siento... Solo... Quería..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:53
translate spanish dressrosa_h14_24e2b2cd:

    # player "Hey, don't apologize. You have nothing to be sorry for."
    player "Oye, no te disculpes. No tienes nada de qué disculparte."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:54
translate spanish dressrosa_h14_30f93a90:

    # player "To be honest... I've been wanting to say that for a long time too."
    player "Para ser honesto... yo también he querido decir eso durante mucho tiempo."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:57
translate spanish dressrosa_h14_517937ba:

    # rebecca "You... you did?"
    rebecca "¿Lo hiciste?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:58
translate spanish dressrosa_h14_77a4ba06:

    # player "Ever since we fought side by side in that colosseum... every time you smiled at me after a tough battle, every time you trusted me when everything seemed lost..."
    player "Desde que luchamos codo con codo en aquel coliseo... cada vez que me sonreíste después de una dura batalla, cada vez que confiaste en mí cuando todo parecía perdido..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:59
translate spanish dressrosa_h14_3464e1e6:

    # player "Those moments we shared, supporting each other through all the pain and fear... they meant everything to me."
    player "Esos momentos que compartimos, apoyándonos mutuamente a través de todo el dolor y el miedo... significaron todo para mí."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:60
translate spanish dressrosa_h14_cbe2a792:

    # player "You've become someone incredibly special, [rebecca.n]. More than just a friend, more than an ally."
    player "Te has convertido en alguien increíblemente especial, [rebecca.n]. Más que un amigo, más que un aliado."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:63
translate spanish dressrosa_h14_31c508c7:

    # rebecca "I... I feel the same way. When I was alone in the arena, I never thought I'd find someone who would fight for me the way you did."
    rebecca "Yo... yo siento lo mismo. Cuando estaba solo en la arena, nunca pensé que encontraría a alguien que luchara por mí como tú."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:64
translate spanish dressrosa_h14_285427fd:

    # rebecca "You gave me hope again. You made me feel safe... and cared for."
    rebecca "Me devolviste la esperanza. Me hiciste sentir segura... y cuidada."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:65
translate spanish dressrosa_h14_265be6b1:

    # rebecca "That's why I couldn't hold back just now. My heart wouldn't let me."
    rebecca "Por eso no pude contenerme ahora. Mi corazón no me lo permitió."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:66
translate spanish dressrosa_h14_e4771fc4:

    # player "And I don't regret a single second of it."
    player "Y no me arrepiento ni un solo segundo de ello."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:67
translate spanish dressrosa_h14_934e1953:

    # player "Holding you close like that... it felt right. It felt like something we've both been carrying inside for a while."
    player "Abrazarte así... se sintió bien. Era algo que ambos llevábamos dentro desde hacía tiempo."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:70
translate spanish dressrosa_h14_9f214e63:

    # rebecca "I'm so glad... It felt warm. It felt... nice. More than nice."
    rebecca "Me alegro tanto... Se sentía cálido. Se sentía... agradable. Más que agradable."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:72
translate spanish dressrosa_h14_1186d0b6:

    # narrador "We stand in silence for a moment, just looking at each other, the air between us soft and full of unspoken feelings."
    narrador "Nos quedamos en silencio por un momento, simplemente mirándonos, el aire entre nosotros suave y lleno de sentimientos tácitos."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:73
translate spanish dressrosa_h14_977fc527:

    # player "Before I have to go face the next fight..."
    player "Antes de tener que enfrentar la siguiente pelea..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:74
translate spanish dressrosa_h14_ec3d1a9c:

    # player "Could I ask for one small thing? Something to carry with me?"
    player "¿Podría pedir algo pequeño? ¿Algo para llevar conmigo?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:75
translate spanish dressrosa_h14_1e0b8038:

    # player "Maybe... a good luck kiss? Just one, from the girl who's become my reason to keep winning."
    player "Quizás... ¿un beso de buena suerte? Solo uno, de la chica que se ha convertido en mi razón para seguir ganando."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:78
translate spanish dressrosa_h14_b97ee563:

    # rebecca "A kiss... for luck?"
    rebecca "Un beso... ¿para la suerte?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:79
translate spanish dressrosa_h14_895520a5:

    # rebecca "I... I'd like that very much."
    rebecca "Me... me gustaría mucho eso."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:81
translate spanish dressrosa_h14_81038c98:

    # narrador "Smiling softly, her cheeks glowing with a tender blush, [rebecca.n] steps closer."
    narrador "Sonriendo suavemente, con sus mejillas brillando con un tierno rubor, [rebecca.n] se acerca más."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:82
translate spanish dressrosa_h14_a91074b0:

    # narrador "She rises slightly on her toes, places a gentle hand on your chest, and presses her warm lips to yours in a slow, loving kiss full of quiet affection and newfound courage."
    narrador "Ella se levanta ligeramente sobre las puntas de los pies, coloca una mano suave sobre tu pecho y presiona sus cálidos labios contra los tuyos en un beso lento y amoroso, lleno de afecto silencioso y coraje recién adquirido."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:83
translate spanish dressrosa_h14_a45bbda3:

    # narrador "When she pulls back, her eyes shine with emotion, and a small shy smile curves her lips."
    narrador "Cuando ella se aparta, sus ojos brillan de emoción y una pequeña sonrisa tímida curva sus labios."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:86
translate spanish dressrosa_h14_0137a1b9:

    # rebecca "Please... come back to me safe."
    rebecca "Por favor... regresa a mí sano y salvo."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:87
translate spanish dressrosa_h14_3e724bec:

    # player "I will. I promise."
    player "Lo haré. Lo prometo."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:90
translate spanish dressrosa_h14_80e49fbe:

    # rebecca "But..."
    rebecca "Pero..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:91
translate spanish dressrosa_h14_0c0f409e:

    # rebecca "But the fight's not over yet."
    rebecca "Pero la lucha aún no ha terminado."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:92
translate spanish dressrosa_h14_e466387b:

    # rebecca "The next round will be even tougher... and after that..."
    rebecca "La siguiente ronda será aún más difícil... y después de eso..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:93
translate spanish dressrosa_h14_a6e5ece1:

    # rebecca "Diamante will be there..."
    rebecca "Diamante estará allí..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:94
translate spanish dressrosa_h14_ec3bffaa:

    # rebecca "I thought if we won the [HanaHanaFruit.n] fruit, we could become strong enough to free [Dressrosa.n] from [donflamingo.n]."
    rebecca "Pensé que si ganábamos la fruta [HanaHanaFruit.n], podríamos volvernos lo suficientemente fuertes para liberar a [Dressrosa.n] de [donflamingo.n]."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:95
translate spanish dressrosa_h14_afa01713:

    # rebecca "But... I never imagined that idea would be so hard to carry out... Only now do I see just how much it really is..."
    rebecca "Pero... nunca imaginé que esa idea sería tan difícil de llevar a cabo... Sólo ahora veo lo mucho que realmente lo es..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:96
translate spanish dressrosa_h14_676bd67b:

    # player "I'm sorry, [rebecca.n]. I promise I'll win that Devil Fruit and use its power to defeat [donflamingo.n]."
    player "Lo siento, [rebecca.n]. Prometo que ganaré esa Fruta del Diablo y usaré su poder para derrotar a [donflamingo.n]."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:97
translate spanish dressrosa_h14_bcb8fc17:

    # rebecca "[donflamingo.n] is so powerful... the thought of facing him scares me. I can't bear to lose anyone else..."
    rebecca "[donflamingo.n] es tan poderoso... la idea de enfrentarlo me asusta. No soporto perder a nadie más..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:98
translate spanish dressrosa_h14_7998d711:

    # player "You won't, I promise. With you cheering me on, I feel like I can defeat anyone... even [donflamingo.n]."
    player "No lo harás, te lo prometo. Con tu apoyo, siento que puedo vencer a cualquiera... incluso a [donflamingo.n]."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:100
translate spanish dressrosa_h14_3d35ca31:

    # rebecca "Hahah... You... really mean that?"
    rebecca "Jajaja... ¿En serio quieres decir eso?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:101
translate spanish dressrosa_h14_56d90271:

    # player "Every word. Having you by my side gives me strength."
    player "Cada palabra. Tenerte a mi lado me da fuerza."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:102
translate spanish dressrosa_h14_4bd04fbb:

    # rebecca "Then I'll be there. I'll cheer for you, no matter what."
    rebecca "Entonces estaré allí. Te animaré, pase lo que pase."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:104
translate spanish dressrosa_h14_e3ffca69:

    # player "Now that we're talking about it... after cooling down from the fight, I'm starting to realize..."
    player "Ahora que estamos hablando de ello... después de enfriarme de la pelea, estoy empezando a darme cuenta..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:105
translate spanish dressrosa_h14_a59b7e93:

    # player "It was a tough one, though. My body's still buzzing with adrenaline."
    player "Pero fue duro. Mi cuerpo todavía vibra de adrenalina."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:107
translate spanish dressrosa_h14_3eccbe1a:

    # player "I could really use some... relaxation right now."
    player "Realmente me vendría bien un poco de… relajación ahora mismo."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:108
translate spanish dressrosa_h14_c66e78ea:

    # rebecca "What do you mean?"
    rebecca "¿Qué quieres decir?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:109
translate spanish dressrosa_h14_28992dea:

    # narrador "I let my gaze drop meaningfully to my waist, then back up to her eyes."
    narrador "Dejé que mi mirada cayera significativamente hacia mi cintura, luego volvía a sus ojos."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:111
translate spanish dressrosa_h14_6c4b5bbd:

    # player "We really are close by now... we've been through so many things... and you really do feel good with me, right?"
    player "Realmente estamos muy cerca ahora... hemos pasado por tantas cosas... y realmente te sientes bien conmigo, ¿verdad?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:113
translate spanish dressrosa_h14_3cfa2f9c:

    # rebecca "Ye... Yes.."
    rebecca "Sí... Sí.."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:114
translate spanish dressrosa_h14_eb3829d4:

    # player "Then... I can think of one perfect way you could help me unwind... as a victor's reward."
    player "Entonces... puedo pensar en una forma perfecta en la que podrías ayudarme a relajarme... como recompensa de un vencedor."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:116
translate spanish dressrosa_h14_3955f809:

    # rebecca "Y-you mean... With my... mouth?"
    rebecca "¿Te refieres a... Con mi... boca?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:118
translate spanish dressrosa_h14_5034e2b5:

    # player "Exactly!. You've already shown me how grateful you can be. One more time wouldn't hurt, right?"
    player "¡Exactamente! Ya me has demostrado lo agradecido que puedes estar. Una vez más no estaría mal, ¿verdad?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:119
translate spanish dressrosa_h14_05ac5f45:

    # rebecca "B-but... we're in the palace now. Anyone could walk in..."
    rebecca "P-pero... ya estamos en el palacio. Cualquiera podría entrar..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:120
translate spanish dressrosa_h14_68c7fd11:

    # rebecca "And I... I'm so embarrassed..."
    rebecca "Y yo...estoy tan avergonzada..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:121
translate spanish dressrosa_h14_f11d8ea4:

    # player "The door's locked. No one's coming. And You'll do amazing. Don't doubt yourself."
    player "La puerta está cerrada. No entra nadie. Y lo harás increíble. No dudes de ti mismo."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:122
translate spanish dressrosa_h14_547b61d3:

    # rebecca "I... I don't know if I can. My heart's pounding just thinking about it."
    rebecca "Yo... no sé si pueda. Me late el corazón con solo pensarlo."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:123
translate spanish dressrosa_h14_e4bcf165:

    # player "[rebecca.n], look at me."
    player "[rebecca.n], mírame."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:124
translate spanish dressrosa_h14_4ddc35d7:

    # player "I fought for you today. I won for you. All I'm asking is a little... personal celebration."
    player "Hoy luché por ti. Gané por ti. Solo te pido una pequeña... celebración personal."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:125
translate spanish dressrosa_h14_ac5440d9:

    # player "Just between us. It'll be our secret."
    player "Solo entre nosotros. Será nuestro secreto."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:127
translate spanish dressrosa_h14_d58d792d:

    # narrador "She bites her lip, glancing away, then back at me. Her hands fidget at her sides."
    narrador "Se muerde el labio, aparta la mirada y luego vuelve a mirarme. Sus manos se mueven nerviosamente a los costados."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:129
translate spanish dressrosa_h14_7fdc56f3:

    # rebecca "I do want to reward you properly... You deserve it more than anyone."
    rebecca "Quiero recompensarte como es debido... Te lo mereces más que nadie."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:130
translate spanish dressrosa_h14_8bde68f4:

    # rebecca "It's just... I... I don't have much experience at all."
    rebecca "Es solo que... yo... yo no tengo mucha experiencia en absoluto."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:131
translate spanish dressrosa_h14_160ada88:

    # player "That's fine. I'll guide you... I know you'll learn quickly."
    player "Está bien. Te guiaré... Sé que aprenderás rápido."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:132
translate spanish dressrosa_h14_f99bd7e0:

    # narrador "She slowly drops to her knees in front of me, face burning red, eyes fixed on the floor at first."
    narrador "Ella cae lentamente de rodillas frente a mí, con el rostro rojo ardiendo y los ojos fijos en el suelo al principio."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:137
translate spanish dressrosa_h14_a6134bbf:

    # player "[rebecca.n]... after everything we've been through together, just looking at you fills my heart with warmth."
    player "[rebecca.n]... después de todo lo que hemos pasado juntos, sólo mirarte llena mi corazón de calidez."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:138
