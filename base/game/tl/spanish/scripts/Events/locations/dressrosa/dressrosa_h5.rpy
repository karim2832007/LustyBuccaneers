translate spanish dressrosa_h5_d16b4598:

    # player "Aaaaaahhh... What's wrong with you, you're scary!"
    player "Aaaaaahhh... ¿Qué te pasa? ¡Das miedo!"

# game/scripts/Events/locations/dressrosa/dressrosa_h5.rpy:181
translate spanish dressrosa_h5_aad035b9:

    # guard "Hey you, stop right there, grab him so he doesn't start a fight!!"
    guard "¡Oye tú, detente ahí, agárralo para que no empiece una pelea!"

# game/scripts/Events/locations/dressrosa/dressrosa_h5.rpy:182
translate spanish dressrosa_h5_02bd2fd2:

    # sai "{size=40}Don't thank me, idiot!!!!{/size}"
    sai "{size=40}¡¡¡No me agradezcas, idiota!!!{/size}"

# game/scripts/Events/locations/dressrosa/dressrosa_h5.rpy:184
translate spanish dressrosa_h5_67583951:

    # rebecca "Hey you, kid, come here quickly... Let's go!"
    rebecca "Oye tú, niño, ven aquí rápido... ¡Vamos!"

# game/scripts/Events/locations/dressrosa/dressrosa_h5.rpy:185
translate spanish dressrosa_h5_329af30c:

    # rebecca "Quick, follow me!!"
    rebecca "¡Rápido, sígueme!"

# game/scripts/Events/locations/dressrosa/dressrosa_h5.rpy:186
