    # player "Alright, I'm coming, I'm coming!! I'm following you!"
    player "¡Bueno, ya voy, ya voy! ¡Te sigo!"

# game/scripts/Events/locations/dressrosa/dressrosa_h5.rpy:202
translate spanish dressrosa_h5_5810c6ca:

    # player "Wow, this place!!"
    player "¡¡¡Guau, este lugar!!!"

# game/scripts/Events/locations/dressrosa/dressrosa_h5.rpy:203
translate spanish dressrosa_h5_f201eac5:

    # player "This place is full of helmets and armor, and all kinds of weapons!!"
    player "¡¡¡Este lugar está lleno de cascos y armaduras y todo tipo de armas!!!"

# game/scripts/Events/locations/dressrosa/dressrosa_h5.rpy:204
