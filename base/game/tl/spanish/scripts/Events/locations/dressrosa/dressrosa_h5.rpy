    # player "Awesome!!! Can I really use whatever I want from here?!?"
    player "¡¡¡Genial!!! ¿De verdad puedo usar lo que quiera de aquí?"

# game/scripts/Events/locations/dressrosa/dressrosa_h5.rpy:206
translate spanish dressrosa_h5_700f9c5b:

    # rebecca "Hahaha, you're not only strong, you're also really fun!!"
    rebecca "¡Jajaja! ¡No sólo eres fuerte, también eres muy divertido!"

# game/scripts/Events/locations/dressrosa/dressrosa_h5.rpy:209
translate spanish dressrosa_h5_632aef7a:

    # narrador "[rebecca.n] love +2"
    narrador "[rebecca.n] amor +2"

# game/scripts/Events/locations/dressrosa/dressrosa_h5.rpy:211
translate spanish dressrosa_h5_e16c2960:

    # player "Mnmnm!?!?"
    player "¡¿Mmmm?!?"

# game/scripts/Events/locations/dressrosa/dressrosa_h5.rpy:212
