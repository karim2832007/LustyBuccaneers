    # player "Wow, do you hear that!?!?"
    player "¡Vaya! ¿¡Escuchas eso!?"

# game/scripts/Events/locations/dressrosa/dressrosa_h5.rpy:213
translate spanish dressrosa_h5_f1fdda70:

    # player "They're really pumped out there in the arena... you can hear the shouting even from here!"
    player "Están realmente entusiasmados en la arena... ¡se pueden oír los gritos incluso desde aquí!"

# game/scripts/Events/locations/dressrosa/dressrosa_h5.rpy:215
