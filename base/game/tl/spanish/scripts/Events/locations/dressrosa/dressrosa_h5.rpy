    # unknown "Did you see what he did?"
    unknown "¿Viste lo que hizo?"

# game/scripts/Events/locations/dressrosa/dressrosa_h5.rpy:124
translate spanish dressrosa_h5_7044930c:

    # unknown "That kid knocked out [spartan.n] very easily..."
    unknown "Ese niño quedó inconsciente [spartan.n] muy fácilmente..."

