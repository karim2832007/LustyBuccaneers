translate spanish dressrosa_h5_5f9510a9:

    # spartan "Too late, damn it, you'll pay for your family..."
    spartan "¡Demasiado tarde, maldita sea, pagarás por tu familia...!"

# game/scripts/Events/locations/dressrosa/dressrosa_h5.rpy:52
