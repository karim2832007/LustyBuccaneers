    player "(¡Qué suerte la mía! ¡La encontré tan rápido!)"

# game/scripts/Events/locations/dressrosa/dressrosa_h5.rpy:38
translate spanish dressrosa_h5_deff48b0:

    # spartan "Taking part in this tournament..."
    spartan "Participando en este torneo..."

# game/scripts/Events/locations/dressrosa/dressrosa_h5.rpy:39
translate spanish dressrosa_h5_93d9d726:

    # spartan "I thought I'd made it clear what would happen if I saw you around here..."
    spartan "Creí haber dejado claro lo que pasaría si te veía por aquí..."

# game/scripts/Events/locations/dressrosa/dressrosa_h5.rpy:40
translate spanish dressrosa_h5_3b8ba537:

    # spartan "Looks like I'll get to enjoy myself and play with you sooner than expected..."
    spartan "Parece que podré disfrutar y jugar contigo antes de lo esperado..."

# game/scripts/Events/locations/dressrosa/dressrosa_h5.rpy:42
translate spanish dressrosa_h5_eda7dbab:

    # spartan "That tasty body of yours... Why don't you give up right now, and we have some fun for a while, beautiful..."
    spartan "Ese cuerpo tan rico tuyo... ¿Por qué no te rindes ahora mismo y nos divertimos un rato, hermosa...?"

# game/scripts/Events/locations/dressrosa/dressrosa_h5.rpy:43
