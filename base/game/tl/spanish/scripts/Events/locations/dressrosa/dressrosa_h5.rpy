    # player "No idea... you tell me... You seem to be from around here..."
    player "Ni idea...dime tú...parece que eres de por aquí..."

# game/scripts/Events/locations/dressrosa/dressrosa_h5.rpy:221
translate spanish dressrosa_h5_adbbbe9c:

    # rebecca "It's simple... They want to see blood..."
    rebecca "Es simple... Quieren ver sangre..."

# game/scripts/Events/locations/dressrosa/dressrosa_h5.rpy:222
