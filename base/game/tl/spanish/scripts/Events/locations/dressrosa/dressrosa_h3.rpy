translate spanish dressrosa_h3_5fd5f430:

    # player "Yes! Sorry, sorry!! I'm here, I'm here!"
    player "¡Sí! ¡Lo siento, lo siento! ¡Aquí estoy, aquí estoy!"

# game/scripts/Events/locations/dressrosa/dressrosa_h3.rpy:51
translate spanish dressrosa_h3_6b8f6c7c:

