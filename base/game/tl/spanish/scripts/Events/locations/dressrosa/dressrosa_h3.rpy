    yamato "¡Así es! ¡Y vamos a ganar!"

# game/scripts/Events/locations/dressrosa/dressrosa_h3.rpy:58
translate spanish dressrosa_h3_f6f97411:

    # unknown "Mmm... I'm sorry to inform you there's only one spot left, only one of you two will be able to participate!"
    unknown "Mmm... Lamento informarles que solo queda un lugar, ¡solo uno de ustedes dos podrá participar!"

# game/scripts/Events/locations/dressrosa/dressrosa_h3.rpy:59
translate spanish dressrosa_h3_48707f49:

    # player "What!?! Are you serious?!... Isn't it possible to add more people?"
    player "¿¡Qué!? ¿En serio? ¿No se puede añadir más gente?"

# game/scripts/Events/locations/dressrosa/dressrosa_h3.rpy:60
translate spanish dressrosa_h3_f7e43a2a:

    # unknown "Unfortunately, the family's rules are very strict... Spots are limited..."
    unknown "Desafortunadamente, las reglas de la familia son muy estrictas... Las plazas son limitadas..."

# game/scripts/Events/locations/dressrosa/dressrosa_h3.rpy:62
translate spanish dressrosa_h3_88ed6ccc:

    # yamato "Incredible!! How could we have arrived so late!!"
    yamato "¡Increíble! ¿Cómo pudimos llegar tan tarde?"

# game/scripts/Events/locations/dressrosa/dressrosa_h3.rpy:63
translate spanish dressrosa_h3_e487931f:

    # yamato "Don't worry, [player.n]... you sign up, I'm sure you won't let us down!"
    yamato "No os preocupéis, [player.n]… ¡apúntate, seguro que no nos defraudaréis!"

# game/scripts/Events/locations/dressrosa/dressrosa_h3.rpy:64
translate spanish dressrosa_h3_bd27a16f:

    # player "It's a shame, [yamato.n], but don't worry, I'll get that fruit!"
    player "Es una pena, [yamato.n], pero no te preocupes, ¡conseguiré esa fruta!"

# game/scripts/Events/locations/dressrosa/dressrosa_h3.rpy:65
