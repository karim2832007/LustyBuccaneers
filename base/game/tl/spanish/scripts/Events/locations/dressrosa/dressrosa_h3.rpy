# game/scripts/Events/locations/dressrosa/dressrosa_h3.rpy:35
translate spanish dressrosa_h3_a020d13b:

    # player "(Wow... [rebecca.n]... She's like an angel in her battle armor!!)"
    player "(Wow... [rebecca.n]... ¡Es como un ángel con su armadura de batalla!)"

# game/scripts/Events/locations/dressrosa/dressrosa_h3.rpy:36
translate spanish dressrosa_h3_86270788:

    # player "(A very revealing armor!!! Now I get why they say the women are fire here!!)"
    player "(¡¡¡Una armadura muy reveladora!!! ¡¡Ahora entiendo por qué dicen que las mujeres son fuego aquí!!)"

# game/scripts/Events/locations/dressrosa/dressrosa_h3.rpy:37
