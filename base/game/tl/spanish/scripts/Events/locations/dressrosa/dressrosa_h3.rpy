translate spanish dressrosa_h3_773d414b:

    # player "(Damn, she left too fast!! And I can't leave without registering...)"
    player "(¡Maldita sea, se fue demasiado rápido! Y no puedo irme sin registrarme...)"

# game/scripts/Events/locations/dressrosa/dressrosa_h3.rpy:49
translate spanish dressrosa_h3_f766e8fc:

    # unknown "Hey, are you there?!?... If not, I'll let the next one through!"
    unknown "¡Oye! ¿Estás ahí? Si no, ¡dejaré pasar al siguiente!"

