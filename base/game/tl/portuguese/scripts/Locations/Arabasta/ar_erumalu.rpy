    # vivi "It could be dangerous, don't get too close! It might be looking for trouble!!"
    vivi "Pode ser perigoso, não chegue muito perto! Pode estar procurando encrenca!!"

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:212
