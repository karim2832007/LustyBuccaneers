translate portuguese m_ar_erumalu_c27fef48:

    # vivi "Not long after, a massive amount of Dance Powder was found inside the palace."
    vivi "Pouco tempo depois, uma grande quantidade de Pó de Dança foi encontrada dentro do palácio."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:144
translate portuguese m_ar_erumalu_40b1ce79:

    # robin "Were there infiltrators in the palace?"
    robin "Havia infiltrados no palácio?"

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:146
translate portuguese m_ar_erumalu_afbd0359:

    # vivi "It seems so... They wanted to frame the royal family for the droughts!"
    vivi "Parece que sim... Eles queriam incriminar a família real pelas secas!"

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:147
translate portuguese m_ar_erumalu_a705a6bd:

    # vivi "Since this incident, the people's distrust in the king has been growing daily..."
    vivi "Desde este incidente, a desconfiança do povo no rei tem crescido diariamente..."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:148
translate portuguese m_ar_erumalu_1d63d52f:

    # vivi "Obviously, this was all orchestrated, but the discontent keeps rising..."
    vivi "Obviamente, tudo isso foi orquestrado, mas o descontentamento continua aumentando..."

# game/scripts/Locations/Arabasta/ar_erumalu.rpy:149
