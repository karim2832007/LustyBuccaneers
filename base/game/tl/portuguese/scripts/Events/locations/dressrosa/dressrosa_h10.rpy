    # gatz "What an interesting matchup we have today!"
    gatz "Que confronto interessante temos hoje!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h10.rpy:52
translate portuguese dressrosa_h10_26141d2a:

    # gatz "[ideo.n] versus [player.n]!!!"
    gatz "[ideo.n] versus [player.n]!!!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h10.rpy:53
translate portuguese dressrosa_h10_a369d1bf:

    # gatz "Who will emerge victorious?!?"
    gatz "Quem sairá vitorioso?!?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h10.rpy:54
translate portuguese dressrosa_h10_0e493592:

    # gatz "Let's enjoy the show these fighters are about to give us!"
    gatz "Vamos aproveitar o espetáculo que esses lutadores estão prestes a nos dar!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h10.rpy:57
translate portuguese dressrosa_h10_022600cb:

    # ideo "So we finally face each other... I've seen your strength in the previous rounds, outsider."
    ideo "Então finalmente nos encaramos... Vi sua força nas rodadas anteriores, forasteiro."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h10.rpy:58
translate portuguese dressrosa_h10_9e41b246:

    # ideo "Your style is unpredictable, wild... but not without purpose."
    ideo "Seu estilo é imprevisível, ousado... mas não sem propósito."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h10.rpy:59
translate portuguese dressrosa_h10_720dc030:

    # player "Coming from you, that almost sounds like a compliment."
    player "Vindo de você, isso quase soa como um elogio."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h10.rpy:60
translate portuguese dressrosa_h10_db6c3155:

    # ideo "Do not be mistaken. I don't respect you... yet. But I recognize power when I see it."
    ideo "Não se engane. Eu não te respeito... ainda. Mas reconheço o poder quando o vejo."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h10.rpy:61
translate portuguese dressrosa_h10_7f638884:

    # ideo "The arena does not lie. Only the worthy rise here... and I plan to be the last one standing."
    ideo "A arena não mente. Só os dignos se erguem aqui... e eu pretendo ser o último a ficar de pé."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h10.rpy:62
translate portuguese dressrosa_h10_e986d9b9:

    # player "Confidence isn't something you're lacking, huh?"
    player "Confiança não é algo que te falte, né?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h10.rpy:63
translate portuguese dressrosa_h10_95279f34:

    # ideo "It's not confidence, it's conviction! My fists burn with the fiery will of my clan!"
    ideo "Não é confiança, é convicção! Meus punhos ardem com a vontade ardente do meu clã!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h10.rpy:64
translate portuguese dressrosa_h10_aba00bff:

    # ideo "I trained among storms, bled over stone... survived where many fell."
    ideo "Treinei em meio a tempestades, sangrei sobre pedras... sobrevivi onde muitos caíram."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h10.rpy:65
translate portuguese dressrosa_h10_47aee65d:

    # ideo "And you? Are you ready to stake your life on this dance of strength?"
    ideo "E você? Está pronto para apostar sua vida nessa dança de força?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h10.rpy:66
translate portuguese dressrosa_h10_64de93c8:

    # player "I didn't come all the way here to back down. Let's see what those fists of yours are made of."
    player "Eu não vim até aqui para recuar. Vamos ver do que esses seus punhos são feitos."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h10.rpy:67
translate portuguese dressrosa_h10_41d3541e:

    # ideo "Ha! That's what I like!"
    ideo "Ah! É isso que eu gosto!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h10.rpy:68
translate portuguese dressrosa_h10_9bdfeb47:

    # ideo "If you fall, you'll fall with honor... But I don't think you'll get that far."
    ideo "Se você cair, cairá com honra... Mas não acho que você chegará tão longe."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h10.rpy:69
translate portuguese dressrosa_h10_8ded19b4:

    # ideo "Losing is not in my vocabulary!"
    ideo "Perder não faz parte do meu vocabulário!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h10.rpy:70
translate portuguese dressrosa_h10_add6a516:

    # ideo "Today, I will write a new chapter of legend with every blow I land on you."
    ideo "Hoje, a cada golpe que eu desferir em você, escreverei um novo capítulo da lenda."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h10.rpy:71
translate portuguese dressrosa_h10_382c311a:

    # ideo "Let this arena hear our names... and tremble with the echo of this battle!"
    ideo "Que esta arena ouça nossos nomes... e trema com o eco desta batalha!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h10.rpy:72
translate portuguese dressrosa_h10_ae3d41db:

    # player "Then let's stop talking... and fight!"
    player "Então vamos parar de falar... e lutar!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h10.rpy:73
translate portuguese dressrosa_h10_1ab17278:

    # ideo "{size=40}Come! Show me you deserve to be in this tournament!{/size}"
    ideo "{size=40}Venha! Mostre-me que você merece estar neste torneio!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h10.rpy:80
translate portuguese dressrosa_h10_f8bdc110:

    # ideo "Heh... damn... I didn't expect you to overpower me like that!"
    ideo "Heh... droga... eu não esperava que você me dominasse assim!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h10.rpy:81
translate portuguese dressrosa_h10_3d60d023:

    # ideo "Your blows... carried more than strength. There was purpose..."
    ideo "Seus golpes... carregavam mais do que força. Havia um propósito..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h10.rpy:82
translate portuguese dressrosa_h10_0dd91301:

    # ideo "You fought with your heart... and that deserves respect."
    ideo "Você lutou com o coração... e isso merece respeito."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h10.rpy:83
translate portuguese dressrosa_h10_b4c6ad86:

    # ideo "Don't forget this battle... because I certainly won't."
    ideo "Não se esqueçam dessa batalha... porque eu certamente não me esquecerei."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h10.rpy:84
translate portuguese dressrosa_h10_2c3aeeba:

    # ideo "Keep moving forward... and may your name thunder louder than mine someday..."
    ideo "Continue avançando... e que seu nome seja mais forte que o meu algum dia..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h10.rpy:92
translate portuguese dressrosa_h10_18e92528:

    # gatz "{size=40}Iiiiiiiiincredibleeeeeee!!!!{/size}"
    gatz "{size=40}Iiiiiiiincrível!!!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h10.rpy:93
translate portuguese dressrosa_h10_daaa07f0:

    # gatz "Once again in an amazing showdown, [player.n] rises victorious!!"
    gatz "Mais uma vez em um confronto incrível, [player.n] sai vitorioso!!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h10.rpy:94
translate portuguese dressrosa_h10_4f4a0008:

    # gatz "{size=40}Is there anyone out there who can stop [player.n]??!!!!{/size}"
    gatz "{size=40}Existe alguém lá fora que possa parar [player.n]??!!!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h10.rpy:95
translate portuguese dressrosa_h10_0cd76273:

    # gatz "For now, that question seems to have no answer!"
    gatz "Por enquanto, essa pergunta parece não ter resposta!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h10.rpy:96
translate portuguese dressrosa_h10_e603382b:

    # gatz "But don't rush, the day is still long!"
    gatz "Mas não se apresse, o dia ainda é longo!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h10.rpy:97
translate portuguese dressrosa_h10_340cacb2:

    # gatz "We'll see you again with more fights after the break, see you soon!"
    gatz "Nos vemos novamente com mais lutas depois do intervalo, até breve!"

