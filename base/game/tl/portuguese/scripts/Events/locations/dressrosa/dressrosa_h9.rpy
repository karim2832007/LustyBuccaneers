# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:7
translate portuguese dressrosa_h9_51420557:

    # player "(Where could my precious warrior angel be... They should've fought by now!)"
    player "(Onde será que está meu precioso anjo guerreiro... Eles já deveriam ter lutado!)"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:9
translate portuguese dressrosa_h9_fa05056c:

    # narrador "While you wander around killing time, you suddenly come face to face with a rather imposing gladiator."
    narrador "Enquanto você vagueia por aí para matar o tempo, de repente se depara com um gladiador bastante imponente."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:16
translate portuguese dressrosa_h9_27f482ac:

    # player "(!!!)"
    player "(!!!)"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:17
translate portuguese dressrosa_h9_934d0521:

    # player "(Woooow!! That helmet is amazing!!!)"
    player "(Uau!! Esse capacete é incrível!!!)"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:18
translate portuguese dressrosa_h9_290ae46b:

    # player "(How did I not think of wearing one like that before!! It's so manly!!)"
    player "(Como é que eu não pensei em usar uma dessas antes?! É tão másculo!!)"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:19
translate portuguese dressrosa_h9_277501da:

    # riku "Mnmmnm..."
    riku "Hummm..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:20
translate portuguese dressrosa_h9_7b861256:

    # riku "Something wrong, kid? Why are you staring at me like that..."
    riku "Algum problema, garoto? Por que você está me encarando assim...?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:21
translate portuguese dressrosa_h9_07eadd9e:

    # player "(He's like the statue of Kyros!! I guess he must be imitating him...)"
    player "(Ele é igualzinho à estátua de Kyros!! Acho que ele deve estar imitando ele...)"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:22
translate portuguese dressrosa_h9_92b8d4fc:

    # riku "Hey... Are you listening?!"
    riku "Ei... Você está me ouvindo?!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:23
translate portuguese dressrosa_h9_62becb34:

    # riku "You're [player.n], right? I've seen your fights... they've been really incredible..."
    riku "Você é [player.n], certo? Eu vi suas lutas... elas foram realmente incríveis..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:24
translate portuguese dressrosa_h9_0f5f02ca:

    # player "!!!"
    player "!!!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:25
translate portuguese dressrosa_h9_69f1ccab:

    # player "Are you talking to me??"
    player "Você está falando comigo??"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:26
translate portuguese dressrosa_h9_5fe991d1:

    # riku "Yeah... I've seen you fight, you're really strong..."
    riku "Sim... eu já te vi lutar, você é muito forte..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:29
translate portuguese dressrosa_h9_76c9608e:

    # riku "I'm Riku... [riku.n] hehe sorry..."
    riku "Eu sou Riku... [riku.n] hehe desculpe..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:31
translate portuguese dressrosa_h9_31d7821e:

    # player "Ohh, nice to meet you! Thanks for the compliment [riku.n]... I haven't seen your fights, but I'm sure you've done well..."
    player "Oh, prazer em conhecê-lo! Obrigado pelo elogio [riku.n]... Não vi suas lutas, mas tenho certeza de que você se saiu bem..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:33
translate portuguese dressrosa_h9_d647f960:

    # riku "Hahaha, I wish that were true! I'm not fit for this kind of thing anymore..."
    riku "Hahaha, quem me dera fosse verdade! Não tenho mais vocação para esse tipo de coisa..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:34
translate portuguese dressrosa_h9_4ec44e62:

    # riku "I'm really rusty... But well... there's no other choice..."
    riku "Estou muito enferrujado... Mas bem... não há outra escolha..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:36
translate portuguese dressrosa_h9_fde4cc91:

    # riku "These old legs need a break, kid. You're resting too?"
    riku "Essas pernas precisam de um descanso, garoto. Você também está descansando?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:37
translate portuguese dressrosa_h9_0a5a412f:

    # player "Something like that... There's not much to do, honestly..."
    player "Algo assim... Honestamente, não há muito o que fazer..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:38
translate portuguese dressrosa_h9_a17db676:

    # riku "Hahaha, you're quite pleasant... Sometimes a good chat is worth more than another hit, don't you think?"
    riku "Hahaha, você é bem legal... Às vezes, um bom papo vale mais do que mais uma dose, não acha?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:39
translate portuguese dressrosa_h9_b9415045:

    # player "You're right about that! Hey, since we're resting... can I ask you something? You seem to know this place well..."
    player "Você tem razão! Ei, já que estamos descansando... posso te perguntar uma coisa? Você parece conhecer bem este lugar..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:40
translate portuguese dressrosa_h9_bda616c3:

    # riku "Hahaha of course, there's still time before my fight!"
    riku "Hahaha, claro, ainda tenho tempo antes da minha luta!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:42
translate portuguese dressrosa_h9_cd2a9afc:

    # riku "What do you want to know?"
    riku "O que você quer saber?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:43
translate portuguese dressrosa_h9_e9cc5eaf:

    # player "It's my first time in [Dressrosa.n], and I've noticed something..."
    player "É a minha primeira vez em [Dressrosa.n], e notei algo..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:44
translate portuguese dressrosa_h9_73f98382:

    # player "For some reason... something here doesn't add up..."
    player "Por algum motivo... algo aqui não está certo..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:45
translate portuguese dressrosa_h9_e9c9e1c0:

    # player "Everything looks fine... but I think there are a lot of problems hidden under the rug... You know what I mean?"
    player "Parece tudo bem... mas acho que há muitos problemas escondidos... Sabe o que quero dizer?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:46
translate portuguese dressrosa_h9_f68ac3bb:

    # riku "Yeah... I understand perfectly..."
    riku "Sim... Entendo perfeitamente..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:47
translate portuguese dressrosa_h9_62a93c2a:

    # player "What really happened with [Dressrosa.n] and its current king, [donflamingo.n]?"
    player "O que realmente aconteceu com [Dressrosa.n] e seu atual rei, [donflamingo.n]?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:48
translate portuguese dressrosa_h9_33a89ab0:

    # riku "Well now..."
    riku "Bem..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:49
translate portuguese dressrosa_h9_5ef21d16:

    # riku "It's interesting that outsiders care about those matters... especially young ones like you..."
    riku "É interessante que pessoas de fora se importem com esses assuntos... especialmente jovens como você..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:51
translate portuguese dressrosa_h9_d4657709:

    # riku "Mnmnm... Where to begin..."
    riku "Hum... Por onde começar..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:52
translate portuguese dressrosa_h9_0cc47fab:

    # riku "This one's a heavy story."
    riku "Essa é uma história pesada."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:53
translate portuguese dressrosa_h9_623b5b06:

    # riku "Are you sure you want to hear it? It's not a cheerful tale."
    riku "Tem certeza de que quer ouvir? Não é uma história alegre."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:54
translate portuguese dressrosa_h9_49da215d:

    # player "I can imagine, but I'd like to understand the truth..."
    player "Posso imaginar, mas gostaria de entender a verdade..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:55
translate portuguese dressrosa_h9_7fd26f92:

    # player "(With more information, I might even surprise my warrior angel...)"
    player "(Com mais informações, eu poderia até surpreender meu anjo da guarda...)"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:56
translate portuguese dressrosa_h9_4048ab48:

    # riku "Alright. I'll tell you like an old tale I once heard — it's quite famous around here..."
    riku "Muito bem. Vou contar uma velha história que ouvi uma vez — é bem famosa por aqui..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:57
translate portuguese dressrosa_h9_fd4f0c3a:

    # riku "In ancient times, [Dressrosa.n] was ruled by one special family — the Riku royal family."
    riku "Nos tempos antigos, [Dressrosa.n] era governado por uma família especial — a família real Riku."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:58
translate portuguese dressrosa_h9_69dce4a5:

    # riku "They say that for centuries, under their rule, this country didn't know war for over 800 years!"
    riku "Dizem que, durante séculos, sob o domínio deles, este país não conheceu a guerra por mais de 800 anos!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:59
translate portuguese dressrosa_h9_f5d0d06c:

    # player "Really? A kingdom without wars for 800 years? Sounds like good rulers."
    player "Sério? Um reino sem guerras por 800 anos? Parece que tinham bons governantes."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:60
translate portuguese dressrosa_h9_6e8ce131:

    # riku "They were..."
    riku "Eles eram..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:61
translate portuguese dressrosa_h9_cb9e1225:

    # riku "King Riku Doldo III, the last of them, was a kind man loved by his people."
    riku "O rei Riku Doldo III, o último deles, era um homem bondoso e amado por seu povo."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:62
translate portuguese dressrosa_h9_ba3ae49f:

    # riku "He firmly believed in peace. It's said he used to say, 'If I can only survive at the cost of an innocent life, I'd rather die by my own will.' That was how noble his philosophy was."
    riku "Ele acreditava firmemente na paz. Dizem que costumava dizer: \"Se eu só puder sobreviver ao custo de uma vida inocente, prefiro morrer por minha própria vontade\". Essa era a nobreza de sua filosofia."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:63
translate portuguese dressrosa_h9_8e3f52f5:

    # player "A king willing to die rather than harm his people... I've never heard anything like that. He must have been deeply loved."
    player "Um rei disposto a morrer em vez de prejudicar seu povo... Nunca ouvi falar de algo assim. Ele devia ser muito amado."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:64
translate portuguese dressrosa_h9_42e4ec37:

    # riku "He was. That's why what happened that night was so... so tragic."
    riku "Ele era. É por isso que o que aconteceu naquela noite foi tão... tão trágico."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:65
translate portuguese dressrosa_h9_d80e3995:

    # player "That night?!?"
    player "Aquela noite?!?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:66
translate portuguese dressrosa_h9_f0bfdf74:

    # riku "Yes..."
    riku "Sim..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:67
translate portuguese dressrosa_h9_0ec79996:

    # riku "One night, a pirate appeared in the royal chamber. An extremely dangerous man, cunning like no other..."
    riku "Certa noite, um pirata apareceu nos aposentos reais. Um homem extremamente perigoso, astuto como nenhum outro..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:68
translate portuguese dressrosa_h9_affa9bc2:

    # riku "A member of the Donquixote family — the very one you mentioned... [donflamingo.n]."
    riku "Um membro da família Donquixote — aquele mesmo que você mencionou... [donflamingo.n]."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:69
translate portuguese dressrosa_h9_a660cf9a:

    # player "[donflamingo.n]? The current king?"
    player "[donflamingo.n]? O rei atual?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:70
translate portuguese dressrosa_h9_49345cbd:

    # riku "The same. Back then he was just a Warlord, a Shichibukai of the navy with massive influence."
    riku "O mesmo. Naquela época, ele era apenas um Shichibukai, um comandante da marinha com enorme influência."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:71
translate portuguese dressrosa_h9_cf15823d:

    # riku "He came claiming his 'right' to the throne of [Dressrosa.n], saying he descended from an ancient royal bloodline."
    riku "Ele veio reivindicando seu 'direito' ao trono de [Dressrosa.n], dizendo que descendia de uma antiga linhagem real."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:72
translate portuguese dressrosa_h9_81081e1d:

    # riku "And he cornered King Riku."
    riku "E ele encurralou o Rei Riku."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:73
translate portuguese dressrosa_h9_f48ea195:

    # player "What did he do exactly?"
    player "O que ele fez exatamente?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:74
translate portuguese dressrosa_h9_e0f6aa38:

    # riku "[donflamingo.n] demanded the impossible... a ransom of 10 billion Berries in exchange for leaving [Dressrosa.n] in peace."
    riku "[donflamingo.n] exigiram o impossível... um resgate de 10 bilhões Berries em troca de deixar [Dressrosa.n] em paz."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:75
translate portuguese dressrosa_h9_6e6fc08f:

    # riku "He threatened the whole kingdom. If the king didn't pay by dawn, there would be war."
    riku "Ele ameaçou todo o reino. Se o rei não pagasse até o amanhecer, haveria guerra."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:76
translate portuguese dressrosa_h9_160f0840:

    # player "10 billion Berries! That's an enormous amount... What could the king do?"
    player "10 bilhões Berries! Isso é uma quantia enorme... O que o rei poderia fazer?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:77
translate portuguese dressrosa_h9_f1707766:

    # riku "The king was desperate to avoid a war that would devastate his people. So he made a difficult decision."
    riku "O rei estava desesperado para evitar uma guerra que devastaria seu povo. Então, ele tomou uma decisão difícil."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:78
translate portuguese dressrosa_h9_a34a8f5b:

    # riku "He gathered his soldiers in the middle of the night and, without explaining the true reason to avoid panic, ordered them to collect money from the citizens."
    riku "Ele reuniu seus soldados no meio da noite e, sem explicar o verdadeiro motivo para evitar o pânico, ordenou que recolhessem dinheiro dos cidadãos."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:79
translate portuguese dressrosa_h9_4754df8a:

    # riku "Every treasure, every saving. Everything to raise the ransom and save the kingdom without bloodshed."
    riku "Todo tesouro, toda economia. Tudo para levantar o resgate e salvar o reino sem derramamento de sangue."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:80
translate portuguese dressrosa_h9_19946c75:

    # player "He asked his own subjects for money out of nowhere? The people must've been confused."
    player "Ele pediu dinheiro aos seus próprios súditos do nada? O povo deve ter ficado confuso."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:81
translate portuguese dressrosa_h9_19244f1f:

    # riku "Of course they were. Imagine soldiers knocking on doors at midnight, asking for all the money they had."
    riku "É claro que sim. Imagine soldados batendo de porta em porta à meia-noite, pedindo todo o dinheiro que tinham."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:82
translate portuguese dressrosa_h9_eb8c9323:

    # riku "Many doubted, thought it was madness. But then the king did something no one expected..."
    riku "Muitos duvidaram, acharam que era loucura. Mas então o rei fez algo que ninguém esperava..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:83
translate portuguese dressrosa_h9_380ba6b5:

    # player "What did he do?"
    player "O que ele fez?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:84
translate portuguese dressrosa_h9_c8bcdef0:

    # riku "King Riku... broadcasted himself to the entire kingdom through a Den Den Mushi. He appeared kneeling, tears in his eyes, begging his people to trust him, to hand over their wealth for a cause he couldn't yet reveal."
    riku "O Rei Riku... transmitiu sua mensagem para todo o reino através de um Den Den Mushi. Ele apareceu ajoelhado, com lágrimas nos olhos, implorando ao seu povo que confiasse nele, que lhe entregasse suas riquezas por uma causa que ele ainda não podia revelar."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:85
translate portuguese dressrosa_h9_07f3902e:

    # riku "He promised it was all to protect them."
    riku "Ele prometeu que tudo era para protegê-los."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:86
translate portuguese dressrosa_h9_ac8f6124:

    # player "The king himself kneeling before his people? That... that must have moved everyone."
    player "O próprio rei ajoelhando-se diante de seu povo? Isso... isso deve ter emocionado a todos."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:87
translate portuguese dressrosa_h9_1e7ccfc4:

    # riku "It did. A king begging on his knees... Many citizens burst into tears seeing him. They loved their king, and his desperation united them."
    riku "Sim, aconteceu. Um rei implorando de joelhos... Muitos cidadãos caíram em lágrimas ao vê-lo. Eles amavam seu rei, e seu desespero os unia."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:88
translate portuguese dressrosa_h9_c70eb2ae:

    # riku "Little by little, everyone began to bring their savings and treasures. They were scared, not knowing why, but trusted their kind king was doing the right thing."
    riku "Aos poucos, todos começaram a trazer suas economias e tesouros. Estavam assustados, sem saber porquê, mas confiavam que seu bondoso rei estava fazendo a coisa certa."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:89
translate portuguese dressrosa_h9_2a01c27c:

    # player "Incredible. Despite their fear, the people trusted him blindly."
    player "Incrível. Apesar do medo, as pessoas confiaram nele cegamente."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:90
translate portuguese dressrosa_h9_55bb73b9:

    # riku "Yes. It seemed that, despite everything, they'd manage to raise the ransom before dawn. But then... tragedy struck."
    riku "Sim. Parecia que, apesar de tudo, eles conseguiriam levantar o resgate antes do amanhecer. Mas então... a tragédia aconteceu."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:92
translate portuguese dressrosa_h9_890749a1:

    # player "... What happened?"
    player "... O que aconteceu?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:93
translate portuguese dressrosa_h9_19b70a35:

    # riku "Suddenly, while the money was being gathered in the central plaza... the king himself appeared, riding through the city... and started attacking his citizens!"
    riku "De repente, enquanto o dinheiro estava sendo recolhido na praça central... o próprio rei apareceu, cavalgando pela cidade... e começou a atacar seus cidadãos!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:94
translate portuguese dressrosa_h9_0f48fdb2:

    # player "What?! That can't be! The king attacking his own people?... After everything you just told me?!"
    player "O quê?! Isso não pode ser! O rei atacando o próprio povo?... Depois de tudo que você me contou?!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:95
translate portuguese dressrosa_h9_32e78f72:

    # riku "Yes... he wielded his sword against innocents, setting fire to homes he had helped rebuild just hours before..."
    riku "Sim... ele brandiu sua espada contra inocentes, incendiando casas que ele mesmo ajudara a reconstruir poucas horas antes..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:96
translate portuguese dressrosa_h9_62b6f44d:

    # riku "As if he had suddenly gone mad. They say his face was soaked in tears as he committed those terrible acts."
    riku "Como se ele tivesse enlouquecido de repente. Dizem que seu rosto estava banhado em lágrimas enquanto cometia aqueles atos terríveis."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:97
translate portuguese dressrosa_h9_a96ab54c:

    # player "That makes no sense... Why would a king who loved his people do something like that?"
    player "Isso não faz sentido... Por que um rei que amava seu povo faria algo assim?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:98
translate portuguese dressrosa_h9_5a096446:

    # riku "Well... that's the heart of it... something not many know..."
    riku "Bem... esse é o ponto crucial... algo que poucos sabem..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:99
translate portuguese dressrosa_h9_cd423ee3:

    # riku "The king... didn't do it of his own will."
    riku "O rei... não fez isso por vontade própria."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:100
translate portuguese dressrosa_h9_0f5f02ca_1:

    # player "!!!"
    player "!!!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:101
translate portuguese dressrosa_h9_63b8e751:

    # player "What do you mean..."
    player "O que você quer dizer..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:102
translate portuguese dressrosa_h9_f7276283:

    # riku "Here lies the dark twist of this story. They say that at that moment, the king no longer controlled his actions."
    riku "Eis a reviravolta sombria desta história. Dizem que, naquele momento, o rei perdeu o controle de seus atos."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:103
translate portuguese dressrosa_h9_feab977d:

    # player "What do you mean? Someone else controlled him?"
    player "Como assim? Alguém o controlava?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:104
translate portuguese dressrosa_h9_f3fa060c:

    # riku "Exactly... Some witnesses claim that night they saw almost invisible strings glimmering under the moonlight, moving the king and his soldiers like puppets."
    riku "Exatamente... Algumas testemunhas afirmam que naquela noite viram fios quase invisíveis brilhando ao luar, movendo o rei e seus soldados como marionetes."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:105
translate portuguese dressrosa_h9_66b7d192:

    # player "Strings? Like someone was controlling them as marionettes? But... is that even possible?"
    player "Cordas? Como se alguém os estivesse controlando como marionetes? Mas... isso é possível?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:106
translate portuguese dressrosa_h9_48b04a33:

    # riku "I know it sounds crazy. Most people didn't see those threads amid the chaos, nor would they want to believe it. They preferred to think their king had simply gone insane."
    riku "Eu sei que parece loucura. A maioria das pessoas não viu esses fios em meio ao caos, nem queria acreditar nisso. Preferiam pensar que seu rei simplesmente havia enlouquecido."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:107
translate portuguese dressrosa_h9_31f72625:

    # riku "But those who fought near him swear he screamed ‘Stay away from me! I can't stop!' as his own hands attacked his people."
    riku "Mas aqueles que lutaram perto dele juram que ele gritou: 'Fiquem longe de mim! Eu não consigo parar!', enquanto suas próprias mãos atacavam seu povo."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:108
translate portuguese dressrosa_h9_bcb7bd6a:

    # player "... Then [donflamingo.n]..."
    player "... Então [donflamingo.n]..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:110
translate portuguese dressrosa_h9_df8ea48c:

    # riku "Exactly, kid!... [donflamingo.n]... with his cursed ability, was controlling King Riku and his entire army from the shadows."
    riku "Exatamente, garoto!... [donflamingo.n]... com sua habilidade amaldiçoada, estava controlando o Rei Riku e todo o seu exército das sombras."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:111
translate portuguese dressrosa_h9_3f4875a9:

    # riku "He turned them into his puppets, forcing them to slaughter the very citizens who trusted them."
    riku "Ele os transformou em seus fantoches, forçando-os a massacrar os próprios cidadãos que confiavam neles."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:112
translate portuguese dressrosa_h9_03775ec8:

    # player "..."
    player "..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:113
translate portuguese dressrosa_h9_4ee73783:

    # riku "The whole kingdom fell into chaos. Imagine it — families fleeing in terror from crazed soldiers, the king crying out in anguish as he hurt his people against his will..."
    riku "Todo o reino mergulhou no caos. Imagine só: famílias fugindo aterrorizadas de soldados enlouquecidos, o rei gritando de angústia enquanto feria seu povo contra a sua vontade..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:114
translate portuguese dressrosa_h9_c008d4a4:

    # riku "The people didn't understand. They only saw blood and fire caused by the man they had placed their faith in."
    riku "O povo não entendia. Eles só viam sangue e fogo causados pelo homem em quem haviam depositado sua fé."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:115
translate portuguese dressrosa_h9_ea754c76:

    # player "And [donflamingo.n]? Where was that bastard while [Dressrosa.n] burned?"
    player "E [donflamingo.n]? Onde estava aquele desgraçado enquanto [Dressrosa.n] queimava?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:116
translate portuguese dressrosa_h9_859639bb:

    # riku "Waiting for the right moment. When the chaos became unbearable, and the people were drowning in panic and despair... bam! [donflamingo.n] appeared with his crew, as if they were heroes coming to save the day."
    riku "Esperando o momento certo. Quando o caos se tornou insuportável e as pessoas estavam se afogando em pânico e desespero... bam! [donflamingo.n] apareceu com sua tripulação, como se fossem heróis vindo para salvar o dia."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:117
translate portuguese dressrosa_h9_c8903fde:

    # player "How cunning... He showed up as the savior, didn't he?"
    player "Que astuto... Ele apareceu como o salvador, não foi?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:118
translate portuguese dressrosa_h9_0b46fa51:

    # riku "Yes... that infamous man entered the scene, defeating King Riku with ease, releasing the soldiers from his control right before the people's eyes."
    riku "Sim... aquele homem infame entrou em cena, derrotando o Rei Riku com facilidade e libertando os soldados de seu controle bem diante dos olhos do povo."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:119
translate portuguese dressrosa_h9_44d137cd:

    # riku "In an instant, he went from being the hidden cause of the tragedy to the apparent hero who stopped it."
    riku "Num instante, ele passou de causa oculta da tragédia ao aparente herói que a impediu."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:120
translate portuguese dressrosa_h9_002d4674:

    # player "Unbelievable... The people must've cheered for him without knowing the truth."
    player "Inacreditável... As pessoas devem tê-lo aplaudido sem saber a verdade."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:121
translate portuguese dressrosa_h9_47f2c9df:

    # riku "Exactly. Terrified and confused, the citizens saw [donflamingo.n] as their savior. They believed he defeated the ‘evil' king who had lost his mind."
    riku "Exatamente. Aterrorizados e confusos, os cidadãos viram [donflamingo.n] como seu salvador. Eles acreditavam que ele havia derrotado o rei 'mau' que havia perdido a cabeça."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:122
translate portuguese dressrosa_h9_abe5fb2b:

    # riku "That very night, [donflamingo.n] crowned himself the new king of [Dressrosa.n]. The former king, Riku Doldo, was overthrown and branded a villain."
    riku "Naquela mesma noite, [donflamingo.n] coroou-se o novo rei de [Dressrosa.n]. O antigo rei, Riku Doldo, foi deposto e considerado um vilão."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:123
translate portuguese dressrosa_h9_876b3218:

    # player "Now I understand... That's why everyone here worships [donflamingo.n] and hates the old King Riku. They think Riku betrayed them."
    player "Agora eu entendo... É por isso que todos aqui veneram [donflamingo.n] e odeiam o antigo Rei Riku. Eles acham que Riku os traiu."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:124
translate portuguese dressrosa_h9_4a5f43a8:

    # riku "Yes. [donflamingo.n] twisted the narrative perfectly. Within hours, the kind king's image was shattered. The people began calling him a demon, a tyrant..."
    riku "Sim. [donflamingo.n] distorceu a narrativa perfeitamente. Em poucas horas, a imagem do rei bondoso foi destruída. O povo começou a chamá-lo de demônio, de tirano..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:126
translate portuguese dressrosa_h9_db42efd3:

    # riku "They said his family, the royal Riku line, had 'tainted blood'."
    riku "Disseram que sua família, a linhagem real Riku, tinha \"sangue impuro\"."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:128
translate portuguese dressrosa_h9_6ce589b5:

    # riku "Sadly, the rest of his family bore the weight of that irrational hatred. Ten years of resentment for something that never truly happened..."
    riku "Infelizmente, o resto de sua família carregou o peso desse ódio irracional. Dez anos de ressentimento por algo que nunca aconteceu de verdade..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:129
translate portuguese dressrosa_h9_8ce2cb1f:

    # player "How unfair... And all because of that bastard..."
    player "Que injustiça... E tudo por causa daquele desgraçado..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:130
translate portuguese dressrosa_h9_1efe7670:

    # riku "[donflamingo.n]... That man destroyed a kingdom in one night with his strings and his lies... I'll never forgive him... *ahem* I mean, many will never forgive him."
    riku "[donflamingo.n]... Aquele homem destruiu um reino em uma noite com seus cordões e suas mentiras... Eu nunca o perdoarei... *cof cof* quero dizer, muitos nunca o perdoarão."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:131
translate portuguese dressrosa_h9_7e0f1d8e:

    # player "I wouldn't forgive him either. A man like that deserves to pay for all the harm he caused."
    player "Eu também não o perdoaria. Um homem como esse merece pagar por todo o mal que causou."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:132
translate portuguese dressrosa_h9_4f476776:

    # riku "Indeed. Someday, I hope, he'll get what he deserves. No one is untouchable forever. The truth always finds its way out, sooner or later."
    riku "De fato. Um dia, espero, ele receberá o que merece. Ninguém é intocável para sempre. A verdade sempre vem à tona, mais cedo ou mais tarde."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:133
translate portuguese dressrosa_h9_b91d99db:

    # player "And what happened to King Riku and his family after that night? Did [donflamingo.n]... kill them?"
    player "E o que aconteceu com o Rei Riku e sua família depois daquela noite? Será que [donflamingo.n]... os matou?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:134
translate portuguese dressrosa_h9_7d5d0d85:

    # riku "The pirate took the throne, but curiously didn't kill the former king. Riku Doldo and his family vanished from public view. Many assume Doflamingo had them executed in secret or that they died during the uprising."
    riku "O pirata assumiu o trono, mas curiosamente não matou o antigo rei. Riku Doldo e sua família desapareceram da vista do público. Muitos presumem que Doflamingo os executou em segredo ou que morreram durante a revolta."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:135
translate portuguese dressrosa_h9_f66fd08b:

    # player "And others say...?"
    player "E outros dizem...?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:136
translate portuguese dressrosa_h9_817d343f:

    # riku "Heh... Well... there are rumors. Some whisper that the old king managed to escape alive. That he's lived hidden among the common folk ever since, right here in [Dressrosa.n]."
    riku "Heh... Bem... há rumores. Alguns sussurram que o velho rei conseguiu escapar com vida. Que ele viveu escondido entre o povo comum desde então, aqui mesmo em [Dressrosa.n]."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:137
translate portuguese dressrosa_h9_7d2cbd12:

    # player "The king living as a common man? That sounds like a legend."
    player "Um rei vivendo como um homem comum? Isso parece uma lenda."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:138
translate portuguese dressrosa_h9_4b001bb2:

    # riku "Maybe it is. They say an old man with sad eyes quietly helps those in need in the corners of the city."
    riku "Talvez seja. Dizem que um velho de olhos tristes ajuda silenciosamente os necessitados nos cantos mais remotos da cidade."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:139
translate portuguese dressrosa_h9_23e22eca:

    # riku "An anonymous figure watching over the people from the shadows, waiting for the day [Dressrosa.n] regains its freedom."
    riku "Uma figura anônima observando o povo das sombras, esperando o dia [Dressrosa.n] em que recupere sua liberdade."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:140
translate portuguese dressrosa_h9_ea2a92c1:

    # player "You speak of that fallen king almost as if you believe he's still alive."
    player "Você fala desse rei caído quase como se acreditasse que ele ainda estivesse vivo."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:141
translate portuguese dressrosa_h9_849306fd:

    # riku "..."
    riku "..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:142
translate portuguese dressrosa_h9_9a2b87f5:

    # riku "I'm just telling you what I heard from... reliable sources. Let's just say I once knew someone very close to King Riku, and that person assured me the king survived."
    riku "Estou apenas lhe contando o que ouvi de... fontes confiáveis. Digamos que eu conheci alguém muito próximo ao Rei Riku, e essa pessoa me garantiu que o rei sobreviveu."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:143
translate portuguese dressrosa_h9_1de35fc9:

    # player "Wow... It must've been hard for that person to witness all that."
    player "Nossa... Deve ter sido difícil para essa pessoa presenciar tudo isso."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:144
translate portuguese dressrosa_h9_0a1d5a06:

    # riku "For him... it was devastating. Imagine watching [donflamingo.n] destroy your reputation, your kingdom, and being powerless to stop it. In one night, he lost everything — his throne, his people's trust... even beloved family members."
    riku "Para ele... foi devastador. Imagine ver [donflamingo.n] sua reputação, seu reino destruídos, e ser impotente para impedi-los. Em uma noite, ele perdeu tudo — seu trono, a confiança de seu povo... até mesmo membros queridos da família."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:145
translate portuguese dressrosa_h9_a6622372:

    # player "Beloved family members?"
    player "Membros queridos da família?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:146
translate portuguese dressrosa_h9_fb0ba3be:

    # riku "They say that during the chaos... King Riku lost his eldest daughter. She... died trying to protect her little daughter. One more tragedy among so many."
    riku "Dizem que, durante o caos, o Rei Riku perdeu sua filha mais velha. Ela morreu tentando proteger sua filhinha. Mais uma tragédia entre tantas."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:147
translate portuguese dressrosa_h9_40ddef3e:

    # player "That's truly heartbreaking..."
    player "Isso é realmente de partir o coração..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:148
translate portuguese dressrosa_h9_9d98a26b:

    # riku "It really is..."
    riku "É mesmo..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:150
translate portuguese dressrosa_h9_03775ec8_1:

    # player "..."
    player "..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:151
translate portuguese dressrosa_h9_ad2601bb:

    # riku "I can't imagine how hard it must've been... But it's important that someone knows the truth, even if told as a story. Keeping the memory of what truly happened alive... keeps hope alive too."
    riku "Não consigo imaginar o quão difícil deve ter sido... Mas é importante que alguém saiba a verdade, mesmo que seja contada como uma história. Manter viva a memória do que realmente aconteceu... mantém viva também a esperança."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:152
translate portuguese dressrosa_h9_5955b90e:

    # player "Thank you for sharing this with me, [riku.n]. Time flew by... I took too much of it from you..."
    player "Obrigado por compartilhar isso comigo, [riku.n]. O tempo voou... Eu tirei muito dele de você..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:153
translate portuguese dressrosa_h9_0bf70887:

    # riku "Thank you for listening, kid. I don't usually tell this story, but... I'm glad I did."
    riku "Obrigado por me ouvir, garoto. Normalmente não conto essa história, mas... fico feliz por ter contado."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:155
translate portuguese dressrosa_h9_d079fe73:

    # narrador "In the distance, a bell rings, calling a new round of fighters..."
    narrador "Ao longe, um sino toca, anunciando o início de uma nova rodada de lutadores..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:156
translate portuguese dressrosa_h9_78767d59:

    # player "Looks like the break's over. They're calling the gladiators again."
    player "Parece que o intervalo acabou. Estão chamando os gladiadores de novo."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:157
translate portuguese dressrosa_h9_860ee2b4:

    # riku "Right. A new act begins... and it's my turn as well..."
    riku "Certo. Um novo ato começa... e é a minha vez também..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:158
translate portuguese dressrosa_h9_63c43b2e:

    # player "Take care out there, so you can tell me more about the island later."
    player "Tome cuidado lá fora, assim você poderá me contar mais sobre a ilha depois."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:159
translate portuguese dressrosa_h9_3429d75f:

    # riku "Heh, I will. But don't get careless, you should take care too! We both have to make it out of that arena in one piece first."
    riku "Heh, eu vou. Mas não se descuide, você também precisa ter cuidado! Nós dois precisamos sair daquela arena ilesos primeiro."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:160
translate portuguese dressrosa_h9_fbd4df0e:

    # player "We will. Count on it. Once the tournament's over, let's grab a drink and you can tell me the rest of [Dressrosa.n]'s story."
    player "Sim, com certeza. Assim que o torneio terminar, vamos tomar um drinque e você pode me contar o resto da história de [Dressrosa.n]."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:161
translate portuguese dressrosa_h9_d6978d0a:

    # riku "Hahaha, deal, my friend. I have a feeling you might help rewrite the true ending of this story yourself."
    riku "Hahaha, combinado, meu amigo. Tenho a impressão de que você mesmo pode ajudar a reescrever o verdadeiro final desta história."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:162
translate portuguese dressrosa_h9_a4a8300c:

    # riku "Don't ask me why, I just have that gut feeling..."
    riku "Não me pergunte porquê, eu simplesmente tenho esse pressentimento..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:163
translate portuguese dressrosa_h9_689eb837:

    # player "Huh? What do you mean...?"
    player "Hã? O que você quer dizer...?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:164
translate portuguese dressrosa_h9_3a681637:

    # riku "Nothing, nothing. Don't mind this old man. Go on, get moving! We'll see each other in the arena, kid!"
    riku "Nada, nada. Não ligue para esse velho. Vai, anda logo! A gente se vê na arena, garoto!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h9.rpy:165
translate portuguese dressrosa_h9_1393b709:

    # player "That's right! And... may the best one win!"
    player "Isso mesmo! E... que vença o melhor!"

