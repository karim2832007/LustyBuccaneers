    gatz "[logan.n] versus [player.n]!!!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:42
translate portuguese dressrosa_h13_5d73d8df:

    # gatz "Our Colosseum shakes with excitement! Two titans, one arena, this is what we've been waiting for!"
    gatz "Nosso Coliseu vibra de emoção! Dois titãs, uma arena, era isso que estávamos esperando!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:43
translate portuguese dressrosa_h13_5d087d79:

    # gatz "Only one will walk out victorious and claim eternal glory this day!"
    gatz "Apenas um sairá vitorioso e conquistará a glória eterna neste dia!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:44
translate portuguese dressrosa_h13_715800a4:

    # gatz "So without further ado..."
    gatz "Então, sem mais delongas..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:45
translate portuguese dressrosa_h13_c56eb200:

    # gatz "Let the battle... BEGIN!!!"
    gatz "Que a batalha... COMECE!!!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:47
translate portuguese dressrosa_h13_c8f1263d:

    # logan "Heh heh... Look at you, all fired up. Enjoy the cheers while they last, kid."
    logan "Hehe... Olha só você, todo animado. Aproveite os aplausos enquanto duram, garoto."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:48
translate portuguese dressrosa_h13_30548b38:

    # logan "These people love a hero now, but just wait till they see me snap you like a twig!"
    logan "Essas pessoas adoram um herói agora, mas esperem só até me verem quebrar vocês como gravetos!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:50
translate portuguese dressrosa_h13_cf8154e4:

    # player "Big talk for someone who's about to eat dirt."
    player "Muita conversa fiada para quem está prestes a comer poeira."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:52
translate portuguese dressrosa_h13_219b126d:

    # logan "Oh? The little hero has some bite! I remember seeing you earlier... sneaking around with that pretty little girl, [rebecca.n]."
    logan "Oh? O pequeno herói tem alguma mordida! Lembro-me de ter visto você mais cedo... se esgueirando com aquela garotinha bonita, [rebecca.n]."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:53
translate portuguese dressrosa_h13_f73b78c5:

    # logan "You two looked cozy in the hallway. What were you whispering, sweet nothings before the big fight?"
    logan "Vocês dois pareciam bem à vontade no corredor. O que vocês estavam sussurrando, coisas doces antes da grande briga?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:54
translate portuguese dressrosa_h13_9be391f0:

    # player "Leave her out of this, [logan.n]! I'm warning you..."
    player "Deixe-a fora disso, [logan.n]! Estou te avisando..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:56
translate portuguese dressrosa_h13_e47b027a:

    # logan "Heh heh..."
    logan "Heh heh..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:57
translate portuguese dressrosa_h13_b6a02540:

    # logan "Why? Afraid the crowd will learn how soft you really are? That you're fighting for a girl's favor?"
    logan "Por quê? Com medo de que todos descubram o quão fraco você realmente é? Que você está brigando pela atenção de uma garota?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:58
translate portuguese dressrosa_h13_f16c8766:

    # logan "Pathetic! A real warrior should focus on the fight, not on pretty dolls."
    logan "Patético! Um verdadeiro guerreiro deveria se concentrar na luta, não em bonecas bonitas."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:59
translate portuguese dressrosa_h13_2cb96b0a:

    # player "[rebecca.n] is twice the warrior you'll ever be! And she's got more honor in her little finger than you do in your whole body!"
    player "[rebecca.n] é duas vezes mais guerreira que você jamais será! E ela tem mais honra no dedinho do que você em todo o seu corpo!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:60
translate portuguese dressrosa_h13_0ad32c05:

    # logan "Ha! Honor won't save her or you. After I'm done here, maybe I'll pay dear [rebecca.n] a visit."
    logan "Ha! A honra não vai salvá-la nem a você. Depois que eu terminar aqui, talvez eu faça uma visita à querida [rebecca.n]."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:61
translate portuguese dressrosa_h13_b057ef02:

    # logan "She'll be heartbroken seeing you in pieces... but don't worry. I'll console her for you."
    logan "Ela ficará com o coração partido ao te ver em pedaços... mas não se preocupe. Eu a consolarei por você."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:62
translate portuguese dressrosa_h13_d561ee85:

    # logan "Perhaps I'll wrap these arms around her delicate frame, the same way I'm about to crush you!"
    logan "Talvez eu a envolva com meus braços, do mesmo jeito que estou prestes a te esmagar!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:64
translate portuguese dressrosa_h13_aabd3abb:

    # player "He... You bastard...!"
    player "Ele... Seu desgraçado...!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:65
translate portuguese dressrosa_h13_a4b81832:

    # player "Look, I wasn't going to forgive you anyway... but it seems you want to suffer."
    player "Olha, eu não ia te perdoar de qualquer jeito... mas parece que você quer sofrer."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:66
translate portuguese dressrosa_h13_fe299d31:

    # player "Say another word about [rebecca.n], and I swear you won't leave this arena conscious!"
    player "Diga mais uma palavra sobre [rebecca.n], e eu juro que você não sairá desta arena consciente!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:68
translate portuguese dressrosa_h13_e0f2ad3d:

    # logan "Heh heh heh..."
    logan "Heh heh heh..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:69
translate portuguese dressrosa_h13_1df89a3f:

    # logan "Hit a nerve, did I? Good! Get mad! It won't help you, but at least you'll scream loud before I break you."
    logan "Toquei num ponto sensível, não é? Ótimo! Fique com raiva! Não vai te ajudar em nada, mas pelo menos você vai gritar bem alto antes que eu te quebre."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:70
translate portuguese dressrosa_h13_4a334ba0:

    # logan "I can already see it... you on the ground, begging for mercy, while [rebecca.n] watches."
    logan "Eu já consigo ver... você no chão, implorando por misericórdia, enquanto [rebecca.n] observa."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:71
translate portuguese dressrosa_h13_e0de7449:

    # logan "Maybe I'll make her watch up close. I'll have her kneel by your broken body as I finish you off!"
    logan "Talvez eu a faça assistir de perto. Vou fazê-la ajoelhar-se ao lado do seu corpo destroçado enquanto eu acabo com você!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:72
translate portuguese dressrosa_h13_b39441a9:

    # player "[logan.n], you're digging your own grave."
    player "[logan.n], você está cavando sua própria sepultura."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:73
translate portuguese dressrosa_h13_4f890e6e:

    # logan "Bold words from a dead man walking."
    logan "Palavras ousadas de um morto-vivo."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:74
translate portuguese dressrosa_h13_b0fed0ee:

    # logan "Face it, 'hero', you're outmatched. I'm going to enjoy every second of this."
    logan "Admita, 'herói', você está em desvantagem. Vou aproveitar cada segundo disso."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:75
translate portuguese dressrosa_h13_ff40c4df:

    # player "The only one who'll be broken today is you."
    player "A única pessoa que vai se decepcionar hoje é você."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:76
translate portuguese dressrosa_h13_9a500fb4:

    # logan "Talk is cheap. Let's see you try! I'll throw you around like a rag doll."
    logan "Falar é fácil. Quero ver você tentar! Vou te jogar para lá e para cá como um boneco de pano."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:77
translate portuguese dressrosa_h13_6616fb2b:

    # player "I've heard enough. You're going to regret every word."
    player "Já ouvi o suficiente. Você vai se arrepender de cada palavra."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:78
translate portuguese dressrosa_h13_3b947a49:

    # logan "Hah! Show me what you've got, little champion! I'll show [rebecca.n] who the real man is!"
    logan "Hah! Mostre-me o que você tem, pequeno campeão! Vou mostrar [rebecca.n] quem é o verdadeiro homem!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:79
translate portuguese dressrosa_h13_220a1259:

    # player "I'm going to shut that filthy mouth of yours right here and now!"
    player "Vou calar essa sua boca imunda aqui e agora!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:80
translate portuguese dressrosa_h13_5dabc296:

    # logan "Come on then! Let's dance, hero!"
    logan "Vamos lá então! Vamos dançar, herói!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:81
translate portuguese dressrosa_h13_01fb1c97:

    # player "With pleasure!"
    player "Com prazer!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:85
translate portuguese dressrosa_h13_5df3f96f:

    # gatz "[player.n] won't stop hitting [logan.n]!"
    gatz "[player.n] não vai parar de bater [logan.n]!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:86
translate portuguese dressrosa_h13_93661a92:

    # gatz "{size=40}This is a massacre!{/size}"
    gatz "{size=40}Isto é um massacre!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:88
translate portuguese dressrosa_h13_1d57d7c2:

    # logan "Gahh—!"
    logan "Gahh—!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:89
translate portuguese dressrosa_h13_3ab6d6eb:

    # logan "You little... I'll crush you! Rolling Cradle!"
    logan "Seu... eu vou te esmagar! Berço rolante!"

