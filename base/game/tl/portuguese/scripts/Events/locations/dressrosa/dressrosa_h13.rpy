    # gatz "[logan.n] can't go on anymore!!!"
    gatz "[logan.n] não consigo continuar mais!!!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:135
translate portuguese dressrosa_h13_66e876b9:

    # gatz "[player.n] has done the impossible again!! [player.n] is truly unstoppable!!!"
    gatz "[player.n] fez o impossível novamente!! [player.n] é verdadeiramente imparável!!!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:136
