    gatz "E no canto leste, um temível veterano do Reino Majiatsuka!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:24
translate portuguese dressrosa_h13_6a5221c7:

    # gatz "A man with a reputation as a bone-crushing brute, who leaves only broken bodies in his wake!"
    gatz "Um homem com a reputação de ser um bruto implacável, que deixa apenas corpos destroçados por onde passa!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:25
translate portuguese dressrosa_h13_d253f45b:

    # gatz "He's big, he's bad, he's hungry for glory, the one and only {size=40}{outlinecolor=#8b0000}{color=#ff6666}Roooollin Loooogan{/color}{/outlinecolor}!!!{/size}"
    gatz "Ele é grande, ele é mau, ele está faminto por glória, o único e inigualável {size=40}{outlinecolor=#8b0000}{color=#ff6666}Roooollin Loooogan{/color}{/outlinecolor}!!!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h13.rpy:27
translate portuguese dressrosa_h13_6d4315c5:

