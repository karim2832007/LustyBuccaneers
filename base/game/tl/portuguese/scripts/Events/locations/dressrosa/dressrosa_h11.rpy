    # player "You need to stop, don't face your next opponent..."
    player "Você precisa parar, não enfrente seu próximo oponente..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:102
translate portuguese dressrosa_h11_bd249d94_1:

    # rebecca "!!!"
    rebecca "!!!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:103
