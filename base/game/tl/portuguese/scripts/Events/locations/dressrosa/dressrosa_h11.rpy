    # rebecca "It's pretty strange, I haven't seen him in the locker rooms either..."
    rebecca "É muito estranho, eu também não o vi nos vestiários..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:111
translate portuguese dressrosa_h11_2aed399d:

    # player "Well... that does surprise me..."
    player "Bem... isso me surpreende..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:112
