    # riku "Either way, if I can't even beat someone like that... How far out of my reach is [donflamingo.n]..."
    riku "De qualquer forma, se eu não consigo nem derrotar alguém assim... Quão fora do meu alcance está [donflamingo.n]..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:27
translate portuguese dressrosa_h11_6f8d6d0a:

    # player "You're after [donflamingo.n] too?!"
    player "Você também quer [donflamingo.n]?!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:28
translate portuguese dressrosa_h11_44585b35:

    # player "Looks like this guy has a fan club, and not the good kind..."
    player "Parece que esse cara tem um fã-clube, e não do tipo bom..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:29
translate portuguese dressrosa_h11_9491a5f5:

    # riku "Anyone who knows what this guy did to the kingdom should be displeased with him, to say the least!"
    riku "Quem souber o que esse sujeito fez ao reino deveria estar, no mínimo, insatisfeito com ele!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:30
