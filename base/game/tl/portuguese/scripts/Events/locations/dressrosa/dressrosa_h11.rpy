    player "Bem, você parece... muito mal..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:21
translate portuguese dressrosa_h11_bdbaf953:

    # riku "I tried to give it my all... but it still wasn't enough..."
    riku "Tentei dar o meu melhor... mas ainda assim não foi suficiente..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:22
translate portuguese dressrosa_h11_6e7d9cfb:

    # riku "Hahaha no one can't say this old man didn't try!!"
    riku "Hahaha, ninguém pode dizer que esse velho não tentou!!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:24
translate portuguese dressrosa_h11_aa53ef05:

    # riku "My rival... A grumpy, pointy-headed old man I met long ago... He gave me a good beating..."
    riku "Meu rival... Um velho rabugento e de cabeça pontuda que conheci há muito tempo... Ele me deu uma boa surra..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:25
translate portuguese dressrosa_h11_072ce39f:

    # riku "He showed no mercy, he was pretty angry about something involving his grandkids apparently..."
    riku "Ele não teve piedade, estava bastante irritado com algo envolvendo seus netos, aparentemente..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:26
