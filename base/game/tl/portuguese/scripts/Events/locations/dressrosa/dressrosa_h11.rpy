    # rebecca "[player.n] It's great to see you safe! I saw your last fight, you're really incredible..."
    rebecca "[player.n] Que bom te ver em segurança! Eu vi sua última luta, você é realmente incrível..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:97
translate portuguese dressrosa_h11_2b3254d9:

    # player "Heh thanks, I'm glad to see you're alright too, looks like I made it in time."
    player "Hehe, obrigado! Fico feliz em saber que você também está bem. Parece que cheguei a tempo."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:98
