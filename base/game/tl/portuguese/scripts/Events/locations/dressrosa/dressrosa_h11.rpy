    riku "Tenho medo de não poder mais protegê-la... Tudo o que posso fazer agora é tentar impedi-la..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:61
translate portuguese dressrosa_h11_693aac1f:

    # riku "We have to make her listen to reason..."
    riku "Temos que fazê-la ouvir a razão..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:62
translate portuguese dressrosa_h11_06e180e8:

    # player "Mnmm... I've run into [rebecca.n] before, she's a good girl... Very determined."
    player "Hum... Eu já encontrei [rebecca.n] antes, ela é uma boa garota... Muito determinada."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:63
translate portuguese dressrosa_h11_4b1ea739:

    # player "I doubt I can convince her to stop..."
    player "Duvido que consiga convencê-la a parar..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:64
translate portuguese dressrosa_h11_4f146eeb:

    # player "She has a clear goal to fulfill!"
    player "Ela tem um objetivo claro a cumprir!"

