    # player "I'll go look for her right now!"
    player "Vou procurá-la agora mesmo!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:75
translate portuguese dressrosa_h11_ab1a9e3e:

    # riku "Good... Koff, koff... Hraaagh!"
    riku "Bom... Koff, koff... Hraaagh!"

