    # rebecca "Heh... Well, that doesn't matter, because my answer wouldn't have changed anyway..."
    rebecca "Heh... Bem, isso não importa, porque minha resposta não teria mudado de qualquer forma..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h11.rpy:114
