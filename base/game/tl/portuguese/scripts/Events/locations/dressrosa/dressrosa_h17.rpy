    player "(Entre os últimos lutadores, ouvi rumores sobre uma habilidade chamada {outlinecolor=#a85d74}{color=#ffffff}Haki{/color}{/outlinecolor})"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:22
