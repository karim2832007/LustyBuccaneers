translate portuguese dressrosa_h17_dfef80cc:

    # diamante "Tch... this arena... no longer deserves my elegance..."
    diamante "Tch... esta arena... já não merece a minha elegância..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:169
translate portuguese dressrosa_h17_7cecf841:

    # gatz "{size=40}UNBELIEVABLE!! IT'S OVER!!!{/size}"
    gatz "{size=40}INACREDITÁVEL!! ACABOU!!!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:170
translate portuguese dressrosa_h17_50ec9d53:

    # gatz "Ladies and gentlemen, hold onto your seats!"
    gatz "Senhoras e senhores, segurem-se em seus assentos!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:171
translate portuguese dressrosa_h17_e4ce770b:

    # gatz "The undefeated champion of the Corrida Colosseum has fallen!"
    gatz "O campeão invicto do Coliseu Corrida caiu!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:172
translate portuguese dressrosa_h17_79093c2b:

    # gatz "{size=40}[diamante.n]... has been DEFEATED!!{/size}"
    gatz "{size=40}[diamante.n]... foi DERROTADO!!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:173
translate portuguese dressrosa_h17_ff9532e2:

    # gatz "And rising from the dust of combat, emerging as the true warrior of [Dressrosa.n]..."
    gatz "E erguendo-se da poeira do combate, emergindo como o verdadeiro guerreiro de [Dressrosa.n]..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:174
translate portuguese dressrosa_h17_de9fa906:

    # gatz "We have a NEW champion!! A name we will never forget..."
    gatz "Temos um NOVO campeão!! Um nome que jamais esqueceremos..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:175
translate portuguese dressrosa_h17_d655c020:

    # gatz "{size=40}Give it up for the one... the only... [player.n]!!!{/size}"
    gatz "{size=40}Aplausos para o único... o inigualável... [player.n]!!!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:176
translate portuguese dressrosa_h17_03815cbb:

    # gatz "From unknown contender to living legend, this fighter has conquered every obstacle!"
    gatz "De um aspirante desconhecido a uma lenda viva, este lutador superou todos os obstáculos!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:177
translate portuguese dressrosa_h17_a05f8947:

    # gatz "From the shadows of obscurity to the very top of the arena!"
    gatz "Das sombras da obscuridade ao topo da arena!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:178
translate portuguese dressrosa_h17_ab77132b:

    # gatz "No trick, no trap, no tyrant could stop him!"
    gatz "Nenhum truque, nenhuma armadilha, nenhum tirano conseguiu detê-lo!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:179
translate portuguese dressrosa_h17_eec16788:

    # gatz "And now, the coveted prize... the {outlinecolor=#a85d74}{color=#ffc0cb}Hana Hana Fruit!{/color}{/outlinecolor}..."
    gatz "E agora, o cobiçado prêmio... a {outlinecolor=#a85d74}{color=#ffc0cb}Fruta Hana Hana!{/color}{/outlinecolor}..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:180
translate portuguese dressrosa_h17_760e3430:

    # gatz "Will be officially awarded to [player.n] at the administration office shortly after this match!"
    gatz "Será oficialmente atribuído a [player.n] no escritório da administração logo após esta partida!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:181
translate portuguese dressrosa_h17_e8472bdb:

    # gatz "But that's not all, folks!"
    gatz "Mas isso não é tudo, pessoal!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:182
translate portuguese dressrosa_h17_99accd3c:

    # gatz "A press conference will be held after the ceremony to celebrate this monumental victory!"
    gatz "Após a cerimônia, será realizada uma coletiva de imprensa para celebrar esta vitória histórica!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:183
translate portuguese dressrosa_h17_377c8726:

    # gatz "[Dressrosa.n], let the cheers echo across the island — your new hero has arrived!!"
    gatz "[Dressrosa.n], que os aplausos ecoem por toda a ilha — seu novo herói chegou!!"

