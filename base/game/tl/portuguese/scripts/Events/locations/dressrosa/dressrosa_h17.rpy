    # player "(I can still prepare a bit more before fighting...)"
    player "(Ainda posso me preparar um pouco mais antes da luta...)"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:36
translate portuguese dressrosa_h17_if_a53cca3b:

    # player "(I'll come back later)"
    player "(Vou voltar mais tarde)"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:50
translate portuguese dressrosa_h17_daf5c4aa:

    # gatz "{size=40}Weeeeeeeeeelcome back, ladies and gentlemen, toys and dolls!{/size}"
    gatz "{size=40}Bem-vindos de volta, senhoras e senhores, brinquedos e bonecas!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:51
translate portuguese dressrosa_h17_26246797:

    # gatz "{size=40}Welcome everyone once again to the Corrida Coliseum!{/size}"
    gatz "{size=40}Sejam todos bem-vindos novamente ao Coliseu Corrida!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:57
translate portuguese dressrosa_h17_cfe4495f:

    # gatz "After a series of breathtaking battles, bone-crushing blows, and roaring crowd chants..."
    gatz "Após uma série de batalhas de tirar o fôlego, golpes brutais e cânticos ensurdecedores da multidão..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:58
translate portuguese dressrosa_h17_dca7d3ce:

    # gatz "We have finally arrived at the moment you've all been waiting for!"
    gatz "Finalmente chegamos ao momento que todos vocês estavam esperando!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:59
translate portuguese dressrosa_h17_bde525c0:

    # gatz "{size=40}The GRAND FINALE of the Corrida Coliseum Tournament!{/size}"
    gatz "{size=40}A GRANDE FINAL do Torneio do Coliseu Corrida!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:61
translate portuguese dressrosa_h17_4e091e32:

    # gatz "Only one will claim the ultimate glory..."
    gatz "Apenas um conquistará a glória suprema..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:62
translate portuguese dressrosa_h17_74c715f1:

    # gatz "Only one will walk away holding the mysterious and coveted prize..."
    gatz "Apenas um sairá com o misterioso e cobiçado prêmio..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:63
translate portuguese dressrosa_h17_c267b85f:

    # gatz "The legendary, {outlinecolor=#a85d74}{color=#ffc0cb}Hana Hana Fruit!{/color}{/outlinecolor}!"
    gatz "A lendária, {outlinecolor=#a85d74}{color=#ffc0cb}Fruta Hana Hana!{/color}{/outlinecolor}!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:64
translate portuguese dressrosa_h17_2cdb6128:

    # gatz "The Devil Fruit of blossoming limbs! A power so rare... so deliciously dangerous..."
    gatz "A Fruta do Diabo dos membros em flor! Um poder tão raro... tão deliciosamente perigoso..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:65
translate portuguese dressrosa_h17_e3e083be:

    # gatz "It will belong to ONE of these two incredible fighters!"
    gatz "Vai pertencer a UM destes dois lutadores incríveis!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:68
translate portuguese dressrosa_h17_7249133a:

    # gatz "Standing in the left corner, with the swagger of a champion and a heart that never quits..."
    gatz "Posicionado no canto esquerdo, com a arrogância de um campeão e um coração que jamais desiste..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:69
translate portuguese dressrosa_h17_e0949867:

    # gatz "The underdog who silenced giants, turned heads, and stole the crowd's hearts!"
    gatz "O azarão que silenciou gigantes, chamou a atenção de todos e conquistou o coração do público!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:70
translate portuguese dressrosa_h17_a3e3a32f:

    # gatz "Give it up for the crowd's new favorite, [player.n]!!!!"
    gatz "Aplausos para o novo favorito da multidão, [player.n]!!!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:72
translate portuguese dressrosa_h17_3398aa7c:

    # unknown "{size=40}[player.n]!! [player.n]!! [player.n]!!{/size}"
    unknown "{size=40}[player.n]!! [player.n]!! [player.n]!!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:74
translate portuguese dressrosa_h17_c7c821a0:

    # gatz "And in the right corner..."
    gatz "E no canto direito..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:75
translate portuguese dressrosa_h17_e98e994a:

    # gatz "The man who needs no introduction..."
    gatz "O homem que dispensa apresentações..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:76
translate portuguese dressrosa_h17_651cdb65:

    # gatz "A member of the elite Donquixote Family!"
    gatz "Um membro da elite da família Donquixote!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:77
translate portuguese dressrosa_h17_bc8e0bb7:

    # gatz "The Hero of the Arena! The Flagbearer of Destruction!"
    gatz "O Herói da Arena! O Porta-estandarte da Destruição!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:78
translate portuguese dressrosa_h17_f813474b:

    # gatz "The living embodiment of cruelty and spectacle..."
    gatz "A personificação viva da crueldade e do espetáculo..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:79
translate portuguese dressrosa_h17_70dff5c2:

    # gatz "Make way for the one and only... {size=40}{outlinecolor=#8b0000}{color=#ff6666}Diamanteeeeeeee{/color}{/outlinecolor}!{/size}"
    gatz "Abram caminho para o único e inigualável... {size=40}{outlinecolor=#8b0000}{color=#ff6666}Diamanteeeeeeee{/color}{/outlinecolor}!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:81
translate portuguese dressrosa_h17_dceb7ff5:

    # unknown "{size=40}[diamante.n]!! [diamante.n]!! [diamante.n]!!{/size}"
    unknown "{size=40}[diamante.n]!! [diamante.n]!! [diamante.n]!!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:88
translate portuguese dressrosa_h17_7c08e8f0:

    # gatz "Diamante has been undefeated in the ring for years!"
    gatz "Diamante está invicto no ringue há anos!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:89
translate portuguese dressrosa_h17_18d4cd09:

    # gatz "His swordplay? Deadly. His cape? Unpredictable. His cruelty? Unmatched!"
    gatz "Sua esgrima? Mortal. Sua capa? Imprevisível. Sua crueldade? Inigualável!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:90
translate portuguese dressrosa_h17_8914efc6:

    # gatz "He represents not just power, but the iron rule of the Donquixote Family!"
    gatz "Ele representa não apenas o poder, mas o domínio férreo da Família Donquixote!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:91
translate portuguese dressrosa_h17_9a51d2b0:

    # gatz "And tonight... he faces a new challenger."
    gatz "E esta noite... ele enfrenta um novo desafiante."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:92
translate portuguese dressrosa_h17_1778583e:

    # gatz "One who's climbed through the ranks, torn through warriors, and earned every drop of applause!"
    gatz "Alguém que galgou todos os degraus da hierarquia, enfrentou guerreiros implacáveis e conquistou cada aplauso merecido!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:93
translate portuguese dressrosa_h17_5f3408c6:

    # gatz "{size=40}Tonight is the night legends are written in blood and glory!{/size}"
    gatz "{size=40}Esta noite é a noite em que as lendas são escritas com sangue e glória!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:95
translate portuguese dressrosa_h17_80c296a8:

    # gatz "And what's more..."
    gatz "E mais..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:96
translate portuguese dressrosa_h17_bf9244ba:

    # gatz "The winner won't just walk away with the Hana Hana no Mi..."
    gatz "O vencedor não sairá simplesmente com a Hana Hana no Mi..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:97
translate portuguese dressrosa_h17_603df856:

    # gatz "They will have proven themselves worthy of standing atop this coliseum's brutal legacy!"
    gatz "Eles terão provado ser dignos de estar no topo do legado brutal deste coliseu!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:98
translate portuguese dressrosa_h17_f7df17d0:

    # gatz "This isn't just a fight... it's a moment carved into the history of [Dressrosa.n]!"
    gatz "Isto não é apenas uma luta... é um momento gravado na história de [Dressrosa.n]!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:100
translate portuguese dressrosa_h17_dc968328:

    # gatz "Let the ground tremble under the weight of your will!"
    gatz "Que a terra trema sob o peso da sua vontade!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:101
translate portuguese dressrosa_h17_bb151a2c:

    # gatz "Let steel clash, let pain sing—this is your final test, warriors!"
    gatz "Que o aço se choque, que a dor cante — este é o seu teste final, guerreiros!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:105
translate portuguese dressrosa_h17_35fe23f6:

    # diamante "So... you're the little star everyone's been cheering for..."
    diamante "Então... você é a estrelinha que todos estão torcendo..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:106
translate portuguese dressrosa_h17_3839d2cd:

    # narrador "Without continuing what he was saying, [diamante.n] stops and watches you for a moment... Noticing something that wasn't part of his plans."
    narrador "Sem continuar o que estava dizendo, [diamante.n] para e observa você por um momento... Percebendo algo que não fazia parte de seus planos."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:107
translate portuguese dressrosa_h17_54171a8a:

    # diamante "What the...?! You're still standing?!"
    diamante "O quê?! Você ainda está de pé?!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:108
translate portuguese dressrosa_h17_4179b52c:

    # diamante "You should be half-dead after that little 'surprise' backstage..."
    diamante "Você deve estar quase morto depois daquela pequena 'surpresa' nos bastidores..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:109
translate portuguese dressrosa_h17_ffd0a098:

    # player "Yeah... someone forgot to tell your goons I'm allergic to cheap tricks."
    player "É... alguém se esqueceu de avisar seus capangas que eu sou alérgico a truques baratos."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:110
translate portuguese dressrosa_h17_7e787108:

    # diamante "Tch... those imbeciles promised you'd be broken before stepping in here."
    diamante "Tch... aqueles imbecis prometeram que você estaria quebrado antes de entrar aqui."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:111
translate portuguese dressrosa_h17_7733ecaf:

    # player "Well, I stepped in, stretched a bit, and now I'm warmed up for *you*."
    player "Bom, entrei, me alonguei um pouco e agora estou aquecido para *você*."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:112
translate portuguese dressrosa_h17_d5554017:

    # diamante "Heh... cocky till the end. I admire that... in a corpse."
    diamante "Heh... arrogante até o fim. Admiro isso... em um cadáver."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:113
translate portuguese dressrosa_h17_a52814c5:

    # player "Better get used to disappointment, shiny boy."
    player "É melhor você se acostumar com a decepção, garoto brilhante."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:114
translate portuguese dressrosa_h17_496765eb:

    # diamante "Damn it... I'm surrounded by incompetents!"
    diamante "Droga... Estou cercado de incompetentes!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:115
translate portuguese dressrosa_h17_01e4292e:

    # diamante "If you want something done right... you do it yourself!"
    diamante "Se você quer algo bem feito... faça você mesmo!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:116
translate portuguese dressrosa_h17_bfcfc5e2:

    # player "Finally something smart came out of your mouth."
    player "Finalmente, algo inteligente saiu da sua boca."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:117
translate portuguese dressrosa_h17_164f050c:

    # diamante "Uhahahaha! I've crushed tougher men than you while fixing my hair in the reflection of my sword."
    diamante "Hahahaha! Já esmaguei homens mais fortes que você enquanto arrumava meu cabelo no reflexo da minha espada."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:118
translate portuguese dressrosa_h17_b72033f5:

    # player "Guess I'll be the first to mess up that pretty reflection then."
    player "Acho que serei o primeiro a estragar esse reflexo bonito, então."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:119
translate portuguese dressrosa_h17_f3d0430c:

    # diamante "Big words for a nobody. Do you even understand who you're talking to?"
    diamante "Palavras difíceis para um ninguém. Você sequer entende com quem está falando?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:120
translate portuguese dressrosa_h17_31021f47:

    # player "The clown standing between me and the Hana Hana no Mi? Yeah, I got that part."
    player "O palhaço parado entre mim e a Hana Hana no Mi? Sim, eu entendi essa parte."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:121
translate portuguese dressrosa_h17_9e1a5198:

    # diamante "You're in way over your head, rookie. This ring is MY kingdom."
    diamante "Você está se metendo em algo muito maior do que pode lidar, novato. Este ringue é o MEU reino."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:122
translate portuguese dressrosa_h17_18a45ec6:

    # diamante "I'm not just a gladiator. I am the standard of pain. The art of torment!"
    diamante "Eu não sou apenas um gladiador. Eu sou o padrão da dor. A arte do tormento!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:123
translate portuguese dressrosa_h17_70b307bc:

    # player "You talk a lot. Maybe if you screamed that at [donflamingo.n] loud enough, he'd finally respect you."
    player "Você fala muito. Talvez se você gritasse isso [donflamingo.n] bem alto, ele finalmente te respeitaria."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:124
translate portuguese dressrosa_h17_83f4d5e1:

    # diamante "You insolent brat... You DARE speak his name like that?"
    diamante "Seu pirralho insolente... Você OUSA pronunciar o nome dele desse jeito?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:125
translate portuguese dressrosa_h17_654bc5f0:

    # player "I'll speak it again after I defeat you... and tear down everything you stand for."
    player "Direi isso novamente depois de derrotá-lo... e destruir tudo o que você representa."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:126
translate portuguese dressrosa_h17_9d054834:

    # diamante "This isn't some fairytale, you fool. People like you don't win in real life."
    diamante "Isso não é um conto de fadas, seu tolo. Pessoas como você não vencem na vida real."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:127
translate portuguese dressrosa_h17_c4d3ae3a:

    # player "Then maybe it's time to rewrite the ending."
    player "Então talvez seja hora de reescrever o final."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:128
translate portuguese dressrosa_h17_bbd811f8:

    # diamante "Oh? Planning to be the hero now?"
    diamante "Ah, é? Planeja bancar o herói agora?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:129
translate portuguese dressrosa_h17_f9b73e6b:

    # player "No. Just the guy who knocks your teeth out in front of thousands."
    player "Não. Só o cara que te dá um soco na boca na frente de milhares de pessoas."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:130
translate portuguese dressrosa_h17_98f05f0f:

    # diamante "You're making a huge mistake... This arena is built to glorify warriors like ME!"
    diamante "Você está cometendo um grande erro... Esta arena foi construída para glorificar guerreiros como EU!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:131
translate portuguese dressrosa_h17_1550992e:

    # player "Then tonight it's under construction, cause I'm about to wreck everything."
    player "Então, esta noite estará em construção, porque estou prestes a destruir tudo."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:132
translate portuguese dressrosa_h17_131dafa4:

    # diamante "You're confident. I'll give you that. Arrogance makes your fall even more satisfying."
    diamante "Você é confiante. Isso eu admito. A arrogância torna sua queda ainda mais satisfatória."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:133
translate portuguese dressrosa_h17_977c257b:

    # player "I'm not here for satisfaction. I'm here to win."
    player "Não estou aqui em busca de satisfação. Estou aqui para vencer."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:134
translate portuguese dressrosa_h17_5d356978:

    # diamante "Let's see if you still talk that big after I make you crawl."
    diamante "Vamos ver se você ainda vai continuar falando tão grosso depois que eu te fizer rastejar."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:135
translate portuguese dressrosa_h17_f1fb6d38:

    # player "Let's see if you still smirk after you taste the dirt."
    player "Vamos ver se você ainda vai sorrir depois de provar a terra."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:139
translate portuguese dressrosa_h17_84b9b280:

    # gatz "Well... It seems everything has been said... The contenders are about to face each other..."
    gatz "Bem... Parece que tudo já foi dito... Os competidores estão prestes a se enfrentar..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:140
translate portuguese dressrosa_h17_b8bcba0a:

    # gatz "[player.n]! [diamante.n]!"
    gatz "[player.n]! [diamante.n]!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:141
translate portuguese dressrosa_h17_26626969:

    # gatz "Give the crowd a show they'll never forget!"
    gatz "Dê ao público um espetáculo que eles jamais esquecerão!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:142
translate portuguese dressrosa_h17_a660ece8:

    # gatz "{size=40}Crowd, are you ready?!{/size}"
    gatz "{size=40}Multidão, estão prontos?!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:143
translate portuguese dressrosa_h17_88031e87:

    # gatz "Let's count it down together!"
    gatz "Vamos fazer a contagem regressiva juntos!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h17.rpy:144
