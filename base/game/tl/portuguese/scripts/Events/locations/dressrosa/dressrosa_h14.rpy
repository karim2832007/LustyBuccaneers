    rebecca "Você... você fez isso?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:58
translate portuguese dressrosa_h14_77a4ba06:

    # player "Ever since we fought side by side in that colosseum... every time you smiled at me after a tough battle, every time you trusted me when everything seemed lost..."
    player "Desde que lutamos lado a lado naquele coliseu... cada vez que você sorriu para mim depois de uma batalha difícil, cada vez que você confiou em mim quando tudo parecia perdido..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:59
