    # player "Those moments we shared, supporting each other through all the pain and fear... they meant everything to me."
    player "Aqueles momentos que compartilhamos, apoiando-nos mutuamente em meio a toda a dor e medo... significaram tudo para mim."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:60
translate portuguese dressrosa_h14_cbe2a792:

    # player "You've become someone incredibly special, [rebecca.n]. More than just a friend, more than an ally."
    player "Você se tornou alguém incrivelmente especial, [rebecca.n]. Mais do que apenas um amigo, mais do que um aliado."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:63
