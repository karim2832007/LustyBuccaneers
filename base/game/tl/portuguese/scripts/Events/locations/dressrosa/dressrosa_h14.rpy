    # player "I could really use some... relaxation right now."
    player "Eu bem que preciso de um pouco de... relaxamento agora."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:108
translate portuguese dressrosa_h14_c66e78ea:

    # rebecca "What do you mean?"
    rebecca "O que você quer dizer?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h14.rpy:109
