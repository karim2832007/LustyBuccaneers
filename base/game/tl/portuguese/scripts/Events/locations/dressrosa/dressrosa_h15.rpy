# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:13
translate portuguese dressrosa_h15_daf5c4aa:

    # gatz "{size=40}Weeeeeeeeeelcome back, ladies and gentlemen, toys and dolls!{/size}"
    gatz "{size=40}Bem-vindos de volta, senhoras e senhores, brinquedos e bonecas!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:14
translate portuguese dressrosa_h15_26246797:

    # gatz "{size=40}Welcome everyone once again to the Corrida Coliseum!{/size}"
    gatz "{size=40}Sejam todos bem-vindos novamente ao Coliseu Corrida!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:20
translate portuguese dressrosa_h15_f8fabcec:

    # gatz "The excitement is at its peak as we bring you the final round of today's tournament!"
    gatz "A emoção está no auge enquanto trazemos para vocês a rodada final do torneio de hoje!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:21
translate portuguese dressrosa_h15_5b8086f4:

    # gatz "This match will decide who earns the right to challenge the Hero of the Colosseum, {size=40}{outlinecolor=#8b0000}{color=#ff6666}Diamanteeeeeeee{/color}{/outlinecolor}!{/size}, in the grand finals!"
    gatz "Esta partida decidirá quem conquista o direito de desafiar o Herói do Coliseu, {size=40}{outlinecolor=#8b0000}{color=#ff6666}Diamanteeeeeeee{/color}{/outlinecolor}!{/size}, na grande final!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:22
translate portuguese dressrosa_h15_832194fa:

    # gatz "And of course, they're fighting for the ultimate prize: the legendary the [HanaHanaFruit.n] fruit!!"
    gatz "E, claro, eles estão lutando pelo prêmio máximo: a lendária fruta [HanaHanaFruit.n]!!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:24
translate portuguese dressrosa_h15_a2d065b4:

    # gatz "In this corner, we have a warrior whose name strikes fear and awe!"
    gatz "Neste canto, temos um guerreiro cujo nome inspira medo e admiração!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:25
translate portuguese dressrosa_h15_46689ef0:

    # gatz "He is the former leader of the Happo Navy, a living legend from Kano Country!"
    gatz "Ele é o antigo líder da Marinha Happo, uma lenda viva do Condado de Kano!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:26
translate portuguese dressrosa_h15_8f69cf46:

    # gatz "A man once known as {outlinecolor=[chinjao.color]}{color=#61f59a}'Chinjao the Drill'{/color}{/outlinecolor} - with a bounty of over 500 million berries on his head!"
    gatz "Um homem outrora conhecido como {outlinecolor=[chinjao.color]}{color=#61f59a}'Chinjao, o Perfurador'{/color}{/outlinecolor} - com uma recompensa de mais de 500 milhões berries pela sua cabeça!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:27
translate portuguese dressrosa_h15_10e3a499:

    # gatz "Yes, folks, it's the one and only DON {size=40}[chinjao.n]{/size}!!!"
    gatz "Sim, pessoal, é o único e inigualável DON {size=40}[chinjao.n]{/size}!!!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:29
translate portuguese dressrosa_h15_86e92f5e:

    # unknown "{size=40}[chinjao.n]!! [chinjao.n]!! [chinjao.n]!!{/size}"
    unknown "{size=40}[chinjao.n]!! [chinjao.n]!! [chinjao.n]!!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:35
translate portuguese dressrosa_h15_ecd41763:

    # gatz "Listen to that roar from the crowd! They remember his glory days!"
    gatz "Ouçam o rugido da multidão! Eles se lembram dos seus dias de glória!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:36
translate portuguese dressrosa_h15_490468c0:

    # gatz "And in the opposite corner, a rising star who has taken this tournament by storm!"
    gatz "E no canto oposto, uma estrela em ascensão que conquistou este torneio!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:37
translate portuguese dressrosa_h15_4f62642f:

    # gatz "This young contender came out of nowhere and defeated veteran gladiators one after another!"
    gatz "Este jovem competidor surgiu do nada e derrotou gladiadores veteranos um após o outro!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:38
translate portuguese dressrosa_h15_6f395053:

    # gatz "He has shown incredible strength, winning the hearts of the audience along the way!"
    gatz "Ele demonstrou uma força incrível, conquistando o coração do público ao longo do caminho!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:39
translate portuguese dressrosa_h15_7cbbf6bd:

    # gatz "Now he stands just one fight away from the championship round!"
    gatz "Agora ele está a apenas uma luta da rodada final do campeonato!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:40
translate portuguese dressrosa_h15_6e8d2cf4:

    # gatz "Give it up for our dark horse contender... {size=40}[player.n]{/size}!!!"
    gatz "Vamos lá, nosso azarão... {size=40}[player.n]{/size}!!!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:42
translate portuguese dressrosa_h15_3398aa7c:

    # unknown "{size=40}[player.n]!! [player.n]!! [player.n]!!{/size}"
    unknown "{size=40}[player.n]!! [player.n]!! [player.n]!!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:44
translate portuguese dressrosa_h15_f98902e2:

    # gatz "The crowd is on their feet for this newcomer!"
    gatz "A multidão está de pé para aplaudir este estreante!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:45
translate portuguese dressrosa_h15_efa8ae46:

    # gatz "Both fighters look ready to clash with everything they've got!"
    gatz "Ambos os lutadores parecem prontos para se enfrentarem com tudo o que têm!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:46
translate portuguese dressrosa_h15_4517af0c:

    # gatz "I can feel the tension from up here - this will be one for the history books!"
    gatz "Consigo sentir a tensão daqui de cima - isto vai ficar para a história!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:47
translate portuguese dressrosa_h15_ff785438:

    # gatz "Only one can move on to face Diamante and seize the [HanaHanaFruit.n] fruit!!"
    gatz "Apenas um pode avançar para enfrentar Diamante e tomar posse da fruta [HanaHanaFruit.n]!!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:48
translate portuguese dressrosa_h15_11f8ff6c:

    # gatz "Who will it be? The veteran legend or the fearless upstart?!"
    gatz "Quem será? A lenda veterana ou o ousado novato?!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:49
translate portuguese dressrosa_h15_114383c1:

    # gatz "Gladiators... FIGHT!!"
    gatz "Gladiadores... LUTEM!!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:53
translate portuguese dressrosa_h15_d1a2178c:

    # chinjao "Before we begin... I have something to say!"
    chinjao "Antes de começarmos... tenho algo a dizer!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:54
translate portuguese dressrosa_h15_9a2346e5:

    # chinjao "This tournament is a sham! Something foul is going on behind the scenes!"
    chinjao "Este torneio é uma farsa! Há algo de errado acontecendo nos bastidores!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:56
translate portuguese dressrosa_h15_0f5f02ca:

    # player "!!!"
    player "!!!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:58
translate portuguese dressrosa_h15_40d394d4:

    # chinjao "My grandsons, Boo and Sai, fought here earlier today."
    chinjao "Meus netos, Boo e Sai, lutaram aqui hoje mais cedo."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:59
translate portuguese dressrosa_h15_f92d8539:

    # chinjao "They were injured and taken away to treat their wounds... but they never returned!"
    chinjao "Eles ficaram feridos e foram levados para tratar seus ferimentos... mas nunca mais voltaram!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:60
translate portuguese dressrosa_h15_40676457:

    # chinjao "What have you people done with them?! I demand to know!"
    chinjao "O que vocês fizeram com eles?! Exijo saber!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:61
translate portuguese dressrosa_h15_cc457059:

    # player "Your grandsons? I... I don't know anything about that."
    player "Seus netos? Eu... eu não sei nada sobre isso."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:62
translate portuguese dressrosa_h15_247bff19:

    # chinjao "Don't lie to me! You're part of this, whether you know it or not!"
    chinjao "Não minta para mim! Você faz parte disso, quer saiba ou não!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:63
translate portuguese dressrosa_h15_c4bdf10b:

    # player "Me?!? Hahah I'm only here to fight for the prize. I'm not involved in whatever happened to them."
    player "Eu?!? Hahaha, estou aqui apenas para lutar pelo prêmio. Não estou envolvido no que aconteceu com eles."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:64
translate portuguese dressrosa_h15_31d5e76f:

    # chinjao "Grr... If those bastards running this event hurt my family, I swear they'll pay!"
    chinjao "Grrr... Se aqueles desgraçados que organizam esse evento fizerem mal à minha família, eu juro que vão pagar!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:65
translate portuguese dressrosa_h15_950702ca:

    # chinjao "I won't rest until I get Boo and Sai back!"
    chinjao "Não descansarei enquanto não tiver Boo e Sai de volta!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:66
translate portuguese dressrosa_h15_f080dacd:

    # player "I'm sorry about Boo and Sai. I'd be angry too if I were in your place."
    player "Sinto muito pelo Boo e pelo Sai. Eu também ficaria com raiva se estivesse no seu lugar."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:67
translate portuguese dressrosa_h15_28d951d9:

    # player "But right now, I'm your opponent. If you want answers, you'll have to go through me first."
    player "Mas agora, eu sou seu oponente. Se você quer respostas, terá que passar por mim primeiro."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:68
translate portuguese dressrosa_h15_4c07badc:

    # chinjao "Hmph, you cocky brat. Fine. I'll go through you!"
    chinjao "Hum, seu pirralho convencido. Ótimo. Vou passar por cima de você!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:69
translate portuguese dressrosa_h15_2efe423c:

    # chinjao "Don't think for a second that I'm some weak old man!"
    chinjao "Não pensem nem por um segundo que eu sou um velho fraco!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:70
translate portuguese dressrosa_h15_8ee29e99:

    # chinjao "I once had a drill for a head that could split an entire ice continent in two!"
    chinjao "Eu tinha uma furadeira com uma cabeça que conseguia partir um continente inteiro de gelo em dois!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:71
translate portuguese dressrosa_h15_3cc64c61:

    # player "A... drill on your head?"
    player "Uma... broca na sua cabeça?"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:72
translate portuguese dressrosa_h15_28af3779:

    # chinjao "That's right! I was [chinjao.n] the Drill!"
    chinjao "Isso mesmo! Eu era [chinjao.n] o Drill!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:73
translate portuguese dressrosa_h15_fc337b34:

    # chinjao "Until a legendary Marine hero smashed it flat with a single punch!"
    chinjao "Até que um lendário herói dos fuzileiros navais a destruiu com um único soco!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:74
translate portuguese dressrosa_h15_0d031db1:

    # player "I guess he was a strong guy..."
    player "Acho que ele era um cara forte..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:75
translate portuguese dressrosa_h15_a6864a88:

    # chinjao "That accursed geezer flattened my head and took away my power!"
    chinjao "Aquele velho maldito achatou minha cabeça e me tirou a energia!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:76
translate portuguese dressrosa_h15_d8602e88:

    # chinjao "All the treasure I had beneath the ice... gone, because I couldn't crack it open anymore!"
    chinjao "Todo o tesouro que eu tinha debaixo do gelo... sumiu, porque eu não consegui mais quebrá-lo!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:77
translate portuguese dressrosa_h15_ce36d984:

    # chinjao "For decades, I carried that shame and hatred!"
    chinjao "Durante décadas, carreguei essa vergonha e esse ódio!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:78
translate portuguese dressrosa_h15_7eabd0bf:

    # chinjao "I won't be made a fool of again!"
    chinjao "Não vou mais ser feito de bobo!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:79
translate portuguese dressrosa_h15_15e6167a:

    # chinjao "First that geezer took my power... and now this colosseum thinks it can take my own flesh and blood!"
    chinjao "Primeiro aquele velho tirou meu poder... e agora esse coliseu acha que pode tirar minha própria carne e sangue!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:80
translate portuguese dressrosa_h15_a3bbc527:

    # chinjao "I will tear this place apart if I have to!"
    chinjao "Eu vou destruir este lugar se for preciso!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:82
translate portuguese dressrosa_h15_00b7e498:

    # chinjao "Show me your strength, kid! Prove that you're worth my time!"
    chinjao "Mostre-me sua força, garoto! Prove que você merece meu tempo!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:83
translate portuguese dressrosa_h15_e7acf1de:

    # player "You'll see soon enough!"
    player "Você verá em breve!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:89
translate portuguese dressrosa_h15_8b6a00cc:

    # chinjao "Heh... I'll be damned. I never thought you'd overpower me like that!"
    chinjao "Heh... Que coisa! Nunca pensei que você fosse me dominar assim!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:90
translate portuguese dressrosa_h15_5ede0433:

    # chinjao "Your blows... they carried more than just brute strength. I felt the conviction behind each strike."
    chinjao "Seus golpes... eles carregavam mais do que mera força bruta. Eu sentia a convicção por trás de cada desferimento."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:91
translate portuguese dressrosa_h15_ca81198e:

    # chinjao "You fought with all your heart... and you've earned this old man's respect."
    chinjao "Você lutou com todas as suas forças... e conquistou o respeito deste velho."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:92
translate portuguese dressrosa_h15_b26feb2c:

    # chinjao "Keep moving forward... and may your name thunder even louder than mine someday..."
    chinjao "Continue avançando... e que seu nome seja ainda mais forte que o meu algum dia..."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:93
translate portuguese dressrosa_h15_c3e53b7a:

    # chinjao "Now... at least I can go see my nephews Boo and Sai in the hospital."
    chinjao "Agora... pelo menos posso ir visitar meus sobrinhos Boo e Sai no hospital."

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:102
translate portuguese dressrosa_h15_f8dc29ef:

    # gatz "DON [chinjao.n] IS DOWN!!"
    gatz "DON [chinjao.n] CAIU!!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:103
translate portuguese dressrosa_h15_ef8f1fc3:

    # gatz "We have a winner! The match goes to... {size=40}[player.n]{/size}!!!"
    gatz "Temos um vencedor! A partida vai para... {size=40}[player.n]{/size}!!!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:104
translate portuguese dressrosa_h15_a65f7213:

    # gatz "He started this tournament as a nobody, but has taken down opponent after opponent!"
    gatz "Ele começou este torneio como um completo desconhecido, mas derrotou um oponente após o outro!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:106
translate portuguese dressrosa_h15_3398aa7c_1:

    # unknown "{size=40}[player.n]!! [player.n]!! [player.n]!!{/size}"
    unknown "{size=40}[player.n]!! [player.n]!! [player.n]!!{/size}"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:108
translate portuguese dressrosa_h15_d0623ce2:

    # gatz "With each victory, he's proven his strength and won the hearts of the audience!"
    gatz "A cada vitória, ele demonstra sua força e conquista o coração do público!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:109
translate portuguese dressrosa_h15_fb9ea802:

    # gatz "Now he's just one step away from claiming the grand prize!"
    gatz "Agora ele está a apenas um passo de conquistar o grande prêmio!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:110
translate portuguese dressrosa_h15_100be0b6:

    # gatz "But that final step is a battle against none other than the Hero of the Colosseum himself - Diamante!"
    gatz "Mas esse passo final é uma batalha contra ninguém menos que o próprio Herói do Coliseu - Diamante!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:111
translate portuguese dressrosa_h15_57b9119c:

    # gatz "The championship match will take place after a short recess!"
    gatz "A partida final do campeonato acontecerá após um breve intervalo!"

# game/scripts/Events/Locations/Dressrosa/dressrosa_h15.rpy:112
translate portuguese dressrosa_h15_322383b0:

    # gatz "So don't go anywhere, folks - the grand finale is coming up next!"
    gatz "Então não saiam daí, pessoal - o grande final está chegando!"

