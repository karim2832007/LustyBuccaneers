# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:9
translate portuguese ar_alubarna_h_ea533ad1:

    # vivi "Well, we've finally arrived. This is Alubarna, the capital of the Kingdom of Arabasta."
    vivi "Bem, finalmente chegamos. Esta é Alubarna, a capital do Reino de Alabasta."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:10
translate portuguese ar_alubarna_h_e979c3ce:

    # vivi "Like any capital, it's a big place full of people."
    vivi "Como qualquer capital, é um lugar grande e cheio de pessoas."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:11
translate portuguese ar_alubarna_h_4762d9b6:

    # vivi "It's easy to get lost, so stay close to me... We must take the fastest route possible..."
    vivi "É fácil se perder, então fique perto de mim... Devemos pegar o caminho mais rápido possível..."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:15
translate portuguese ar_alubarna_h_a83ddf54:

    # vivi "Chaos seems to be spreading everywhere already..."
    vivi "O caos parece já estar se espalhando por toda parte..."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:16
translate portuguese ar_alubarna_h_726d3611:

    # vivi "The rebels must have started clashing in the streets with the royal forces..."
    vivi "Os rebeldes devem ter começado a entrar em confronto nas ruas com as forças reais..."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:17
translate portuguese ar_alubarna_h_f623f734:

    # vivi "I have to stop the bloodshed no matter what... We must hurry!"
    vivi "Tenho que parar o derramamento de sangue, não importa o que aconteça... Temos que nos apressar!"

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:19
translate portuguese ar_alubarna_h_e05e2508:

    # vivi "We need to go to the royal palace."
    vivi "Precisamos ir ao palácio real."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:20
translate portuguese ar_alubarna_h_2625cdcb:

    # vivi "I know a shortcut I used as a child with [koza.n]."
    vivi "Conheço um atalho que usei quando criança com [koza.n]."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:21
translate portuguese ar_alubarna_h_f68b79bc:

    # vivi "It's the fastest way to get there while avoiding detection."
    vivi "É a maneira mais rápida de chegar lá sem ser detectado."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:23
translate portuguese ar_alubarna_h_688c5abf:

    # player "Alright!! On our way, let's go defeat [crocodile.n]!"
    player "Tudo bem!! Vamos derrotar [crocodile.n]!"

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:25
translate portuguese ar_alubarna_h_4e7ec1c2:

    # vivi "I'm glad to see you so confident... He's a very difficult enemy, please don't underestimate him..."
    vivi "Fico feliz em ver você tão confiante... Ele é um inimigo muito difícil, por favor, não o subestime..."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:26
translate portuguese ar_alubarna_h_abcf607c:

    # vivi "I've been thinking about this day for a long time... And I came prepared..."
    vivi "Eu estava pensando sobre esse dia há muito tempo... E eu vim preparado..."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:27
translate portuguese ar_alubarna_h_8b3c2fc4:

    # vivi "Before the fight, I need to tell you something."
    vivi "Antes da luta, preciso te contar uma coisa."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:28
translate portuguese ar_alubarna_h_16c271b7:

    # vivi "When I infiltrated the Baroque Works organization, I tried to gather all the information I could about its leader."
    vivi "Quando me infiltrei na organização Baroque Works, tentei reunir todas as informações possíveis sobre seu líder."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:29
translate portuguese ar_alubarna_h_a49608e9:

    # vivi "And my efforts paid off..."
    vivi "E meus esforços valeram a pena..."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:30
translate portuguese ar_alubarna_h_0c7cde7a:

    # vivi "I discovered one of [crocodile.n]'s secrets, and it's that his strength doesn't just come from his intelligence, violence, and leadership..."
    vivi "Descobri um dos segredos de [crocodile.n], e é que sua força não vem apenas de sua inteligência, violência e liderança..."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:31
translate portuguese ar_alubarna_h_ec8e46e6:

    # vivi "[crocodile.n] is a Devil Fruit user..."
    vivi "[crocodile.n] é um usuário de Akuma no Mi..."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:33
translate portuguese ar_alubarna_h_2fccefef:

    # player "One of those fruits that give you supernatural powers?"
    player "Uma daquelas frutas que lhe dão poderes sobrenaturais?"

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:35
translate portuguese ar_alubarna_h_ab87d114:

    # vivi "Exactly..."
    vivi "Exatamente..."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:36
translate portuguese ar_alubarna_h_6cc9f814:

    # vivi "[crocodile.n] is a user of the Suna Suna no Mi fruit."
    vivi "[crocodile.n] é um usuário da fruta Suna Suna no Mi."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:37
translate portuguese ar_alubarna_h_998bc8c8:

    # vivi "This isn't just any fruit, it has a strange power that allows him to control sand at will."
    vivi "Esta não é uma fruta qualquer, ela tem um poder estranho que lhe permite controlar a areia quando quiser."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:38
translate portuguese ar_alubarna_h_bcaa3c44:

    # vivi "His body turns into sand, and he can manipulate it as he pleases. In these deserts, he's nearly invincible..."
    vivi "Seu corpo se transforma em areia, e ele pode manipulá-la como quiser. Nesses desertos, ele é quase invencível..."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:39
translate portuguese ar_alubarna_h_4b79647a:

    # vivi "But even though he's very dangerous, I discovered that he has a weakness..."
    vivi "Mas mesmo sendo muito perigoso, descobri que ele tem uma fraqueza..."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:40
translate portuguese ar_alubarna_h_838d2575:

    # vivi "Water!"
    vivi "Água!"

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:42
translate portuguese ar_alubarna_h_d88aa100:

    # player "Water?!"
    player "Água?!"

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:44
translate portuguese ar_alubarna_h_fa3fe434:

    # vivi "Yes, water is his weakness."
    vivi "Sim, a água é sua fraqueza."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:45
translate portuguese ar_alubarna_h_5fe1470c:

    # vivi "If we manage to get him wet, he'll lose much of his power and become vulnerable, making the fight easier."
    vivi "Se conseguirmos molhá-lo, ele perderá muito de sua força e ficará vulnerável, tornando a luta mais fácil."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:46
translate portuguese ar_alubarna_h_6d5cb558:

    # vivi "So if it were to rain when we face him, the water would weaken him."
    vivi "Então, se chovesse quando o enfrentássemos, a água o enfraqueceria."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:52
translate portuguese ar_alubarna_h_7d3254dd:

    # robin "The Dance Powder!"
    robin "O pó da dança!"

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:54
translate portuguese ar_alubarna_h_c3c3a0c2:

    # vivi "Exactly, that's precisely my plan... With Dance Powder, we can make it rain."
    vivi "Exatamente, esse é exatamente o meu plano... Com o Dance Powder, podemos fazer chover."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:55
translate portuguese ar_alubarna_h_29cdd080:

    # vivi "With the terrain in our favor, we'll have the advantage..."
    vivi "Com o terreno a nosso favor, teremos vantagem..."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:61
translate portuguese ar_alubarna_h_3eb6ed77:

    # nami "Captain!! The situation is too delicate to be thinking about that..."
    nami "Capitão!! A situação é delicada demais para ficar pensando nisso..."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:62
translate portuguese ar_alubarna_h_7eedd56a:

    # player "Mnmnm... I'll do it only because [vivi.n] is asking for it..."
    player "Mnmnm... Vou fazer isso só porque [vivi.n] está pedindo..."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:64
translate portuguese ar_alubarna_h_0c68f406:

    # vivi "Thank you, [player.n], I really appreciate everything you're doing!"
    vivi "Obrigado, [player.n], eu realmente aprecio tudo o que você está fazendo!"

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:67
translate portuguese ar_alubarna_h_17e0e5f7:

    # narrador "[vivi.n] Love +2"
    narrador "[vivi.n] Amor +2"

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:69
translate portuguese ar_alubarna_h_cf2cfad2:

    # nami "Alright, back to the topic..."
    nami "Certo, voltando ao assunto..."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:70
translate portuguese ar_alubarna_h_b21ae8f4:

    # nami "Where can we find Dance Powder?"
    nami "Onde podemos encontrar Dance Powder?"

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:72
translate portuguese ar_alubarna_h_140eb4fb:

    # vivi "Do you remember when they tried to frame my father with a shipment of Dance Powder?"
    vivi "Você se lembra quando tentaram incriminar meu pai com um carregamento de Dance Powder?"

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:73
translate portuguese ar_alubarna_h_22c1257f:

    # vivi "According to information [igaram.n] obtained recently..."
    vivi "De acordo com informações [igaram.n] obtidas recentemente..."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:74
translate portuguese ar_alubarna_h_114e1ada:

    # vivi "Part of that shipment is stored in the Royal Palace as confiscated goods."
    vivi "Parte dessa remessa está armazenada no Palácio Real como mercadoria confiscada."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:76
translate portuguese ar_alubarna_h_65bc3e57:

    # player "Perfect, then lead us to where the Dance Powder is."
    player "Perfeito, então nos leve até onde fica o Pó de Dança."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:77
translate portuguese ar_alubarna_h_f0b1dddc:

    # vivi "Alright!! Follow me."
    vivi "Tudo bem!! Siga-me."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:82
translate portuguese ar_alubarna_h_0d035dc8:

    # narrador "[vivi.n] leads you through different alleys and passageways."
    narrador "[vivi.n] leva você por diferentes becos e passagens."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:83
translate portuguese ar_alubarna_h_dcc8e5e1:

    # narrador "Until reaching a secret entrance to the royal palace."
    narrador "Até chegar a uma entrada secreta para o palácio real."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:84
translate portuguese ar_alubarna_h_f047ef05:

    # narrador "Upon entering the palace, [vivi.n] takes you to a room with the confiscated shipment."
    narrador "Ao entrar no palácio, [vivi.n] leva você para uma sala com a remessa confiscada."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:95
translate portuguese ar_alubarna_h_dac65c81:

    # vivi "We've arrived. Here is the Dance Powder."
    vivi "Chegamos. Aqui está o Pó de Dança."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:97
translate portuguese ar_alubarna_h_28f7543d:

    # vivi "Besides that, I'd like to give you these 10 Minor Potions. They'll be useful in battle."
    vivi "Além disso, gostaria de lhe dar estas 10 Poções Menores. Elas serão úteis em batalha."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:100
translate portuguese ar_alubarna_h_51472e59:

    # narrador "+10 Minor Potions"
    narrador "+10 Poções Menores"

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:102
translate portuguese ar_alubarna_h_828b522d:

    # vivi "I know it's not much, but it's all I have."
    vivi "Sei que não é muito, mas é tudo o que tenho."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:104
translate portuguese ar_alubarna_h_ce39cbdb:

    # player "Thank you so much, [vivi.n]! This will be more than enough!"
    player "Muito obrigado, [vivi.n]! Isso será mais do que suficiente!"

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:106
translate portuguese ar_alubarna_h_f2419734:

    # player "Now let's go outside, prepare the rain, and defeat [crocodile.n]."
    player "Agora vamos lá fora, preparar a chuva e derrotar [crocodile.n]."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:108
translate portuguese ar_alubarna_h_c4bada13:

    # narrador "After a few minutes of planning, they gathered what they needed and prepared the battlefield for the confrontation."
    narrador "Após alguns minutos de planejamento, eles reuniram o que precisavam e prepararam o campo de batalha para o confronto."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:120
translate portuguese ar_alubarna_h_1544a2d8:

    # robin "Do you hear that?!?"
    robin "Você ouviu isso?!?"

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:124
translate portuguese ar_alubarna_h_d265893d:

    # vivi "It's the voice of [crocodile.n]!"
    vivi "É a voz de [crocodile.n]!"

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:125
translate portuguese ar_alubarna_h_b38edb64:

    # vivi "He's already here, we must hurry!"
    vivi "Ele já está aqui, precisamos nos apressar!"

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:127
translate portuguese ar_alubarna_h_e68a2624:

    # vivi "You prepare the rain, I'll handle distracting him."
    vivi "Você prepara a chuva, eu cuido de distraí-lo."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:129
translate portuguese ar_alubarna_h_0b62eb72:

    # player "It's dangerous, you shouldn't face him alone."
    player "É perigoso, você não deve enfrentá-lo sozinho."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:131
translate portuguese ar_alubarna_h_594624e8:

    # vivi "Don't worry, I just need to buy some time."
    vivi "Não se preocupe, eu só preciso ganhar algum tempo."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:133
translate portuguese ar_alubarna_h_7e19c0dc:

    # player "Understood, we'll take care of preparing the rain."
    player "Entendido, nós cuidaremos de preparar a chuva."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:149
translate portuguese ar_alubarna_h_819c5c25:

    # vivi "Father!"
    vivi "Pai!"

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:151
translate portuguese ar_alubarna_h_d3c62b9d:

    # crocodile "Well, well, well, I didn't expect to see you here, Miss Wednesday."
    crocodile "Bem, bem, bem, eu não esperava vê-la aqui, Srta. Wednesday."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:153
translate portuguese ar_alubarna_h_9478f745:

    # vivi "Don't ever call me that again!"
    vivi "Nunca mais me chame assim!"

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:154
translate portuguese ar_alubarna_h_8dc1c807:

    # vivi "I'm no longer part of your horrible criminal organization!"
    vivi "Não faço mais parte da sua horrível organização criminosa!"

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:156
translate portuguese ar_alubarna_h_c65c4591:

    # crocodile "Ahahahahah"
    crocodile "Ahahahahah"

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:157
translate portuguese ar_alubarna_h_acc9aff7:

    # crocodile "What a shame... I didn't want you to suffer, you should've stayed as a prisoner in peace..."
    crocodile "Que pena... Eu não queria que você sofresse, você deveria ter ficado prisioneiro em paz..."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:158
translate portuguese ar_alubarna_h_9c77637e:

    # vivi "And watch as you get away with everything?!?... Never!"
    vivi "E ver você escapar de tudo?!?... Nunca!"

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:159
translate portuguese ar_alubarna_h_96bcb549:

    # vivi "What did you do to my father!?!"
    vivi "O que você fez com meu pai!?!"

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:160
translate portuguese ar_alubarna_h_31667010:

    # vivi "Why is he in that terrible state?"
    vivi "Por que ele está nesse estado terrível?"

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:161
translate portuguese ar_alubarna_h_6ee6374c:

    # crocodile "You didn't think it was easy to capture him, did you...?"
    crocodile "Você não achou que seria fácil capturá-lo, não é mesmo?"

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:162
translate portuguese ar_alubarna_h_2be5c79d:

    # crocodile "Don't worry, princess, the king will live... For now..."
    crocodile "Não se preocupe, princesa, o rei viverá... Por enquanto..."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:163
translate portuguese ar_alubarna_h_2200874c:

    # crocodile "Obviously, someone warned him about the situation, and he was already prepared... It was probably [pell.n], who mysteriously escaped from my grasp..."
    crocodile "Obviamente, alguém o avisou sobre a situação, e ele já estava preparado... Provavelmente foi [pell.n], que misteriosamente escapou das minhas mãos..."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:164
translate portuguese ar_alubarna_h_acb23803:

    # crocodile "You being here makes me think..."
    crocodile "Você estar aqui me faz pensar..."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:165
translate portuguese ar_alubarna_h_5f177d6b:

    # crocodile "You're probably responsible for all of this..."
    crocodile "Você provavelmente é responsável por tudo isso..."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:166
translate portuguese ar_alubarna_h_b725e1a4:

    # crocodile "Either way, it was of little use..."
    crocodile "De qualquer forma, foi de pouca utilidade..."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:167
translate portuguese ar_alubarna_h_8531e56f:

    # crocodile "Ever since you escaped from [CactusIsland.n], I knew you'd be a problem..."
    crocodile "Desde que você escapou de [CactusIsland.n], eu sabia que você seria um problema..."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:168
translate portuguese ar_alubarna_h_5068c0b8:

    # crocodile "Now I understand why there have been so many setbacks in my plans lately..."
    crocodile "Agora entendo por que houve tantos contratempos em meus planos ultimamente..."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:172
translate portuguese ar_alubarna_h_38d88857:

    # crocodile "The fact that chaos hasn't erupted in the city must be your doing..."
    crocodile "O fato de o caos não ter se instalado na cidade deve ser obra sua..."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:173
translate portuguese ar_alubarna_h_bae0b695:

    # crocodile "I thought I had that [koza.n] dancing in the palm of my hand, seems I was overconfident..."
    crocodile "Eu pensei que tinha aquela [koza.n] dança na palma da minha mão, parece que eu estava confiante demais..."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:174
translate portuguese ar_alubarna_h_cd83e2f3:

    # crocodile "Anyway, that's not a problem, I'll deal with the rebels later..."
    crocodile "De qualquer forma, isso não é um problema, eu lido com os rebeldes mais tarde..."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:176
translate portuguese ar_alubarna_h_8a0c9c53:

    # cobra "I'm sorry, [vivi.n], I couldn't take advantage of the opportunity you gave us, despite the fact that you risked your own life."
    cobra "Sinto muito, [vivi.n], não pude aproveitar a oportunidade que você nos deu, apesar de ter arriscado sua própria vida."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:178
translate portuguese ar_alubarna_h_44043416:

    # crocodile "Ahahah, what a sad reunion!"
    crocodile "Ahahah, que reencontro triste!"

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:179
translate portuguese ar_alubarna_h_9c9fa9a0:

    # crocodile "Let me make it clear that I don't intend to let either of you live."
    crocodile "Quero deixar claro que não pretendo deixar nenhum de vocês viver."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:180
translate portuguese ar_alubarna_h_44df2510:

    # crocodile "When a kingdom dies, it's normal for its royal family to perish as well."
    crocodile "Quando um reino morre, é normal que sua família real também pereça."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:181
translate portuguese ar_alubarna_h_0eeab078:

    # crocodile "This palace will soon be my home."
    crocodile "Este palácio em breve será meu lar."

# game/scripts/Events/Arabasta/Alubarna/ar_alubarna_h.rpy:183
translate portuguese ar_alubarna_h_8672d99f:

