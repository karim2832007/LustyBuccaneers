# game/scripts/Events/Vivi/Hangout/vivi_hangout_3.rpy:9
translate portuguese vivi_hangout_3_78e28f22:

    # vivi "But I must always act for the good of my people, and even though I trust you, I must do what I believe is best for Alabasta."
    vivi "Mas devo sempre agir pelo bem do meu povo e, embora eu confie em você, devo fazer o que acredito ser melhor para Alabasta."

# game/scripts/Events/Vivi/Hangout/vivi_hangout_3.rpy:10
translate portuguese vivi_hangout_3_32ceaa4e:

    # vivi "I cannot allow anyone else to dictate my decisions, especially if they go against these interests."
    vivi "Não posso permitir que ninguém dite minhas decisões, especialmente se elas forem contra esses interesses."

# game/scripts/Events/Vivi/Hangout/vivi_hangout_3.rpy:15
translate portuguese vivi_hangout_3_1ffcd9e7:

