# game/scripts/Events/Player/newscoo/newscoo_1.rpy:21
translate portuguese newcoo_1_18fe7b5a:

    # robin "It's a culturally significant island for the world government... If i'm not mistaken, it's either a summer or spring island."
    robin "É uma ilha culturalmente significativa para o governo mundial... Se não me engano, é uma ilha de verão ou de primavera."

# game/scripts/Events/Player/newscoo/newscoo_1.rpy:27
