# game/scripts/Events/Alvida/bounty/alvida_bounty.rpy:16
translate portuguese bounty_board_alvida_d7879eda:

    # nami "If we manage to defeat her in combat, we'll get a good reward!!"
    nami "Se conseguirmos derrotá-la em combate, ganharemos uma boa recompensa!!"

# game/scripts/Events/Alvida/bounty/alvida_bounty.rpy:17
translate portuguese bounty_board_alvida_0ced1b37:

    # nami "Plus, I'm sure the crew will be motivated by this!!"
    nami "Além disso, tenho certeza de que a equipe ficará motivada com isso!!"

# game/scripts/Events/Alvida/bounty/alvida_bounty.rpy:18
translate portuguese bounty_board_alvida_d4dbb20e:

    # nami "To achieve this, we must find her first..."
    nami "Para conseguir isso, precisamos encontrá-la primeiro..."

# game/scripts/Events/Alvida/bounty/alvida_bounty.rpy:19
translate portuguese bounty_board_alvida_9a59da9a:

    # nami "From the information provided by the poster, we'll find her on the nearby coast..."
    nami "Pelas informações fornecidas pelo autor da postagem, vamos encontrá-la na costa próxima..."

# game/scripts/Events/Alvida/bounty/alvida_bounty.rpy:20
translate portuguese bounty_board_alvida_166646c8:

    # nami "We must travel and explore the seas, and then see what nearby ships we encounter..."
    nami "Devemos viajar e explorar os mares, e então ver quais navios próximos encontramos..."

# game/scripts/Events/Alvida/bounty/alvida_bounty.rpy:21
translate portuguese bounty_board_alvida_b966db2f:

    # nami "But we must go prepared, having some cannonballs, wood, and food would be ideal..."
    nami "Mas devemos ir preparados, ter algumas balas de canhão, madeira e comida seria o ideal..."

# game/scripts/Events/Alvida/bounty/alvida_bounty.rpy:22
translate portuguese bounty_board_alvida_785f28ee:

    # nami "Because if we find her, we'll have to face her ship!!"
    nami "Porque se a encontrarmos, teremos que enfrentar o navio dela!!"

# game/scripts/Events/Alvida/bounty/alvida_bounty.rpy:26
translate portuguese bounty_board_alvida_db02b643:

    # yamato "Yesssssss! A fight at sea!"
    yamato "Simmmmm! Uma luta no mar!"

# game/scripts/Events/Alvida/bounty/alvida_bounty.rpy:27
translate portuguese bounty_board_alvida_80a46159:

    # yamato "If we weaken her ship enough, they won't be able to move quickly, and we can board them."
    yamato "Se enfraquecermos a nave dela o suficiente, eles não conseguirão se mover rapidamente, e poderemos abordá-los."

# game/scripts/Events/Alvida/bounty/alvida_bounty.rpy:28
translate portuguese bounty_board_alvida_359e352e:

    # yamato "And then we can fight against [alvida.n]!!!"
    yamato "E então poderemos lutar contra [alvida.n]!!!"

# game/scripts/Events/Alvida/bounty/alvida_bounty.rpy:29
translate portuguese bounty_board_alvida_63e9e1f5:

    # yamato "Maybe it's better to train on the ship before going to face her..."
    yamato "Talvez seja melhor treinar no navio antes de ir enfrentá-la..."

# game/scripts/Events/Alvida/bounty/alvida_bounty.rpy:31
translate portuguese bounty_board_alvida_3fd282ec:

    # nami "At that moment, it will all depend on you, Captain! If you defeat her, we'll receive the reward!"
    nami "Naquele momento, tudo dependerá de você, Capitão! Se você derrotá-la, nós receberemos a recompensa!"

# game/scripts/Events/Alvida/bounty/alvida_bounty.rpy:32
translate portuguese bounty_board_alvida_01c39a31:

    # yamato "So it is, Captain!!!... So, what do you say?"
    yamato "Então é isso, Capitão!!!... Então, o que você diz?"

